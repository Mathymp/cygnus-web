# ===========================================
# Variables de entorno — NUNCA subir valores reales al repo.
# Configúralas en Render → Environment (Dashboard del servicio).
# ===========================================

# Base de datos PostgreSQL
DATABASE_URL=

# Sesiones (obligatorio en producción)
SESSION_SECRET=

# Supabase — solo login/usuarios (NO se usa para subir documentos)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudinary — imágenes (propiedades, banners, 360°, documentos IM en JPG/PNG)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Wasabi — PDFs y documentos del módulo inmobiliaria
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=
WASABI_BUCKET=cygnus-documentos
WASABI_REGION=us-east-2
WASABI_ENDPOINT=https://s3.us-east-2.wasabisys.com

# Opcionales
GOOGLE_MAPS_KEY=
RESEND_API_KEY=
