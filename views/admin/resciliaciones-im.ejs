<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/inmobiliaria.css">
    <style>
        .resc-header{padding:22px 28px 14px;border-bottom:1px solid #e2e8f0;display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
        .resc-toolbar{padding:12px 28px;border-bottom:1px solid #f1f5f9;display:flex;gap:10px;flex-wrap:wrap;align-items:center;background:#fff;}
        .resc-body{padding:20px 28px;}
        .summary-cards{display:flex;gap:12px;flex-wrap:wrap;padding:14px 28px;background:#f8fafc;border-bottom:1px solid #e2e8f0;}
        .summary-card{background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:12px 18px;display:flex;flex-direction:column;align-items:center;min-width:130px;flex:1;}
        .summary-card .val{font-size:1.35rem;font-weight:800;line-height:1.1;}
        .summary-card .lbl{font-size:.7rem;color:#64748b;margin-top:3px;text-align:center;font-weight:600;text-transform:uppercase;letter-spacing:.3px;}
        .summary-card .sub{font-size:.68rem;color:#94a3b8;margin-top:2px;text-align:center;}
        /* Barra progreso por fila */
        .dev-bar-wrap{height:5px;background:#e2e8f0;border-radius:3px;overflow:hidden;margin-top:4px;width:100%;min-width:80px;}
        .dev-bar-fill{height:100%;border-radius:3px;transition:width .4s;}
        /* Panel resumen por proyecto */
        .proj-summary-panel{padding:10px 28px 0;border-bottom:1px solid #e2e8f0;}
        .proj-summary-toggle{font-size:.8rem;font-weight:700;color:#2563eb;cursor:pointer;display:inline-flex;align-items:center;gap:5px;padding:8px 0;user-select:none;}
        .proj-group-card{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:12px 16px;margin-bottom:8px;display:flex;flex-wrap:wrap;gap:12px;align-items:center;}
        .proj-group-name{font-weight:800;color:#0f172a;font-size:.85rem;min-width:160px;flex:1;}
        .proj-stat{text-align:center;min-width:80px;}
        .proj-stat .sv{font-size:1rem;font-weight:800;}
        .proj-stat .sl{font-size:.68rem;color:#64748b;text-transform:uppercase;font-weight:600;letter-spacing:.3px;}
        .proj-dev-bar{height:8px;background:#e2e8f0;border-radius:4px;overflow:hidden;min-width:120px;flex:1;max-width:200px;margin-top:2px;}
        .proj-dev-fill{height:100%;background:linear-gradient(90deg,#16a34a,#22c55e);border-radius:4px;transition:width .5s;}
        .badge-venc-mini{background:#fee2e2;color:#991b1b;border-radius:12px;padding:2px 7px;font-size:.67rem;font-weight:700;display:inline-flex;align-items:center;gap:3px;}
        .filter-chip{padding:6px 14px;border-radius:20px;font-size:.78rem;font-weight:600;border:1.5px solid #e2e8f0;background:#fff;cursor:pointer;color:#64748b;transition:all .15s;}
        .filter-chip.active{background:#2563eb;color:#fff;border-color:#2563eb;}
        .search-box{display:flex;align-items:center;gap:8px;background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:10px;padding:0 12px;flex:1;max-width:320px;}
        .search-box input{border:none;background:transparent;padding:8px 0;font-size:.85rem;font-family:inherit;color:#0f172a;outline:none;width:100%;}
        .resc-table{width:100%;border-collapse:collapse;font-size:.83rem;}
        .resc-table th{padding:10px 14px;text-align:left;font-weight:700;color:#475569;font-size:.74rem;text-transform:uppercase;letter-spacing:.3px;background:#f8fafc;border-bottom:2px solid #e2e8f0;white-space:nowrap;}
        .resc-table td{padding:11px 14px;border-bottom:1px solid #f1f5f9;vertical-align:middle;}
        .resc-main-row{cursor:pointer;transition:background .12s;}
        .resc-main-row:hover td{background:#fef3f2!important;}
        .resc-main-row.row-completada td{background:#f0fdf4;}
        .resc-main-row.row-en-proceso td{background:#fff7ed;}
        .resc-detail-row td{padding:0!important;border-bottom:2px solid #e2e8f0;}
        .resc-detail-inner{padding:16px 20px;background:#f8fafc;animation:slideDown .2s ease;}
        @keyframes slideDown{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
        .detail-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:14px;margin-bottom:14px;}
        .detail-card{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:13px 16px;}
        .detail-card-title{font-size:.7rem;font-weight:800;color:#64748b;text-transform:uppercase;letter-spacing:.4px;margin:0 0 8px;display:flex;align-items:center;gap:6px;}
        .detail-row{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;padding:4px 0;border-bottom:1px solid #f1f5f9;font-size:.8rem;}
        .detail-row:last-child{border-bottom:none;}
        .detail-key{color:#64748b;white-space:nowrap;}
        .detail-val{color:#0f172a;font-weight:600;text-align:right;word-break:break-word;}
        .badge-completada{background:#dcfce7;color:#166534;border-radius:20px;padding:3px 10px;font-size:.74rem;font-weight:700;display:inline-flex;align-items:center;gap:4px;white-space:nowrap;}
        .badge-proceso{background:#fef3c7;color:#92400e;border-radius:20px;padding:3px 10px;font-size:.74rem;font-weight:700;display:inline-flex;align-items:center;gap:4px;white-space:nowrap;}
        .badge-pagada{background:#dcfce7;color:#166534;border-radius:20px;padding:3px 10px;font-size:.74rem;font-weight:700;}
        .badge-pendiente{background:#fef3c7;color:#92400e;border-radius:20px;padding:3px 10px;font-size:.74rem;font-weight:700;}
        .badge-vencida{background:#fee2e2;color:#991b1b;border-radius:20px;padding:3px 10px;font-size:.74rem;font-weight:700;}
        .mini-cuota-dev{display:flex;align-items:center;gap:8px;padding:7px 10px;border-radius:7px;background:#fff;border:1px solid #e2e8f0;font-size:.79rem;margin-bottom:5px;}
        .mini-cuota-dev.pagada-mini{background:#f0fdf4;border-color:#86efac;}
        .mini-cuota-dev.vencida-mini{background:#fff5f5;border-color:#fca5a5;}
        .comp-thumb{width:40px;height:40px;border-radius:6px;object-fit:cover;border:1px solid #e2e8f0;cursor:pointer;flex-shrink:0;}
        .comp-pdf{width:40px;height:40px;border-radius:6px;background:#fee2e2;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;border:1px solid #fecaca;}
        .dev-type-btn{padding:7px 14px;border-radius:8px;border:1.5px solid #e2e8f0;font-size:.8rem;font-weight:600;cursor:pointer;background:#fff;color:#64748b;transition:all .15s;}
        .dev-type-btn.active{background:#dc2626;color:#fff;border-color:#dc2626;}
        /* Modals */
        .rm-overlay{position:fixed;inset:0;background:rgba(15,23,42,.5);z-index:8000;display:none;align-items:center;justify-content:center;padding:20px;}
        .rm-overlay.open{display:flex;}
        .rm-box{background:#fff;border-radius:16px;width:100%;max-width:540px;box-shadow:0 20px 60px rgba(0,0,0,.25);overflow:hidden;}
        .rm-box.wide{max-width:700px;}
        .rm-header{padding:16px 20px;background:linear-gradient(135deg,#dc2626,#b91c1c);color:#fff;display:flex;justify-content:space-between;align-items:center;}
        .rm-body{padding:20px;}
        .preview-frame{width:100%;height:500px;border:none;border-radius:8px;background:#f1f5f9;}
        .dz-mini{border:2px dashed #e2e8f0;border-radius:8px;padding:12px;text-align:center;cursor:pointer;transition:all .2s;position:relative;overflow:hidden;background:#f8fafc;}
        .dz-mini:hover{border-color:#2563eb;background:#eff6ff;}
        .dz-mini input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;}
        .dz-mini p{font-size:.78rem;color:#64748b;margin:4px 0 0;}
    </style>
</head>
<body class="dashboard-body">
    <%- include('../partials/alerts') %>

    <div id="im-toast" style="position:fixed;top:20px;right:20px;z-index:9999;pointer-events:none;opacity:0;transform:translateX(30px);transition:all .3s;"><div id="im-toast-inner" style="background:#1e293b;color:#fff;padding:12px 18px;border-radius:10px;font-size:.85rem;font-weight:600;box-shadow:0 8px 24px rgba(0,0,0,.3);max-width:340px;"></div></div>

    <div class="app-layout">
        <%- include('../partials/sidebar-admin', { page: 'resciliaciones-im' }) %>
        <main class="main-content">
        <div class="dashboard-scroll" style="padding:0;">

        <!-- HEADER -->
        <div class="resc-header">
            <div style="background:linear-gradient(135deg,#dc2626,#b91c1c);border-radius:12px;padding:10px 14px;color:#fff;flex-shrink:0;">
                <i class="bi bi-file-earmark-x-fill" style="font-size:1.5rem;"></i>
            </div>
            <div style="flex:1;">
                <h1 style="font-size:1.25rem;font-weight:800;color:#0f172a;margin:0;">Resciliaciones</h1>
                <p style="font-size:.82rem;color:#64748b;margin:2px 0 0;">Gestión de contratos resciliados y devoluciones a clientes</p>
            </div>
            <button class="im-btn im-btn-primary" onclick="openNuevaResc()" style="background:#dc2626;border:none;">
                <i class="bi bi-plus-circle"></i> Nueva Resciliación
            </button>
        </div>

        <!-- SUMMARY CARDS -->
        <div class="summary-cards" id="summary-cards">
            <div class="summary-card">
                <span class="val" id="sc-total">—</span>
                <span class="lbl">Total Resciliaciones</span>
            </div>
            <div class="summary-card" style="border-color:#fde68a;">
                <span class="val" style="color:#d97706;" id="sc-proceso">—</span>
                <span class="lbl">En Proceso</span>
            </div>
            <div class="summary-card" style="border-color:#86efac;">
                <span class="val" style="color:#16a34a;" id="sc-comp">—</span>
                <span class="lbl">Completadas</span>
            </div>
            <div class="summary-card" style="border-color:#fca5a5;">
                <span class="val" style="color:#dc2626;" id="sc-venc">—</span>
                <span class="lbl">Cuotas Vencidas</span>
                <span class="sub">sin pagar y pasada fecha</span>
            </div>
            <div class="summary-card" style="border-color:#fca5a5;">
                <span class="val" style="color:#ef4444;font-size:1rem;" id="sc-pend-monto">—</span>
                <span class="lbl">Saldo Pendiente</span>
                <span class="sub" id="sc-pend-cuotas">0 cuotas</span>
            </div>
            <div class="summary-card" style="border-color:#86efac;">
                <span class="val" style="color:#16a34a;font-size:1rem;" id="sc-pagado">—</span>
                <span class="lbl">Ya Devuelto</span>
                <span class="sub" id="sc-pagado-cuotas">0 cuotas</span>
            </div>
            <div class="summary-card" style="border-color:#bfdbfe;flex:2;min-width:200px;">
                <span class="val" style="color:#1d4ed8;font-size:1rem;" id="sc-total-dev">—</span>
                <span class="lbl">Total a Devolver</span>
                <div class="dev-bar-wrap" style="margin-top:8px;">
                    <div class="dev-bar-fill" id="sc-bar-fill" style="background:linear-gradient(90deg,#16a34a,#22c55e);width:0%;"></div>
                </div>
                <span class="sub" id="sc-bar-pct">0% completado</span>
            </div>
        </div>

        <!-- RESUMEN POR PROYECTO -->
        <div class="proj-summary-panel" id="proj-summary-wrap">
            <div class="proj-summary-toggle" onclick="toggleProjSummary()">
                <i class="bi bi-bar-chart-line" id="proj-sum-icon"></i>
                <span id="proj-sum-label">Ver resumen por proyecto</span>
            </div>
            <div id="proj-summary-body" style="display:none;padding-bottom:12px;"></div>
        </div>

        <!-- TOOLBAR -->
        <div class="resc-toolbar">
            <div class="search-box">
                <i class="bi bi-search" style="color:#94a3b8;font-size:.9rem;flex-shrink:0;"></i>
                <input type="text" id="search-input" placeholder="Buscar cliente, RUT, parcela, proyecto..." oninput="applyFilters()">
            </div>
            <select id="filter-proyecto" class="styled-input" style="max-width:200px;padding:8px 12px;" onchange="applyFilters()">
                <option value="">Todos los proyectos</option>
                <% proyectos.forEach(p => { %>
                <option value="<%= p.id %>"><%= p.nombre %></option>
                <% }); %>
            </select>
            <button class="filter-chip active" onclick="setFilter('all',this)">Todas</button>
            <button class="filter-chip" onclick="setFilter('en_proceso',this)">En Proceso</button>
            <button class="filter-chip" onclick="setFilter('completada',this)">Completadas</button>
        </div>

        <!-- TABLE -->
        <div class="resc-body">
            <div id="resc-loading" style="text-align:center;padding:40px;color:#94a3b8;">
                <i class="bi bi-hourglass-split" style="font-size:2rem;"></i>
                <p style="margin:8px 0 0;font-weight:600;">Cargando resciliaciones...</p>
            </div>
            <div id="resc-empty" style="display:none;text-align:center;padding:40px;color:#94a3b8;">
                <i class="bi bi-file-earmark-x" style="font-size:3rem;color:#fca5a5;"></i>
                <p style="margin:10px 0 0;font-weight:600;color:#64748b;">No hay resciliaciones registradas</p>
                <p style="font-size:.8rem;color:#94a3b8;">Cuando se rescilie un contrato, aparecerá aquí.</p>
            </div>
            <div style="overflow-x:auto;">
            <table class="resc-table" id="resc-table" style="display:none;">
                <thead>
                    <tr>
                        <th style="width:32px;"></th>
                        <th>Proyecto / Parcela</th>
                        <th>Cliente</th>
                        <th>Fecha</th>
                        <th>Progreso Devolución</th>
                        <th>Cuotas Dev.</th>
                        <th>Estado</th>
                        <th>Documento</th>
                    </tr>
                </thead>
                <tbody id="resc-tbody"></tbody>
            </table>
            </div>
        </div>

        </div><!-- /dashboard-scroll -->
        </main>
    </div>

    <!-- ─── MODAL: PAGAR CUOTA DEVOLUCION ─── -->
    <div class="rm-overlay" id="modal-pagar-dev">
        <div class="rm-box">
            <div class="rm-header">
                <span style="font-weight:700;font-size:1rem;"><i class="bi bi-cash-coin"></i> Registrar Devolución Cuota</span>
                <button onclick="closeModal('pagar-dev')" style="background:none;border:none;color:#fff;font-size:1.3rem;cursor:pointer;">×</button>
            </div>
            <div class="rm-body">
                <input type="hidden" id="pd-cuota-id">
                <div class="im-form-row" style="margin-bottom:12px;">
                    <div class="im-input-group">
                        <label>Fecha de Pago</label>
                        <input type="date" id="pd-fecha" class="styled-input">
                    </div>
                    <div class="im-input-group">
                        <label>Notas (opcional)</label>
                        <input type="text" id="pd-notas" class="styled-input" placeholder="Ej: transferencia banco X">
                    </div>
                </div>
                <div class="im-input-group" style="margin-bottom:14px;">
                    <label><i class="bi bi-paperclip"></i> Comprobante de Pago</label>
                    <div class="dz-mini">
                        <input type="file" id="pd-file" accept="image/*,.pdf">
                        <i class="bi bi-cloud-arrow-up" style="font-size:1.5rem;color:#2563eb;"></i>
                        <p>Foto/PDF del comprobante (opcional)</p>
                        <p id="pd-file-name" style="font-weight:600;color:#0f172a;display:none;"></p>
                    </div>
                </div>
                <div style="display:flex;gap:10px;justify-content:flex-end;">
                    <button class="im-btn im-btn-ghost" onclick="closeModal('pagar-dev')">Cancelar</button>
                    <button class="im-btn im-btn-primary" id="pd-btn" onclick="confirmarPagarDev()" style="background:#16a34a;border:none;">
                        <i class="bi bi-check-circle"></i> Confirmar Devolución
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ─── MODAL: NUEVA RESCILIACION ─── -->
    <div class="rm-overlay" id="modal-nueva-resc">
        <div class="rm-box wide">
            <div class="rm-header">
                <span style="font-weight:700;font-size:1rem;"><i class="bi bi-file-earmark-x"></i> Nueva Resciliación</span>
                <button onclick="closeModal('nueva-resc')" style="background:none;border:none;color:#fff;font-size:1.3rem;cursor:pointer;">×</button>
            </div>
            <div class="rm-body">
                <div class="im-form-row" style="margin-bottom:12px;">
                    <div class="im-input-group">
                        <label>Proyecto</label>
                        <select id="nr-proyecto" class="styled-input" onchange="cargarParcelasVendidas()">
                            <option value="">— Selecciona proyecto —</option>
                            <% proyectos.forEach(p => { %>
                            <option value="<%= p.id %>"><%= p.nombre %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="im-input-group">
                        <label>Parcela con Venta Activa</label>
                        <select id="nr-parcela" class="styled-input" onchange="onSeleccionarParcela()">
                            <option value="">— Selecciona primero el proyecto —</option>
                        </select>
                    </div>
                </div>
                <div id="nr-cliente-info" style="display:none;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:10px 14px;margin-bottom:12px;font-size:.82rem;"></div>
                <div class="im-form-row" style="margin-bottom:12px;">
                    <div class="im-input-group">
                        <label>Fecha de Resciliación</label>
                        <input type="date" id="nr-fecha" class="styled-input">
                    </div>
                </div>
                <div class="im-input-group" style="margin-bottom:12px;">
                    <label>Motivo</label>
                    <input type="text" id="nr-motivo" class="styled-input" placeholder="Ej: Desistimiento del comprador, incumplimiento de pago...">
                </div>
                <div class="im-input-group" style="margin-bottom:14px;">
                    <label>Notas Adicionales</label>
                    <textarea id="nr-notas" class="styled-input" rows="2" style="resize:vertical;" placeholder="Observaciones, acuerdos, etc."></textarea>
                </div>
                <div style="display:flex;gap:10px;justify-content:flex-end;">
                    <button class="im-btn im-btn-ghost" onclick="closeModal('nueva-resc')">Cancelar</button>
                    <button class="im-btn im-btn-primary" id="nr-btn" onclick="confirmarNuevaResc()" style="background:#dc2626;border:none;">
                        <i class="bi bi-file-earmark-x"></i> Confirmar Resciliación
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ─── MODAL: PREVIEW DOCUMENTO ─── -->
    <div class="rm-overlay" id="modal-preview">
        <div class="rm-box wide">
            <div class="rm-header">
                <span id="preview-title" style="font-weight:700;font-size:1rem;">Vista Previa</span>
                <button onclick="closeModal('preview')" style="background:none;border:none;color:#fff;font-size:1.3rem;cursor:pointer;">×</button>
            </div>
            <div class="rm-body" style="padding:14px;">
                <div id="preview-content"></div>
            </div>
        </div>
    </div>

<script>
// ─────────────────────────────────────────────
//  Helpers
// ─────────────────────────────────────────────
const $id=id=>document.getElementById(id);
function openModal(id){const el=$id(`modal-${id}`);if(el)el.classList.add('open');}
function closeModal(id){const el=$id(`modal-${id}`);if(el)el.classList.remove('open');}
function escH(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function fmtCLP(v){return v?'$'+Number(v).toLocaleString('es-CL'):'—';}
function fmtFecha(d){return d?new Date(d).toLocaleDateString('es-CL',{day:'2-digit',month:'short',year:'numeric'}):'—';}
function showToast(msg,type='info'){
    const t=$id('im-toast'),ti=$id('im-toast-inner');
    ti.textContent=msg;
    ti.style.background=type==='success'?'#16a34a':type==='error'?'#dc2626':'#1e293b';
    t.style.opacity='1';t.style.transform='translateX(0)';
    setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(30px)';},4000);
}
const isOverdue=d=>d&&!d.pagado&&d.fecha_vencimiento&&new Date(d.fecha_vencimiento)<new Date();

// ─────────────────────────────────────────────
//  Estado
// ─────────────────────────────────────────────
let allResc=[],filtroEstado='all';

// ─────────────────────────────────────────────
//  Cargar datos
// ─────────────────────────────────────────────
async function loadResc(){
    try{
        const res=await fetch('/api/im/resciliaciones');
        if(!res.ok)throw new Error('Error cargando resciliaciones');
        allResc=await res.json();
        updateSummary();
        applyFilters();
    }catch(e){
        $id('resc-loading').innerHTML=`<i class="bi bi-exclamation-triangle" style="font-size:2rem;color:#ef4444;"></i><p style="color:#ef4444;margin:8px 0 0;">${escH(e.message)}</p>`;
    }
}

function updateSummary(){
    $id('sc-total').textContent    = allResc.length;
    $id('sc-proceso').textContent  = allResc.filter(r=>r.estado!=='completada').length;
    $id('sc-comp').textContent     = allResc.filter(r=>r.estado==='completada').length;

    const totalVenc   = allResc.reduce((s,r)=>s+Number(r.cuotas_dev_vencidas||0),0);
    const totalPend   = allResc.reduce((s,r)=>s+Number(r.cuotas_dev_pendientes||0),0);
    const totalPagCq  = allResc.reduce((s,r)=>s+Number(r.total_cuotas_dev||0)-Number(r.cuotas_dev_pendientes||0),0);
    const montoPend   = allResc.reduce((s,r)=>s+Number(r.monto_dev_pendiente||0),0);
    const montoPagado = allResc.reduce((s,r)=>s+Number(r.monto_dev_pagado||0),0);
    const montoTotal  = montoPend + montoPagado;
    const pct         = montoTotal>0 ? Math.round((montoPagado/montoTotal)*100) : 0;

    $id('sc-venc').textContent         = totalVenc;
    $id('sc-pend-monto').textContent   = '$'+montoPend.toLocaleString('es-CL');
    $id('sc-pend-cuotas').textContent  = totalPend+' cuota'+(totalPend!==1?'s':'')+' pendiente'+(totalPend!==1?'s':'');
    $id('sc-pagado').textContent       = '$'+montoPagado.toLocaleString('es-CL');
    $id('sc-pagado-cuotas').textContent= totalPagCq+' cuota'+(totalPagCq!==1?'s':'')+' pagada'+(totalPagCq!==1?'s':'');
    $id('sc-total-dev').textContent    = '$'+montoTotal.toLocaleString('es-CL');
    $id('sc-bar-fill').style.width     = pct+'%';
    $id('sc-bar-pct').textContent      = pct+'% completado';

    renderProjSummary();
}

let _projSummaryOpen = false;
function toggleProjSummary(){
    _projSummaryOpen = !_projSummaryOpen;
    $id('proj-summary-body').style.display = _projSummaryOpen ? 'block' : 'none';
    $id('proj-sum-label').textContent      = _projSummaryOpen ? 'Ocultar resumen por proyecto' : 'Ver resumen por proyecto';
    $id('proj-sum-icon').className         = _projSummaryOpen ? 'bi bi-chevron-up' : 'bi bi-bar-chart-line';
}

function renderProjSummary(){
    // Agrupar por proyecto
    const map={};
    allResc.forEach(r=>{
        const k=r.proyecto_id;
        if(!map[k]){ map[k]={nombre:r.proyecto_nombre,resc:0,pagado:0,pendiente:0,vencidas:0,cuotasPend:0,cuotasPag:0}; }
        map[k].resc++;
        map[k].pagado    += Number(r.monto_dev_pagado||0);
        map[k].pendiente += Number(r.monto_dev_pendiente||0);
        map[k].vencidas  += Number(r.cuotas_dev_vencidas||0);
        map[k].cuotasPend+= Number(r.cuotas_dev_pendientes||0);
        map[k].cuotasPag += Number(r.total_cuotas_dev||0)-Number(r.cuotas_dev_pendientes||0);
    });
    const body=$id('proj-summary-body'); if(!body) return;
    const entries=Object.values(map);
    if(!entries.length){ body.innerHTML='<p style="font-size:.8rem;color:#94a3b8;padding:8px 0;">Sin datos.</p>'; return; }
    body.innerHTML = entries.map(p=>{
        const total=p.pagado+p.pendiente;
        const pct=total>0?Math.round((p.pagado/total)*100):0;
        return `<div class="proj-group-card">
            <div class="proj-group-name"><i class="bi bi-folder2" style="color:#2563eb;margin-right:6px;"></i>${escH(p.nombre)}</div>
            <div class="proj-stat"><div class="sv">${p.resc}</div><div class="sl">Resciliac.</div></div>
            <div class="proj-stat"><div class="sv" style="color:#16a34a;">$${p.pagado.toLocaleString('es-CL')}</div><div class="sl">Devuelto</div></div>
            <div class="proj-stat"><div class="sv" style="color:#ef4444;">$${p.pendiente.toLocaleString('es-CL')}</div><div class="sl">Pendiente</div>
                ${p.vencidas>0?`<span class="badge-venc-mini"><i class="bi bi-exclamation-triangle-fill"></i>${p.vencidas} venc.</span>`:''}</div>
            <div style="flex:1;min-width:120px;">
                <div style="font-size:.7rem;color:#64748b;font-weight:600;margin-bottom:3px;">${pct}% devuelto · ${p.cuotasPag}/${p.cuotasPag+p.cuotasPend} cuotas</div>
                <div class="proj-dev-bar"><div class="proj-dev-fill" style="width:${pct}%;"></div></div>
            </div>
        </div>`;
    }).join('');
}

function setFilter(est,btn){
    filtroEstado=est;
    document.querySelectorAll('.filter-chip').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    applyFilters();
}

function applyFilters(){
    const q=($id('search-input').value||'').toLowerCase().trim();
    const proj=$id('filter-proyecto').value;
    let list=allResc;
    if(filtroEstado!=='all') list=list.filter(r=>(r.estado||'en_proceso')===filtroEstado);
    if(proj) list=list.filter(r=>r.proyecto_id===proj);
    if(q) list=list.filter(r=>[r.cliente_nombre,r.cliente_rut,r.numero_parcela,r.proyecto_nombre]
        .some(v=>(v||'').toLowerCase().includes(q)));
    renderTable(list);
}

// ─────────────────────────────────────────────
//  Render tabla
// ─────────────────────────────────────────────
function renderTable(list){
    $id('resc-loading').style.display='none';
    if(list.length===0){
        $id('resc-table').style.display='none';
        $id('resc-empty').style.display='block';
        return;
    }
    $id('resc-empty').style.display='none';
    $id('resc-table').style.display='table';
    $id('resc-tbody').innerHTML=list.map(r=>rowHTML(r)).join('');
}

function rowHTML(r){
    const estado=r.estado||'en_proceso';
    const badgeEst=estado==='completada'
        ?`<span class="badge-completada"><i class="bi bi-check-circle-fill"></i> Completada</span>`
        :`<span class="badge-proceso"><i class="bi bi-hourglass-split"></i> En Proceso</span>`;

    const pendNum  = Number(r.cuotas_dev_pendientes||0);
    const totalCDev= Number(r.total_cuotas_dev||0);
    const pagNum   = totalCDev - pendNum;
    const vencNum  = Number(r.cuotas_dev_vencidas||0);
    const montoPend= Number(r.monto_dev_pendiente||0);
    const montoPag = Number(r.monto_dev_pagado||0);
    const montoTot = montoPend + montoPag;
    const pct      = montoTot>0 ? Math.round((montoPag/montoTot)*100) : 0;

    // Columna progreso devolución
    const devBadge = montoTot>0
        ? `<div style="min-width:130px;">
            <div style="display:flex;justify-content:space-between;font-size:.72rem;margin-bottom:3px;">
                <span style="color:#16a34a;font-weight:700;">$${montoPag.toLocaleString('es-CL')} devuelto</span>
                <span style="color:#94a3b8;">${pct}%</span>
            </div>
            <div class="dev-bar-wrap"><div class="dev-bar-fill" style="width:${pct}%;background:${pct===100?'#16a34a':'#2563eb'};"></div></div>
            <div style="font-size:.7rem;color:#ef4444;margin-top:2px;">$${montoPend.toLocaleString('es-CL')} pendiente</div>
          </div>`
        : r.tipo_devolucion==='completa'
            ? `<span style="font-size:.76rem;color:#64748b;font-style:italic;">Pago único</span>`
            : `<span style="font-size:.76rem;color:#94a3b8;">Sin plan definido</span>`;

    // Columna cuotas
    const cuotasBadge = totalCDev>0
        ? `<div style="white-space:nowrap;">
            <span class="${pendNum>0?'badge-pendiente':'badge-pagada'}" style="font-size:.72rem;">${pagNum}/${totalCDev} pag.</span>
            ${vencNum>0?`<br><span class="badge-vencida" style="font-size:.68rem;margin-top:3px;display:inline-flex;align-items:center;gap:3px;"><i class="bi bi-exclamation-triangle-fill"></i>${vencNum} venc.</span>`:''}
          </div>`
        : `<span style="font-size:.78rem;color:#94a3b8;">—</span>`;

    const docIcon=r.documento_url
        ?`<button class="im-btn im-btn-sm im-btn-ghost" onclick="event.stopPropagation();previewDoc('${escH(r.documento_url)}','Documento Resciliación')" title="Ver">
            <i class="bi bi-eye"></i></button>
          <a href="${escH(r.documento_url)}" download target="_blank" class="im-btn im-btn-sm im-btn-ghost" onclick="event.stopPropagation()" title="Descargar">
            <i class="bi bi-download"></i></a>`
        :`<span style="font-size:.75rem;color:#94a3b8;">Sin documento</span>`;

    return `
    <tr class="resc-main-row ${estado==='completada'?'row-completada':'row-en-proceso'}" onclick="toggleDetail('resc-${r.id}',${JSON.stringify(JSON.stringify(r)).slice(1,-1)})">
        <td><i class="bi bi-chevron-right" id="chev-resc-${r.id}" style="transition:transform .2s;font-size:.8rem;color:#94a3b8;"></i></td>
        <td>
            <div style="font-weight:700;color:#0f172a;">${escH(r.proyecto_nombre)}</div>
            <div style="font-size:.76rem;color:#64748b;">Parcela ${escH(r.numero_parcela)}</div>
        </td>
        <td>
            <div style="font-weight:600;">${escH(r.cliente_nombre)}</div>
            <div style="font-size:.75rem;color:#64748b;">${escH(r.cliente_rut||'')}</div>
        </td>
        <td style="white-space:nowrap;">${fmtFecha(r.fecha)}</td>
        <td>${devBadge}</td>
        <td>${cuotasBadge}</td>
        <td>${badgeEst}</td>
        <td onclick="event.stopPropagation();">${docIcon}</td>
    </tr>
    <tr class="resc-detail-row" id="resc-${r.id}" style="display:none;">
        <td colspan="8"><div class="resc-detail-inner" id="resc-inner-${r.id}"></div></td>
    </tr>`;
}

// ─────────────────────────────────────────────
//  Expandir / contraer fila
// ─────────────────────────────────────────────
let activeRow=null;
async function toggleDetail(rowId, rStr){
    const row=$id(rowId);
    const chev=$id('chev-'+rowId);
    if(!row)return;
    if(row.style.display!=='none'){
        row.style.display='none';
        if(chev){chev.style.transform='rotate(0deg)';}
        activeRow=null;
        return;
    }
    if(activeRow&&activeRow!==rowId){
        const prev=$id(activeRow);
        if(prev)prev.style.display='none';
        const prevChev=$id('chev-'+activeRow);
        if(prevChev)prevChev.style.transform='rotate(0deg)';
    }
    row.style.display='table-row';
    if(chev)chev.style.transform='rotate(90deg)';
    activeRow=rowId;
    const inner=$id('resc-inner-'+rowId);
    inner.innerHTML='<div style="text-align:center;padding:20px;color:#94a3b8;"><i class="bi bi-hourglass-split"></i> Cargando detalle...</div>';

    // Parsear el id numérico del rowId
    const rescId=rowId.replace('resc-','');
    await renderDetail(rescId, inner);
}

