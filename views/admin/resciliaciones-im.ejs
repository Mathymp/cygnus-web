                <button class="filter-chip" id="doc-tab-${rescId}-persona" onclick="loadRelDocs(${rescId},'persona','${escH(r.cliente_id)}',this)">Docs Cliente</button>
            </div>
            <div id="rel-docs-${rescId}"><div style="color:#94a3b8;font-size:.8rem;padding:8px 0;"><i class="bi bi-hourglass-split"></i> Cargando...</div></div>
        </div>`;

        // Auto-cargar docs parcela
        setTimeout(()=>loadRelDocs(rescId,'parcela',r.parcela_id,$id(`doc-tab-${rescId}-parcela`)),100);
    }catch(e){
        container.innerHTML=`<div style="color:#ef4444;padding:16px;">${escH(e.message)}</div>`;
    }
}

// ─────────────────────────────────────────────
//  Plan de devolución
// ─────────────────────────────────────────────
function setDevTipo(rescId, tipo, btn){
    $id(`dev-type-btns-${rescId}`).querySelectorAll('.dev-type-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    const cuotasConfig=$id(`dev-cuotas-config-${rescId}`);
    const pieWrap=$id(`dev-pie-wrap-${rescId}`);
    if(tipo==='completa'){cuotasConfig.style.display='none';if(pieWrap)pieWrap.style.display='none';}
    else{cuotasConfig.style.display='block';if(pieWrap)pieWrap.style.display=(tipo==='pie_mas_cuotas'?'block':'none');}
}

function fmtDevInput(inp){
    const raw=inp.value.replace(/\./g,'').replace(/[^0-9]/g,'');
    if(raw)inp.value=Number(raw).toLocaleString('es-CL');
}

function parsePesos(s){return parseInt((s||'').replace(/\./g,'').replace(/[^0-9]/g,''))||null;}

function recalcDevCuotas(rescId){
    const nc=parseInt($id(`dev-ncuotas-${rescId}`)?.value)||0;
    const mc=parsePesos($id(`dev-mcuota-${rescId}`)?.value);
    if(nc&&mc) {
        // auto fill monto cuota if total is set
    }
}

function generarCuotasDev(rescId){
    const nc=parseInt($id(`dev-ncuotas-${rescId}`)?.value)||0;
    const mc=parsePesos($id(`dev-mcuota-${rescId}`)?.value);
    const fecha1=$id(`dev-fecha1-${rescId}`)?.value;
    if(!nc||!mc){showToast('Completa cantidad y monto de cuotas.','error');return;}

    const filas=[];
    for(let i=1;i<=nc;i++){
        let fv='';
        if(fecha1){
            const d=new Date(fecha1);
            d.setMonth(d.getMonth()+(i-1));
            fv=d.toISOString().split('T')[0];
        }
        filas.push({numero_cuota:i,monto:mc,fecha_vencimiento:fv});
    }
    // Preview en UI
    const tbl=$id(`dev-cuotas-table-${rescId}`);
    tbl.innerHTML=previewCuotasDevHTML(filas,rescId)+
        `<button class="im-btn im-btn-primary" style="margin-top:10px;background:#dc2626;border:none;" onclick='guardarCuotasDev(${rescId},${JSON.stringify(filas)})'>
            <i class="bi bi-floppy"></i> Guardar Cuotas de Devolución
         </button>`;
}

function previewCuotasDevHTML(cuotas,rescId){
    return `<table style="width:100%;border-collapse:collapse;font-size:.8rem;margin-top:8px;">
        <thead><tr>
            <th style="padding:6px 10px;text-align:left;background:#f8fafc;border-bottom:2px solid #e2e8f0;">N°</th>
            <th style="padding:6px 10px;text-align:left;background:#f8fafc;border-bottom:2px solid #e2e8f0;">Monto</th>
            <th style="padding:6px 10px;text-align:left;background:#f8fafc;border-bottom:2px solid #e2e8f0;">Vencimiento</th>
            <th style="padding:6px 10px;text-align:left;background:#f8fafc;border-bottom:2px solid #e2e8f0;">Estado</th>
        </tr></thead>
        <tbody>${cuotas.map(c=>`<tr>
            <td style="padding:7px 10px;border-bottom:1px solid #f1f5f9;">${c.numero_cuota}</td>
            <td style="padding:7px 10px;border-bottom:1px solid #f1f5f9;font-weight:600;">${fmtCLP(c.monto)}</td>
            <td style="padding:7px 10px;border-bottom:1px solid #f1f5f9;">${fmtFecha(c.fecha_vencimiento)}</td>
            <td style="padding:7px 10px;border-bottom:1px solid #f1f5f9;"><span class="badge-pendiente">Pendiente</span></td>
        </tr>`).join('')}</tbody>
    </table>`;
}

function renderCuotasDev(cuotas,rescId){
    if(!cuotas||cuotas.length===0) return `<p style="font-size:.8rem;color:#94a3b8;margin:8px 0;">No hay cuotas de devolución definidas aún.</p>`;

    const pagadas  = cuotas.filter(c=>c.pagado).length;
    const vencidas = cuotas.filter(c=>!c.pagado&&c.fecha_vencimiento&&new Date(c.fecha_vencimiento)<new Date()).length;
    const pendientes= cuotas.length - pagadas;
    const montoPag = cuotas.filter(c=>c.pagado).reduce((s,c)=>s+Number(c.monto||0),0);
    const montoPend= cuotas.filter(c=>!c.pagado).reduce((s,c)=>s+Number(c.monto||0),0);

    const resumenHeader=`
        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:10px;padding:10px 12px;background:#f8fafc;border-radius:8px;border:1px solid #e2e8f0;align-items:center;">
            <div style="font-size:.72rem;font-weight:600;">
                <span style="color:#16a34a;"><i class="bi bi-check-circle-fill"></i> ${pagadas} pagada${pagadas!==1?'s':''}</span>
                &nbsp;·&nbsp;
                <span style="color:#f59e0b;"><i class="bi bi-clock"></i> ${pendientes} pendiente${pendientes!==1?'s':''}</span>
                ${vencidas>0?`&nbsp;·&nbsp;<span style="color:#dc2626;font-weight:800;"><i class="bi bi-exclamation-triangle-fill"></i> ${vencidas} vencida${vencidas!==1?'s':''}</span>`:''}
            </div>
            <div style="margin-left:auto;font-size:.72rem;text-align:right;">
                <div style="color:#16a34a;font-weight:700;">$${montoPag.toLocaleString('es-CL')} devuelto</div>
                <div style="color:#ef4444;">$${montoPend.toLocaleString('es-CL')} pendiente</div>
            </div>
        </div>`;

    const html=cuotas.map(c=>{
        const venc=isOverdue({pagado:c.pagado,fecha_vencimiento:c.fecha_vencimiento});
        const cls=c.pagado?'pagada-mini':venc?'vencida-mini':'';
        const badge=c.pagado
            ?`<span class="badge-pagada"><i class="bi bi-check-circle-fill"></i> Pagada ${c.fecha_pago?'· '+fmtFecha(c.fecha_pago):''}</span>`
            :venc?`<span class="badge-vencida"><i class="bi bi-exclamation-triangle-fill"></i> Vencida</span>`
            :`<span class="badge-pendiente"><i class="bi bi-clock"></i> Pendiente</span>`;
        const compIcon=c.comprobante_url
            ?`<button class="im-btn im-btn-sm im-btn-ghost" onclick="previewDoc('${escH(c.comprobante_url)}','Comprobante Devolución ${c.numero_cuota}')" title="Ver comprobante">
                <i class="bi bi-eye"></i></button>`
            :'';
        const pagarBtn=!c.pagado
            ?`<button class="im-btn im-btn-sm im-btn-primary" style="background:#16a34a;border:none;" onclick="abrirPagarDev(${c.id})">
                <i class="bi bi-check-circle"></i> Marcar Pagada</button>`
            :'';
        return `<div class="mini-cuota-dev ${cls}">
            <span style="font-weight:800;min-width:30px;color:#0f172a;">N°${c.numero_cuota}</span>
            <span style="font-weight:700;min-width:100px;">${fmtCLP(c.monto)}</span>
            <span style="font-size:.74rem;color:#64748b;white-space:nowrap;min-width:80px;">Vence: ${fmtFecha(c.fecha_vencimiento)}</span>
            <div style="flex:1;">${badge}</div>
            ${compIcon}
            ${pagarBtn}
        </div>`;
    }).join('');
    return `<div style="margin-top:8px;">
        <p style="font-size:.75rem;font-weight:800;color:#475569;margin:0 0 8px;text-transform:uppercase;letter-spacing:.3px;"><i class="bi bi-list-check" style="color:#2563eb;"></i> Cuotas de Devolución</p>
        ${resumenHeader}
        ${html}
    </div>`;
}

async function guardarDevPlan(rescId){
    const btn=$id(`btn-guardar-dev-${rescId}`);
    const tipoEl=$id(`dev-type-btns-${rescId}`);
    const tipo=tipoEl?.querySelector('.dev-type-btn.active')?.textContent?.trim();
    const tipoMap={'Devolución Completa':'completa','Pie + Cuotas':'pie_mas_cuotas','Solo Cuotas':'cuotas'};
    const tipoVal=tipoMap[tipo]||'completa';
    const monto=parsePesos($id(`dev-monto-${rescId}`)?.value);
    const pie=parsePesos($id(`dev-pie-${rescId}`)?.value);
    const nc=parseInt($id(`dev-ncuotas-${rescId}`)?.value)||null;
    const mc=parsePesos($id(`dev-mcuota-${rescId}`)?.value);
    btn.disabled=true;btn.innerHTML='<i class="bi bi-hourglass-split"></i> Guardando...';
    try{
        const res=await fetch(`/api/im/resciliaciones/${rescId}`,{method:'PATCH',headers:{'Content-Type':'application/json'},
            body:JSON.stringify({tipo_devolucion:tipoVal,monto_total_devolucion:monto,monto_pie_devolucion:pie,numero_cuotas_devolucion:nc,monto_cuota_devolucion:mc})});
        if(!res.ok)throw new Error((await res.json().catch(()=>({}))).message||`Error ${res.status}`);
        showToast('Plan de devolución guardado.','success');
        await loadResc();
    }catch(e){showToast(e.message,'error');}
    finally{btn.disabled=false;btn.innerHTML='<i class="bi bi-floppy"></i> Guardar Plan';}
}

async function guardarCuotasDev(rescId,cuotas){
    try{
        const res=await fetch(`/api/im/resciliaciones/${rescId}/cuotas-devolucion`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({cuotas})});
        if(!res.ok)throw new Error((await res.json().catch(()=>({}))).message||`Error ${res.status}`);
        showToast('Cuotas de devolución guardadas.','success');
        // Reload detail
        const inner=$id(`resc-inner-${rescId}`);
        if(inner) await renderDetail(rescId,inner);
        await loadResc();
    }catch(e){showToast(e.message,'error');}
}

async function actualizarEstado(rescId,estado){
    try{
        const res=await fetch(`/api/im/resciliaciones/${rescId}`,{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({estado})});
        if(!res.ok)throw new Error('Error actualizando estado');
        showToast('Estado actualizado.','success');
        await loadResc();
    }catch(e){showToast(e.message,'error');}
}

// ─────────────────────────────────────────────
//  Pagar cuota de devolución
// ─────────────────────────────────────────────
function abrirPagarDev(cuotaId){
    $id('pd-cuota-id').value=cuotaId;
    $id('pd-fecha').value=new Date().toISOString().split('T')[0];
    $id('pd-notas').value='';
    $id('pd-file').value='';
    $id('pd-file-name').style.display='none';
    $id('pd-file').onchange=function(){
        const fn=this.files[0]?.name||'';
        if(fn){$id('pd-file-name').textContent=fn;$id('pd-file-name').style.display='block';}
    };
    openModal('pagar-dev');
}

async function confirmarPagarDev(){
    const btn=$id('pd-btn');
    const cuotaId=$id('pd-cuota-id').value;
    btn.disabled=true;btn.innerHTML='<i class="bi bi-hourglass-split"></i> Procesando...';
    try{
        const fd=new FormData();
        fd.append('fecha_pago',$id('pd-fecha').value||'');
        fd.append('notas',$id('pd-notas').value||'');
        const file=$id('pd-file').files[0];
        if(file) fd.append('archivo',file,file.name);
        const res=await fetch(`/api/im/cuotas-devolucion/${cuotaId}/pagar`,{method:'PATCH',body:fd});
        if(!res.ok)throw new Error((await res.json().catch(()=>({}))).message||`Error ${res.status}`);
        showToast('Devolución registrada correctamente.','success');
        closeModal('pagar-dev');
        await loadResc();
        if(activeRow){const inner=$id('resc-inner-'+activeRow);if(inner)await renderDetail(activeRow.replace('resc-',''),inner);}
    }catch(e){showToast(e.message,'error');}
    finally{btn.disabled=false;btn.innerHTML='<i class="bi bi-check-circle"></i> Confirmar Devolución';}
}

// ─────────────────────────────────────────────
//  Upload documento resciliación
// ─────────────────────────────────────────────
async function uploadDocResc(rescId, file){
    if(!file)return;
    const prog=$id(`doc-resc-prog-${rescId}`);
    if(prog){prog.style.display='block';prog.innerHTML='<i class="bi bi-hourglass-split"></i> Subiendo...';}
    try{
        const fd=new FormData();
        fd.append('archivo',file,file.name);
        const res=await fetch(`/api/im/resciliaciones/${rescId}/documento`,{method:'POST',body:fd});
        if(!res.ok)throw new Error((await res.json().catch(()=>({}))).message||`Error ${res.status}`);
        showToast('Documento de resciliación subido.','success');
        const inner=$id(`resc-inner-${rescId}`);
        if(inner) await renderDetail(rescId,inner);
        await loadResc();
    }catch(e){
        if(prog){prog.style.display='block';prog.style.color='#dc2626';prog.innerHTML=`<i class="bi bi-x-circle"></i> ${escH(e.message)}`;}
        showToast(e.message,'error');
    }
}

// ─────────────────────────────────────────────
//  Documentos relacionados
// ─────────────────────────────────────────────
async function loadRelDocs(rescId, tipo, asociId, btn){
    document.querySelectorAll(`[id^="doc-tab-${rescId}-"]`).forEach(b=>b.classList.remove('active'));
    if(btn)btn.classList.add('active');
    const cont=$id(`rel-docs-${rescId}`);
    if(!cont)return;
    cont.innerHTML='<div style="color:#94a3b8;font-size:.8rem;padding:8px 0;"><i class="bi bi-hourglass-split"></i> Cargando...</div>';
    try{
        const res=await fetch(`/api/im/documentos?tipo_asociacion=${tipo}&asociacion_id=${asociId}`);
        if(!res.ok)throw new Error('Error cargando docs');
        const docs=await res.json();
        if(docs.length===0){cont.innerHTML='<p style="font-size:.8rem;color:#94a3b8;margin:8px 0;">Sin documentos en esta sección.</p>';return;}
        cont.innerHTML=docs.map(d=>{
            const ext=(d.storage_path||'').split('.').pop().toLowerCase();
            const canPrev=['pdf','jpg','jpeg','png','webp','gif'].includes(ext);
            return `<div style="display:flex;align-items:center;gap:8px;padding:7px 10px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:7px;margin-bottom:5px;font-size:.8rem;">
                <i class="bi bi-file-earmark${ext==='pdf'?'-pdf':['jpg','jpeg','png','webp'].includes(ext)?'-image':''}" style="font-size:1.1rem;color:#2563eb;flex-shrink:0;"></i>
                <span style="flex:1;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${escH(d.nombre_personalizado)}</span>
                <span style="font-size:.72rem;color:#94a3b8;white-space:nowrap;">${new Date(d.creado_at).toLocaleDateString('es-CL')}</span>
                ${canPrev?`<button class="im-btn im-btn-sm im-btn-ghost" onclick="previewDoc('${escH(d.url_storage)}','${escH(d.nombre_personalizado)}')"><i class="bi bi-eye"></i></button>`:''}
                <a href="${escH(d.url_storage)}" download="${escH(d.nombre_personalizado)}" target="_blank" class="im-btn im-btn-sm im-btn-ghost"><i class="bi bi-download"></i></a>
            </div>`;
        }).join('');
    }catch(e){cont.innerHTML=`<p style="color:#ef4444;font-size:.8rem;">${escH(e.message)}</p>`;}
}

// ─────────────────────────────────────────────
//  Preview documento
// ─────────────────────────────────────────────
function previewDoc(url, nombre){
    const ext=(url||'').split('.').pop().split('?')[0].toLowerCase();
    $id('preview-title').textContent=nombre||'Vista Previa';
    const cont=$id('preview-content');
    if(['jpg','jpeg','png','webp','gif'].includes(ext)){
        cont.innerHTML=`<img src="${escH(url)}" style="max-width:100%;border-radius:8px;">`;
    }else{
        cont.innerHTML=`<iframe src="${escH(url)}" class="preview-frame"></iframe>`;
    }
    openModal('preview');
}

// ─────────────────────────────────────────────
//  Nueva Resciliación
// ─────────────────────────────────────────────
function openNuevaResc(){
    $id('nr-proyecto').value='';
    $id('nr-parcela').innerHTML='<option value="">— Selecciona primero el proyecto —</option>';
    $id('nr-fecha').value=new Date().toISOString().split('T')[0];
    $id('nr-motivo').value='';
    $id('nr-notas').value='';
    $id('nr-cliente-info').style.display='none';
    openModal('nueva-resc');
}

let _ventaIdParaResc=null;
async function cargarParcelasVendidas(){
    const proyId=$id('nr-proyecto').value;
    if(!proyId){$id('nr-parcela').innerHTML='<option value="">— Selecciona primero el proyecto —</option>';return;}
    $id('nr-parcela').innerHTML='<option>Cargando...</option>';
    try{
        const res=await fetch(`/api/im/parcelas/vendidas?proyecto_id=${proyId}`);
        const list=await res.json();
        if(!list.length){$id('nr-parcela').innerHTML='<option value="">Sin parcelas con venta activa</option>';return;}
        $id('nr-parcela').innerHTML='<option value="">— Selecciona parcela —</option>'
            +list.map(p=>`<option value="${p.venta_id}" data-cliente="${escH(p.cliente_nombre)}" data-rut="${escH(p.cliente_rut||'')}">Parcela ${p.numero_parcela} — ${p.cliente_nombre}</option>`).join('');
    }catch(e){$id('nr-parcela').innerHTML='<option>Error al cargar</option>';}
}

function onSeleccionarParcela(){
    const sel=$id('nr-parcela');
    const opt=sel.options[sel.selectedIndex];
    _ventaIdParaResc=sel.value||null;
    if(_ventaIdParaResc&&opt){
        const info=$id('nr-cliente-info');
        info.style.display='block';
        info.innerHTML=`<i class="bi bi-person-fill" style="color:#2563eb;"></i> <strong>${opt.dataset.cliente}</strong>${opt.dataset.rut?' — '+opt.dataset.rut:''}`;
    }else{
        $id('nr-cliente-info').style.display='none';
    }
}

async function confirmarNuevaResc(){
    if(!_ventaIdParaResc){showToast('Selecciona una parcela con venta activa.','error');return;}
    const btn=$id('nr-btn');
    btn.disabled=true;btn.innerHTML='<i class="bi bi-hourglass-split"></i> Procesando...';
    try{
        const body={
            fecha:$id('nr-fecha').value,
            motivo:$id('nr-motivo').value.trim(),
            notas:$id('nr-notas').value.trim()
        };
        const res=await fetch(`/api/im/ventas/${_ventaIdParaResc}/resciliar`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
        if(!res.ok)throw new Error((await res.json().catch(()=>({}))).message||`Error ${res.status}`);
        showToast('Resciliación registrada. La parcela volvió a Disponible.','success');
        closeModal('nueva-resc');
        await loadResc();
    }catch(e){showToast(e.message,'error');}
    finally{btn.disabled=false;btn.innerHTML='<i class="bi bi-file-earmark-x"></i> Confirmar Resciliación';}
}

