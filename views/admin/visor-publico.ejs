<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= proyecto.nombre %> - Visita Virtual 360° | Cygnus Group</title>
    
    <link rel="icon" type="image/png" href="/img/fav.png">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@photo-sphere-viewer/core@5.7.3/index.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@photo-sphere-viewer/markers-plugin@5.7.3/index.min.css">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    
    <style>
        :root { --primary: #2563eb; --secondary: #64748b; --dark: #0f172a; }
        body { margin: 0; overflow: hidden; font-family: 'Inter', sans-serif; background: var(--dark); }
        #viewer { width: 100vw; height: 100vh; }

        /* Branding Cygnus Flotante */
        .company-logo {
            position: absolute; top: 20px; left: 20px; z-index: 10;
            background: rgba(255, 255, 255, 0.95); padding: 10px 20px;
            border-radius: 16px; box-shadow: 0 4px 15px rgba(0,0,0,0.15);
            display: flex; align-items: center; gap: 15px;
            backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.2);
        }
        .company-logo img { height: 35px; object-fit: contain; }
        .project-info { display: flex; flex-direction: column; border-left: 1px solid #e2e8f0; padding-left: 15px; }
        .project-name { font-weight: 800; color: var(--dark); font-size: 1rem; }
        .project-loc { font-size: 0.75rem; color: var(--secondary); font-weight: 500; }

        /* Estilo Botón Contactar */
        .btn-contactar {
            position: absolute; top: 20px; right: 20px; z-index: 10;
            background: var(--primary); color: white; padding: 12px 24px;
            border-radius: 50px; font-weight: 700; font-size: 0.9rem;
            text-decoration: none; box-shadow: 0 4px 15px rgba(37, 99, 235, 0.4);
            display: flex; align-items: center; gap: 8px; transition: 0.3s;
        }
        .btn-contactar:hover { background: #1d4ed8; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(37, 99, 235, 0.5); }

        /* Leyenda de Estados */
        .legend-box {
            position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%);
            background: rgba(15, 23, 42, 0.85); backdrop-filter: blur(10px);
            padding: 10px 25px; border-radius: 50px; display: flex; gap: 20px; z-index: 10;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .legend-item { display: flex; align-items: center; gap: 8px; color: white; font-size: 0.85rem; font-weight: 600; }
        .dot { width: 12px; height: 12px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.8); }

        /* Nano Cards (El popup al pasar el mouse por un polígono) */
        .psv-tooltip-content { padding: 0 !important; border-radius: 16px !important; overflow: hidden; background: transparent !important; }
        .lote-card-nano {
            background: white; border-radius: 16px; padding: 15px 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2); min-width: 160px; text-align: center;
            border: 1px solid #e2e8f0; font-family: 'Inter', sans-serif;
        }
        .nano-status {
            display: inline-block; padding: 4px 12px; border-radius: 20px; color: white;
            font-size: 0.7rem; font-weight: 800; text-transform: uppercase; margin-bottom: 8px; letter-spacing: 0.5px;
        }
        .nano-price { display: block; font-size: 1.4rem; font-weight: 800; color: var(--dark); line-height: 1; }
        .nano-meta { display: block; font-size: 0.8rem; color: var(--secondary); margin-top: 6px; font-weight: 500; }

        /* Badges de Lotes (El numerito en el mapa) */
        .lote-badge-wrapper { pointer-events: none; }
        .lote-badge-content {
            padding: 4px 10px; border-radius: 8px; font-family: 'Inter', sans-serif; font-size: 0.8rem;
            font-weight: 800; box-shadow: 0 4px 10px rgba(0,0,0,0.3); text-shadow: 0 1px 2px rgba(0,0,0,0.5);
            transition: transform 0.2s;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .company-logo img { height: 25px; }
            .project-name { font-size: 0.85rem; }
            .legend-box { bottom: 20px; padding: 8px 15px; width: 90%; justify-content: space-around; }
            .btn-contactar { top: auto; bottom: 80px; left: 50%; transform: translateX(-50%); right: auto; width: max-content; }
        }
    </style>
</head>
<body>

    <div class="company-logo">
        <img src="/img/logo.png" alt="Cygnus Group">
        <div class="project-info">
            <span class="project-name"><%= proyecto.nombre %></span>
            <span class="project-loc"><i class="bi bi-geo-alt-fill"></i> <%= proyecto.localidad || 'Ubicación' %></span>
        </div>
    </div>

    <a href="/contacto" class="btn-contactar"><i class="bi bi-whatsapp"></i> Me interesa</a>

    <div class="legend-box">
        <div class="legend-item"><div class="dot" style="background: #22c55e;"></div> Disponible</div>
        <div class="legend-item"><div class="dot" style="background: #eab308;"></div> Reservado</div>
        <div class="legend-item"><div class="dot" style="background: #ef4444;"></div> Vendido</div>
    </div>

    <div id="viewer"></div>

    <script>
        const PROJECT_DATA = <%- JSON.stringify(proyecto) %>;
    </script>

    <script type="importmap">
    {
        "imports": {
            "three": "https://cdn.jsdelivr.net/npm/three@0.164.0/build/three.module.js",
            "@photo-sphere-viewer/core": "https://cdn.jsdelivr.net/npm/@photo-sphere-viewer/core@5.7.3/index.module.js",
            "@photo-sphere-viewer/markers-plugin": "https://cdn.jsdelivr.net/npm/@photo-sphere-viewer/markers-plugin@5.7.3/index.module.js"
        }
    }
    </script>
    
    <script type="module">
        import { Viewer } from '@photo-sphere-viewer/core';
        import { MarkersPlugin } from '@photo-sphere-viewer/markers-plugin';

        // Constantes extraídas de tu código original
        const COLORS = { 1: '#22c55e', 2: '#eab308', 3: '#ef4444' }; // Verde, Amarillo, Rojo
        const OPACITIES = { 1: 0.4, 2: 0.5, 3: 0.5 };
        const TEXTS = { 1: 'Disponible', 2: 'Reservado', 3: 'Vendido' };

        let viewer, markersPlugin;

        async function init() {
            viewer = new Viewer({
                container: 'viewer',
                panorama: PROJECT_DATA.imagen_360_url, // URL inyectada
                navbar: ['zoom', 'fullscreen'],
                defaultZoomLvl: 30,
                plugins: [[MarkersPlugin, {}]]
            });

            markersPlugin = viewer.getPlugin(MarkersPlugin);
            
            viewer.addEventListener('ready', () => {
                loadLotes();
            }, { once: true });

            viewer.addEventListener('position-updated', updateAllMarkersScale);
            viewer.addEventListener('zoom-updated', updateAllMarkersScale);
        }

        function getPolygonCenter(polygonArray) {
            let sumYaw = 0, sumPitch = 0;
            polygonArray.forEach(p => { sumYaw += p[0]; sumPitch += p[1]; });
            return [sumYaw / polygonArray.length, sumPitch / polygonArray.length];
        }

        function updateAllMarkersScale() {
            if(!viewer || !markersPlugin) return;
            const zoom = viewer.getZoomLevel();
            const scale = 0.5 + (zoom / 100) * 1.5;
            const markers = markersPlugin.getMarkers();
            markers.forEach(m => {
                if (m.config.data && m.config.data.tipo === 'badge') {
                    const el = document.querySelector(`#${m.id} .lote-badge-content`);
                    if(el) el.style.transform = `scale(${scale})`;
                }
            });
        }

        async function loadLotes() {
            try {
                // Hacemos FETCH a la API que ya creamos en tu backend
                const res = await fetch(`/api/lotes/proyecto/${PROJECT_DATA.id}`);
                const data = await res.json();

                data.forEach(el => {
                    if (el.tipo === 'poi') {
                        // Marcador Clásico (POI)
                        markersPlugin.addMarker({
                            id: `poi_${el.id}`,
                            position: { yaw: el.poligono_json.yaw, pitch: el.poligono_json.pitch },
                            html: `<i class="bi bi-geo-alt-fill" style="font-size:32px; color:${el.poligono_json.color || '#fff'}; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.5));"></i>`,
                            anchor: 'bottom center',
                            tooltip: { content: `<b>${el.titulo}</b><br>${el.descripcion}`, position: 'top center' }
                        });
                    } 
                    else if (el.tipo === 'camino') {
                        // Camino o Calle
                        markersPlugin.addMarker({
                            id: `camino_${el.id}`,
                            polygonRad: el.poligono_json,
                            svgStyle: { fill: 'rgba(255,255,255,0.2)', stroke: el.color_hex || '#ffffff', strokeWidth: '3px', strokeDasharray: '5,5' },
                            tooltip: { content: el.numero_lote || 'Camino', position: 'center' }
                        });
                    }
                    else {
                        // LOTE REGULAR
                        const color = COLORS[el.estado_id] || '#ffffff';
                        const opacity = OPACITIES[el.estado_id] || 0.4;
                        
                        // Añadir Polígono
                        markersPlugin.addMarker({
                            id: `poly_${el.id}`,
                            polygonRad: el.poligono_json,
                            svgStyle: { fill: color, fillOpacity: opacity, stroke: '#ffffff', strokeWidth: '2px' },
                            data: { tipo: 'lote', id_lote: el.id, estado: el.estado_id }
                        });

                        // Añadir el Número (Badge) al centro
                        if (el.poligono_json.length > 2) {
                            const center = getPolygonCenter(el.poligono_json);
                            const badgeStyle = el.estado_id === 1 ? 'background: rgba(255,255,255,0.9); color: #1e293b; border: 2px solid white;' : `background: ${color}; border: 2px solid white; color: white;`;
                            const badgeHtml = `<div class="lote-badge-wrapper"><div class="lote-badge-content" style="${badgeStyle}">${el.numero_lote}</div></div>`;
                            
                            markersPlugin.addMarker({ 
                                id: `badge_${el.id}`, 
                                position: { yaw: center[0], pitch: center[1] }, 
                                html: badgeHtml, anchor: 'center center', 
                                tooltip: { content: createNanoCard(el, color), position: 'top center' }, 
                                data: { tipo: 'badge' } 
                            });
                        }
                    } 
                });
                updateAllMarkersScale();
            } catch (error) { console.error('Error al cargar lotes:', error); }
        }

        function createNanoCard(el, color) {
            const precio = parseInt(el.precio || 0).toLocaleString('es-CL');
            const sup = parseInt(el.superficie || 0).toLocaleString('es-CL');
            return `
                <div class="lote-card-nano">
                    <span class="nano-status" style="background:${color};">${TEXTS[el.estado_id]}</span>
                    <span class="nano-price">$${precio}</span>
                    <span class="nano-meta">${sup} m²</span>
                </div>
            `;
        }
        
        init();
    </script>
</body>
</html>