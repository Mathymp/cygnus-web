<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= proyecto.nombre %> - Visita Virtual | Cygnus Group</title>
    <link rel="icon" type="image/png" href="/img/fav.png">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@photo-sphere-viewer/core@5.7.3/index.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@photo-sphere-viewer/markers-plugin@5.7.3/index.min.css">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    
    <style>
        :root { --primary: #2563eb; --secondary: #64748b; --dark: #0f172a; --wsp: #22c55e; }
        body { margin: 0; overflow: hidden; font-family: 'Plus Jakarta Sans', sans-serif; background: var(--dark); }
        #viewer { width: 100vw; height: 100vh; }

        /* --- Logo Cygnus Superior Derecha --- */
        .company-logo { 
            position: fixed; top: 30px; right: 30px; z-index: 100; 
            height: 70px; width: auto; object-fit: contain; pointer-events: none; 
            filter: drop-shadow(0 2px 10px rgba(0,0,0,0.3)); 
        }
        
        /* --- Header del Proyecto Estilo Premium (Izquierda) --- */
        .project-header { 
            position: fixed; top: 30px; left: 25px; z-index: 100; 
            max-width: 380px; display: flex; justify-content: flex-start; 
            animation: slideInLeft 0.7s cubic-bezier(0.25, 0.8, 0.25, 1); 
        }
        
        .project-card-header { 
            background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(12px); 
            padding: 20px 30px; border-radius: 16px 50px 50px 16px; 
            box-shadow: 0 15px 35px rgba(0,0,0,0.2); text-align: left; 
            border: 1px solid rgba(255,255,255,0.5); border-left: 5px solid var(--primary); 
        }
        
        .project-card-header h1 { 
            margin: 0; font-size: 1.5rem; font-weight: 800; color: var(--dark); 
            line-height: 1.1; letter-spacing: -0.5px;
        }
        
        .project-location { 
            margin-top: 8px; font-size: 0.85rem; color: var(--secondary); font-weight: 700; 
            display: flex; align-items: center; gap: 6px; text-transform: uppercase; letter-spacing: 0.5px;
        }
        .project-location i { color: var(--primary); }
        
        .project-desc { 
            margin-top: 10px; font-size: 0.85rem; color: var(--secondary); 
            font-weight: 500; line-height: 1.4; border-top: 1px solid rgba(0,0,0,0.1); padding-top: 10px;
        }

        /* --- WhatsApp Latente --- */
        .btn-wsp-float {
            position: fixed; bottom: 30px; right: 30px; z-index: 110;
            background: var(--wsp); color: white; padding: 15px 25px;
            border-radius: 50px; font-weight: 800; text-decoration: none;
            display: flex; align-items: center; gap: 10px; box-shadow: 0 10px 25px rgba(34, 197, 94, 0.4);
            transition: 0.3s; animation: pulse-wsp 2.5s infinite;
        }
        .btn-wsp-float:hover { background: #16a34a; transform: translateY(-5px); }
        @keyframes pulse-wsp { 0% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.6); } 70% { box-shadow: 0 0 0 15px rgba(34, 197, 94, 0); } 100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); } }

        /* --- Estilos Marcadores & Tooltips --- */
        .psv-tooltip { background: transparent !important; box-shadow: none !important; border: none !important; padding: 0 !important; }
        
        .lote-card-nano {
            background: white; border-radius: 12px; padding: 10px 15px;
            text-align: center; box-shadow: 0 8px 25px rgba(0,0,0,0.3);
            margin-bottom: 15px; position: relative;
        }
        .lote-card-nano::after {
            content: ''; position: absolute; top: 100%; left: 50%; transform: translateX(-50%);
            border-width: 6px 6px 0; border-style: solid; border-color: white transparent transparent transparent;
        }

        .nano-status { font-size: 0.7rem; font-weight: 800; color: white !important; padding: 4px 10px; border-radius: 20px; display: inline-block; margin-bottom: 5px; }
        .nano-price { font-size: 1.2rem; font-weight: 800; color: var(--dark); display: block; }
        .nano-meta { font-size: 0.75rem; color: var(--secondary); font-weight: 600; display: block; }

        .lote-badge-content {
            position: absolute; transform: translate(-50%, -50%);
            min-width: 30px; height: 30px; border-radius: 50px; 
            display: flex; align-items: center; justify-content: center;
            font-weight: 800; font-size: 0.9rem; box-shadow: 0 4px 10px rgba(0,0,0,0.4); 
            cursor: pointer; transition: 0.2s; border: 2px solid white; color: white;
        }
        .lote-badge-content:hover { transform: translate(-50%, -50%) scale(1.2); z-index: 101; }

        /* Marcadores POI con Línea */
        .poi-wrapper { width: 0; height: 0; position: absolute; overflow: visible; pointer-events: none; }
        .poi-content { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; pointer-events: auto; cursor: pointer; }
        .poi-pill { min-width: 90px; padding: 8px 15px; border-radius: 10px; text-align: center; color: white; font-weight: 700; font-size: 0.9rem; box-shadow: 0 5px 15px rgba(0,0,0,0.3); }
        .poi-sub { font-size: 0.75rem; font-weight: 400; opacity: 0.9; margin-top: 2px; display: block; }
        .poi-line { width: 3px; background: white; box-shadow: 0 2px 5px rgba(0,0,0,0.3); }
        .poi-anchor { width: 12px; height: 12px; border-radius: 50%; border: 2px solid white; }

        .legal-bar { position: fixed; bottom: 20px; width: 100%; z-index: 80; display: flex; justify-content: center; pointer-events: none; }
        .legal-pill { background: rgba(0, 0, 0, 0.7); padding: 8px 25px; border-radius: 30px; font-size: 0.75rem; color: white; font-weight: 600; backdrop-filter: blur(5px); }

        @keyframes slideInLeft { from { opacity: 0; transform: translateX(-40px); } to { opacity: 1; transform: translateX(0); } }

        @media (max-width: 768px) {
            .project-header { top: 15px; left: 15px; max-width: 80%; }
            .project-card-header { padding: 15px 20px; border-radius: 12px 35px 35px 12px; }
            .project-card-header h1 { font-size: 1.1rem; }
            .project-desc { display: none; }
            .company-logo { top: 15px; right: 15px; height: 45px; }
            .btn-wsp-float { bottom: 80px; left: 50%; transform: translateX(-50%); right: auto; width: 80%; justify-content: center; }
        }
    </style>
</head>
<body>
    <div id="viewer"></div>

    <div class="project-header" id="header-container">
        <div class="project-card-header">
            <h1 id="p-title"><%= proyecto.nombre %></h1>
            <div class="project-location" id="p-location-container">
                <i class="bi bi-geo-alt-fill"></i> <span id="p-location"><%= proyecto.localidad || 'Chile' %></span>
            </div>
            <% if (proyecto.descripcion) { %>
                <div class="project-desc"><%= proyecto.descripcion %></div>
            <% } %>
        </div>
    </div>

    <img src="/img/logo.png" class="company-logo" alt="Cygnus Group Logo">

    <a href="#" id="wa-link" target="_blank" class="btn-wsp-float">
        <i class="bi bi-whatsapp"></i> Me interesa una parcela
    </a>

    <div class="legal-bar">
        <div class="legal-pill"><i class="bi bi-info-circle-fill"></i> Imágenes y deslindes referenciales sujetos a topografía final.</div>
    </div>

    <script type="importmap">{ "imports": { "three": "https://cdn.jsdelivr.net/npm/three@0.164.0/build/three.module.js", "@photo-sphere-viewer/core": "https://cdn.jsdelivr.net/npm/@photo-sphere-viewer/core@5.7.3/index.module.js", "@photo-sphere-viewer/markers-plugin": "https://cdn.jsdelivr.net/npm/@photo-sphere-viewer/markers-plugin@5.7.3/index.module.js" } }</script>
    
    <script type="module">
        import { Viewer } from '@photo-sphere-viewer/core';
        import { MarkersPlugin } from '@photo-sphere-viewer/markers-plugin';

        const PROJECT_DATA = <%- JSON.stringify(proyecto) %>;
        const WA_PHONE = "569XXXXXXXX"; // <-- CAMBIA TU TELÉFONO AQUÍ
        const TEXTS = { 1: 'DISPONIBLE', 2: 'RESERVADO', 3: 'VENDIDO' };
        const COLORS = { 1: '#10b981', 2: '#2563eb', 3: '#ef4444' };
        
        let viewer, markersPlugin;

        // Configuración de WhatsApp Dinámica
        const msg = `Hola! Me interesa información del proyecto *${PROJECT_DATA.nombre}*. Vi el recorrido 360 aquí: ${window.location.href}`;
        document.getElementById('wa-link').href = `https://wa.me/${WA_PHONE}?text=${encodeURIComponent(msg)}`;

        // Escalas dinámicas según zoom
        const getCaminoScale = (zoom) => 0.4 + (0.6 * (zoom / 100)); 
        const getLoteScale = (zoom) => 0.6 + (0.5 * (zoom / 100));

        function getPolygonCenter(points) {
            if (!points || points.length === 0) return null;
            let sumYaw = 0, sumPitch = 0;
            points.forEach(p => { sumYaw += p[0]; sumPitch += p[1]; });
            return [sumYaw / points.length, sumPitch / points.length];
        }

        function updateAllMarkersScale() {
            if (!viewer || !markersPlugin) return;
            const currentZoom = viewer.getZoomLevel();
            const markers = markersPlugin.getMarkers();
            
            markers.forEach(m => {
                if (m.config.data?.tipo === 'camino') {
                    const baseW = parseInt(m.config.data.width) || 15;
                    const w = Math.max(4, baseW * getCaminoScale(currentZoom));
                    markersPlugin.updateMarker({ id: m.id, svgStyle: { strokeWidth: w } });
                } else if (m.config.data?.tipo === 'lote_poly') {
                    const baseW = 4;
                    const scaledW = Math.max(2, baseW * getLoteScale(currentZoom));
                    markersPlugin.updateMarker({ id: m.id, svgStyle: { strokeWidth: scaledW } });
                } else if (m.config.data?.tipo === 'badge') {
                    const textScale = 0.8 + (0.4 * (currentZoom / 100)); 
                    const el = document.querySelector(`#psv-marker-${m.id} .lote-badge-content`);
                    if(el) el.style.transform = `translate(-50%, -50%) scale(${textScale})`;
                }
            });
        }

        async function init() {
            viewer = new Viewer({
                container: 'viewer',
                panorama: PROJECT_DATA.imagen_360_url,
                navbar: ['zoom', 'fullscreen'],
                defaultZoomLvl: 30,
                plugins: [[MarkersPlugin, { markers: [] }]]
            });

            markersPlugin = viewer.getPlugin(MarkersPlugin);
            viewer.addEventListener('ready', loadElements, { once: true });
            viewer.addEventListener('zoom-updated', updateAllMarkersScale);
        }

        async function loadElements() {
            try {
                const res = await fetch(`/api/lotes/proyecto/${PROJECT_DATA.id}`);
                const data = await res.json();

                data.forEach(el => {
                    const puntos = typeof el.poligono_json === 'string' ? JSON.parse(el.poligono_json) : el.poligono_json;
                    if(!puntos) return;

                    if (el.tipo === 'poi') {
                        const h = puntos.height || 80;
                        const bg = puntos.bg || '#2563eb';
                        const html = `
                            <div class="poi-wrapper">
                                <div class="poi-content">
                                    <div class="poi-pill" style="background:${bg};">
                                        ${el.titulo}<br><span class="poi-sub">${el.descripcion || ''}</span>
                                    </div>
                                    <div class="poi-line" style="height:${h}px; background:${bg};"></div>
                                    <div class="poi-anchor" style="background:${bg};"></div>
                                </div>
                            </div>`;
                        markersPlugin.addMarker({ id: `poi_${el.id}`, position: { yaw: puntos.yaw, pitch: puntos.pitch }, html: html, anchor: 'center center', data: { tipo: 'poi' } });
                    } 
                    else if (el.tipo === 'camino') {
                        markersPlugin.addMarker({ 
                            id: `camino_${el.id}`, 
                            polygon: puntos, 
                            svgStyle: { fill: 'rgba(255,255,255,0.1)', stroke: el.color_hex || '#ffffff', strokeWidth: 10, strokeLinecap: 'round' },
                            data: { tipo: 'camino', width: 10 } 
                        });
                    }
                    else {
                        const color = COLORS[el.estado_id] || '#10b981';
                        // Polígono sutil
                        markersPlugin.addMarker({ 
                            id: `poly_${el.id}`, 
                            polygon: puntos, 
                            svgStyle: { fill: 'rgba(255,255,255,0.0)', stroke: 'white', strokeWidth: 3 }, 
                            data: { tipo: 'lote_poly' } 
                        });

                        // Círculo central (Badge)
                        const center = getPolygonCenter(puntos);
                        if(center) {
                            const badgeHtml = `<div class="lote-badge-content" style="background:${color}">${el.numero_lote}</div>`;
                            markersPlugin.addMarker({ 
                                id: `badge_${el.id}`, 
                                position: { yaw: center[0], pitch: center[1] }, 
                                html: badgeHtml, anchor: 'center center', 
                                tooltip: { content: createNanoCard(el, color), position: 'top center' }, 
                                data: { tipo: 'badge' } 
                            });
                        }
                    }
                });
                updateAllMarkersScale();
            } catch (e) { console.error("Error cargando elementos:", e); }
        }

        function createNanoCard(el, color) {
            const precio = parseInt(el.precio || 0).toLocaleString('es-CL');
            const sup = parseInt(el.superficie || 0).toLocaleString('es-CL');
            return `
                <div class="lote-card-nano">
                    <span class="nano-status" style="background:${color};">${TEXTS[el.estado_id]}</span>
                    <span class="nano-price">$${precio}</span>
                    <span class="nano-meta">${sup} m² superficie</span>
                </div>`;
        }

        init();
    </script>
</body>
</html>