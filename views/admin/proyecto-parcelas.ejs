                        <button onclick="saveProjRename(${doc.id})" title="Guardar"
                            style="background:linear-gradient(135deg,#2563eb,#1d4ed8);color:#fff;border:none;border-radius:7px;padding:5px 12px;font-size:.8rem;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:5px;white-space:nowrap;flex-shrink:0;">
                            <i class="bi bi-check-lg"></i> Guardar
