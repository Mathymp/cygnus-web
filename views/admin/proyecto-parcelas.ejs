}

// ── Preview con Zoom centrado en cursor ──────────────────────────────
const ZOOM_MIN = 0.25, ZOOM_MAX = 8;
let _pState = { zoom:1, panX:0, panY:0, drag:false, lastX:0, lastY:0, img:null, isImg:false };

function openProjPreviewById(id){
    const doc = _projDocsCache[id];
    if(!doc) return;
    openProjPreview(doc.url_storage, doc.nombre_personalizado, getDocExt(doc), id);
}

async function _projRetryUrl(docId, img, loader){
    try{
        const res = await fetch(`/api/im/documentos/${docId}/url`);
        if(!res.ok) throw new Error('No se pudo refrescar URL');
        const data = await res.json();
        if(data.url && data.url !== img.src){
            if(_projDocsCache[docId]) _projDocsCache[docId].url_storage = data.url;
            img.onerror = () => _projShowImgError(data.url);
            img.src = data.url;
            return;
        }
    }catch(_){}
    _projShowImgError(img.src);
}

function _projShowImgError(url){
    const body = $('proj-preview-body');
    body.innerHTML = `<div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:#94a3b8;text-align:center;padding:24px;">
        <div><i class="bi bi-exclamation-triangle" style="font-size:2rem;display:block;margin-bottom:10px;"></i>
        <p>No se pudo cargar la imagen.</p>
        <a href="${escH(url)}" target="_blank" class="im-btn im-btn-primary" style="margin-top:12px;display:inline-flex;"><i class="bi bi-box-arrow-up-right"></i> Abrir en nueva pestaña</a></div></div>`;
}

function openProjPreview(url, nombre, ext, docId){
    $('proj-preview-overlay').style.display = 'flex';
    $('proj-preview-title').textContent = nombre || 'Vista Previa';
    const body    = $('proj-preview-body');
    const zoomBar = $('proj-zoom-bar');
    const dl      = $('proj-preview-dl');
    const icon    = $('proj-preview-icon');
    if(dl){ dl.href = url; dl.download = nombre||'archivo'; }

    _cleanPreviewListeners();
    _pState = { zoom:1, panX:0, panY:0, drag:false, lastX:0, lastY:0, img:null, isImg:false };

    const isImg = ['jpg','jpeg','png','webp','gif'].includes(ext);
    const isPdf = ext === 'pdf';
    _pState.isImg = isImg;

    body.className = 'proj-preview-body' + (isPdf ? ' mode-pdf' : '');
    zoomBar.classList.toggle('visible', isImg);
    if(icon){
        icon.className = 'bi ' + (isImg ? 'bi-file-earmark-image' : isPdf ? 'bi-file-earmark-pdf' : 'bi-file-earmark');
        icon.style.flexShrink = '0';
    }

    if(isImg){
        body.innerHTML = `<div class="proj-img-loading" id="_pLoad"><i class="bi bi-hourglass-split"></i><span>Cargando imagen...</span></div>
            <div id="_pWrap" class="proj-img-wrap">
                <img id="_pImg" src="${escH(url)}" decoding="async" alt="${escH(nombre)}">
            </div>`;

        _pState.img = document.getElementById('_pImg');
        const wrap  = document.getElementById('_pWrap');
        const loader = document.getElementById('_pLoad');

        const onReady = () => {
            if(loader) loader.style.display = 'none';
            _pState.zoom = 1; _pState.panX = 0; _pState.panY = 0;
            _projApply(false);
        };
        _pState.img.onload = onReady;
        if(_pState.img.complete && _pState.img.naturalWidth > 0) onReady();

        _pState.img.onerror = () => {
            if(docId) _projRetryUrl(docId, _pState.img, loader);
            else _projShowImgError(url);
        };

        wrap._onWheel = e => {
            e.preventDefault();
            const rect = wrap.getBoundingClientRect();
            const mx = e.clientX - rect.left - rect.width/2;
            const my = e.clientY - rect.top - rect.height/2;
            const factor = e.deltaY < 0 ? 1.12 : 0.9;
            const newZ = Math.min(ZOOM_MAX, Math.max(ZOOM_MIN, _pState.zoom * factor));
            _pState.panX = mx - (mx - _pState.panX) * (newZ / _pState.zoom);
            _pState.panY = my - (my - _pState.panY) * (newZ / _pState.zoom);
            _pState.zoom = newZ;
            _projApply(false);
        };
        wrap.addEventListener('wheel', wrap._onWheel, { passive:false });

        wrap._onMD = e => {
            if(_pState.zoom <= 1) return;
            _pState.drag = true;
            _pState.lastX = e.clientX;
            _pState.lastY = e.clientY;
            wrap.style.cursor = 'grabbing';
        };
        wrap.addEventListener('mousedown', wrap._onMD);

        document._pMM = e => {
            if(!_pState.drag) return;
            _pState.panX += e.clientX - _pState.lastX;
            _pState.panY += e.clientY - _pState.lastY;
            _pState.lastX = e.clientX;
            _pState.lastY = e.clientY;
            _projApply(false);
        };
        document._pMU = () => {
            _pState.drag = false;
            if(wrap) wrap.style.cursor = _pState.zoom > 1 ? 'grab' : 'default';
        };
        document.addEventListener('mousemove', document._pMM);
        document.addEventListener('mouseup',   document._pMU);

        let _lastTouchDist = null, _lastTouchMid = null;
        wrap._onTouchStart = e => {
            if(e.touches.length === 2){
                const dx = e.touches[0].clientX - e.touches[1].clientX;
                const dy = e.touches[0].clientY - e.touches[1].clientY;
                _lastTouchDist = Math.hypot(dx, dy);
                _lastTouchMid  = {x:(e.touches[0].clientX+e.touches[1].clientX)/2, y:(e.touches[0].clientY+e.touches[1].clientY)/2};
            }
        };
        wrap._onTouchMove = e => {
            e.preventDefault();
            if(e.touches.length === 2 && _lastTouchDist){
                const dx = e.touches[0].clientX - e.touches[1].clientX;
                const dy = e.touches[0].clientY - e.touches[1].clientY;
                const dist = Math.hypot(dx, dy);
                const rect = wrap.getBoundingClientRect();
                const mx = _lastTouchMid.x - rect.left - rect.width/2;
                const my = _lastTouchMid.y - rect.top - rect.height/2;
                const factor = dist / _lastTouchDist;
                const newZ = Math.min(ZOOM_MAX, Math.max(ZOOM_MIN, _pState.zoom * factor));
                _pState.panX = mx - (mx - _pState.panX) * (newZ / _pState.zoom);
                _pState.panY = my - (my - _pState.panY) * (newZ / _pState.zoom);
                _pState.zoom = newZ;
                _lastTouchDist = dist;
                _projApply(false);
            }
        };
        wrap.addEventListener('touchstart', wrap._onTouchStart, {passive:true});
        wrap.addEventListener('touchmove',  wrap._onTouchMove,  {passive:false});
    } else if(isPdf){
        const pdfSrc = escH(url) + '#toolbar=1&navpanes=1&scrollbar=1&view=FitH';
        body.innerHTML = `<iframe class="proj-pdf-frame" src="${pdfSrc}" title="${escH(nombre)}"></iframe>`;
    } else {
        body.innerHTML = `<div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:#f1f5f9;color:#64748b;text-align:center;padding:24px;">
            <div><i class="bi bi-file-earmark-text" style="font-size:3rem;display:block;margin-bottom:12px;"></i>
            <p>Vista previa no disponible para este tipo de archivo.</p>
            <a href="${escH(url)}" target="_blank" class="im-btn im-btn-primary" style="margin-top:12px;display:inline-flex;"><i class="bi bi-box-arrow-up-right"></i> Abrir en nueva pestaña</a></div></div>`;
    }
}

function _projApply(animate){
    const img = _pState.img; if(!img) return;
    img.style.transition = animate ? 'transform .2s' : 'none';
    img.style.transform = `translate(${_pState.panX}px,${_pState.panY}px) scale(${_pState.zoom})`;
    const wrap = document.getElementById('_pWrap');
    if(wrap) wrap.style.cursor = _pState.zoom > 1 ? (_pState.drag ? 'grabbing' : 'grab') : 'default';
    _updateZoomUI();
}

function projZoom(delta){
    const newZ = Math.min(ZOOM_MAX, Math.max(ZOOM_MIN, _pState.zoom + delta));
    _pState.zoom = newZ;
    if(newZ <= 1){ _pState.panX = 0; _pState.panY = 0; }
    _projApply(true);
}
function projZoomReset(){
    _pState.zoom = 1; _pState.panX = 0; _pState.panY = 0;
    _projApply(true);
}

function _updateZoomUI(){
    const pct = Math.round(_pState.zoom * 100);
    const el  = $('proj-zoom-pct'); if(el) el.textContent = pct + '%';
    const bar = $('proj-zoom-bar-fill');
    if(bar){
        const frac = (_pState.zoom - ZOOM_MIN) / (ZOOM_MAX - ZOOM_MIN);
        bar.style.width = Math.max(0, Math.min(100, Math.round(frac*100))) + '%';
    }
}

function _cleanPreviewListeners(){
    if(document._pMM) document.removeEventListener('mousemove', document._pMM);
    if(document._pMU) document.removeEventListener('mouseup',   document._pMU);
    document._pMM = null; document._pMU = null;
}

function closeProjPreview(){
    _cleanPreviewListeners();
    _pState.drag = false; _pState.img = null;
    $('proj-preview-overlay').style.display = 'none';
}
$('proj-preview-overlay') && ($('proj-preview-overlay').onclick = function(e){ if(e.target===this) closeProjPreview(); });
$('proj-del-overlay')     && ($('proj-del-overlay').onclick     = function(e){ if(e.target===this) closeProjDel(); });

// Precargar conteo de docs para mostrar el badge en la pestaña sin entrar a ella
async function prefetchDocCount(){
    try{
        const res = await fetch(`/api/im/documentos?tipo_asociacion=proyecto&asociacion_id=${PROYECTO_ID}`);
        if(!res.ok) return;
        const docs = await res.json();
        const badge = $('docs-tab-badge');
        if(badge && docs.length > 0){
            badge.textContent    = docs.length;
            badge.style.display  = 'inline-block';
        }
    }catch(_){}
}

document.addEventListener('DOMContentLoaded', () => { init(); prefetchDocCount(); });
</script>
