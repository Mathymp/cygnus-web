                const pre = new Image();
                pre.decoding = 'async';
                pre.src = doc.url_storage;
            }
            const fecha = new Date(doc.creado_at).toLocaleDateString('es-CL',{day:'2-digit',month:'short',year:'numeric'});
            return `<div class="im-doc-item" id="projdoc-${doc.id}" style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;margin-bottom:8px;transition:all .15s;">
                <i class="bi ${ext2icon(ext)}" style="font-size:1.4rem;color:#2563eb;flex-shrink:0;"></i>
                <div style="flex:1;min-width:0;">
                    <!-- Nombre (modo lectura) -->
                    <div class="doc-name-display" id="pdname-${doc.id}" style="font-weight:700;color:#0f172a;font-size:.85rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${escH(doc.nombre_personalizado)}">${escH(doc.nombre_personalizado)}</div>
                    <!-- Input + botones (modo edición) -->
                    <div id="pdedit-wrap-${doc.id}" style="display:none;align-items:center;gap:6px;">
                        <input id="pdedit-${doc.id}" value="${escH(doc.nombre_personalizado)}"
