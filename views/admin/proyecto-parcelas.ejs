                        <button onclick="cancelProjRename(${doc.id})" title="Cancelar"
                            style="background:#f1f5f9;color:#64748b;border:1px solid #e2e8f0;border-radius:7px;padding:5px 10px;font-size:.8rem;font-weight:600;cursor:pointer;flex-shrink:0;">
