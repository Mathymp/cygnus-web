// ── Upload ──────────────────────────────
async function handleProjFiles(files){
    const fileArr = Array.from(files||[]);
    if(!fileArr.length) return;
    if(window.IMUpload){
        const errs=IMUpload.validateFiles(fileArr);
        if(errs.length){ showToast(errs.join(' · '),'error','Archivo demasiado pesado'); return; }
    }
    const queue = $('proj-upload-queue');
    let ok = 0, failMsgs = [];

    for(const f of fileArr){
        const uid = 'p'+Date.now()+Math.random().toString(36).slice(2,6);
        const ext = (f.name||'').split('.').pop().toLowerCase();
        const sizeMB = (f.size/1024/1024).toFixed(1);
        const nombre = (f.name||'archivo').replace(/\.[^/.]+$/,'').replace(/[_-]/g,' ');

        // Fila de progreso
        const row = document.createElement('div');
        row.style.cssText = 'display:flex;align-items:center;gap:10px;padding:8px 10px;background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:8px;margin-bottom:6px;transition:all .3s;';

        const statusEl = document.createElement('div');
        statusEl.style.cssText = 'font-size:.72rem;color:#94a3b8;margin-top:2px;';
        statusEl.textContent = `${sizeMB} MB · Subiendo...`;

        const pbarEl = document.createElement('div');
        pbarEl.style.cssText = 'height:100%;width:15%;background:#2563eb;border-radius:2px;transition:width .4s;';
        const progWrap = document.createElement('div');
        progWrap.style.cssText = 'height:4px;background:#e2e8f0;border-radius:2px;margin-top:4px;overflow:hidden;';
        progWrap.appendChild(pbarEl);

        const info = document.createElement('div');
        info.style.cssText = 'flex:1;min-width:0;';
        const nameEl = document.createElement('div');
        nameEl.style.cssText = 'font-size:.82rem;font-weight:600;color:#0f172a;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;';
        nameEl.textContent = nombre;
        info.appendChild(nameEl); info.appendChild(statusEl); info.appendChild(progWrap);

        const iconEl = document.createElement('i');
        iconEl.className = `bi ${ext2icon(ext)}`;
        iconEl.style.cssText = 'font-size:1.2rem;color:#2563eb;flex-shrink:0;';

        const closeBtn = document.createElement('button');
        closeBtn.textContent = '×';
        closeBtn.style.cssText = 'border:none;background:none;font-size:1.1rem;color:#94a3b8;cursor:pointer;padding:0 2px;display:none;flex-shrink:0;';
        closeBtn.onclick = () => { try{ row.remove(); }catch(_){} };

        row.appendChild(iconEl); row.appendChild(info); row.appendChild(closeBtn);
        queue.appendChild(row);
        pbarEl.style.width = '25%';

        try{
            const fd = new FormData();
            fd.append('archivo', f, f.name);
            fd.append('nombre_personalizado', nombre);
            fd.append('tipo_asociacion', 'proyecto');
            fd.append('asociacion_id', PROYECTO_ID);
            pbarEl.style.width = '60%';
            const res = await fetch('/api/im/documentos', {method:'POST', body:fd});
            let body = {};
            try{ body = await res.clone().json(); }catch(_){}
            if(!res.ok) throw new Error(body.message||body.error||`Error ${res.status}`);
            pbarEl.style.width = '100%'; pbarEl.style.background = '#16a34a';
            row.style.borderColor = '#86efac'; row.style.background = '#f0fdf4';
            iconEl.style.color = '#16a34a';
            statusEl.textContent = `${sizeMB} MB · ¡Subido!`; statusEl.style.color = '#16a34a';
            ok++;
            setTimeout(()=>{ try{ row.remove(); }catch(_){} }, 3500);
        }catch(err){
            pbarEl.style.width = '100%'; pbarEl.style.background = '#ef4444';
            row.style.borderColor = '#fca5a5'; row.style.background = '#fff5f5';
            iconEl.style.color = '#ef4444';
            statusEl.textContent = `⚠ ${err.message}`; statusEl.style.color = '#ef4444'; statusEl.style.fontWeight = '600';
            closeBtn.style.display = 'block';
            failMsgs.push(`"${nombre}": ${err.message}`);
            console.error('[Proj Doc Upload]', err.message);
        }
    }
    if(ok > 0) showToast(`${ok} documento${ok>1?'s':''} subido${ok>1?'s':''}.`, 'success');
    if(failMsgs.length) showToast(`Error: ${failMsgs[0]}`, 'error');
    await loadProjDocs();
}

// ── Rename ──────────────────────────────
function startProjRename(id){
    const dn   = $(`pdname-${id}`);
    const wrap = $(`pdedit-wrap-${id}`);
    const btns = $(`pdbtns-${id}`);
    const ed   = $(`pdedit-${id}`);
    const date = $(`pddate-${id}`);
    if(dn)   dn.style.display   = 'none';
    if(btns) btns.style.display = 'none';
    if(date) date.style.display = 'none';
    if(wrap){ wrap.style.display = 'flex'; }
    if(ed){  ed.focus(); ed.select(); }
}
function cancelProjRename(id){
    const dn   = $(`pdname-${id}`);
    const wrap = $(`pdedit-wrap-${id}`);
    const btns = $(`pdbtns-${id}`);
    const date = $(`pddate-${id}`);
    if(wrap) wrap.style.display = 'none';
    if(dn)   dn.style.display   = 'block';
    if(btns) btns.style.display = 'flex';
    if(date) date.style.display = 'block';
}
async function saveProjRename(id){
    const ed = $(`pdedit-${id}`); if(!ed) return;
    const n = ed.value.trim();
    if(!n){ showToast('El nombre no puede estar vacío.','error'); return; }
    try{
        const res = await fetch(`/api/im/documentos/${id}`,{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({nombre_personalizado:n})});
        if(!res.ok) throw new Error((await res.json().catch(()=>({}))).message||`Error ${res.status}`);
        showToast('Nombre actualizado.','success');
        loadProjDocs();
    }catch(e){ showToast(e.message,'error'); cancelProjRename(id); }
}

