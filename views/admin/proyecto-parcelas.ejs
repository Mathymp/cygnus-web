<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/inmobiliaria.css">
    <style>
        .pp-header{background:#fff;border-bottom:1px solid #e2e8f0;padding:18px 28px;display:flex;align-items:center;gap:16px;flex-wrap:wrap;}
        .pp-breadcrumb{font-size:.8rem;color:#94a3b8;display:flex;align-items:center;gap:6px;margin-bottom:4px;}
        .pp-breadcrumb a{color:#2563eb;text-decoration:none;font-weight:600;}
        .pp-breadcrumb a:hover{text-decoration:underline;}
        .pp-title{font-size:1.35rem;font-weight:800;color:#0f172a;margin:0;}
        .pp-badges{display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-top:4px;}
        .badge-tipo-verde{background:#fef9c3;color:#713f12;border:1px solid #fde047;border-radius:999px;font-size:.72rem;font-weight:700;padding:3px 10px;}
        .badge-tipo-rol{background:#d1fae5;color:#065f46;border:1px solid #6ee7b7;border-radius:999px;font-size:.72rem;font-weight:700;padding:3px 10px;}
        .badge-estado{background:#eff6ff;color:#1e40af;border:1px solid #bfdbfe;border-radius:999px;font-size:.72rem;font-weight:700;padding:3px 10px;text-transform:capitalize;}

        .pp-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:14px;padding:20px 28px;background:#f8fafc;border-bottom:1px solid #e2e8f0;}

        /* --- REPORTE --- */
        .rep-table{width:100%;border-collapse:collapse;font-size:.79rem;}
        .rep-table th{background:#1e293b;color:#fff;padding:10px 12px;text-align:left;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.4px;white-space:nowrap;position:sticky;top:0;z-index:1;}
        .rep-table td{padding:9px 12px;border-bottom:1px solid #f1f5f9;color:#334155;vertical-align:middle;white-space:nowrap;}
        .rep-table tr:hover td{background:#f8fafc;}
        .rep-table .num-cell{font-weight:800;color:#0f172a;}
        .rep-badge{display:inline-block;padding:2px 8px;border-radius:999px;font-size:.68rem;font-weight:700;}
        .rep-badge.vend{background:#dcfce7;color:#166534;}
        .rep-badge.disp{background:#dbeafe;color:#1e40af;}
        .rep-badge.res{background:#fef3c7;color:#92400e;}
        .rep-badge.contado{background:#ede9fe;color:#5b21b6;}
        .rep-badge.credito{background:#fff7ed;color:#c2410c;}
        .rep-check{color:#16a34a;font-size:1rem;}
        .rep-cross{color:#94a3b8;font-size:1rem;}
        .rep-saldo{color:#ef4444;font-weight:700;}
        .rep-ok{color:#16a34a;font-weight:700;}
        .stat-card{background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:14px 16px;text-align:center;}
        .stat-card .stat-val{font-size:1.6rem;font-weight:800;line-height:1;}
        .stat-card .stat-lbl{font-size:.72rem;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:.4px;margin-top:4px;}
        .stat-card.total .stat-val{color:#0f172a;}
        .stat-card.disp .stat-val{color:#0284c7;}
        .stat-card.res .stat-val{color:#d97706;}
        .stat-card.vend .stat-val{color:#16a34a;}

        .pp-toolbar{padding:16px 28px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;border-bottom:1px solid #e2e8f0;background:#fff;}
        .pp-search{flex:1;min-width:200px;max-width:320px;position:relative;}
        .pp-search input{width:100%;padding:9px 14px 9px 36px;border:1px solid #e2e8f0;border-radius:10px;font-size:.85rem;background:#f8fafc;font-family:inherit;}
        .pp-search i{position:absolute;left:11px;top:50%;transform:translateY(-50%);color:#94a3b8;}
        .filter-btn{padding:8px 14px;border:1px solid #e2e8f0;border-radius:8px;background:#fff;font-size:.8rem;font-weight:600;cursor:pointer;color:#475569;transition:all .15s;}
        .filter-btn.active{background:#eff6ff;border-color:#2563eb;color:#2563eb;}
        .view-btn{width:34px;height:34px;display:flex;align-items:center;justify-content:center;border:1px solid #e2e8f0;border-radius:8px;background:#fff;cursor:pointer;color:#64748b;transition:all .15s;}
        .view-btn.active{background:#eff6ff;border-color:#2563eb;color:#2563eb;}

        .pp-body{padding:24px 28px;}

        /* --- GRID VIEW --- */
        .parc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px;}
        .parc-card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:16px;cursor:pointer;transition:box-shadow .15s,border-color .15s;text-decoration:none;display:block;position:relative;}
        .parc-card:hover{box-shadow:0 6px 24px rgba(0,0,0,.08);border-color:#2563eb;}
        .parc-card.disp{border-top:3px solid #0284c7;}
        .parc-card.res{border-top:3px solid #d97706;}
        .parc-card.vend{border-top:3px solid #16a34a;}
        .parc-num{font-size:1.4rem;font-weight:800;color:#0f172a;margin-bottom:4px;}
        .parc-rol{font-size:.73rem;color:#64748b;margin-bottom:8px;}
        .parc-status{display:inline-flex;align-items:center;gap:4px;font-size:.72rem;font-weight:700;padding:3px 9px;border-radius:999px;}
        .parc-status.disponible{background:#dbeafe;color:#1e40af;}
        .parc-status.reservado{background:#fef3c7;color:#92400e;}
        .parc-status.vendido{background:#dcfce7;color:#166534;}
        .parc-meta{margin-top:10px;display:flex;flex-direction:column;gap:3px;}
        .parc-meta-row{font-size:.76rem;color:#64748b;display:flex;gap:6px;}
        .parc-meta-row strong{color:#334155;}
        .parc-comprador{margin-top:8px;padding-top:8px;border-top:1px solid #f1f5f9;font-size:.75rem;color:#475569;font-weight:600;display:flex;align-items:center;gap:4px;}

        /* --- LIST VIEW --- */
        .parc-table{width:100%;border-collapse:collapse;font-size:.84rem;}
        .parc-table th{background:#f8fafc;padding:10px 14px;text-align:left;font-size:.73rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.4px;border-bottom:2px solid #e2e8f0;white-space:nowrap;}
        .parc-table td{padding:12px 14px;border-bottom:1px solid #f1f5f9;color:#334155;vertical-align:middle;}
        .parc-table tr:hover td{background:#f8fafc;}
        .parc-table tr{cursor:pointer;}
        .parc-table .num-col{font-weight:800;color:#0f172a;font-size:.95rem;}

        .pp-empty{text-align:center;padding:60px 20px;color:#94a3b8;}
        .pp-empty i{font-size:2.5rem;display:block;margin-bottom:10px;}

        /* --- ADD PARCELA PANEL --- */
        .add-panel{background:#fff;border:1px solid #e2e8f0;border-radius:14px;overflow:hidden;margin-top:24px;}
        .add-panel-header{padding:14px 18px;background:#f8fafc;border-bottom:1px solid #e2e8f0;display:flex;align-items:center;justify-content:space-between;cursor:pointer;}
        .add-panel-header h4{margin:0;font-size:.85rem;font-weight:700;color:#334155;display:flex;align-items:center;gap:8px;}
        .add-panel-body{padding:20px 18px;display:none;}
        .add-panel-body.open{display:block;}
        .add-form-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:14px;}
        .add-form-row label{font-size:.77rem;font-weight:600;color:#475569;display:block;margin-bottom:4px;}
        .add-form-row input,.add-form-row select{width:100%;padding:9px 12px;border:1px solid #e2e8f0;border-radius:8px;font-size:.84rem;font-family:inherit;background:#f8fafc;box-sizing:border-box;}
        .add-form-row input:focus,.add-form-row select:focus{outline:none;border-color:#2563eb;background:#fff;}

        .im-toast{position:fixed;bottom:24px;right:24px;z-index:9999;opacity:0;transform:translateX(30px);pointer-events:none;transition:all .3s;max-width:360px;}

        /* --- Preview modal documentos --- */
        .proj-preview-overlay{position:fixed;inset:0;background:rgba(15,23,42,.78);z-index:9000;display:none;align-items:center;justify-content:center;padding:16px;box-sizing:border-box;}
        .proj-preview-card{background:#fff;border-radius:16px;width:min(960px,calc(100vw - 32px));height:min(92vh,calc(100vh - 32px));min-height:420px;display:flex;flex-direction:column;box-shadow:0 28px 70px rgba(0,0,0,.45);overflow:hidden;}
        .proj-preview-header{padding:11px 16px;background:linear-gradient(135deg,#1d4ed8,#2563eb);color:#fff;display:flex;align-items:center;gap:10px;flex-shrink:0;}
        .proj-preview-header span{flex:1;font-weight:700;font-size:.88rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
        .proj-zoom-bar{padding:8px 14px;background:#f8fafc;border-bottom:1px solid #e2e8f0;display:none;align-items:center;gap:8px;flex-shrink:0;}
        .proj-zoom-bar.visible{display:flex;}
        .proj-preview-body{flex:1 1 auto;min-height:0;position:relative;overflow:hidden;background:#0f172a;}
        .proj-preview-body.mode-pdf{background:#525659;}
        .proj-preview-body .proj-pdf-frame{position:absolute;inset:0;width:100%;height:100%;border:none;display:block;background:#525659;}
        .proj-preview-body .proj-img-wrap{position:absolute;inset:0;overflow:hidden;cursor:grab;display:flex;align-items:center;justify-content:center;}
        .proj-preview-body .proj-img-wrap img{max-width:100%;max-height:100%;width:auto;height:auto;object-fit:contain;display:block;user-select:none;-webkit-user-drag:none;transform-origin:center center;will-change:transform;}
        .proj-img-loading{position:absolute;inset:0;z-index:2;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;background:rgba(15,23,42,.75);color:#94a3b8;font-size:.85rem;pointer-events:none;}
        .proj-img-loading i{font-size:1.6rem;animation:projSpin 1s linear infinite;}
        @keyframes projSpin{to{transform:rotate(360deg)}}
    </style>
</head>
<body class="dashboard-body">
    <%- include('../partials/alerts') %>

    <!-- Toast -->
    <div id="im-toast" class="im-toast"><div id="im-toast-inner"></div></div>

    <div class="app-layout">
    <%- include('../partials/sidebar-admin', { page: 'inmobiliaria' }) %>
    <main class="main-content">
    <div class="dashboard-scroll" style="padding:0;">

    <!-- Header -->
    <div class="pp-header">
        <div style="flex:1;">
            <div class="pp-breadcrumb">
                <a href="/admin/inmobiliaria"><i class="bi bi-grid-3x3-gap"></i> Gestión de Campos</a>
                <i class="bi bi-chevron-right"></i>
                <span id="bc-nombre">Cargando...</span>
            </div>
            <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
                <h1 class="pp-title" id="proj-titulo">—</h1>
                <div class="pp-badges" id="proj-badges"></div>
            </div>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;" id="header-btns">
            <a href="/admin/inmobiliaria" class="im-btn im-btn-ghost"><i class="bi bi-arrow-left"></i> Volver</a>
        </div>
    </div>

    <!-- Stats -->
    <div class="pp-stats" id="pp-stats">
        <div class="stat-card total"><div class="stat-val" id="s-total">—</div><div class="stat-lbl">Total Parcelas</div></div>
        <div class="stat-card disp"><div class="stat-val" id="s-disp">—</div><div class="stat-lbl">Disponibles</div></div>
        <div class="stat-card res"><div class="stat-val" id="s-res">—</div><div class="stat-lbl">Reservadas</div></div>
        <div class="stat-card vend"><div class="stat-val" id="s-vend">—</div><div class="stat-lbl">Vendidas</div></div>
    </div>

    <!-- Pestañas principales -->
    <div style="background:#f1f5f9;border-bottom:2px solid #e2e8f0;padding:10px 24px;display:flex;align-items:center;gap:6px;">
        <button id="tab-btn-parcelas" onclick="setTab('parcelas')"
            style="padding:9px 18px;border:none;background:linear-gradient(135deg,#2563eb,#1d4ed8);color:#fff;font-size:.84rem;font-weight:700;border-radius:10px;cursor:pointer;display:flex;align-items:center;gap:7px;transition:all .18s;box-shadow:0 2px 8px rgba(37,99,235,.25);">
            <i class="bi bi-grid-3x3-gap-fill"></i> Parcelas
        </button>
        <button id="tab-btn-documentos" onclick="setTab('documentos')"
            style="padding:9px 18px;border:none;background:#fff;color:#475569;font-size:.84rem;font-weight:700;border-radius:10px;cursor:pointer;display:flex;align-items:center;gap:8px;transition:all .18s;border:1.5px solid #e2e8f0;"
            onmouseover="if(this.dataset.active!=='1')this.style.background='#e0e7ff';if(this.dataset.active!=='1')this.style.color='#2563eb';"
            onmouseout="if(this.dataset.active!=='1'){this.style.background='#fff';this.style.color='#475569';}">
            <span style="background:linear-gradient(135deg,#2563eb,#1d4ed8);border-radius:6px;padding:3px 6px;display:inline-flex;align-items:center;">
                <i class="bi bi-folder2-open" style="color:#fff;font-size:.8rem;"></i>
            </span>
            Documentos del Proyecto
            <span id="docs-tab-badge" style="display:none;background:#2563eb;color:#fff;border-radius:20px;padding:1px 8px;font-size:.68rem;font-weight:700;"></span>
        </button>
    </div>

    <!-- Toolbar Parcelas -->
    <div class="pp-toolbar" id="toolbar-parcelas">
        <div class="pp-search">
            <i class="bi bi-search"></i>
            <input type="text" id="search-input" placeholder="Buscar por N°, rol, comprador..." oninput="applyFilters()">
        </div>
        <div style="display:flex;gap:6px;flex-wrap:wrap;" id="filter-btns">
            <button class="filter-btn active" data-estado="todos" onclick="setFiltro('todos',this)">Todos</button>
            <button class="filter-btn" data-estado="disponible" onclick="setFiltro('disponible',this)"><i class="bi bi-circle"></i> Disponible</button>
            <button class="filter-btn" data-estado="reservado" onclick="setFiltro('reservado',this)"><i class="bi bi-clock-history"></i> Reservado</button>
            <button class="filter-btn" data-estado="vendido" onclick="setFiltro('vendido',this)"><i class="bi bi-bag-check-fill"></i> Vendido</button>
        </div>
        <div style="margin-left:auto;display:flex;gap:6px;align-items:center;">
            <!-- Botón agregar parcela (solo admin/puede_crear) -->
            <button id="btn-agregar-parcela" onclick="toggleAddPanel()" style="display:none;padding:9px 16px;background:linear-gradient(135deg,#16a34a,#15803d);color:#fff;border:none;border-radius:10px;font-size:.83rem;font-weight:700;cursor:pointer;display:none;align-items:center;gap:7px;box-shadow:0 2px 8px rgba(22,163,74,.3);transition:all .15s;"
                onmouseover="this.style.filter='brightness(1.1)'" onmouseout="this.style.filter='brightness(1)'">
                <i class="bi bi-plus-circle-fill"></i> Agregar Parcela
            </button>
            <div style="width:1px;height:24px;background:#e2e8f0;margin:0 2px;" id="sep-agregar" style="display:none;"></div>
            <button class="im-btn im-btn-ghost" id="btn-reporte" onclick="toggleReporte()" style="font-size:.8rem;">
                <i class="bi bi-table"></i> Base de Ventas
            </button>
            <button class="im-btn im-btn-success" id="btn-csv" onclick="descargarCSV()" style="font-size:.8rem;display:none;">
                <i class="bi bi-file-earmark-spreadsheet"></i> Descargar Excel/CSV
            </button>
            <div style="width:1px;height:24px;background:#e2e8f0;margin:0 4px;"></div>
            <button class="view-btn active" id="btn-grid" title="Vista cuadrícula" onclick="setVista('grid')"><i class="bi bi-grid-3x3-gap-fill"></i></button>
            <button class="view-btn" id="btn-list" title="Vista lista" onclick="setVista('list')"><i class="bi bi-list-ul"></i></button>
        </div>
    </div>

    <!-- Formulario agregar parcela (se despliega bajo el toolbar) -->
    <div id="add-panel-inline" style="display:none;background:linear-gradient(135deg,#f0fdf4,#dcfce7);border-bottom:2px solid #86efac;padding:18px 28px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;">
            <div style="background:linear-gradient(135deg,#16a34a,#15803d);border-radius:8px;padding:6px 9px;color:#fff;"><i class="bi bi-plus-circle-fill"></i></div>
            <h4 style="margin:0;font-size:.92rem;font-weight:800;color:#14532d;">Nueva Parcela</h4>
            <button onclick="toggleAddPanel()" style="margin-left:auto;background:none;border:none;color:#64748b;font-size:1.2rem;cursor:pointer;line-height:1;">×</button>
        </div>
        <form id="form-add" onsubmit="crearParcela(event)">
            <div class="add-form-row">
                <div>
                    <label>N° Parcela <span style="color:#ef4444;">*</span></label>
                    <input type="text" id="ap-numero" placeholder="Ej: 5 ó 1-A" maxlength="20" oninput="this.value=this.value.toUpperCase()" required>
                    <div id="ap-dup-warn" style="display:none;color:#f59e0b;font-size:.73rem;margin-top:3px;"><i class="bi bi-exclamation-triangle-fill"></i> <span></span></div>
                </div>
                <div>
                    <label>N° Rol Parcela <span style="color:#94a3b8;font-weight:400;">(opcional)</span></label>
                    <input type="text" id="ap-rol" placeholder="Ej: 123-45">
                </div>
                <div>
                    <label>Metraje (m²) <span style="color:#94a3b8;font-weight:400;">(opcional)</span></label>
                    <input type="number" id="ap-metraje" placeholder="Ej: 5000" min="0">
                </div>
                <div>
                    <label>Precio Lista (CLP) <span style="color:#94a3b8;font-weight:400;">(opcional)</span></label>
                    <input type="text" id="ap-precio" placeholder="Ej: 15.000.000" oninput="fmtPrecio(this)">
                </div>
            </div>
            <button type="submit" class="im-btn im-btn-success" id="btn-add" style="background:linear-gradient(135deg,#16a34a,#15803d);border:none;padding:10px 20px;font-size:.85rem;">
                <i class="bi bi-plus-circle-fill"></i> Confirmar Parcela
            </button>
        </form>
    </div>

    <!-- Reporte Panel -->
    <div id="reporte-panel" style="display:none;border-bottom:2px solid #e2e8f0;background:#fff;">
        <div style="padding:14px 28px;display:flex;align-items:center;gap:10px;border-bottom:1px solid #f1f5f9;flex-wrap:wrap;">
            <span style="font-size:.82rem;font-weight:700;color:#0f172a;"><i class="bi bi-table" style="color:#2563eb;"></i> Base de Ventas del Proyecto</span>
            <span id="rep-count" style="font-size:.76rem;color:#64748b;"></span>
            <input type="text" id="rep-search" placeholder="Filtrar por nombre, RUT, parcela..." oninput="filtrarReporte()"
                style="margin-left:auto;padding:7px 12px;border:1px solid #e2e8f0;border-radius:8px;font-size:.81rem;width:260px;font-family:inherit;background:#f8fafc;">
        </div>
        <div id="rep-content" style="overflow-x:auto;max-height:520px;overflow-y:auto;">
            <div style="text-align:center;padding:40px;color:#94a3b8;"><i class="bi bi-hourglass-split" style="font-size:1.8rem;"></i><p style="margin-top:8px;">Cargando base de ventas...</p></div>
        </div>
    </div>

    <!-- ─── TAB: PARCELAS ─── -->
    <div id="tab-parcelas">
        <div class="pp-body">
            <div id="pp-content">
                <div class="pp-empty"><i class="bi bi-hourglass-split"></i><p>Cargando parcelas...</p></div>
            </div>
        </div>
    </div>

    <!-- ─── TAB: DOCUMENTOS DEL PROYECTO ─── -->
    <div id="tab-documentos" style="display:none;">
        <div style="padding:24px 28px;">

            <!-- Intro -->
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
                <div style="background:linear-gradient(135deg,#2563eb,#1d4ed8);border-radius:10px;padding:10px 13px;color:#fff;flex-shrink:0;">
                    <i class="bi bi-folder2-open" style="font-size:1.3rem;"></i>
                </div>
                <div>
                    <p style="margin:0;font-weight:800;color:#0f172a;font-size:1rem;">Documentos del Proyecto</p>
                    <p style="margin:0;font-size:.78rem;color:#64748b;">Escrituras, certificados, planos y archivos vinculados a este proyecto. Visibles también desde cada lote.</p>
                </div>
            </div>

            <!-- Upload zone -->
            <div style="background:#f8fafc;border:2px dashed #cbd5e1;border-radius:14px;padding:22px;text-align:center;position:relative;transition:all .2s;margin-bottom:20px;"
                onmouseover="this.style.borderColor='#2563eb';this.style.background='#eff6ff'"
                onmouseout="this.style.borderColor='#cbd5e1';this.style.background='#f8fafc'">
                <input type="file" multiple accept="image/*,.pdf,.doc,.docx,.xls,.xlsx,.zip,.rar"
                    style="position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;"
                    onchange="handleProjFiles(this.files)">
                <i class="bi bi-cloud-arrow-up" style="font-size:2.2rem;color:#2563eb;"></i>
                <p style="margin:8px 0 2px;font-weight:700;color:#0f172a;font-size:.95rem;">Arrastra archivos aquí o <strong>haz clic para seleccionar</strong></p>
                <p style="margin:0;font-size:.78rem;color:#94a3b8;">Varios archivos · imágenes máx. 20 MB · PDF/docs máx. 100 MB</p>
            </div>

            <!-- Progreso de subida -->
            <div id="proj-upload-queue" style="margin-bottom:12px;"></div>

            <!-- Lista de documentos -->
            <div id="proj-doc-list">
                <div style="text-align:center;padding:28px;color:#94a3b8;"><i class="bi bi-hourglass-split" style="font-size:1.5rem;"></i><p style="margin:8px 0 0;">Cargando documentos...</p></div>
            </div>
        </div>
    </div>

    <!-- Modal preview -->
    <div id="proj-preview-overlay" class="proj-preview-overlay">
        <div class="proj-preview-card">
            <div class="proj-preview-header">
                <i id="proj-preview-icon" class="bi bi-file-earmark-image" style="font-size:1rem;flex-shrink:0;"></i>
                <span id="proj-preview-title"></span>
                <button onclick="closeProjPreview()" style="background:rgba(255,255,255,.2);border:none;color:#fff;font-size:.82rem;font-weight:700;cursor:pointer;border-radius:6px;padding:5px 10px;flex-shrink:0;transition:background .15s;" onmouseover="this.style.background='rgba(255,255,255,.35)'" onmouseout="this.style.background='rgba(255,255,255,.2)'">✕ Cerrar</button>
            </div>
            <div id="proj-zoom-bar" class="proj-zoom-bar">
                <button onclick="projZoom(-0.25)" title="Alejar" style="width:32px;height:32px;border:1px solid #e2e8f0;border-radius:7px;background:#fff;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;transition:all .15s;" onmouseover="this.style.background='#eff6ff'" onmouseout="this.style.background='#fff'"><i class="bi bi-zoom-out"></i></button>
                <div style="height:4px;flex:1;background:#e2e8f0;border-radius:2px;overflow:hidden;cursor:pointer;" onclick="projZoomReset()" title="Click para restablecer">
                    <div id="proj-zoom-bar-fill" style="height:100%;width:50%;background:linear-gradient(90deg,#2563eb,#60a5fa);border-radius:2px;transition:width .2s;"></div>
                </div>
                <button onclick="projZoom(0.25)" title="Acercar" style="width:32px;height:32px;border:1px solid #e2e8f0;border-radius:7px;background:#fff;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;transition:all .15s;" onmouseover="this.style.background='#eff6ff'" onmouseout="this.style.background='#fff'"><i class="bi bi-zoom-in"></i></button>
                <span id="proj-zoom-pct" style="font-size:.75rem;font-weight:700;color:#475569;min-width:38px;text-align:center;">100%</span>
                <button onclick="projZoomReset()" title="Ajustar a pantalla" style="width:32px;height:32px;border:1px solid #e2e8f0;border-radius:7px;background:#fff;cursor:pointer;font-size:.75rem;font-weight:700;color:#64748b;display:flex;align-items:center;justify-content:center;transition:all .15s;" onmouseover="this.style.background='#eff6ff'" onmouseout="this.style.background='#fff'"><i class="bi bi-arrows-fullscreen"></i></button>
                <div style="width:1px;height:20px;background:#e2e8f0;margin:0 2px;"></div>
                <a id="proj-preview-dl" href="#" download target="_blank" title="Descargar" style="width:32px;height:32px;border:1px solid #e2e8f0;border-radius:7px;background:#fff;cursor:pointer;font-size:.95rem;color:#475569;display:flex;align-items:center;justify-content:center;text-decoration:none;transition:all .15s;" onmouseover="this.style.background='#eff6ff'" onmouseout="this.style.background='#fff'"><i class="bi bi-download"></i></a>
                <span style="font-size:.7rem;color:#94a3b8;">Rueda del mouse · arrastra para mover</span>
            </div>
            <div id="proj-preview-body" class="proj-preview-body"></div>
        </div>
    </div>

    <!-- Modal eliminar doc -->
    <div id="proj-del-overlay" style="position:fixed;inset:0;background:rgba(15,23,42,.55);z-index:9001;display:none;align-items:center;justify-content:center;padding:20px;">
        <div style="background:#fff;border-radius:16px;width:100%;max-width:420px;overflow:hidden;box-shadow:0 24px 60px rgba(0,0,0,.3);">
            <div style="padding:14px 20px;background:linear-gradient(135deg,#dc2626,#b91c1c);color:#fff;">
                <p style="margin:0;font-weight:800;font-size:.95rem;"><i class="bi bi-trash3"></i> Eliminar Documento</p>
            </div>
            <div style="padding:20px;">
                <p style="margin:0 0 6px;font-size:.9rem;color:#0f172a;">¿Eliminar <strong id="proj-del-nombre"></strong>?</p>
                <p style="margin:0 0 18px;font-size:.8rem;color:#64748b;">Esta acción no se puede deshacer.</p>
                <input type="hidden" id="proj-del-id">
                <div style="display:flex;gap:10px;justify-content:flex-end;">
                    <button onclick="closeProjDel()" class="im-btn im-btn-ghost">Cancelar</button>
                    <button id="proj-del-btn" onclick="confirmProjDel()" class="im-btn" style="background:#dc2626;color:#fff;border:none;">
                        <i class="bi bi-trash3"></i> Eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>

    </div><!-- /dashboard-scroll -->
    </main>
    </div><!-- /app-layout -->

<script>
const PROYECTO_ID  = '<%= proyectoId %>';
const IS_ADMIN     = '<%= user && user.role === "admin" ? "true" : "false" %>' === 'true';
const PUEDE_CREAR  = '<%= typeof puedeCrear !== "undefined" && puedeCrear ? "true" : "false" %>' === 'true';

let allParcelas   = [];
let filtroEstado  = 'todos';
let vistaActual   = 'grid';
let _projDocsCache = {};

function $(id){ return document.getElementById(id); }
function escH(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function getDocExt(doc){
    const fromPath=(doc.storage_path||'').split('.').pop().toLowerCase();
    if(fromPath&&fromPath.length<=5&&!fromPath.includes('/'))return fromPath;
    const fromUrl=(doc.url_storage||'').split('?')[0].split('.').pop().toLowerCase();
    if(fromUrl&&fromUrl.length<=5&&!fromUrl.includes('/'))return fromUrl;
    return '';
}
function fmt(n){ return Math.floor(parseFloat(n)||0).toLocaleString('es-CL'); }
function fmtPrecio(input){ input.value=input.value.replace(/\D/g,'').replace(/\B(?=(\d{3})+(?!\d))/g,'.'); }

function showToast(msg,type='success',title=''){
    const t=$('im-toast'),i=$('im-toast-inner');
    const cfg={success:{bg:'#dcfce7',c:'#166534',b:'#86efac',ic:'bi-check-circle-fill',d:'Éxito'},error:{bg:'#fee2e2',c:'#991b1b',b:'#fca5a5',ic:'bi-exclamation-triangle-fill',d:'Error'},warning:{bg:'#fef3c7',c:'#92400e',b:'#fde68a',ic:'bi-exclamation-circle-fill',d:'Atención'},info:{bg:'#eff6ff',c:'#1e40af',b:'#bfdbfe',ic:'bi-info-circle-fill',d:'Info'}};
    const s=cfg[type]||cfg.info;
    i.style.cssText=`background:${s.bg};color:${s.c};border:1.5px solid ${s.b};padding:14px 18px;border-radius:12px;box-shadow:0 8px 30px rgba(0,0,0,.12);display:flex;align-items:flex-start;gap:10px;`;
    i.innerHTML=`<i class="bi ${s.ic}" style="font-size:1.1rem;flex-shrink:0;margin-top:1px;"></i><div><div style="font-weight:700;font-size:.88rem;">${title||s.d}</div><div style="font-size:.82rem;margin-top:2px;opacity:.9;word-break:break-word;">${escH(msg)}</div></div>`;
    t.style.opacity='1';t.style.transform='translateX(0)';t.style.pointerEvents='auto';
    clearTimeout(t._t);t._t=setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(30px)';t.style.pointerEvents='none';},5000);
}

// ──── INIT ────
async function init(){
    try{
        const [projRes, parcRes] = await Promise.all([
            fetch('/api/im/proyectos'),
            fetch(`/api/im/proyectos/${PROYECTO_ID}/parcelas`)
        ]);

        if(!projRes.ok) throw new Error(`No se pudo cargar el proyecto (HTTP ${projRes.status}). Verifica tu conexión.`);
        if(!parcRes.ok) throw new Error(`No se pudo cargar las parcelas (HTTP ${parcRes.status}). Verifica tu conexión.`);

        const proyectos = await projRes.json();
        const proj = proyectos.find(p=>p.id===PROYECTO_ID);
        allParcelas = await parcRes.json();

        if(proj) renderProyecto(proj);
        renderStats();
        applyFilters();
        if(IS_ADMIN||PUEDE_CREAR){
            const btn = $('btn-agregar-parcela');
            if(btn){ btn.style.display='flex'; }
        }

    }catch(e){
        $('pp-content').innerHTML=`
            <div style="text-align:center;padding:60px 20px;">
                <i class="bi bi-exclamation-triangle-fill" style="font-size:2.5rem;color:#ef4444;display:block;margin-bottom:12px;"></i>
                <p style="font-weight:700;color:#991b1b;font-size:1rem;margin-bottom:6px;">No se pudo cargar la información</p>
                <p style="color:#64748b;font-size:.85rem;">${escH(e.message)}</p>
                <button class="im-btn im-btn-primary" style="margin-top:16px;" onclick="init()"><i class="bi bi-arrow-clockwise"></i> Reintentar</button>
            </div>`;
    }
}

function renderProyecto(p){
    $('bc-nombre').textContent = p.nombre;
    $('proj-titulo').textContent = p.nombre;

    const tipoBadge = p.tipo_proyecto==='con_rol_propio'
        ? `<span class="badge-tipo-rol"><i class="bi bi-check-circle-fill"></i> Con Rol Propio</span>`
        : `<span class="badge-tipo-verde"><i class="bi bi-tree-fill"></i> En Verde</span>`;
    const estadoBadge = `<span class="badge-estado"><i class="bi bi-circle-fill" style="font-size:.5rem;"></i> ${p.estado||'activo'}</span>`;

    const roles = [p.numero_rol_1, p.numero_rol_2].filter(Boolean).map(r=>`<span style="font-size:.72rem;background:#f1f5f9;border:1px solid #e2e8f0;border-radius:6px;padding:2px 8px;color:#475569;">Rol ${r}</span>`).join('');
    const matriz = p.numero_matriz?`<span style="font-size:.72rem;background:#f1f5f9;border:1px solid #e2e8f0;border-radius:6px;padding:2px 8px;color:#475569;">Matriz ${p.numero_matriz}</span>`:'';

    $('proj-badges').innerHTML = tipoBadge + estadoBadge + roles + matriz;
    document.title = `${p.nombre} — Parcelas`;
}

function renderStats(){
    const t=allParcelas.length;
    const d=allParcelas.filter(p=>p.estado_venta==='disponible').length;
    const r=allParcelas.filter(p=>p.estado_venta==='reservado').length;
    const v=allParcelas.filter(p=>p.estado_venta==='vendido').length;
    $('s-total').textContent=t;
    $('s-disp').textContent=d;
    $('s-res').textContent=r;
    $('s-vend').textContent=v;
}

function setFiltro(estado,btn){
    filtroEstado=estado;
    document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
    if(btn)btn.classList.add('active');
    applyFilters();
}

function setVista(v){
    vistaActual=v;
    $('btn-grid').classList.toggle('active',v==='grid');
    $('btn-list').classList.toggle('active',v==='list');
    applyFilters();
}

function applyFilters(){
    const q=$('search-input').value.trim().toLowerCase();
    let filtered=allParcelas.filter(p=>{
        if(filtroEstado!=='todos'&&p.estado_venta!==filtroEstado)return false;
        if(q){
            const hay=String(p.numero_parcela).toLowerCase().includes(q)
                ||(p.numero_rol_parcela||'').toLowerCase().includes(q)
                ||(p.cliente_nombre||'').toLowerCase().includes(q);
            if(!hay)return false;
        }
        return true;
    });
    vistaActual==='grid'?renderGrid(filtered):renderList(filtered);
}

function renderGrid(parcelas){
    if(parcelas.length===0){
        $('pp-content').innerHTML=`<div class="pp-empty"><i class="bi bi-inbox"></i><p>Sin parcelas que coincidan.</p></div>`;
        return;
    }
    const eMap={disponible:{cl:'disponible',ic:'bi-circle',t:'Disponible'},reservado:{cl:'reservado',ic:'bi-clock-history',t:'Reservado'},vendido:{cl:'vendido',ic:'bi-bag-check-fill',t:'Vendido'}};
    $('pp-content').innerHTML=`<div class="parc-grid">${parcelas.map(p=>{
        const e=eMap[p.estado_venta]||eMap.disponible;
        return `<a class="parc-card ${e.cl}" href="/admin/inmobiliaria/parcela/${p.id}">
            <div class="parc-num">N° ${escH(String(p.numero_parcela))}</div>
            <div class="parc-rol">${p.numero_rol_parcela?`Rol: ${escH(p.numero_rol_parcela)}`:'Sin rol asignado'}</div>
            <span class="parc-status ${e.cl}"><i class="bi ${e.ic}"></i> ${e.t}</span>
            <div class="parc-meta">
                ${p.metraje?`<div class="parc-meta-row"><strong>${fmt(p.metraje)}</strong> m²</div>`:''}
                ${p.ultimo_precio||p.precio_actual?`<div class="parc-meta-row"><strong>$${fmt(p.ultimo_precio||p.precio_actual)}</strong></div>`:''}
            </div>
            ${p.cliente_nombre?`<div class="parc-comprador"><i class="bi bi-person-fill" style="color:#16a34a;"></i>${escH(p.cliente_nombre.split(' ').slice(0,2).join(' '))}</div>`:''}
        </a>`;
    }).join('')}</div>`;
}

function renderList(parcelas){
    if(parcelas.length===0){
        $('pp-content').innerHTML=`<div class="pp-empty"><i class="bi bi-inbox"></i><p>Sin parcelas que coincidan.</p></div>`;
        return;
    }
    const eMap={disponible:{ic:'bi-circle',c:'#0284c7',t:'Disponible'},reservado:{ic:'bi-clock-history',c:'#d97706',t:'Reservado'},vendido:{ic:'bi-bag-check-fill',c:'#16a34a',t:'Vendido'}};
    $('pp-content').innerHTML=`<div style="overflow-x:auto;border:1px solid #e2e8f0;border-radius:12px;background:#fff;">
        <table class="parc-table">
            <thead>
                <tr>
                    <th>N° Parcela</th><th>N° Rol</th><th>Estado</th>
                    <th>Metraje</th><th>Precio Lista</th><th>Comprador</th><th></th>
                </tr>
            </thead>
            <tbody>
            ${parcelas.map(p=>{
                const e=eMap[p.estado_venta]||eMap.disponible;
                return `<tr onclick="window.location='/admin/inmobiliaria/parcela/${p.id}'">
                    <td class="num-col">N° ${escH(String(p.numero_parcela))}</td>
                    <td>${p.numero_rol_parcela?escH(p.numero_rol_parcela):'<span style="color:#94a3b8;">—</span>'}</td>
                    <td><span style="display:inline-flex;align-items:center;gap:5px;font-size:.78rem;font-weight:700;color:${e.c};"><i class="bi ${e.ic}"></i>${e.t}</span></td>
                    <td>${p.metraje?fmt(p.metraje)+' m²':'<span style="color:#94a3b8;">—</span>'}</td>
                    <td>${(p.ultimo_precio||p.precio_actual)?'$'+fmt(p.ultimo_precio||p.precio_actual):'<span style="color:#94a3b8;">—</span>'}</td>
                    <td>${p.cliente_nombre?`<span style="display:flex;align-items:center;gap:5px;"><i class="bi bi-person-fill" style="color:#16a34a;"></i>${escH(p.cliente_nombre.split(' ').slice(0,2).join(' '))}</span>`:'<span style="color:#94a3b8;">Disponible</span>'}</td>
                    <td><span class="im-btn im-btn-sm im-btn-ghost" style="font-size:.75rem;padding:4px 10px;"><i class="bi bi-arrow-right"></i> Abrir</span></td>
                </tr>`;
            }).join('')}
            </tbody>
        </table>
    </div>`;
}

// ──── ADD PARCELA ────
function toggleAddPanel(){
    const panel = $('add-panel-inline');
    const btn   = $('btn-agregar-parcela');
    if(!panel) return;
    const open = panel.style.display === 'none' || panel.style.display === '';
    panel.style.display = open ? 'block' : 'none';
    if(btn){
        btn.style.background = open
            ? 'linear-gradient(135deg,#15803d,#166534)'
            : 'linear-gradient(135deg,#16a34a,#15803d)';
        btn.innerHTML = open
            ? '<i class="bi bi-x-circle-fill"></i> Cancelar'
            : '<i class="bi bi-plus-circle-fill"></i> Agregar Parcela';
    }
}

async function crearParcela(e){
    e.preventDefault();
    const btn=$('btn-add');
    const numStr=$('ap-numero').value.trim().toUpperCase();
    if(!numStr){showToast('El número de parcela es obligatorio.','error','Campo requerido');return;}

    // Dedup check local
    const dup=allParcelas.some(p=>String(p.numero_parcela).toUpperCase().trim()===numStr);
    if(dup){
        $('ap-dup-warn').style.display='flex';
        $('ap-dup-warn').querySelector('span').textContent=`La parcela "${numStr}" ya existe en este proyecto.`;
        showToast(`Ya existe la parcela "${numStr}" en este proyecto.`,'warning','Número duplicado');
        return;
    }
    $('ap-dup-warn').style.display='none';

    btn.disabled=true;btn.innerHTML='<i class="bi bi-hourglass-split"></i> Guardando...';
    try{
        const precioRaw=$('ap-precio').value.replace(/\./g,'');
        const body={
            proyecto_id: PROYECTO_ID,
            numero_parcela: numStr,
            numero_rol_parcela: $('ap-rol').value.trim()||null,
            metraje: $('ap-metraje').value||null,
            precio_actual: precioRaw||null
        };
        const res=await fetch('/api/im/parcelas',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
        if(!res.ok){
            const err=await res.json().catch(()=>({}));
            throw new Error(err.message||`No se pudo crear la parcela (HTTP ${res.status}).`);
        }
        document.getElementById('form-add').reset();
        toggleAddPanel(); // cerrar panel tras crear
        showToast(`Parcela "${numStr}" creada correctamente.`,'success');
        await reloadParcelas();
    }catch(err){
        showToast(err.message,'error','No se pudo crear la parcela');
    }finally{
        btn.disabled=false;btn.innerHTML='<i class="bi bi-plus-circle"></i> Agregar Parcela';
    }
}

async function reloadParcelas(){
    try{
        const res=await fetch(`/api/im/proyectos/${PROYECTO_ID}/parcelas`);
        if(!res.ok)throw new Error(`No se pudieron actualizar las parcelas (HTTP ${res.status}).`);
        allParcelas=await res.json();
        renderStats();
        applyFilters();
    }catch(e){ showToast(e.message,'error','Error al recargar'); }
}

// ──── REPORTE / BASE DE VENTAS ────
let reporteData = [];
let reporteVisible = false;

async function toggleReporte(){
    reporteVisible = !reporteVisible;
    const panel = $('reporte-panel');
    const btn   = $('btn-reporte');
    const csvBtn= $('btn-csv');

    if(reporteVisible){
        panel.style.display = 'block';
        btn.innerHTML='<i class="bi bi-x-circle"></i> Cerrar Base';
        btn.style.background='#fee2e2';btn.style.color='#991b1b';btn.style.borderColor='#fca5a5';
        csvBtn.style.display='flex';
        await cargarReporte();
    } else {
        panel.style.display = 'none';
        btn.innerHTML='<i class="bi bi-table"></i> Base de Ventas';
        btn.style.background='';btn.style.color='';btn.style.borderColor='';
        csvBtn.style.display='none';
    }
}

async function cargarReporte(){
    const cont=$('rep-content');
    cont.innerHTML='<div style="text-align:center;padding:40px;color:#94a3b8;"><i class="bi bi-hourglass-split" style="font-size:1.8rem;"></i><p style="margin-top:8px;">Cargando...</p></div>';
    try{
        const res=await fetch(`/api/im/proyectos/${PROYECTO_ID}/reporte`);
        if(!res.ok){const e=await res.json().catch(()=>({}));throw new Error(e.error||`HTTP ${res.status}`);}
        reporteData=await res.json();
        $('rep-count').textContent=`${reporteData.length} parcelas`;
        renderReporte(reporteData);
    }catch(e){
        cont.innerHTML=`<div style="text-align:center;padding:40px;color:#ef4444;"><i class="bi bi-exclamation-triangle-fill" style="font-size:1.8rem;"></i><p style="margin-top:8px;">${escH(e.message)}</p></div>`;
    }
}

function filtrarReporte(){
    const q=$('rep-search').value.trim().toLowerCase();
    if(!q){renderReporte(reporteData);return;}
    const f=reporteData.filter(r=>
        String(r.numero_parcela||'').toLowerCase().includes(q)||
        (r.nombre_completo||'').toLowerCase().includes(q)||
        (r.rut||'').toLowerCase().includes(q)||
        (r.telefono||'').toLowerCase().includes(q)||
        (r.email||'').toLowerCase().includes(q)
    );
    renderReporte(f);
}

function renderReporte(rows){
    if(!rows||rows.length===0){
        $('rep-content').innerHTML='<div style="text-align:center;padding:40px;color:#94a3b8;"><i class="bi bi-inbox" style="font-size:1.8rem;"></i><p style="margin-top:8px;">Sin resultados.</p></div>';
        return;
    }
    const cols=[
        ['Parcela','numero_parcela'],['Rol','numero_rol_parcela'],['m²','metraje'],
        ['Estado','estado_parcela'],
        ['Comprador','nombre_completo'],['RUT','rut'],['Teléfono','telefono'],['Email','email'],
        ['Estado Civil','estado_civil'],['Régimen','regimen_matrimonial'],
        ['Cónyuge','nombre_conyugue'],['Tel. Cónyuge','telefono_conyugue'],['Email Cónyuge','email_conyugue'],
        ['Fecha Venta','fecha_venta'],['Modalidad','tipo_pago'],
        ['Precio Lista','precio_lista'],['Precio Acordado','precio_acordado'],
        ['Pie','monto_pie'],['N° Crédito','numero_credito'],
        ['Cuotas','numero_cuotas'],['Valor Cuota','monto_cuota'],
        ['Cuotas Pagadas','cuotas_pagadas'],['Cuotas Pend.','cuotas_pendientes'],['Saldo Pendiente','saldo_pendiente'],
        ['Promesa','firmo_promesa'],['Compraventa','firmo_compraventa'],
        ['Agente','agente_nombre'],['Condiciones','condiciones_compra']
    ];
    const thead=`<tr>${cols.map(([l])=>`<th>${l}</th>`).join('')}</tr>`;
    const tbody=rows.map(r=>{
        const cells=cols.map(([,k])=>{
            const v=r[k];
            if(k==='estado_parcela'){
                const cl=v==='vendido'?'vend':v==='reservado'?'res':'disp';
                return `<td><span class="rep-badge ${cl}">${v||'—'}</span></td>`;
            }
            if(k==='tipo_pago'){
                if(!v)return`<td>—</td>`;
                return`<td><span class="rep-badge ${v}">${v==='contado'?'Contado':'Crédito'}</span></td>`;
            }
            if(k==='firmo_promesa'||k==='firmo_compraventa'){
                return`<td>${v?'<i class="bi bi-check-circle-fill rep-check"></i>':'<i class="bi bi-dash rep-cross"></i>'}</td>`;
            }
            if(k==='precio_lista'||k==='precio_acordado'||k==='monto_pie'||k==='monto_cuota'){
                return`<td>${v?'$'+fmt(v):'—'}</td>`;
            }
            if(k==='saldo_pendiente'){
                const n=parseFloat(v)||0;
                return`<td>${n>0?`<span class="rep-saldo">$${fmt(n)}</span>`:`<span class="rep-ok">Al día</span>`}</td>`;
            }
            if(k==='fecha_venta'){
                return`<td>${v?new Date(v).toLocaleDateString('es-CL'):'—'}</td>`;
            }
            if(k==='metraje'){return`<td>${v?fmt(v)+' m²':'—'}</td>`;}
            if(k==='numero_parcela'){return`<td class="num-cell">N° ${escH(String(v))}</td>`;}
            return`<td>${v!=null&&v!==''?escH(String(v)):'—'}</td>`;
        }).join('');
        return`<tr>${cells}</tr>`;
    }).join('');
    $('rep-content').innerHTML=`<table class="rep-table"><thead>${thead}</thead><tbody>${tbody}</tbody></table>`;
}

function descargarCSV(){
    if(!reporteData||reporteData.length===0){showToast('Carga la base primero.','warning');return;}
    const nombreProj=($('proj-titulo').textContent||'Proyecto').replace(/[^\w\s-]/g,'').trim();
    const fecha=new Date().toLocaleDateString('es-CL').replace(/\//g,'-');

    const headers=['Parcela','Rol Parcela','Metraje m²','Estado','Comprador','RUT','Teléfono','Email','Dirección','Estado Civil','Régimen Matrimonial','Cónyuge','RUT Cónyuge','Tel. Cónyuge','Email Cónyuge','Fecha Venta','Modalidad Pago','Precio Lista','Precio Acordado','Pie','N° Crédito','N° Cuotas','Valor Cuota','Cuotas Pagadas','Cuotas Pendientes','Saldo Pendiente','Firmó Promesa','Firmó Compraventa','Agente','Condiciones'];
    const keys=['numero_parcela','numero_rol_parcela','metraje','estado_parcela','nombre_completo','rut','telefono','email','direccion','estado_civil','regimen_matrimonial','nombre_conyugue','rut_conyugue','telefono_conyugue','email_conyugue','fecha_venta','tipo_pago','precio_lista','precio_acordado','monto_pie','numero_credito','numero_cuotas','monto_cuota','cuotas_pagadas','cuotas_pendientes','saldo_pendiente','firmo_promesa','firmo_compraventa','agente_nombre','condiciones_compra'];

    const esc=v=>{if(v==null||v==='')return'';const s=String(v).replace(/"/g,'""');return s.includes(',')||s.includes('"')||s.includes('\n')?`"${s}"`:s;};

    let csv='\uFEFF'+headers.join(',')+'\n';
    reporteData.forEach(r=>{
        csv+=keys.map(k=>{
            const v=r[k];
            if(k==='firmo_promesa'||k==='firmo_compraventa')return v?'Sí':'No';
            if(k==='fecha_venta')return v?new Date(v).toLocaleDateString('es-CL'):'';
            if(k==='tipo_pago')return v==='contado'?'Contado':v==='credito'?'Crédito':'';
            return esc(v);
        }).join(',')+'\n';
    });

    const blob=new Blob([csv],{type:'text/csv;charset=utf-8;'});
    const url=URL.createObjectURL(blob);
    const a=document.createElement('a');
    a.href=url;a.download=`Base_Ventas_${nombreProj}_${fecha}.csv`;
    document.body.appendChild(a);a.click();document.body.removeChild(a);
    URL.revokeObjectURL(url);
    showToast(`Archivo descargado: Base_Ventas_${nombreProj}_${fecha}.csv`,'success');
}

