<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editor de Lotes 360 - Cygnus Group</title>
    <link rel="icon" type="image/png" href="/img/fav.png">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@photo-sphere-viewer/core@5.7.3/index.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@photo-sphere-viewer/markers-plugin@5.7.3/index.min.css">
    
    <link rel="stylesheet" href="/css/visor.css">

    <style>
        /* INYECCIÓN DE ESTILOS CYGNUS SOBRE EL VISOR */
        body { font-family: 'Inter', sans-serif; margin: 0; overflow: hidden; background: #0f172a; }
        
        /* Top Capsule (Glassmorphism Cygnus) */
        .top-capsule {
            background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2); box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            border-radius: 50px; padding: 8px 20px 8px 8px; display: flex; align-items: center; gap: 15px;
        }
        .back-circle {
            background: #2563eb; color: white; transition: 0.3s;
        }
        .back-circle:hover { background: #1d4ed8; transform: scale(1.05); }
        .project-title { color: #1e293b; font-weight: 700; font-size: 0.95rem; }

        /* Toolbar Cygnus */
        .toolbar {
            background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2); box-shadow: 0 -10px 25px rgba(0,0,0,0.05);
            border-radius: 20px 20px 0 0;
        }
        .toolbar-title { color: #64748b; font-size: 0.75rem; text-transform: uppercase; font-weight: 800; letter-spacing: 0.5px; }
        .tool-btn { border-radius: 12px; transition: 0.2s; color: #334155; }
        .tool-btn.active { background: #eff6ff; color: #2563eb; border-color: #bfdbfe; }
        .tool-btn:hover { background: #f8fafc; transform: translateY(-2px); }
        
        .btn-save-main { background: #10b981; color: white; border-radius: 12px; font-weight: 600; box-shadow: 0 4px 10px rgba(16, 185, 129, 0.3); }
        .btn-save-main:hover { background: #059669; transform: translateY(-2px); }

        /* Modales adaptados */
        .modal-box { border-radius: 24px; border: none; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); }
        .modal-header { border-bottom: 1px solid #f1f5f9; }
        .modal-title { font-weight: 800; color: #0f172a; }
        .btn-close-modal { background: #f1f5f9; color: #64748b; border-radius: 50%; }
        .input-group label { font-weight: 600; color: #334155; font-size: 0.85rem; }
        .input-group input, .input-group select, .input-group textarea {
            border-radius: 12px; border: 1px solid #cbd5e1; background: #f8fafc; transition: 0.2s;
        }
        .input-group input:focus, .input-group select:focus, .input-group textarea:focus {
            border-color: #3b82f6; background: white; box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1); outline: none;
        }
    </style>
</head>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editor de Lotes 360 - Cygnus Group</title>
    <link rel="icon" type="image/png" href="/img/fav.png">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@photo-sphere-viewer/core@5.7.3/index.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@photo-sphere-viewer/markers-plugin@5.7.3/index.min.css">
    
    <link rel="stylesheet" href="/css/visor.css">

    <style>
        body { font-family: 'Inter', sans-serif; margin: 0; overflow: hidden; background: #0f172a; }
        .top-capsule {
            background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2); box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            border-radius: 50px; padding: 8px 20px 8px 8px; display: flex; align-items: center; gap: 15px;
        }
        .back-circle { background: #2563eb; color: white; transition: 0.3s; }
        .back-circle:hover { background: #1d4ed8; transform: scale(1.05); }
        .project-title { color: #1e293b; font-weight: 700; font-size: 0.95rem; }
        .toolbar {
            background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);
            border-radius: 20px 20px 0 0; box-shadow: 0 -10px 25px rgba(0,0,0,0.05);
        }
        .toolbar-title { color: #64748b; font-size: 0.75rem; text-transform: uppercase; font-weight: 800; }
        .tool-btn { border-radius: 12px; transition: 0.2s; color: #334155; }
        .tool-btn.active { background: #eff6ff; color: #2563eb; border-color: #bfdbfe; }
        .btn-save-main { background: #10b981; color: white; border-radius: 12px; font-weight: 600; }
    </style>
</head>
<body>

    <div id="viewer"></div>

    <div class="top-capsule">
        <a href="/admin/proyectos" class="back-circle"><i class="bi bi-arrow-left"></i></a>
        <span class="project-title" id="project-title">Cargando Proyecto...</span>
    </div>

    <div class="toolbar">
        <div class="toolbar-title">Herramientas de Dibujo</div>
        <div class="tools-container">
            <button class="tool-btn" id="btn-add-poi"><i class="bi bi-geo-alt"></i> POI</button>
            <button class="tool-btn" id="btn-draw-poly"><i class="bi bi-bounding-box-circles"></i> Lote</button>
            <button class="tool-btn" id="btn-draw-road"><i class="bi bi-sign-turn-right"></i> Camino</button>
            <div class="separator"></div>
            <button class="tool-btn btn-danger-lite" id="btn-reset"><i class="bi bi-x-circle"></i> Cancelar</button>
            <button class="btn-save-main" id="btn-save-all"><i class="bi bi-cloud-arrow-up"></i> Guardar</button>
        </div>
    </div>

    <div class="modal-overlay" id="modal-poly">
        <div class="modal-box">
            <div class="modal-header">
                <div class="modal-title" id="poly-modal-title">Configurar Parcela</div>
                <button class="btn-close-modal" onclick="closeModal()"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="poly-id">
                <input type="hidden" id="poly-type" value="lote">
                <div class="input-group"><label>Número/Nombre</label><input type="text" id="poly-numero"></div>
                <div class="row-inputs">
                    <div class="input-group">
                        <label>Estado</label>
                        <select id="poly-estado" onchange="updatePolyColor()">
                            <option value="1">Disponible</option><option value="2">Reservado</option><option value="3">Vendido</option>
                        </select>
                    </div>
                    <div class="input-group" id="group-color" style="display:none;"><label>Color</label><input type="color" id="poly-color" class="color-input"></div>
                </div>
                <div class="row-inputs">
                    <div class="input-group"><label>Precio ($)</label><input type="text" id="poly-precio" onkeyup="formatCurrency(this)"></div>
                    <div class="input-group"><label>Superficie (m²)</label><input type="text" id="poly-superficie"></div>
                </div>
            </div>
            <div class="modal-footer" style="background:transparent; border:none; padding:0; margin-top:10px;">
                <button class="btn-delete" id="btn-poly-delete" style="display:none;" onclick="confirmDelete()"><i class="bi bi-trash"></i></button>
                <button class="btn-cancel" onclick="closeModal()">Cancelar</button>
                <button class="btn-save" onclick="savePoly()">Guardar</button>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="modal-poi">
        <div class="modal-box">
            <div class="modal-header">
                <div class="modal-title">Punto de Interés</div>
                <button class="btn-close-modal" onclick="closeModal()"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="poi-id">
                <div class="input-group"><label>Título</label><input type="text" id="poi-titulo"></div>
                <div class="input-group"><label>Descripción</label><textarea id="poi-descripcion" rows="3"></textarea></div>
                <div class="input-group"><label>Color</label><input type="color" id="poi-color" value="#ffffff" class="color-input" oninput="updateActivePoi()"></div>
            </div>
            <div class="modal-footer" style="background:transparent; border:none; padding:0; margin-top:10px;">
                <button class="btn-delete" id="btn-poi-delete" style="display:none;" onclick="confirmDelete()"><i class="bi bi-trash"></i></button>
                <button class="btn-cancel" onclick="closeModal()">Cerrar</button>
                <button class="btn-save" onclick="savePoi()">Guardar</button>
            </div>
        </div>
    </div>

 <div class="modal-overlay" id="dialog-overlay">
        <div class="modal-box" style="text-align: center; max-width: 400px; padding: 30px;">
            <div class="dialog-content">
                <i id="dialog-icon" class="bi bi-exclamation-triangle-fill dialog-icon" style="font-size: 3rem; color: #ef4444; margin-bottom: 10px;"></i>
                <div id="dialog-title" class="dialog-title" style="font-size: 1.2rem; font-weight: bold; margin-bottom: 10px;">¿Estás seguro?</div>
                <p id="dialog-message" class="dialog-text" style="color: #64748b; margin-bottom: 20px;"></p>
                <div class="dialog-buttons" id="dialog-buttons" style="display: flex; gap: 10px; justify-content: center;"></div>
            </div>
        </div>
    </div>

    <script type="importmap">
    {
        "imports": {
            "three": "https://cdn.jsdelivr.net/npm/three@0.164.0/build/three.module.js",
            "@photo-sphere-viewer/core": "https://cdn.jsdelivr.net/npm/@photo-sphere-viewer/core@5.7.3/index.module.js",
            "@photo-sphere-viewer/markers-plugin": "https://cdn.jsdelivr.net/npm/@photo-sphere-viewer/markers-plugin@5.7.3/index.module.js"
        }
    }
    </script>
    <script type="module" src="/js/visor-logic.js"></script>
    <script>
        function formatCurrency(input) {
            let val = input.value.replace(/\D/g, '');
            if(val === '') return;
            input.value = parseInt(val).toLocaleString('es-CL');
        }
    </script>
</body>
</html>