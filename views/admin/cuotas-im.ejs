<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/inmobiliaria.css">
    <style>
        .cuotas-header{padding:24px 28px 16px;border-bottom:1px solid #e2e8f0;display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
        .cuotas-toolbar{padding:14px 28px;border-bottom:1px solid #f1f5f9;display:flex;gap:10px;flex-wrap:wrap;align-items:center;background:#fff;}
        .cuotas-body{padding:20px 28px;}
        .badge-pagada{background:#dcfce7;color:#166534;border-radius:20px;padding:3px 10px;font-size:.74rem;font-weight:700;display:inline-flex;align-items:center;gap:4px;white-space:nowrap;}
        .badge-pendiente{background:#fef3c7;color:#92400e;border-radius:20px;padding:3px 10px;font-size:.74rem;font-weight:700;display:inline-flex;align-items:center;gap:4px;white-space:nowrap;}
        .badge-vencida{background:#fee2e2;color:#991b1b;border-radius:20px;padding:3px 10px;font-size:.74rem;font-weight:700;display:inline-flex;align-items:center;gap:4px;white-space:nowrap;}
        .cuotas-table{width:100%;border-collapse:collapse;font-size:.83rem;}
        .cuotas-table th{padding:10px 14px;text-align:left;font-weight:700;color:#475569;font-size:.74rem;text-transform:uppercase;letter-spacing:.3px;background:#f8fafc;border-bottom:2px solid #e2e8f0;white-space:nowrap;}
        .cuotas-table td{padding:11px 14px;border-bottom:1px solid #f1f5f9;vertical-align:middle;}
        .cuota-main-row{cursor:pointer;transition:background .12s;}
        .cuota-main-row:hover td{background:#f0f9ff!important;}
        .cuota-main-row.row-pagada td{background:#f0fdf4;}
        .cuota-main-row.row-vencida td{background:#fff5f5;}
        .cuota-detail-row td{padding:0!important;border-bottom:2px solid #e2e8f0;}
        .cuota-detail-inner{padding:16px 20px;background:#f8fafc;animation:slideDown .2s ease;}
        @keyframes slideDown{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
        .detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;}
        .detail-card{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:13px 16px;}
        .detail-card-title{font-size:.7rem;font-weight:800;color:#64748b;text-transform:uppercase;letter-spacing:.4px;margin:0 0 8px;}
        .detail-row{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;padding:4px 0;border-bottom:1px solid #f1f5f9;font-size:.8rem;}
        .detail-row:last-child{border-bottom:none;}
        .detail-key{color:#64748b;white-space:nowrap;}
        .detail-val{color:#0f172a;font-weight:600;text-align:right;word-break:break-word;}
        .mini-cuotas{display:flex;flex-direction:column;gap:5px;}
        .mini-cuota{display:flex;align-items:center;gap:8px;padding:6px 10px;border-radius:7px;background:#fff;border:1px solid #e2e8f0;font-size:.78rem;}
        .mini-cuota.pagada-mini{background:#f0fdf4;border-color:#86efac;}
        .mini-cuota.vencida-mini{background:#fff5f5;border-color:#fca5a5;}
        .mini-cuota.this-one{border:2px solid #2563eb;background:#eff6ff;}
        .comp-thumb{width:44px;height:44px;border-radius:6px;object-fit:cover;border:1px solid #e2e8f0;cursor:pointer;flex-shrink:0;}
        .comp-pdf{width:44px;height:44px;border-radius:6px;background:#fee2e2;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;border:1px solid #fecaca;}
        .al-dia-chip{background:#dcfce7;color:#166534;border-radius:20px;padding:4px 12px;font-size:.75rem;font-weight:700;display:inline-flex;align-items:center;gap:5px;}
        .no-al-dia-chip{background:#fee2e2;color:#991b1b;border-radius:20px;padding:4px 12px;font-size:.75rem;font-weight:700;display:inline-flex;align-items:center;gap:5px;}
        .filter-chip{padding:6px 14px;border-radius:20px;font-size:.78rem;font-weight:600;border:1.5px solid #e2e8f0;background:#fff;cursor:pointer;color:#64748b;transition:all .15s;}
        .filter-chip.active{background:#2563eb;color:#fff;border-color:#2563eb;}
        .search-box{display:flex;align-items:center;gap:8px;background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:10px;padding:0 12px;flex:1;max-width:320px;}
        .search-box input{border:none;background:transparent;padding:8px 0;font-size:.85rem;font-family:inherit;color:#0f172a;outline:none;width:100%;}
        .summary-cards{display:flex;gap:12px;flex-wrap:wrap;padding:12px 28px;background:#f8fafc;border-bottom:1px solid #e2e8f0;}
        .summary-card{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:10px 18px;display:flex;flex-direction:column;align-items:center;}
        .summary-card .val{font-size:1.3rem;font-weight:800;}
        .summary-card .lbl{font-size:.72rem;color:#64748b;margin-top:2px;}
        /* Modals */
        .cq-modal-overlay{position:fixed;inset:0;background:rgba(15,23,42,.5);z-index:8000;display:none;align-items:center;justify-content:center;padding:20px;}
        .cq-modal-overlay.open{display:flex;}
        .cq-modal-box{background:#fff;border-radius:16px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,.25);overflow:hidden;}
        .cq-modal-header{padding:16px 20px;background:linear-gradient(135deg,#1d4ed8,#2563eb);color:#fff;display:flex;justify-content:space-between;align-items:center;}
        .cq-modal-body{padding:20px;}
        .preview-frame{width:100%;height:500px;border:none;border-radius:8px;background:#f1f5f9;}
    </style>
</head>
<body class="dashboard-body">
    <%- include('../partials/alerts') %>

    <div id="im-toast" style="position:fixed;top:20px;right:20px;z-index:9999;pointer-events:none;opacity:0;transform:translateX(30px);transition:all .3s;">
        <div id="im-toast-inner" style="padding:14px 18px;border-radius:12px;min-width:260px;max-width:420px;box-shadow:0 8px 30px rgba(0,0,0,.15);display:flex;align-items:flex-start;gap:10px;"></div>
    </div>

    <!-- Modal pagar cuota -->
    <div id="modal-pago" class="cq-modal-overlay">
        <div class="cq-modal-box" style="max-width:480px;">
            <div class="cq-modal-header">
                <div><p style="font-size:.72rem;opacity:.8;margin:0;">Registrar Pago</p><p id="modal-title" style="font-weight:800;font-size:1rem;margin:2px 0 0;"></p></div>
                <button onclick="closeModal()" style="background:rgba(255,255,255,.2);border:none;border-radius:8px;color:#fff;padding:6px 10px;cursor:pointer;"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="cq-modal-body">
                <input type="hidden" id="modal-cuota-id">
                <div class="im-input-group" style="margin-bottom:12px;">
                    <label>Fecha de Pago</label>
                    <input type="date" id="modal-fecha-pago" class="styled-input">
                </div>
                <div class="im-input-group" style="margin-bottom:12px;">
                    <label>Comprobante de Pago <span style="color:#94a3b8;font-size:.75rem;">(foto, imagen, PDF)</span></label>
                    <input type="file" id="modal-file" class="styled-input" accept="image/*,.pdf" style="padding:8px;" multiple>
                    <p style="font-size:.72rem;color:#94a3b8;margin:4px 0 0;">Varios archivos · imágenes máx. 20 MB · PDF máx. 100 MB</p>
                    <p style="font-size:.75rem;color:#64748b;margin:4px 0 0;"><i class="bi bi-info-circle"></i> Se guardará automáticamente en "Docs Venta" de la parcela.</p>
                </div>
                <div class="im-input-group" style="margin-bottom:16px;">
                    <label>Notas <span style="color:#94a3b8;font-size:.75rem;">(opcional)</span></label>
                    <textarea id="modal-notas" class="styled-input" rows="2" placeholder="Observaciones del pago..."></textarea>
                </div>
                <div style="display:flex;gap:8px;">
                    <button onclick="closeModal()" class="im-btn im-btn-ghost" style="flex:1;">Cancelar</button>
                    <button onclick="guardarPago()" class="im-btn im-btn-success" style="flex:2;" id="btn-guardar-pago">
                        <i class="bi bi-check-circle"></i> Marcar como Pagada
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal preview documento -->
    <div id="modal-preview" class="cq-modal-overlay">
        <div class="cq-modal-box" style="max-width:860px;">
            <div class="cq-modal-header">
                <p id="prev-title" style="font-weight:700;margin:0;"></p>
                <div style="display:flex;gap:8px;align-items:center;">
                    <a id="prev-dl" href="#" target="_blank" download class="im-btn im-btn-sm im-btn-ghost" style="color:#fff;border-color:rgba(255,255,255,.4);"><i class="bi bi-download"></i> Descargar</a>
                    <button onclick="closePreview()" style="background:rgba(255,255,255,.2);border:none;border-radius:8px;color:#fff;padding:6px 10px;cursor:pointer;"><i class="bi bi-x-lg"></i></button>
                </div>
            </div>
            <div style="padding:16px;background:#1e293b;min-height:200px;display:flex;align-items:center;justify-content:center;">
                <div id="prev-content" style="width:100%;text-align:center;"></div>
            </div>
        </div>
    </div>

    <div class="app-layout">
        <%- include('../partials/sidebar-admin', { page: 'cuotas-im' }) %>
        <main class="main-content">
        <div class="dashboard-scroll" style="padding:0;">

            <div class="cuotas-header">
                <div style="background:linear-gradient(135deg,#1d4ed8,#2563eb);border-radius:10px;width:42px;height:42px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="bi bi-calendar-check-fill" style="font-size:1.2rem;color:#fff;"></i>
                </div>
                <div>
                    <h1 style="font-size:1.25rem;font-weight:800;color:#0f172a;margin:0;">Pago de Cuotas</h1>
                    <p style="font-size:.82rem;color:#64748b;margin:2px 0 0;">Todas las cuotas · haz clic en una fila para ver detalle, historial y comprobantes</p>
                </div>
            </div>

            <div class="summary-cards">
                <div class="summary-card"><span class="val" id="sc-total" style="color:#0f172a;">—</span><span class="lbl">Total</span></div>
                <div class="summary-card"><span class="val" id="sc-pendientes" style="color:#d97706;">—</span><span class="lbl">Pendientes</span></div>
                <div class="summary-card"><span class="val" id="sc-vencidas" style="color:#dc2626;">—</span><span class="lbl">Vencidas</span></div>
                <div class="summary-card"><span class="val" id="sc-pagadas" style="color:#16a34a;">—</span><span class="lbl">Pagadas</span></div>
                <div class="summary-card"><span class="val" id="sc-saldo" style="color:#1d4ed8;font-size:.95rem;">—</span><span class="lbl">Saldo Pendiente Total</span></div>
            </div>

            <div class="cuotas-toolbar">
                <div class="search-box">
                    <i class="bi bi-search" style="color:#94a3b8;"></i>
                    <input type="text" id="search-input" placeholder="Nombre, RUT, parcela, proyecto..." oninput="applyFilters()">
                </div>
                <button class="filter-chip active" data-f="todos" onclick="setFiltro('todos',this)">Todos</button>
                <button class="filter-chip" data-f="pendiente" onclick="setFiltro('pendiente',this)"><i class="bi bi-clock"></i> Pendientes</button>
                <button class="filter-chip" data-f="vencida" onclick="setFiltro('vencida',this)"><i class="bi bi-exclamation-triangle"></i> Vencidas</button>
                <button class="filter-chip" data-f="pagada" onclick="setFiltro('pagada',this)"><i class="bi bi-check-circle"></i> Pagadas</button>
                <select id="filter-proyecto" class="styled-input" style="max-width:200px;padding:7px 12px;font-size:.82rem;" onchange="applyFilters()">
                    <option value="">Todos los proyectos</option>
                </select>
                <span id="count-label" style="margin-left:auto;font-size:.78rem;color:#94a3b8;"></span>
            </div>

            <div class="cuotas-body">
                <div id="cuotas-container" style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;overflow-x:auto;">
                    <div style="text-align:center;padding:60px;color:#94a3b8;"><i class="bi bi-hourglass-split" style="font-size:2rem;display:block;margin-bottom:8px;"></i><p>Cargando cuotas...</p></div>
                </div>
            </div>

        </div>
        </main>
    </div>

<script>
let allCuotas = [];
let filtroEstado = 'todos';
let expandedRows = new Set();
let ventaCuotasCache = {};

function $(id){ return document.getElementById(id); }
function escH(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function fmt(n){ return Math.floor(parseFloat(n)||0).toLocaleString('es-CL'); }
function fmtFecha(d){ return d ? new Date(d+'T12:00').toLocaleDateString('es-CL',{day:'2-digit',month:'short',year:'numeric'}) : '—'; }
function isImg(url){ return url && /\.(jpg|jpeg|png|webp|gif)(\?|$)/i.test(url); }
function isPdf(url){ return url && /\.pdf(\?|$)/i.test(url); }

function showToast(msg,type='success',title=''){
    const t=$('im-toast'),i=$('im-toast-inner');
    const cfg={success:{bg:'#dcfce7',c:'#166534',b:'#86efac',ic:'bi-check-circle-fill',d:'Éxito'},error:{bg:'#fee2e2',c:'#991b1b',b:'#fca5a5',ic:'bi-exclamation-triangle-fill',d:'Error'},warning:{bg:'#fef3c7',c:'#92400e',b:'#fde68a',ic:'bi-exclamation-circle-fill',d:'Atención'},info:{bg:'#eff6ff',c:'#1e40af',b:'#bfdbfe',ic:'bi-info-circle-fill',d:'Info'}};
    const s=cfg[type]||cfg.info;
    i.style.cssText=`background:${s.bg};color:${s.c};border:1.5px solid ${s.b};padding:14px 18px;border-radius:12px;box-shadow:0 8px 30px rgba(0,0,0,.12);display:flex;align-items:flex-start;gap:10px;`;
    i.innerHTML=`<i class="bi ${s.ic}" style="font-size:1.1rem;flex-shrink:0;margin-top:1px;"></i><div><div style="font-weight:700;font-size:.88rem;">${title||s.d}</div><div style="font-size:.82rem;margin-top:2px;opacity:.9;">${escH(msg)}</div></div>`;
    t.style.opacity='1';t.style.transform='translateX(0)';t.style.pointerEvents='auto';
    clearTimeout(t._t);t._t=setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(30px)';t.style.pointerEvents='none';},5000);
}

async function init(){
    try{
        const res=await fetch('/api/im/cuotas',{credentials:'same-origin'});
        if(!res.ok) throw new Error(`Error ${res.status}`);
        allCuotas=await res.json();
        buildProyectoFilter();
        renderSummary(allCuotas);
        applyFilters();
    }catch(e){
        $('cuotas-container').innerHTML=`<div style="text-align:center;padding:60px;color:#94a3b8;"><i class="bi bi-exclamation-triangle-fill" style="font-size:2rem;color:#ef4444;display:block;margin-bottom:8px;"></i><p style="color:#991b1b;font-weight:700;">${escH(e.message)}</p><button class="im-btn im-btn-primary" onclick="init()" style="margin-top:12px;"><i class="bi bi-arrow-clockwise"></i> Reintentar</button></div>`;
    }
}

function buildProyectoFilter(){
    const proyectos=[...new Map(allCuotas.map(c=>[c.proyecto_id,c.proyecto_nombre])).entries()];
    const sel=$('filter-proyecto');
    sel.innerHTML='<option value="">Todos los proyectos</option>';
    proyectos.forEach(([id,nombre])=>{ const o=document.createElement('option'); o.value=id; o.textContent=nombre; sel.appendChild(o); });
}

function renderSummary(cuotas){
    const hoy=new Date().toISOString().split('T')[0];
    const pend=cuotas.filter(c=>!c.pagado).length;
    const venc=cuotas.filter(c=>!c.pagado&&c.fecha_vencimiento&&c.fecha_vencimiento<hoy).length;
    const pag=cuotas.filter(c=>c.pagado).length;
    const saldo=cuotas.filter(c=>!c.pagado).reduce((s,c)=>s+(parseFloat(c.monto)||0),0);
    $('sc-total').textContent=cuotas.length;
    $('sc-pendientes').textContent=pend;
    $('sc-vencidas').textContent=venc;
    $('sc-pagadas').textContent=pag;
    $('sc-saldo').textContent='$'+fmt(saldo);
}

function setFiltro(f,btn){
    filtroEstado=f;
    expandedRows.clear();
    document.querySelectorAll('.filter-chip').forEach(b=>b.classList.remove('active'));
    if(btn)btn.classList.add('active');
    applyFilters();
}

function applyFilters(){
    const q=$('search-input').value.trim().toLowerCase();
    const filtProj=$('filter-proyecto').value;
    const hoy=new Date().toISOString().split('T')[0];
    let filtered=allCuotas.filter(c=>{
        const esVencida=!c.pagado&&c.fecha_vencimiento&&c.fecha_vencimiento<hoy;
        if(filtroEstado==='pendiente'&&(c.pagado||esVencida))return false;
        if(filtroEstado==='vencida'&&!esVencida)return false;
        if(filtroEstado==='pagada'&&!c.pagado)return false;
        if(filtProj&&c.proyecto_id!==filtProj)return false;
        if(q){
            const hay=(c.cliente_nombre||'').toLowerCase().includes(q)
                ||(c.numero_parcela||'').toLowerCase().includes(q)
                ||(c.proyecto_nombre||'').toLowerCase().includes(q)
                ||(c.cliente_rut||'').toLowerCase().includes(q)
                ||(c.cliente_telefono||'').toLowerCase().includes(q);
            if(!hay)return false;
        }
        return true;
    });
    $('count-label').textContent=`${filtered.length} cuota${filtered.length!==1?'s':''}`;
    renderTable(filtered);
}

function badgeHtml(c, hoy){
    const esVencida=!c.pagado&&c.fecha_vencimiento&&c.fecha_vencimiento<hoy;
    return c.pagado
        ?`<span class="badge-pagada"><i class="bi bi-check-circle-fill"></i> Pagada</span>`
        :esVencida
            ?`<span class="badge-vencida"><i class="bi bi-exclamation-triangle-fill"></i> Vencida</span>`
            :`<span class="badge-pendiente"><i class="bi bi-clock"></i> Pendiente</span>`;
}

function comprobanteHtml(url, small=false){
    if(!url) return '<span style="color:#94a3b8;font-size:.75rem;">—</span>';
    if(isImg(url)) return `<img src="${escH(url)}" class="comp-thumb" onclick="previewDoc('${escH(url)}','Comprobante','img')" title="Ver comprobante" style="${small?'width:32px;height:32px;':''}">`;
    if(isPdf(url)) return `<div class="comp-pdf" onclick="previewDoc('${escH(url)}','Comprobante','pdf')" title="Ver PDF" style="${small?'width:32px;height:32px;':''}"><i class="bi bi-file-earmark-pdf" style="color:#dc2626;font-size:${small?'1rem':'1.3rem'};"></i></div>`;
    return `<a href="${escH(url)}" target="_blank" class="im-btn im-btn-sm im-btn-ghost" style="font-size:.72rem;"><i class="bi bi-eye"></i></a>`;
}

function renderTable(cuotas){
    const cont=$('cuotas-container');
    if(cuotas.length===0){
        cont.innerHTML=`<div style="text-align:center;padding:60px;color:#94a3b8;"><i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:8px;"></i><p>No hay cuotas que coincidan.</p></div>`;
        return;
    }
    const hoy=new Date().toISOString().split('T')[0];
    let html=`<table class="cuotas-table"><thead><tr>
        <th style="width:28px;"></th>
        <th>#</th><th>Cliente</th><th>Contacto</th>
        <th>Parcela</th><th>Proyecto</th>
        <th>Monto</th><th>Vencimiento</th><th>Comprobante</th><th>Estado</th><th></th>
    </tr></thead><tbody>`;

    cuotas.forEach(c=>{
        const esVencida=!c.pagado&&c.fecha_vencimiento&&c.fecha_vencimiento<hoy;
        const rowCl=c.pagado?'row-pagada':esVencida?'row-vencida':'';
        const isExp=expandedRows.has(c.id);
        const cData=JSON.stringify(c).replace(/"/g,'&quot;');

        html+=`<tr class="cuota-main-row ${rowCl}" onclick="toggleRow('${c.id}','${escH(c.venta_id)}')">
            <td><i class="bi bi-chevron-${isExp?'down':'right'}" id="chev-${c.id}" style="color:#94a3b8;font-size:.8rem;transition:.15s;"></i></td>
            <td style="font-weight:700;color:#334155;white-space:nowrap;">Cuota ${c.numero_cuota}</td>
            <td>
                <div style="font-weight:700;color:#0f172a;">${escH(c.cliente_nombre||'—')}</div>
                <div style="font-size:.74rem;color:#64748b;">${escH(c.cliente_rut||'')}</div>
            </td>
            <td style="font-size:.78rem;color:#64748b;">
                ${c.cliente_telefono?`<div><i class="bi bi-telephone"></i> ${escH(c.cliente_telefono)}</div>`:''}
                ${c.cliente_email?`<div><i class="bi bi-envelope"></i> ${escH(c.cliente_email)}</div>`:''}
            </td>
            <td><span style="background:#eff6ff;color:#1d4ed8;border-radius:6px;padding:2px 8px;font-size:.74rem;font-weight:700;">N° ${escH(String(c.numero_parcela))}</span></td>
            <td><a href="/admin/inmobiliaria/proyectos/${escH(c.proyecto_id)}" onclick="event.stopPropagation()" style="text-decoration:none;"><span style="background:#f0fdf4;color:#166534;border-radius:6px;padding:2px 8px;font-size:.74rem;font-weight:700;">${escH(c.proyecto_nombre||'—')}</span></a></td>
            <td style="font-weight:700;color:#0f172a;white-space:nowrap;">${c.monto?'$'+fmt(c.monto):'—'}</td>
            <td style="white-space:nowrap;color:${esVencida?'#dc2626':'#475569'};font-weight:${esVencida?700:400};">${fmtFecha(c.fecha_vencimiento)}</td>
            <td onclick="event.stopPropagation();">${comprobanteHtml(c.comprobante_url,true)}</td>
            <td>${badgeHtml(c,hoy)}</td>
            <td onclick="event.stopPropagation();" style="white-space:nowrap;">
                <a href="/admin/inmobiliaria/parcela/${escH(c.parcela_id)}" class="im-btn im-btn-sm im-btn-ghost" title="Ver parcela"><i class="bi bi-arrow-up-right"></i></a>
                ${!c.pagado?`<button class="im-btn im-btn-sm im-btn-success" onclick="openPago(${cData})" title="Registrar pago"><i class="bi bi-check-lg"></i> Pagar</button>`:''}
            </td>
        </tr>
        <tr id="detail-${c.id}" class="cuota-detail-row" style="display:${isExp?'table-row':'none'};">
            <td colspan="11"><div class="cuota-detail-inner" id="detail-inner-${c.id}">
                <div style="text-align:center;padding:20px;color:#94a3b8;"><i class="bi bi-hourglass-split"></i> Cargando detalle...</div>
            </div></td>
        </tr>`;
    });

    html+='</tbody></table>';
    cont.innerHTML=html;
}

async function toggleRow(cuotaId, ventaId){
    const detailRow=$(`detail-${cuotaId}`);
    const chev=$(`chev-${cuotaId}`);
    const isOpen=detailRow.style.display!=='none';

    if(isOpen){
        detailRow.style.display='none';
        if(chev)chev.className='bi bi-chevron-right';
        expandedRows.delete(cuotaId);
        return;
    }

    detailRow.style.display='table-row';
    if(chev)chev.className='bi bi-chevron-down';
    expandedRows.add(cuotaId);

    const inner=$(`detail-inner-${cuotaId}`);
    // Obtener cuota actual
    const cuota=allCuotas.find(c=>c.id===cuotaId);
    if(!cuota){inner.innerHTML='<p style="color:#ef4444;">Error al cargar datos.</p>';return;}

    // Cargar todas las cuotas de esta venta
    let ventaCuotas=ventaCuotasCache[ventaId];
    if(!ventaCuotas){
        try{
            const r=await fetch(`/api/im/cuotas/${ventaId}`);
            ventaCuotas=r.ok?await r.json():[];
            ventaCuotasCache[ventaId]=ventaCuotas;
        }catch(_){ventaCuotas=[];}
    }

    const hoy=new Date().toISOString().split('T')[0];
    const pagadas=ventaCuotas.filter(c=>c.pagado).length;
    const total=ventaCuotas.length;
    const vencidas=ventaCuotas.filter(c=>!c.pagado&&c.fecha_vencimiento&&c.fecha_vencimiento<hoy).length;
    const alDia=vencidas===0;
    const saldo=ventaCuotas.filter(c=>!c.pagado).reduce((s,c)=>s+(parseFloat(c.monto)||0),0);

    inner.innerHTML=`
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;flex-wrap:wrap;">
        <span style="font-size:.78rem;font-weight:700;color:#475569;"><i class="bi bi-diagram-3"></i> Detalle de la Operación</span>
        ${alDia
            ?`<span class="al-dia-chip"><i class="bi bi-check-circle-fill"></i> Al día</span>`
            :`<span class="no-al-dia-chip"><i class="bi bi-exclamation-triangle-fill"></i> ${vencidas} cuota${vencidas>1?'s':''} vencida${vencidas>1?'s':''}</span>`}
        <span style="font-size:.76rem;color:#64748b;">${pagadas} de ${total} pagadas · Saldo: <strong>$${fmt(saldo)}</strong></span>
    </div>

    <div class="detail-grid">
        <!-- Cliente -->
        <div class="detail-card">
            <p class="detail-card-title"><i class="bi bi-person-fill" style="color:#2563eb;"></i> Comprador</p>
            <div class="detail-row"><span class="detail-key">Nombre</span><span class="detail-val">${escH(cuota.cliente_nombre||'—')}</span></div>
            <div class="detail-row"><span class="detail-key">RUT</span><span class="detail-val">${escH(cuota.cliente_rut||'—')}</span></div>
            <div class="detail-row"><span class="detail-key">Teléfono</span><span class="detail-val">${escH(cuota.cliente_telefono||'—')}</span></div>
            <div class="detail-row"><span class="detail-key">Email</span><span class="detail-val">${escH(cuota.cliente_email||'—')}</span></div>
        </div>
        <!-- Lote -->
        <div class="detail-card">
            <p class="detail-card-title"><i class="bi bi-geo-alt-fill" style="color:#16a34a;"></i> Lote y Proyecto</p>
            <div class="detail-row"><span class="detail-key">Parcela</span><span class="detail-val">N° ${escH(String(cuota.numero_parcela))}</span></div>
            <div class="detail-row"><span class="detail-key">Proyecto</span><span class="detail-val">${escH(cuota.proyecto_nombre||'—')}</span></div>
            <div class="detail-row"><span class="detail-key">Monto cuota</span><span class="detail-val">${cuota.monto?'$'+fmt(cuota.monto):'—'}</span></div>
            <div class="detail-row"><span class="detail-key">Esta cuota</span><span class="detail-val">${badgeHtml(cuota,hoy)}</span></div>
            ${cuota.comprobante_url?`<div class="detail-row" style="align-items:center;"><span class="detail-key">Comprobante</span><span class="detail-val">${comprobanteHtml(cuota.comprobante_url)}</span></div>`:''}
        </div>
    </div>

    <!-- Historial de cuotas de esta venta -->
    <div class="detail-card" style="margin-bottom:0;">
        <p class="detail-card-title" style="margin-bottom:10px;"><i class="bi bi-list-ol" style="color:#7c3aed;"></i> Todas las cuotas de esta venta</p>
        <div class="mini-cuotas">
        ${ventaCuotas.length===0
            ?'<p style="color:#94a3b8;font-size:.8rem;text-align:center;padding:10px;">Sin cuotas registradas.</p>'
            :ventaCuotas.map(vc=>{
                const esEsta=vc.id===cuotaId;
                const vcVenc=!vc.pagado&&vc.fecha_vencimiento&&vc.fecha_vencimiento<hoy;
                const miniCl=vc.pagado?'pagada-mini':vcVenc?'vencida-mini':'';
                return `<div class="mini-cuota ${miniCl} ${esEsta?'this-one':''}">
                    <span style="font-size:.75rem;font-weight:800;color:#475569;width:58px;flex-shrink:0;">Cuota ${vc.numero_cuota}</span>
                    <span style="font-size:.78rem;font-weight:700;color:#0f172a;flex:1;">${vc.monto?'$'+fmt(vc.monto):'—'}</span>
                    <span style="font-size:.75rem;color:#64748b;white-space:nowrap;">${fmtFecha(vc.fecha_vencimiento)}</span>
                    ${badgeHtml(vc,hoy)}
                    ${vc.comprobante_url?comprobanteHtml(vc.comprobante_url,true):''}
                    ${esEsta?'<span style="font-size:.7rem;background:#eff6ff;color:#2563eb;border-radius:20px;padding:1px 8px;font-weight:700;">← esta</span>':''}
                </div>`;
            }).join('')}
        </div>
    </div>
    <div style="margin-top:12px;display:flex;gap:8px;">
        <a href="/admin/inmobiliaria/parcela/${escH(cuota.parcela_id)}" class="im-btn im-btn-ghost" style="font-size:.8rem;"><i class="bi bi-arrow-up-right"></i> Ver ficha completa de la parcela</a>
    </div>`;
}

// ── Preview doc ───────────────────────────────────────
function previewDoc(url,nombre,tipo){
    $('prev-title').textContent=nombre||'Vista previa';
    $('prev-dl').href=url;
    const imgs=['img','jpg','jpeg','png','webp','gif'];
    let content;
    if(tipo==='img'||imgs.includes(tipo))
        content=`<img src="${escH(url)}" style="max-width:100%;max-height:70vh;border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,.3);">`;
    else if(tipo==='pdf')
        content=`<iframe src="${escH(url)}" style="width:100%;height:520px;border:none;border-radius:8px;"></iframe>`;
    else
        content=`<div style="padding:40px;color:#94a3b8;"><i class="bi bi-file-earmark-text" style="font-size:3rem;display:block;margin-bottom:12px;"></i><p>Vista previa no disponible.</p><a href="${escH(url)}" target="_blank" class="im-btn im-btn-primary" style="display:inline-flex;margin-top:10px;"><i class="bi bi-box-arrow-up-right"></i> Abrir en nueva pestaña</a></div>`;
    $('prev-content').innerHTML=content;
    $('modal-preview').classList.add('open');
}
function closePreview(){ $('modal-preview').classList.remove('open'); }

// ── Modal pago ────────────────────────────────────────
function openPago(c){
    $('modal-cuota-id').value=c.id;
    $('modal-title').textContent=`Cuota ${c.numero_cuota} — ${c.cliente_nombre||''}`;
    $('modal-fecha-pago').value=new Date().toISOString().split('T')[0];
    $('modal-file').value='';
    $('modal-notas').value=c.notas||'';
    $('modal-pago').classList.add('open');
}
function closeModal(){ $('modal-pago').classList.remove('open'); }

async function guardarPago(){
    const id=$('modal-cuota-id').value;
    const btn=$('btn-guardar-pago');
    btn.disabled=true; btn.innerHTML='<i class="bi bi-hourglass-split"></i> Guardando...';
    try{
        const body={pagado:true,fecha_pago:$('modal-fecha-pago').value||null,notas:$('modal-notas').value||null};
        const r=await fetch(`/api/im/cuotas/${id}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
        if(!r.ok){const e=await r.json().catch(()=>({}));throw new Error(e.message||`Error ${r.status}`);}

        const files=Array.from($('modal-file').files||[]);
        if(files.length){
            if(window.IMUpload){
                const errs=IMUpload.validateFiles(files);
                if(errs.length){showToast(errs.join(' · '),'error','Archivo demasiado pesado');throw new Error(errs[0]);}
            }
            btn.innerHTML='<i class="bi bi-hourglass-split"></i> Subiendo comprobante...';
            for(const file of files){
                const fd=new FormData(); fd.append('archivo',file,file.name);
                const r2=await fetch(`/api/im/cuotas/${id}/comprobante`,{method:'POST',body:fd});
                if(!r2.ok){
                    const msg=window.IMUpload?await IMUpload.readErrorMessage(r2,'Error al subir comprobante'):((await r2.json().catch(()=>({}))).message||'Error al subir comprobante');
                    showToast(msg,'warning','Aviso');
                }
            }
        }

        ventaCuotasCache={};
        closeModal();
        showToast('Cuota marcada como pagada.','success');
        await init();
    }catch(e){showToast(e.message,'error','Error al guardar');}
    finally{btn.disabled=false; btn.innerHTML='<i class="bi bi-check-circle"></i> Marcar como Pagada';}
}

$('modal-pago').addEventListener('click',e=>{if(e.target===$('modal-pago'))closeModal();});
$('modal-preview').addEventListener('click',e=>{if(e.target===$('modal-preview'))closePreview();});

init();
</script>
</body>
</html>
