<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/inmobiliaria.css">
    <style>
        /* ── Fix scroll: forzar área scrolleable en esta página ── */
        html, body.dashboard-body {
            height: 100% !important;
            overflow: hidden !important;
        }
        body.dashboard-body .app-layout {
            height: 100vh !important;
            overflow: hidden !important;
        }
        body.dashboard-body .main-content {
            height: 100% !important;
            min-height: 0 !important;
            overflow: hidden !important;
            display: flex !important;
            flex-direction: column !important;
        }
        body.dashboard-body .dashboard-scroll {
            flex: 1 1 auto !important;
            min-height: 0 !important;
            height: auto !important;
            overflow-y: auto !important;
            overflow-x: hidden !important;
            -webkit-overflow-scrolling: touch;
            padding-bottom: 80px !important;
        }

        /* ── Input base ── */
        .si { width:100%; padding:10px 14px; border:1px solid #e2e8f0; border-radius:10px; font-size:.88rem; font-family:inherit; transition:all .2s; background:#f8fafc; color:#0f172a; box-sizing:border-box; }
        .si:focus { outline:none; border-color:#2563eb; background:#fff; box-shadow:0 0 0 3px rgba(37,99,235,.1); }
        select.si { cursor:pointer; }
        textarea.si { resize:vertical; }
        .field-lbl { display:block; font-size:.78rem; font-weight:700; color:#475569; margin-bottom:5px; }

        /* ── Filtros sticky ── */
        .cli-filters-sticky {
            position: sticky;
            top: 0;
            z-index: 20;
            background: #f1f5f9;
            padding: 4px 0 12px;
            margin: 0 -4px;
            padding-left: 4px;
            padding-right: 4px;
        }

        /* ── Tabla ── */
        .cli-table-wrap {
            overflow: visible;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
            background: #fff;
            box-shadow: 0 2px 8px rgba(0,0,0,.04);
        }
        .cli-table-scroll {
            overflow-x: auto;
            overflow-y: visible;
            -webkit-overflow-scrolling: touch;
        }
        .cli-table { width:100%; border-collapse:collapse; }
        .cli-table thead th {
            position: sticky;
            top: 0;
            z-index: 10;
            background:#f8fafc;
            font-size:.73rem; font-weight:700; color:#475569;
            text-transform:uppercase; letter-spacing:.5px;
            padding:12px 14px; text-align:left;
            border-bottom:2px solid #e2e8f0; white-space:nowrap;
            box-shadow: 0 1px 0 #e2e8f0;
        }
        .cli-table td { padding:12px 14px; border-bottom:1px solid #f1f5f9; font-size:.85rem; color:#334155; vertical-align:middle; }
        .cli-table tbody tr.cli-row:hover td { background:#f8fafc; }
        .cli-table tbody tr.cli-row.expanded td { background:#eff6ff; border-bottom-color:transparent; }
        .cli-table tbody tr.cli-row { cursor:pointer; }

        /* ── Expand panel ── */
        .cli-expand { background:#f0f7ff; }
        .cli-expand td { padding:0 !important; border-bottom:2px solid #bfdbfe !important; }
        .cli-expand-inner {
            padding:16px 18px 20px;
            display:flex;
            flex-direction:column;
            gap:14px;
            max-width:100%;
        }
        .cli-expand-section {
            background:#fff;
            border-radius:12px;
            border:1px solid #e2e8f0;
            padding:16px 18px;
        }
        .cli-expand-grid {
            display:grid;
            grid-template-columns: 1.4fr 1fr;
            gap:14px;
            align-items:start;
        }
        .section-label { font-size:.72rem; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:.5px; margin:0 0 10px; display:flex; align-items:center; gap:6px; }
        .cli-form-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
        .cli-form-field { display:flex; flex-direction:column; gap:4px; }
        .cli-form-field.full { grid-column:1/-1; }
        .badge-proyecto { display:inline-flex; align-items:center; gap:5px; background:#eff6ff; color:#1e40af; border:1px solid #bfdbfe; border-radius:20px; padding:3px 10px; font-size:.73rem; font-weight:600; }
        .badge-contado { background:#f0fdf4; color:#166534; border:1px solid #86efac; }
        .badge-credito  { background:#eff6ff; color:#1e40af; border:1px solid #bfdbfe; }
        .rut-wrap { position:relative; }
        .rut-icon { position:absolute; right:10px; top:50%; transform:translateY(-50%); font-size:.88rem; pointer-events:none; }
        .no-results { text-align:center; padding:48px 20px; color:#94a3b8; }
        .no-results i { font-size:2.5rem; display:block; margin-bottom:10px; }

        .cli-side-stack { display:flex; flex-direction:column; gap:12px; }
        .cli-parcela-item {
            display:flex; justify-content:space-between; align-items:center; gap:10px;
            background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; padding:10px 12px;
        }
        .cli-chevron { color:#94a3b8; transition:transform .2s; display:inline-block; }

        /* Modal */
        .cm-overlay { position:fixed; inset:0; background:rgba(15,23,42,.7); backdrop-filter:blur(6px); display:flex; align-items:flex-start; justify-content:center; padding-top:5vh; z-index:1000; opacity:0; pointer-events:none; transition:.3s; overflow-y:auto; }
        .cm-overlay.show { opacity:1; pointer-events:auto; }
        .cm-card { background:#fff; width:100%; max-width:620px; border-radius:16px; box-shadow:0 25px 50px -12px rgba(0,0,0,.4); max-height:90vh; display:flex; flex-direction:column; transform:translateY(20px); transition:transform .3s; overflow:hidden; margin-bottom:5vh; }
        .cm-overlay.show .cm-card { transform:translateY(0); }
        .cm-header { padding:18px 22px; border-bottom:1px solid #f1f5f9; display:flex; justify-content:space-between; align-items:center; flex-shrink:0; }
        .cm-header h3 { margin:0; font-size:1.1rem; font-weight:700; color:#0f172a; }
        .cm-body { flex-grow:1; overflow-y:auto; padding:20px 22px; -webkit-overflow-scrolling:touch; }
        .cm-footer { padding:14px 22px; border-top:1px solid #f1f5f9; display:flex; justify-content:flex-end; gap:10px; flex-shrink:0; }

        @media(max-width:900px){
            .cli-expand-grid { grid-template-columns:1fr; }
        }
        @media(max-width:640px){
            .cli-form-grid { grid-template-columns:1fr; }
            .cli-table th:nth-child(3), .cli-table td:nth-child(3),
            .cli-table th:nth-child(4), .cli-table td:nth-child(4) { display:none; }
        }
    </style>
</head>
<body class="dashboard-body">
    <%- include('../partials/alerts') %>

    <!-- Toast -->
    <div id="im-toast" style="position:fixed;top:20px;right:20px;z-index:9999;pointer-events:none;opacity:0;transform:translateX(30px);transition:all .3s ease;max-width:400px;">
        <div id="im-toast-inner" style="padding:13px 16px;border-radius:12px;box-shadow:0 8px 30px rgba(0,0,0,.15);display:flex;align-items:flex-start;gap:10px;"></div>
    </div>

    <!-- Modal Nuevo Cliente -->
    <div id="modal-nuevo-cliente" class="cm-overlay">
        <div class="cm-card">
            <div class="cm-header">
                <h3><i class="bi bi-person-plus-fill" style="color:#2563eb;"></i> Nuevo Cliente</h3>
                <button onclick="closeNuevo()" style="background:none;border:none;color:#64748b;cursor:pointer;font-size:1.2rem;"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="cm-body">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">

                    <div class="cli-form-field full">
                        <label class="field-lbl">Nombre Completo <span style="color:#ef4444;">*</span></label>
                        <input type="text" id="nc-nombre" class="si" placeholder="Nombre y apellidos">
                    </div>

                    <div class="cli-form-field">
                        <label class="field-lbl">RUT <span style="color:#ef4444;">*</span></label>
                        <div class="rut-wrap">
                            <input type="text" id="nc-rut" class="si" placeholder="12.345.678-9"
                                oninput="autoFmtRut(this,'nc-rut-ic')" style="padding-right:36px;">
                            <span id="nc-rut-ic" class="rut-icon"></span>
                        </div>
                    </div>

                    <div class="cli-form-field">
                        <label class="field-lbl">Teléfono</label>
                        <input type="tel" id="nc-tel" class="si" placeholder="+56 9 1234 5678" oninput="autoFmtTel(this)">
                    </div>

                    <div class="cli-form-field full">
                        <label class="field-lbl">Correo Electrónico</label>
                        <input type="email" id="nc-email" class="si" placeholder="correo@ejemplo.cl">
                    </div>

                    <div class="cli-form-field full">
                        <label class="field-lbl">Dirección</label>
                        <textarea id="nc-direccion" class="si" rows="2" placeholder="Calle, número, ciudad, región"></textarea>
                    </div>

                    <div class="cli-form-field">
                        <label class="field-lbl">Estado Civil</label>
                        <select id="nc-civil" class="si" onchange="toggleNcConyuge(this.value)">
                            <option value="Soltero/a">Soltero/a</option>
                            <option value="Casado/a">Casado/a</option>
                            <option value="Divorciado/a">Divorciado/a</option>
                            <option value="Viudo/a">Viudo/a</option>
                            <option value="Conviviente Civil">Conviviente Civil</option>
                        </select>
                    </div>
                    <div class="cli-form-field" id="nc-regimen-box" style="display:none;">
                        <label class="field-lbl">Régimen Matrimonial</label>
                        <select id="nc-regimen" class="si">
                            <option value="Sociedad Conyugal">Sociedad Conyugal</option>
                            <option value="Separación de Bienes">Separación de Bienes</option>
                            <option value="Participación en los Gananciales">Participación en los Gananciales</option>
                        </select>
                    </div>
                </div>

                <!-- Cónyuge / Conviviente -->
                <div id="nc-conyuge-box" style="display:none;margin-top:14px;background:#faf5ff;border:1px solid #e9d5ff;border-radius:10px;padding:14px;">
                    <p style="font-size:.78rem;font-weight:700;color:#7c3aed;margin:0 0 10px;"><i class="bi bi-people-fill"></i> Cónyuge / Conviviente Civil</p>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                        <div class="cli-form-field">
                            <label class="field-lbl">Nombre Cónyuge</label>
                            <input type="text" id="nc-con-nombre" class="si" placeholder="Nombre y apellidos">
                        </div>
                        <div class="cli-form-field">
                            <label class="field-lbl">RUT Cónyuge</label>
                            <div class="rut-wrap">
                                <input type="text" id="nc-con-rut" class="si" placeholder="12.345.678-9"
                                    oninput="autoFmtRut(this,'nc-con-rut-ic')" style="padding-right:36px;">
                                <span id="nc-con-rut-ic" class="rut-icon"></span>
                            </div>
                        </div>
                        <div class="cli-form-field">
                            <label class="field-lbl">Email Cónyuge <span style="color:#94a3b8;font-weight:400;">(opcional)</span></label>
                            <input type="email" id="nc-con-email" class="si" placeholder="email@ejemplo.cl">
                        </div>
                        <div class="cli-form-field">
                            <label class="field-lbl">Teléfono Cónyuge <span style="color:#94a3b8;font-weight:400;">(opcional)</span></label>
                            <input type="tel" id="nc-con-tel" class="si" placeholder="+56 9 1234 5678" oninput="autoFmtTel(this)">
                        </div>
                    </div>
                </div>
            </div>
            <div class="cm-footer">
                <button class="im-btn im-btn-ghost" onclick="closeNuevo()">Cancelar</button>
                <button class="im-btn im-btn-success" onclick="crearCliente()"><i class="bi bi-person-check-fill"></i> Crear Cliente</button>
            </div>
        </div>
    </div>

    <div class="app-layout">
        <%- include('../partials/sidebar-admin', { page: 'clientes-im' }) %>

        <main class="main-content">
            <div class="dashboard-scroll">

                <!-- Breadcrumb -->
                <div style="display:flex;align-items:center;gap:8px;margin-top:16px;margin-bottom:16px;font-size:.85rem;color:#64748b;">
                    <a href="/admin/inmobiliaria" style="color:#2563eb;text-decoration:none;font-weight:600;"><i class="bi bi-arrow-left"></i> Gestión de Campos</a>
                    <span>›</span><b style="color:#0f172a;">Clientes</b>
                </div>

                <!-- Header -->
                <div class="im-page-header" style="margin-top:0;margin-bottom:20px;">
                    <div>
                        <h1 style="font-size:1.5rem;">Clientes Inmobiliarios</h1>
                        <p style="color:#64748b;font-size:.85rem;margin:4px 0 0;">Todos los compradores registrados en el sistema.</p>
                    </div>
                    <div style="display:flex;align-items:center;gap:12px;">
                        <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:10px;padding:10px 18px;text-align:center;">
                            <span id="total-count" style="font-size:1.5rem;font-weight:800;color:#2563eb;">—</span>
                            <span style="display:block;font-size:.73rem;color:#64748b;font-weight:600;">clientes</span>
                        </div>
                        <button class="im-btn im-btn-success" onclick="openNuevo()">
                            <i class="bi bi-person-plus-fill"></i> Nuevo Cliente
                        </button>
                    </div>
                </div>

                <!-- Filtros (sticky) -->
                <div class="cli-filters-sticky">
                    <div class="im-panel" style="margin-bottom:0;padding:14px 18px;">
                        <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
                            <div style="flex:1;min-width:220px;position:relative;">
                                <i class="bi bi-search" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#94a3b8;pointer-events:none;"></i>
                                <input type="text" id="filter-q" class="si" style="padding-left:36px;" placeholder="Buscar por nombre, RUT o email...">
                            </div>
                            <div style="min-width:200px;">
                                <select id="filter-proyecto" class="si">
                                    <option value="">Todos los proyectos</option>
                                </select>
                            </div>
                            <button class="im-btn im-btn-ghost" onclick="clearFilters()">
                                <i class="bi bi-x-circle"></i> Limpiar
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Tabla -->
                <div class="cli-table-wrap">
                    <div class="cli-table-scroll">
                        <table class="cli-table">
                            <thead>
                                <tr>
                                    <th>Nombre Completo</th>
                                    <th>RUT</th>
                                    <th>Contacto</th>
                                    <th>Estado Civil</th>
                                    <th>Proyecto / Parcela</th>
                                    <th style="width:40px;"></th>
                                </tr>
                            </thead>
                            <tbody id="clientes-tbody">
                                <tr><td colspan="6" class="no-results"><i class="bi bi-hourglass-split"></i>Cargando...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </main>
    </div>

<script>
const IS_ADMIN = '<%= user && user.role === "admin" ? "true" : "false" %>' === 'true';

// ── Toast ──
function showToast(msg,type='success',title=''){
    const t=document.getElementById('im-toast'),i=document.getElementById('im-toast-inner');
    const cfg={success:{bg:'#dcfce7',c:'#166534',b:'#86efac',ic:'bi-check-circle-fill',d:'Éxito'},error:{bg:'#fee2e2',c:'#991b1b',b:'#fca5a5',ic:'bi-exclamation-triangle-fill',d:'Error'},warning:{bg:'#fef3c7',c:'#92400e',b:'#fde68a',ic:'bi-exclamation-circle-fill',d:'Atención'},info:{bg:'#eff6ff',c:'#1e40af',b:'#bfdbfe',ic:'bi-info-circle-fill',d:'Info'}};
    const s=cfg[type]||cfg.info;
    i.style.cssText=`background:${s.bg};color:${s.c};border:1.5px solid ${s.b};padding:13px 16px;border-radius:12px;box-shadow:0 8px 30px rgba(0,0,0,.12);display:flex;align-items:flex-start;gap:10px;`;
    i.innerHTML=`<i class="bi ${s.ic}" style="font-size:1.1rem;flex-shrink:0;margin-top:1px;"></i><div><div style="font-weight:700;font-size:.86rem;">${title||s.d}</div><div style="font-size:.8rem;margin-top:2px;opacity:.9;">${escH(msg)}</div></div>`;
    t.style.opacity='1';t.style.transform='translateX(0)';t.style.pointerEvents='auto';
    clearTimeout(t._t);t._t=setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(30px)';t.style.pointerEvents='none';},5000);
}
function escH(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
const $=id=>document.getElementById(id);

// ── RUT helpers ──
function autoFmtRut(input,statusId){
    let v=input.value.replace(/[^0-9kK]/g,'').toUpperCase().slice(0,9);
    if(v.length>1)v=v.slice(0,-1).replace(/\B(?=(\d{3})+(?!\d))/g,'.')+'-'+v.slice(-1);
    input.value=v;
    const el=$(statusId);if(!el)return;
    if(v.length<3){el.textContent='';input.style.borderColor='';return;}
    const ok=validarRut(v);el.textContent=ok?'✅':'❌';
    input.style.borderColor=ok?'#10b981':(v.length>4?'#ef4444':'');
}
function validarRut(rut){
    const c=rut.replace(/[^0-9kK]/g,'').toUpperCase();if(c.length<2)return false;
    const body=c.slice(0,-1),dv=c.slice(-1);let s=0,m=2;
    for(let i=body.length-1;i>=0;i--){s+=parseInt(body[i],10)*m;m=m>=7?2:m+1;}
    const r=11-(s%11);return dv===(r===11?'0':r===10?'K':String(r));
}
function autoFmtTel(input){
    const raw=input.value.replace(/[^\d]/g,'').slice(0,11);
    let f='';
    if(raw.length>0)f='+'+raw.slice(0,2);
    if(raw.length>2)f+=' '+raw.slice(2,3);
    if(raw.length>3)f+=' '+raw.slice(3,7);
    if(raw.length>7)f+=' '+raw.slice(7,11);
    input.value=f;
}

// ── Modal Nuevo Cliente ──
function openNuevo(){
    ['nc-nombre','nc-rut','nc-tel','nc-email','nc-direccion','nc-con-nombre','nc-con-rut','nc-con-email','nc-con-tel'].forEach(id=>{const el=$(id);if(el)el.value='';});
    $('nc-civil').value='Soltero/a';
    $('nc-conyuge-box').style.display='none';
    $('modal-nuevo-cliente').classList.add('show');
    setTimeout(()=>$('nc-nombre').focus(),150);
}
function closeNuevo(){$('modal-nuevo-cliente').classList.remove('show');}
function toggleNcConyuge(val){
    $('nc-conyuge-box').style.display=(val==='Casado/a'||val==='Conviviente Civil')?'block':'none';
    const rb=$('nc-regimen-box');if(rb)rb.style.display=(val==='Casado/a')?'flex':'none';
}

async function crearCliente(){
    const nombre=$('nc-nombre').value.trim();
    const rut=$('nc-rut').value.trim();
    if(!nombre||!rut){showToast('Nombre y RUT son obligatorios.','warning');return;}
    if(!validarRut(rut)){showToast('El RUT no es válido (Módulo 11).','error','RUT inválido');return;}
    const btn=document.querySelector('#modal-nuevo-cliente .cm-footer button:last-child');
    btn.disabled=true;btn.innerHTML='<i class="bi bi-hourglass-split"></i> Guardando...';
    try{
        const ncCivil=$('nc-civil').value;
        const body={
            nombre_completo:nombre, rut,
            email:$('nc-email').value||null,
            telefono:$('nc-tel').value||null,
            direccion:$('nc-direccion').value||null,
            estado_civil:ncCivil,
            regimen_matrimonial:(ncCivil==='Casado/a'&&$('nc-regimen'))?$('nc-regimen').value:null,
            nombre_conyugue:$('nc-con-nombre').value||null,
            rut_conyugue:$('nc-con-rut').value||null,
            email_conyugue:$('nc-con-email').value||null,
            telefono_conyugue:$('nc-con-tel').value||null
        };
        const res=await fetch('/api/im/clientes',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
        const data=await res.json().catch(()=>({}));
        if(!res.ok){
            if(res.status===409&&data.cliente){
                throw new Error(`Ya existe un cliente con ese RUT: ${data.cliente.nombre_completo}. Búscalo en la lista en lugar de crear uno nuevo.`);
            }
            throw new Error(data.message||data.error||`No se pudo crear el cliente (HTTP ${res.status}).`);
        }
        closeNuevo();
        showToast(`Cliente "${nombre}" creado correctamente.`,'success');
        loadClientes();
    }catch(e){showToast(e.message,'error','No se pudo crear');}
    finally{btn.disabled=false;btn.innerHTML='<i class="bi bi-person-check-fill"></i> Crear Cliente';}
}

// Cerrar modal al clickear fuera
$('modal-nuevo-cliente').addEventListener('click',e=>{if(e.target===$('modal-nuevo-cliente'))closeNuevo();});

// ── Datos ──
let allClientes=[], expandedRow=null, proyectos=[];

async function loadProyectos(){
    try{
        const res=await fetch('/api/im/proyectos');if(!res.ok)return;
        proyectos=await res.json();
        const sel=$('filter-proyecto');
        proyectos.forEach(p=>{const opt=document.createElement('option');opt.value=p.id;opt.textContent=p.nombre;sel.appendChild(opt);});
    }catch(_){}
}

async function loadClientes(){
    const tbody=$('clientes-tbody');
    tbody.innerHTML='<tr><td colspan="6" class="no-results"><i class="bi bi-hourglass-split"></i>Cargando...</td></tr>';
    const q=$('filter-q').value.trim(),proj=$('filter-proyecto').value;
    let url='/api/im/clientes?';
    if(q)url+=`q=${encodeURIComponent(q)}&`;
    if(proj)url+=`proyecto_id=${encodeURIComponent(proj)}&`;
    try{
        const res=await fetch(url);
        if(!res.ok){const eb=await res.json().catch(()=>({}));throw new Error(eb.message||eb.error||`No se pudieron cargar los clientes (HTTP ${res.status}). Intenta recargar la página.`);}
        allClientes=await res.json();
        $('total-count').textContent=allClientes.length;
        renderTable(allClientes);
    }catch(e){tbody.innerHTML=`<tr><td colspan="6" class="no-results" style="color:#ef4444;"><i class="bi bi-exclamation-triangle"></i>${escH(e.message)}</td></tr>`;}
}

function clearFilters(){$('filter-q').value='';$('filter-proyecto').value='';loadClientes();}

function renderTable(list){
    const tbody=$('clientes-tbody');
    if(list.length===0){tbody.innerHTML='<tr><td colspan="6" class="no-results"><i class="bi bi-people"></i><br>No se encontraron clientes con esos filtros.<br><button class="im-btn im-btn-primary" style="margin-top:12px;" onclick="openNuevo()"><i class="bi bi-person-plus-fill"></i> Crear primer cliente</button></td></tr>';return;}
    tbody.innerHTML=list.map((c,idx)=>{
        const ventas=c.ventas||[];
        const parcelas=ventas.map(v=>`<span class="badge-proyecto" style="margin:2px;"><i class="bi bi-geo-alt"></i>${escH(v.proyecto_nombre)} · P${escH(v.numero_parcela||v.parcela_numero||'?')}</span>`).join('');
        const totalC=parseInt(c.total_compras)||0;
        return `
        <tr id="row-${c.id}" class="cli-row" onclick="toggleExpand(event,'${c.id}',${idx})">
            <td>
                <strong>${escH(c.nombre_completo)}</strong>
                ${totalC>0?`<span style="margin-left:6px;background:#eff6ff;color:#2563eb;border:1px solid #bfdbfe;border-radius:20px;padding:1px 8px;font-size:.7rem;font-weight:700;">${totalC} parcela${totalC!==1?'s':''}</span>`:''}
            </td>
            <td><span style="font-family:monospace;font-size:.82rem;background:#f1f5f9;padding:2px 8px;border-radius:5px;">${escH(c.rut)}</span></td>
            <td>
                ${c.email?`<div style="font-size:.8rem;"><i class="bi bi-envelope" style="color:#64748b;"></i> ${escH(c.email)}</div>`:''}
                ${c.telefono?`<div style="font-size:.8rem;"><i class="bi bi-telephone" style="color:#64748b;"></i> ${escH(c.telefono)}</div>`:''}
                ${!c.email&&!c.telefono?'<span style="color:#94a3b8;font-size:.8rem;">—</span>':''}
            </td>
            <td>${escH(c.estado_civil)||'—'}</td>
            <td>${ventas.length>0?`<div style="display:flex;flex-wrap:wrap;gap:2px;">${parcelas}</div>`:'<span style="color:#94a3b8;font-size:.8rem;">Sin asignar</span>'}</td>
            <td style="text-align:center;"><i class="bi bi-chevron-down cli-chevron" id="chevron-${c.id}"></i></td>
        </tr>
        <tr class="cli-expand" id="expand-${c.id}" style="display:none;"><td colspan="6"><div class="cli-expand-inner" id="expand-inner-${c.id}"></div></td></tr>`;
    }).join('');
}

function getScrollRoot(){
    return document.querySelector('.dashboard-scroll')||document.documentElement;
}

function cerrarExpand(id){
    const row=$(`expand-${id}`),chev=$(`chevron-${id}`),mainRow=$(`row-${id}`);
    if(row)row.style.display='none';
    if(chev)chev.style.transform='';
    if(mainRow)mainRow.classList.remove('expanded');
    if(expandedRow===id)expandedRow=null;
}

function toggleExpand(event,id,idx){
    // No colapsar/abrir si se clickea un control interactivo dentro del expand
    if(event&&event.target){
        const t=event.target;
        if(t.closest('a,button,input,select,textarea,label,form'))return;
    }
    const row=$(`expand-${id}`),chev=$(`chevron-${id}`),mainRow=$(`row-${id}`),isOpen=row.style.display!=='none';
    if(expandedRow&&expandedRow!==id){
        const prev=$(`expand-${expandedRow}`);if(prev)prev.style.display='none';
        const oc=$(`chevron-${expandedRow}`);if(oc)oc.style.transform='';
        const or=$(`row-${expandedRow}`);if(or)or.classList.remove('expanded');
    }
    if(isOpen){
        row.style.display='none';
        if(chev)chev.style.transform='';
        mainRow.classList.remove('expanded');
        expandedRow=null;
    }else{
        row.style.display='table-row';
        if(chev)chev.style.transform='rotate(180deg)';
        mainRow.classList.add('expanded');
        expandedRow=id;
        renderExpand(id,allClientes[idx]);
        // Scroll suave para ver el panel expandido completo
        requestAnimationFrame(()=>{
            setTimeout(()=>{
                const target=$(`expand-inner-${id}`)||row;
                const root=getScrollRoot();
                const rect=target.getBoundingClientRect();
                const rootRect=root.getBoundingClientRect?root.getBoundingClientRect():{top:0};
                const offset=rect.top-rootRect.top+root.scrollTop-80;
                root.scrollTo({top:Math.max(0,offset),behavior:'smooth'});
            },60);
        });
    }
}

function renderExpand(id,c){
    const el=$(`expand-inner-${id}`);
    if(!el||!c)return;
    const tieneC=c.estado_civil==='Casado/a'||c.estado_civil==='Conviviente Civil';
    const ventas=c.ventas||[];

    el.innerHTML=`
    <div class="cli-expand-grid" onclick="event.stopPropagation()">
        <!-- Datos del cliente -->
        <div class="cli-expand-section">
            <p class="section-label"><i class="bi bi-person-fill"></i> Datos del Cliente</p>
            <form onsubmit="saveCliente(event,'${c.id}')">
                <div class="cli-form-grid">
                    <div class="cli-form-field full">
                        <label class="field-lbl">Nombre Completo</label>
                        <input type="text" id="ec-nombre-${id}" class="si" value="${escH(c.nombre_completo)}" required>
                    </div>
                    <div class="cli-form-field">
                        <label class="field-lbl">RUT</label>
                        <div class="rut-wrap">
                            <input type="text" id="ec-rut-${id}" class="si" value="${escH(c.rut)}"
                                oninput="autoFmtRut(this,'ec-rut-ic-${id}')" style="padding-right:36px;">
                            <span id="ec-rut-ic-${id}" class="rut-icon">${validarRut(c.rut)?'✅':''}</span>
                        </div>
                    </div>
                    <div class="cli-form-field">
                        <label class="field-lbl">Teléfono</label>
                        <input type="tel" id="ec-tel-${id}" class="si" value="${escH(c.telefono||'')}" oninput="autoFmtTel(this)">
                    </div>
                    <div class="cli-form-field full">
                        <label class="field-lbl">Correo Electrónico</label>
                        <input type="email" id="ec-email-${id}" class="si" value="${escH(c.email||'')}">
                    </div>
                    <div class="cli-form-field full">
                        <label class="field-lbl">Dirección</label>
                        <textarea id="ec-dir-${id}" class="si" rows="2">${escH(c.direccion||'')}</textarea>
                    </div>
                    <div class="cli-form-field">
                        <label class="field-lbl">Estado Civil</label>
                        <select id="ec-civil-${id}" class="si" onchange="toggleConyugeExpand('${id}',this.value)">
                            ${['Soltero/a','Casado/a','Divorciado/a','Viudo/a','Conviviente Civil'].map(op=>`<option value="${op}" ${c.estado_civil===op?'selected':''}>${op}</option>`).join('')}
                        </select>
                    </div>
                    <div class="cli-form-field" id="ec-regimen-box-${id}" style="display:${c.estado_civil==='Casado/a'?'flex':'none'};">
                        <label class="field-lbl">Régimen Matrimonial</label>
                        <select id="ec-regimen-${id}" class="si">
                            ${['Sociedad Conyugal','Separación de Bienes','Participación en los Gananciales'].map(op=>`<option value="${op}" ${c.regimen_matrimonial===op?'selected':''}>${op}</option>`).join('')}
                        </select>
                    </div>
                </div>

                <div id="ec-conyuge-${id}" style="display:${tieneC?'block':'none'};margin-top:14px;background:#faf5ff;border:1px solid #e9d5ff;border-radius:10px;padding:14px;">
                    <p class="section-label" style="color:#7c3aed;"><i class="bi bi-people-fill"></i> Cónyuge / Conviviente Civil</p>
                    <div class="cli-form-grid">
                        <div class="cli-form-field">
                            <label class="field-lbl">Nombre</label>
                            <input type="text" id="ec-con-nombre-${id}" class="si" value="${escH(c.nombre_conyugue||'')}">
                        </div>
                        <div class="cli-form-field">
                            <label class="field-lbl">RUT</label>
                            <div class="rut-wrap">
                                <input type="text" id="ec-con-rut-${id}" class="si" value="${escH(c.rut_conyugue||'')}"
                                    oninput="autoFmtRut(this,'ec-con-rut-ic-${id}')" style="padding-right:36px;">
                                <span id="ec-con-rut-ic-${id}" class="rut-icon">${c.rut_conyugue&&validarRut(c.rut_conyugue)?'✅':''}</span>
                            </div>
                        </div>
                        <div class="cli-form-field">
                            <label class="field-lbl">Email <span style="color:#94a3b8;font-weight:400;">(opcional)</span></label>
                            <input type="email" id="ec-con-email-${id}" class="si" value="${escH(c.email_conyugue||'')}">
                        </div>
                        <div class="cli-form-field">
                            <label class="field-lbl">Teléfono <span style="color:#94a3b8;font-weight:400;">(opcional)</span></label>
                            <input type="tel" id="ec-con-tel-${id}" class="si" value="${escH(c.telefono_conyugue||'')}" oninput="autoFmtTel(this)">
                        </div>
                    </div>
                </div>

                <div style="margin-top:14px;display:flex;gap:8px;flex-wrap:wrap;">
                    <button type="submit" class="im-btn im-btn-success"><i class="bi bi-save"></i> Guardar Cambios</button>
                    <button type="button" class="im-btn im-btn-ghost" onclick="cerrarExpand('${id}')"><i class="bi bi-chevron-up"></i> Cerrar</button>
                </div>
            </form>
        </div>

        <!-- Lateral: parcelas + documentos + auditoría -->
        <div class="cli-side-stack">
            <div class="cli-expand-section">
                <p class="section-label"><i class="bi bi-geo-alt-fill"></i> Parcelas Adquiridas (${ventas.length})</p>
                ${ventas.length>0?`
                <div style="display:flex;flex-direction:column;gap:8px;max-height:320px;overflow-y:auto;">
                    ${ventas.map(v=>{
                        const tb=v.tipo_pago==='credito'?`<span class="badge-credito badge-proyecto">Crédito</span>`:`<span class="badge-contado badge-proyecto">Contado</span>`;
                        return `<div class="cli-parcela-item">
                            <div style="min-width:0;">
                                <div style="font-weight:700;color:#0f172a;">${escH(v.proyecto_nombre)} <span style="color:#64748b;font-weight:500;font-size:.82rem;">· P${escH(v.numero_parcela||v.parcela_numero||'?')}</span> ${estadoVentaBadge(v)}</div>
                                <div style="margin-top:4px;display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
                                    ${tb}
                                    ${v.precio_acordado?`<span style="font-size:.78rem;color:#475569;">$${Math.floor(parseFloat(v.precio_acordado)).toLocaleString('es-CL')}</span>`:''}
                                    ${v.fecha_venta?`<span style="font-size:.72rem;color:#94a3b8;"><i class="bi bi-calendar3"></i> ${new Date(v.fecha_venta).toLocaleDateString('es-CL',{day:'2-digit',month:'short',year:'numeric'})}</span>`:''}
                                </div>
                            </div>
                            <a href="/admin/inmobiliaria/parcela/${v.parcela_id}" class="im-btn im-btn-sm im-btn-ghost" onclick="event.stopPropagation()"><i class="bi bi-arrow-up-right"></i> Ver</a>
                        </div>`;
                    }).join('')}
                </div>`:`<p style="margin:0;font-size:.84rem;color:#94a3b8;">Sin parcelas asignadas todavía.</p>`}
            </div>

            <!-- Documentos del cliente -->
            <div class="cli-expand-section">
                <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:10px;">
                    <p class="section-label" style="margin:0;"><i class="bi bi-folder2-open"></i> Documentos del Cliente</p>
                    <label class="im-btn im-btn-sm im-btn-primary" style="cursor:pointer;margin:0;">
                        <i class="bi bi-upload"></i> Subir
                        <input type="file" style="display:none;" onchange="uploadClienteDoc('${c.id}',this)" onclick="event.stopPropagation()">
                    </label>
                </div>
                <div id="docs-cli-${id}" style="display:flex;flex-direction:column;gap:6px;max-height:240px;overflow-y:auto;font-size:.82rem;color:#64748b;">Cargando documentos...</div>
            </div>

            <div class="cli-expand-section">
                <p class="section-label"><i class="bi bi-clock-history"></i> Actividad Reciente</p>
                <div id="audit-cli-${id}" style="font-size:.8rem;color:#64748b;max-height:220px;overflow-y:auto;">Cargando...</div>
            </div>
        </div>
    </div>`;

    loadClienteDocs(c.id);

    fetch(`/api/im/auditoria?entidad_id=${c.id}`)
        .then(r=>r.json()).then(logs=>{
            const el2=$(`audit-cli-${id}`);if(!el2)return;
            if(!logs||logs.length===0){el2.textContent='Sin actividad registrada.';return;}
            el2.innerHTML=logs.slice(0,8).map(l=>`<div style="padding:6px 0;border-bottom:1px solid #f1f5f9;">
                <span style="font-weight:700;color:#334155;">${escH(l.accion)}</span>
                ${l.descripcion?` — ${escH(l.descripcion)}`:''}
                <span style="color:#94a3b8;font-size:.72rem;display:block;">${new Date(l.fecha).toLocaleString('es-CL',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'})} · ${escH(l.usuario_nombre||'Sistema')}</span>
            </div>`).join('');
        }).catch(()=>{const el2=$(`audit-cli-${id}`);if(el2)el2.textContent='No se pudo cargar la actividad.';});
}

// ── Estado de una compra (para la previsualización) ──
function estadoVentaBadge(v){
    const st=(s,bg,c,b)=>`<span style="font-size:.66rem;font-weight:700;padding:2px 8px;border-radius:999px;background:${bg};color:${c};border:1px solid ${b};">${s}</span>`;
    if(v.estado==='resciliada') return st('Resciliada','#fee2e2','#991b1b','#fca5a5');
    if(v.estado==='liberada')   return st('Liberada','#f1f5f9','#64748b','#e2e8f0');
    if(v.firmo_compraventa||v.estado_venta==='vendido') return st('Vendida','#dcfce7','#166534','#86efac');
    if(v.firmo_promesa||v.estado_venta==='reservado')   return st('Reservada','#fef3c7','#92400e','#fde68a');
    return st('Vigente','#dcfce7','#166534','#86efac');
}

// ── Documentos del cliente (tipo_asociacion = persona) ──
async function loadClienteDocs(clienteId){
    const cont=$(`docs-cli-${clienteId}`);
    if(!cont)return;
    try{
        const res=await fetch(`/api/im/documentos?tipo_asociacion=persona&asociacion_id=${encodeURIComponent(clienteId)}`);
        if(!res.ok)throw new Error(`HTTP ${res.status}`);
        const docs=await res.json();
        if(!docs||docs.length===0){cont.innerHTML='<p style="margin:0;color:#94a3b8;">Aún no hay documentos. Usa “Subir” para agregar cédula, contrato u otros.</p>';return;}
        cont.innerHTML=docs.map(d=>`
            <div style="display:flex;align-items:center;gap:8px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:8px 10px;">
                <i class="bi bi-file-earmark-text" style="color:#2563eb;font-size:1rem;flex-shrink:0;"></i>
                <span style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#0f172a;font-weight:600;">${escH(d.nombre_personalizado||'Documento')}</span>
                <a href="${escH(d.url_storage||'#')}" target="_blank" title="Ver / descargar" class="im-btn im-btn-sm im-btn-ghost" onclick="event.stopPropagation()"><i class="bi bi-eye"></i></a>
                <button title="Eliminar" class="im-btn im-btn-sm im-btn-ghost" style="color:#ef4444;" onclick="event.stopPropagation();deleteClienteDoc('${d.id}','${clienteId}')"><i class="bi bi-trash"></i></button>
            </div>`).join('');
    }catch(e){cont.innerHTML='<p style="margin:0;color:#ef4444;">No se pudieron cargar los documentos.</p>';}
}

async function uploadClienteDoc(clienteId,input){
    const file=input.files&&input.files[0];
    if(!file)return;
    const cont=$(`docs-cli-${clienteId}`);
    if(cont)cont.innerHTML='<p style="margin:0;color:#64748b;"><i class="bi bi-hourglass-split"></i> Subiendo documento...</p>';
    try{
        const fd=new FormData();
        fd.append('archivo',file,file.name);
        fd.append('tipo_asociacion','persona');
        fd.append('asociacion_id',clienteId);
        fd.append('nombre_personalizado',file.name.replace(/\.[^/.]+$/,''));
        const res=await fetch('/api/im/documentos',{method:'POST',body:fd});
        if(!res.ok){const e=await res.json().catch(()=>({}));throw new Error(e.message||`No se pudo subir (HTTP ${res.status}).`);}
        showToast('Documento subido correctamente.','success');
    }catch(e){showToast(e.message,'error','No se pudo subir');}
    finally{input.value='';loadClienteDocs(clienteId);}
}

async function deleteClienteDoc(docId,clienteId){
    if(!confirm('¿Eliminar este documento? Esta acción no se puede deshacer.'))return;
    try{
        const res=await fetch(`/api/im/documentos/${docId}`,{method:'DELETE'});
        if(!res.ok&&res.status!==204){const e=await res.json().catch(()=>({}));throw new Error(e.message||`No se pudo eliminar (HTTP ${res.status}).`);}
        showToast('Documento eliminado.','success');
    }catch(e){showToast(e.message,'error','No se pudo eliminar');}
    finally{loadClienteDocs(clienteId);}
}

function toggleConyugeExpand(id,val){
    const el=$(`ec-conyuge-${id}`);
    if(el)el.style.display=(val==='Casado/a'||val==='Conviviente Civil')?'block':'none';
    const rb=$(`ec-regimen-box-${id}`);
    if(rb)rb.style.display=(val==='Casado/a')?'flex':'none';
}

async function saveCliente(event,clienteId){
    event.preventDefault();
    const btn=event.submitter||event.target.querySelector('[type="submit"]');
    if(btn){btn.disabled=true;btn.innerHTML='<i class="bi bi-hourglass-split"></i> Guardando...';}
    try{
        const id=clienteId;
        const rut=$(`ec-rut-${id}`).value;
        if(!validarRut(rut)){showToast('RUT inválido (Módulo 11).','error','RUT inválido');return;}
        const ecCivil=$(`ec-civil-${id}`).value;
        const body={
            nombre_completo:$(`ec-nombre-${id}`).value,
            rut,
            email:$(`ec-email-${id}`).value||null,
            telefono:$(`ec-tel-${id}`).value||null,
            direccion:$(`ec-dir-${id}`).value||null,
            estado_civil:ecCivil,
            regimen_matrimonial:(ecCivil==='Casado/a'&&$(`ec-regimen-${id}`))?$(`ec-regimen-${id}`).value:null,
            nombre_conyugue:$(`ec-con-nombre-${id}`).value||null,
            rut_conyugue:$(`ec-con-rut-${id}`).value||null,
            email_conyugue:$(`ec-con-email-${id}`).value||null,
            telefono_conyugue:$(`ec-con-tel-${id}`).value||null
        };
        const res=await fetch(`/api/im/clientes/${clienteId}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
        if(!res.ok){const e=await res.json().catch(()=>({}));throw new Error(e.message||`No se pudo actualizar el cliente (HTTP ${res.status}). Verifica los campos y vuelve a intentar.`);}
        showToast('Cliente actualizado correctamente.','success');
        loadClientes();
    }catch(e){showToast(e.message,'error','No se pudo guardar');}
    finally{if(btn){btn.disabled=false;btn.innerHTML='<i class="bi bi-save"></i> Guardar Cambios';}}
}

// ── Búsqueda en tiempo real ──
let searchTimeout;
$('filter-q').addEventListener('input',()=>{clearTimeout(searchTimeout);searchTimeout=setTimeout(loadClientes,350);});
$('filter-proyecto').addEventListener('change',loadClientes);

document.addEventListener('DOMContentLoaded',async()=>{await loadProyectos();loadClientes();});
</script>
