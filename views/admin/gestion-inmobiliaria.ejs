<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/inmobiliaria.css">
</head>
<body class="dashboard-body">
    <%- include('../partials/alerts') %>

    <!-- ====== TOAST NOTIFICATION ====== -->
    <div id="im-toast" style="position:fixed; top:20px; right:20px; z-index:9999; pointer-events:none; opacity:0; transform:translateX(30px); transition:all 0.3s ease;">
        <div id="im-toast-inner" style="padding:14px 18px; border-radius:12px; min-width:260px; max-width:420px; box-shadow:0 8px 30px rgba(0,0,0,0.15); display:flex; align-items:flex-start; gap:10px;">
            <i id="im-toast-icon" class="bi" style="font-size:1.15rem; flex-shrink:0; margin-top:1px;"></i>
            <div style="flex:1;">
                <div id="im-toast-title" style="font-weight:700; font-size:0.88rem;"></div>
                <div id="im-toast-msg" style="font-size:0.82rem; margin-top:2px; opacity:0.85;"></div>
            </div>
        </div>
    </div>

    <div class="app-layout">
        <%- include('../partials/sidebar-admin', { page: 'inmobiliaria' }) %>

        <main class="main-content">
            <div class="dashboard-scroll">

                <div class="im-page-header">
                    <div>
                        <h1><i class="bi bi-geo-alt-fill" style="color:#2563eb;"></i> Gestión de Campos</h1>
                        <p>Proyectos de venta de campos y parcelas · Cygnus Group</p>
                    </div>
                    <div style="display:flex; gap:10px; flex-wrap:wrap;">
                        <% if (user && user.role === 'admin') { %>
                        <button class="im-btn im-btn-ghost" onclick="openModal('accesos')" title="Gestionar accesos">
                            <i class="bi bi-person-gear"></i> Accesos
                        </button>
                        <% } %>
                        <% if (puedeCrear) { %>
                        <button class="im-btn im-btn-primary" onclick="openModalCreate()">
                            <i class="bi bi-plus-lg"></i> Generar Proyecto
                        </button>
                        <% } %>
                    </div>
                </div>

                <div class="im-legend">
                    <div class="im-legend-item"><div class="im-legend-dot disponible"></div> Disponible</div>
                    <div class="im-legend-item"><div class="im-legend-dot reservado"></div> Reservado</div>
                    <div class="im-legend-item"><div class="im-legend-dot vendido"></div> Vendido</div>
                </div>

                <div id="im-grid" class="im-projects-grid">
                    <div class="im-sk-proj"><div class="im-sk-proj-cover"></div><div class="im-sk-proj-body"><div class="im-sk im-sk-line" style="width:70%;height:16px;margin-bottom:10px;"></div><div class="im-sk im-sk-line" style="width:45%;height:12px;margin-bottom:14px;"></div><div style="display:flex;gap:8px;"><div class="im-sk im-sk-pill"></div><div class="im-sk im-sk-pill"></div><div class="im-sk im-sk-pill"></div></div></div></div>
                    <div class="im-sk-proj"><div class="im-sk-proj-cover"></div><div class="im-sk-proj-body"><div class="im-sk im-sk-line" style="width:70%;height:16px;margin-bottom:10px;"></div><div class="im-sk im-sk-line" style="width:45%;height:12px;margin-bottom:14px;"></div><div style="display:flex;gap:8px;"><div class="im-sk im-sk-pill"></div><div class="im-sk im-sk-pill"></div><div class="im-sk im-sk-pill"></div></div></div></div>
                    <div class="im-sk-proj"><div class="im-sk-proj-cover"></div><div class="im-sk-proj-body"><div class="im-sk im-sk-line" style="width:70%;height:16px;margin-bottom:10px;"></div><div class="im-sk im-sk-line" style="width:45%;height:12px;margin-bottom:14px;"></div><div style="display:flex;gap:8px;"><div class="im-sk im-sk-pill"></div><div class="im-sk im-sk-pill"></div><div class="im-sk im-sk-pill"></div></div></div></div>
                    <div class="im-sk-proj"><div class="im-sk-proj-cover"></div><div class="im-sk-proj-body"><div class="im-sk im-sk-line" style="width:70%;height:16px;margin-bottom:10px;"></div><div class="im-sk im-sk-line" style="width:45%;height:12px;margin-bottom:14px;"></div><div style="display:flex;gap:8px;"><div class="im-sk im-sk-pill"></div><div class="im-sk im-sk-pill"></div><div class="im-sk im-sk-pill"></div></div></div></div>
                    <div class="im-sk-proj"><div class="im-sk-proj-cover"></div><div class="im-sk-proj-body"><div class="im-sk im-sk-line" style="width:70%;height:16px;margin-bottom:10px;"></div><div class="im-sk im-sk-line" style="width:45%;height:12px;margin-bottom:14px;"></div><div style="display:flex;gap:8px;"><div class="im-sk im-sk-pill"></div><div class="im-sk im-sk-pill"></div><div class="im-sk im-sk-pill"></div></div></div></div>
                    <div class="im-sk-proj"><div class="im-sk-proj-cover"></div><div class="im-sk-proj-body"><div class="im-sk im-sk-line" style="width:70%;height:16px;margin-bottom:10px;"></div><div class="im-sk im-sk-line" style="width:45%;height:12px;margin-bottom:14px;"></div><div style="display:flex;gap:8px;"><div class="im-sk im-sk-pill"></div><div class="im-sk im-sk-pill"></div><div class="im-sk im-sk-pill"></div></div></div></div>
                </div>

            </div>
        </main>
    </div>

    <!-- ====== MODAL CREAR / EDITAR PROYECTO ====== -->
    <div id="modal-project" class="im-modal-overlay">
        <div class="im-modal-card">
            <div class="im-modal-header">
                <h3 id="modal-proj-title"><i class="bi bi-folder-plus"></i> Nuevo Proyecto</h3>
                <button class="btn-close" onclick="closeModal('project')"><i class="bi bi-x-lg"></i></button>
            </div>
            <form id="form-project" autocomplete="off">
                <input type="hidden" id="proj-id">
                <div class="im-modal-body">
                    <div class="im-input-group">
                        <label>Nombre del Proyecto <span style="color:#ef4444;">*</span></label>
                        <input type="text" id="proj-nombre" class="styled-input" placeholder="Ej: Fundo Los Robles" required>
                    </div>
                    <div class="im-form-row">
                        <div class="im-input-group">
                            <label>Tipo de Proyecto</label>
                            <select id="proj-tipo" class="styled-input">
                                <option value="en_verde">En Verde (sin rol propio aún)</option>
                                <option value="con_rol_propio">Con Rol Propio asignado</option>
                            </select>
                        </div>
                        <div class="im-input-group">
                            <label>Estado</label>
                            <select id="proj-estado" class="styled-input">
                                <option value="activo">Activo</option>
                                <option value="inactivo">Inactivo</option>
                                <option value="cerrado">Cerrado</option>
                            </select>
                        </div>
                    </div>
                    <div class="im-form-row">
                        <div class="im-input-group" id="grupo-total-parcelas">
                            <label>Total de Parcelas <span style="color:#94a3b8; font-weight:400;">(opcional)</span></label>
                            <input type="number" id="proj-total" class="styled-input" min="0" placeholder="Ej: 20">
                            <small style="color:#94a3b8; font-size:0.72rem;">Se auto-generarán al guardar</small>
                        </div>
                    </div>
                    <div class="im-form-row">
                        <div class="im-input-group">
                            <label>N° Rol 1 <span style="color:#94a3b8; font-weight:400;">(opcional)</span></label>
                            <input type="text" id="proj-rol1" class="styled-input" placeholder="Ej: 123-45">
                        </div>
                        <div class="im-input-group">
                            <label>N° Rol 2 <span style="color:#94a3b8; font-weight:400;">(opcional)</span></label>
                            <input type="text" id="proj-rol2" class="styled-input" placeholder="Ej: 678-90">
                        </div>
                    </div>
                    <div class="im-input-group">
                        <label>N° Matriz <span style="color:#94a3b8; font-weight:400;">(opcional)</span></label>
                        <input type="text" id="proj-matriz" class="styled-input" placeholder="Ej: 99-99">
                    </div>
                </div>
                <div class="im-modal-footer">
                    <button type="button" class="im-btn im-btn-ghost" onclick="closeModal('project')">Cancelar</button>
                    <button type="submit" class="im-btn im-btn-primary" id="btn-save-proj">
                        <i class="bi bi-check-lg"></i> Crear Proyecto
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- ====== MODAL PARCELAS DEL PROYECTO ====== -->
    <div id="modal-parcelas" class="im-modal-overlay">
        <div class="im-modal-card wide" style="max-width:860px;">
            <div class="im-modal-header">
                <div>
                    <h3 id="modal-parc-title"><i class="bi bi-grid-3x3-gap"></i> Parcelas</h3>
                    <p id="modal-parc-sub" style="margin:4px 0 0; font-size:0.8rem; color:#64748b;"></p>
                </div>
                <div style="display:flex; gap:8px; align-items:center;">
                    <button class="btn-close" onclick="closeModal('parcelas')"><i class="bi bi-x-lg"></i></button>
                </div>
            </div>
            <div class="im-modal-body" style="padding:0;">
                <!-- Tabs dentro del modal de parcelas -->
                <div class="im-tabs-header" style="padding:0 22px; border-radius:0;">
                    <button class="im-tab-btn active" onclick="switchParcelasTab('lista', this)">
                        <i class="bi bi-grid-3x3-gap"></i> Parcelas
                    </button>
                    <button class="im-tab-btn" onclick="switchParcelasTab('docs', this)">
                        <i class="bi bi-folder2"></i> Docs del Proyecto
                    </button>
                    <% if (puedeCrear) { %>
                    <button class="im-tab-btn" onclick="switchParcelasTab('agregar', this)">
                        <i class="bi bi-plus-circle"></i> Agregar Parcela
                    </button>
                    <% } %>
                </div>

                <!-- Tab: Lista de parcelas -->
                <div id="tab-parc-lista" class="im-tab-content active" style="padding:20px 22px;">
                    <div id="parc-stats" style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom:16px;"></div>
                    <div id="parcelas-grid-modal" class="im-parcelas-grid">
                        <div class="im-sk-parcela"><div class="im-sk im-sk-line" style="width:40%;height:12px;margin:0 auto 8px;"></div><div class="im-sk im-sk-line" style="width:60%;height:10px;margin:0 auto;"></div></div>
                        <div class="im-sk-parcela"><div class="im-sk im-sk-line" style="width:40%;height:12px;margin:0 auto 8px;"></div><div class="im-sk im-sk-line" style="width:60%;height:10px;margin:0 auto;"></div></div>
                        <div class="im-sk-parcela"><div class="im-sk im-sk-line" style="width:40%;height:12px;margin:0 auto 8px;"></div><div class="im-sk im-sk-line" style="width:60%;height:10px;margin:0 auto;"></div></div>
                        <div class="im-sk-parcela"><div class="im-sk im-sk-line" style="width:40%;height:12px;margin:0 auto 8px;"></div><div class="im-sk im-sk-line" style="width:60%;height:10px;margin:0 auto;"></div></div>
                        <div class="im-sk-parcela"><div class="im-sk im-sk-line" style="width:40%;height:12px;margin:0 auto 8px;"></div><div class="im-sk im-sk-line" style="width:60%;height:10px;margin:0 auto;"></div></div>
                        <div class="im-sk-parcela"><div class="im-sk im-sk-line" style="width:40%;height:12px;margin:0 auto 8px;"></div><div class="im-sk im-sk-line" style="width:60%;height:10px;margin:0 auto;"></div></div>
                    </div>
                </div>

                <!-- Tab: Documentos del proyecto -->
                <div id="tab-parc-docs" class="im-tab-content" style="padding:20px 22px;">
                    <div id="proj-doc-uploader" style="margin-bottom:16px;"></div>
                    <div id="proj-doc-list" class="im-doc-list"></div>
                </div>

                <!-- Tab: Agregar parcela individual -->
                <div id="tab-parc-agregar" class="im-tab-content" style="padding:20px 22px;">
                    <p style="font-size:0.82rem; color:#64748b; margin:0 0 14px;">
                        <i class="bi bi-info-circle"></i> Agrega una parcela específica con todos sus datos, o un rango de una sola vez.
                    </p>
                    <form id="form-add-individual">
                        <div class="im-form-row" style="align-items:end;">
                            <div class="im-input-group">
                                <label>Número de Parcela <span style="color:#ef4444;">*</span></label>
                                <input type="text" id="ind-numero" class="styled-input" placeholder="Ej: 5 ó 1-A" required
                                    maxlength="20" oninput="this.value=this.value.toUpperCase()">
                                <small style="color:#94a3b8;font-size:.72rem;">Puede ser numérico (5) o alfanumérico (1-A)</small>
                                <div id="ind-numero-warn" style="display:none;color:#f59e0b;font-size:.75rem;margin-top:2px;">
                                    <i class="bi bi-exclamation-triangle-fill"></i> <span></span>
                                </div>
                            </div>
                            <div class="im-input-group">
                                <label>N° Rol Parcela <span style="color:#94a3b8; font-weight:400;">(opcional)</span></label>
                                <input type="text" id="ind-rol" class="styled-input" placeholder="Ej: 123-45-05">
                            </div>
                        </div>
                        <div class="im-form-row">
                            <div class="im-input-group">
                                <label>Metraje (m²) <span style="color:#94a3b8; font-weight:400;">(opcional)</span></label>
                                <input type="number" id="ind-metraje" class="styled-input" step="0.01" placeholder="Ej: 5000">
                            </div>
                            <div class="im-input-group">
                                <label>Precio (CLP) <span style="color:#94a3b8; font-weight:400;">(opcional)</span></label>
                                <input type="text" id="ind-precio" class="styled-input" placeholder="Ej: 25.000.000" oninput="fmtPrecio(this)">
                            </div>
                        </div>
                        <button type="submit" class="im-btn im-btn-primary" style="margin-top:4px;">
                            <i class="bi bi-plus-circle"></i> Agregar Esta Parcela
                        </button>
                    </form>
                    <div style="height:1px; background:#e2e8f0; margin:20px 0;"></div>
                    <p style="font-size:0.82rem; font-weight:700; color:#334155; margin:0 0 10px;">O generar un rango</p>
                    <form id="form-add-rango">
                        <div class="im-form-row" style="align-items:end;">
                            <div class="im-input-group">
                                <label>Desde N°</label>
                                <input type="number" id="rango-desde" class="styled-input" min="1" placeholder="Ej: 1">
                            </div>
                            <div class="im-input-group">
                                <label>Hasta N°</label>
                                <input type="number" id="rango-hasta" class="styled-input" min="1" placeholder="Ej: 20">
                            </div>
                            <div style="padding-bottom:14px;">
                                <button type="submit" class="im-btn im-btn-ghost">
                                    <i class="bi bi-stack"></i> Generar Rango
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- ====== MODAL ACCESOS ====== -->
    <div id="modal-accesos" class="im-modal-overlay">
        <div class="im-modal-card wide">
            <div class="im-modal-header">
                <h3><i class="bi bi-person-gear"></i> Gestión de Accesos al Módulo</h3>
                <button class="btn-close" onclick="closeModal('accesos')"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="im-modal-body">
                <p style="font-size:0.85rem; color:#64748b; margin:0 0 16px;">
                    Selecciona qué usuarios del equipo pueden acceder al módulo de Gestión de Campos. 
                    Activa "Puede crear" para permitirles generar proyectos y parcelas.
                </p>
                <div id="accesos-list">
                    <div class="im-sk-list">
                        <div class="im-sk-list-row"><div class="im-sk im-sk-avatar"></div><div style="flex:1;"><div class="im-sk im-sk-line" style="width:50%;height:12px;margin-bottom:6px;"></div><div class="im-sk im-sk-line" style="width:35%;height:10px;"></div></div><div class="im-sk im-sk-pill"></div></div>
                        <div class="im-sk-list-row"><div class="im-sk im-sk-avatar"></div><div style="flex:1;"><div class="im-sk im-sk-line" style="width:55%;height:12px;margin-bottom:6px;"></div><div class="im-sk im-sk-line" style="width:40%;height:10px;"></div></div><div class="im-sk im-sk-pill"></div></div>
                        <div class="im-sk-list-row"><div class="im-sk im-sk-avatar"></div><div style="flex:1;"><div class="im-sk im-sk-line" style="width:45%;height:12px;margin-bottom:6px;"></div><div class="im-sk im-sk-line" style="width:30%;height:10px;"></div></div><div class="im-sk im-sk-pill"></div></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ====== MODAL CONFIRMAR ELIMINACIÓN ====== -->
    <div id="modal-delete" class="im-modal-overlay">
        <div class="im-modal-card" style="max-width:420px;">
            <div class="im-modal-header">
                <h3><i class="bi bi-exclamation-triangle" style="color:#ef4444;"></i> Eliminar Proyecto</h3>
                <button class="btn-close" onclick="closeModal('delete')"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="im-modal-body" style="text-align:center; padding:30px 22px;">
                <i class="bi bi-trash3-fill" style="font-size:3rem; color:#ef4444; display:block; margin-bottom:12px;"></i>
                <p style="font-size:1rem; font-weight:700; color:#0f172a; margin-bottom:6px;" id="del-proj-name"></p>
                <p style="font-size:0.85rem; color:#64748b;">Esta acción eliminará el proyecto y todas sus parcelas. No se puede deshacer.</p>
                <input type="hidden" id="del-proj-id">
            </div>
            <div class="im-modal-footer">
                <button class="im-btn im-btn-ghost" onclick="closeModal('delete')">Cancelar</button>
                <button class="im-btn im-btn-danger" onclick="confirmarEliminar()">
                    <i class="bi bi-trash3"></i> Eliminar
                </button>
            </div>
        </div>
    </div>

    <script>
        const IS_ADMIN = '<%= user && user.role === "admin" ? "true" : "false" %>' === 'true';
        const PUEDE_CREAR = '<%= puedeCrear ? "true" : "false" %>' === 'true';
        let proyectosData = [];
        let currentProyectoId = null;
        let currentProyectoNombre = '';

        // ---- Toast ----
        function showToast(msg, type = 'success', title = '') {
            const toast = document.getElementById('im-toast');
            const inner = document.getElementById('im-toast-inner');
            const icon  = document.getElementById('im-toast-icon');
            const titleEl = document.getElementById('im-toast-title');
            const msgEl = document.getElementById('im-toast-msg');

            const cfg = {
                success: { bg: '#dcfce7', color: '#166534', border: '#86efac', icon: 'bi-check-circle-fill', def: 'Éxito' },
                error:   { bg: '#fee2e2', color: '#991b1b', border: '#fca5a5', icon: 'bi-exclamation-triangle-fill', def: 'Error' },
                warning: { bg: '#fef3c7', color: '#92400e', border: '#fde68a', icon: 'bi-exclamation-circle-fill', def: 'Atención' },
                info:    { bg: '#eff6ff', color: '#1e40af', border: '#bfdbfe', icon: 'bi-info-circle-fill', def: 'Info' }
            };
            const s = cfg[type] || cfg.info;
            inner.style.cssText = `background:${s.bg}; color:${s.color}; border:1.5px solid ${s.border}; padding:14px 18px; border-radius:12px; box-shadow:0 8px 30px rgba(0,0,0,0.12); display:flex; align-items:flex-start; gap:10px; min-width:260px; max-width:420px;`;
            icon.className = `bi ${s.icon}`;
            icon.style.cssText = `font-size:1.1rem; flex-shrink:0; margin-top:1px;`;
            titleEl.style.cssText = `font-weight:700; font-size:0.88rem;`;
            msgEl.style.cssText = `font-size:0.82rem; margin-top:2px; opacity:0.9; word-break:break-word;`;
            titleEl.textContent = title || s.def;
            msgEl.textContent = msg;

            toast.style.opacity = '1';
            toast.style.transform = 'translateX(0)';
            toast.style.pointerEvents = 'auto';

            clearTimeout(toast._timer);
            toast._timer = setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(30px)';
                toast.style.pointerEvents = 'none';
            }, 5000);
        }

        // ---- Helpers ----
        function fmt(n) { return Math.floor(n).toLocaleString('es-CL'); }
        function escapeHtml(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
        function closeModal(id) { document.getElementById(`modal-${id}`).classList.remove('show'); }
        function fmtPrecio(input) { input.value = input.value.replace(/\D/g,'').replace(/\B(?=(\d{3})+(?!\d))/g,'.'); }

        function openModal(id) {
            const el = document.getElementById(`modal-${id}`);
            if (!el) return;
            el.classList.add('show');
            if (id === 'accesos') setTimeout(loadAccesos, 60);
            if (id === 'parcelas') projDocsInit = false;
        }

        function switchParcelasTab(name, btn) {
            document.querySelectorAll('#modal-parcelas .im-tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('#modal-parcelas .im-tab-content').forEach(c => c.classList.remove('active'));
            if (btn) btn.classList.add('active');
            document.getElementById(`tab-parc-${name}`).classList.add('active');

            if (name === 'docs' && currentProyectoId) {
                initProjDocs(currentProyectoId);
            }
        }

        // ---- Cargar proyectos ----
        async function loadProyectos() {
            const grid = document.getElementById('im-grid');
            grid.innerHTML = (window.IMSkeleton && IMSkeleton.projectCards(6)) || '<div class="im-sk-proj"><div class="im-sk-proj-cover"></div><div class="im-sk-proj-body"><div class="im-sk im-sk-line" style="width:70%;height:16px;"></div></div></div>';
            try {
                const res = await fetch('/api/im/proyectos');
                if (!res.ok) {
                    const err = await res.json().catch(() => ({ error: `HTTP ${res.status}` }));
                    throw new Error(err.error || err.message || `Error HTTP ${res.status}`);
                }
                proyectosData = await res.json();
                renderGrid();
            } catch (e) {
                grid.innerHTML = `<div style="grid-column:1/-1;">
                    <div style="background:#fee2e2; border:1px solid #fca5a5; border-radius:12px; padding:24px; text-align:center; color:#991b1b; max-width:600px; margin:0 auto;">
                        <i class="bi bi-exclamation-triangle-fill" style="font-size:2rem; display:block; margin-bottom:8px;"></i>
                        <p style="font-weight:700; margin:0 0 6px;">Error al cargar proyectos</p>
                        <p style="font-size:0.85rem; opacity:0.85; margin:0 0 12px;">${escapeHtml(e.message)}</p>
                        <button class="im-btn im-btn-danger" onclick="loadProyectos()"><i class="bi bi-arrow-clockwise"></i> Reintentar</button>
                    </div>
                </div>`;
            }
        }

