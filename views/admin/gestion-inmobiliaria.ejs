        // ---- Crear proyecto ----
        function openModalCreate() {
            document.getElementById('form-project').reset();
            document.getElementById('proj-id').value = '';
            document.getElementById('modal-proj-title').innerHTML = '<i class="bi bi-folder-plus"></i> Nuevo Proyecto';
            document.getElementById('btn-save-proj').innerHTML = '<i class="bi bi-check-lg"></i> Crear Proyecto';
            document.getElementById('grupo-total-parcelas').style.display = 'block';
            openModal('project');
        }

        // ---- Editar proyecto ----
        function openModalEdit(p) {
            document.getElementById('proj-id').value = p.id;
            document.getElementById('proj-nombre').value = p.nombre;
            document.getElementById('proj-tipo').value  = p.tipo_proyecto || 'en_verde';
            document.getElementById('proj-estado').value = p.estado;
            document.getElementById('proj-rol1').value = p.numero_rol_1 || '';
            document.getElementById('proj-rol2').value = p.numero_rol_2 || '';
            document.getElementById('proj-matriz').value = p.numero_matriz || '';
            document.getElementById('modal-proj-title').innerHTML = '<i class="bi bi-pencil-fill"></i> Editar Proyecto';
            document.getElementById('btn-save-proj').innerHTML = '<i class="bi bi-check-lg"></i> Guardar Cambios';
            document.getElementById('grupo-total-parcelas').style.display = 'none';
            openModal('project');
        }

        document.getElementById('form-project').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('btn-save-proj');
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Guardando...';
            try {
                const id = document.getElementById('proj-id').value;
                const totalStr = document.getElementById('proj-total').value;
                const body = {
                    nombre:         document.getElementById('proj-nombre').value.trim(),
                    tipo_proyecto:  document.getElementById('proj-tipo').value,
                    estado:         document.getElementById('proj-estado').value,
                    total_parcelas: totalStr ? parseInt(totalStr, 10) : 0,
                    numero_rol_1:   document.getElementById('proj-rol1').value.trim() || null,
                    numero_rol_2:   document.getElementById('proj-rol2').value.trim() || null,
                    numero_matriz:  document.getElementById('proj-matriz').value.trim() || null
                };
                const url    = id ? `/api/im/proyectos/${id}` : '/api/im/proyectos';
                const method = id ? 'PUT' : 'POST';
                const res = await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
                if (!res.ok) {
                    const err = await res.json().catch(() => ({ error: `HTTP ${res.status}` }));
                    throw new Error(err.message || err.error || `Error ${res.status}`);
                }
                closeModal('project');
                showToast(id ? 'Proyecto actualizado correctamente.' : 'Proyecto creado correctamente.', 'success');
                loadProyectos();
            } catch (err) {
                showToast(err.message, 'error', 'No se pudo guardar');
            } finally {
                btn.disabled = false;
                btn.innerHTML = document.getElementById('proj-id').value ? '<i class="bi bi-check-lg"></i> Guardar Cambios' : '<i class="bi bi-check-lg"></i> Crear Proyecto';
            }
        });

        // ---- Eliminar proyecto ----
        function prepareDelete(id, nombre) {
            document.getElementById('del-proj-id').value = id;
            document.getElementById('del-proj-name').textContent = nombre;
            openModal('delete');
        }

        async function confirmarEliminar() {
            const id = document.getElementById('del-proj-id').value;
            try {
                const res = await fetch(`/api/im/proyectos/${id}`, { method: 'DELETE' });
                if (!res.ok) {
                    const err = await res.json().catch(() => ({}));
                    throw new Error(err.message || `Error ${res.status}`);
                }
                closeModal('delete');
                showToast('Proyecto eliminado.', 'success');
                loadProyectos();
            } catch (err) {
                showToast(err.message, 'error', 'No se pudo eliminar');
            }
        }

        // ---- Abrir parcelas ----
        async function abrirParcelas(proyectoId, nombre) {
            currentProyectoId = proyectoId;
            currentProyectoNombre = nombre;
            document.getElementById('modal-parc-title').innerHTML = `<i class="bi bi-grid-3x3-gap"></i> ${escapeHtml(nombre)}`;
            document.getElementById('modal-parc-sub').textContent = '';
            document.getElementById('parcelas-grid-modal').innerHTML = (window.IMSkeleton && IMSkeleton.parcelas(12)) || '<div class="im-sk im-sk-block"></div>';
            document.getElementById('parc-stats').innerHTML = '';

            // Reset tabs
            document.querySelectorAll('#modal-parcelas .im-tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('#modal-parcelas .im-tab-content').forEach(c => c.classList.remove('active'));
            document.querySelector('#modal-parcelas .im-tab-btn').classList.add('active');
            document.getElementById('tab-parc-lista').classList.add('active');

            openModal('parcelas');
            await loadParcelasModal(proyectoId);
        }

        async function loadParcelasModal(proyectoId) {
            try {
                const res = await fetch(`/api/im/proyectos/${proyectoId}/parcelas`);
                if (!res.ok) throw new Error(`No se pudieron cargar las parcelas (HTTP ${res.status}). Intenta recargar.`);
                const parcelas = await res.json();
                renderParcelasModal(parcelas);
            } catch (e) {
                document.getElementById('parcelas-grid-modal').innerHTML = `<div class="im-empty" style="color:#ef4444;"><i class="bi bi-exclamation-triangle"></i><p>${escapeHtml(e.message)}</p></div>`;
            }
        }

        function renderParcelasModal(parcelas) {
            const grid = document.getElementById('parcelas-grid-modal');
            const stats = document.getElementById('parc-stats');
            const disp  = parcelas.filter(p => p.estado_venta === 'disponible').length;
            const res2  = parcelas.filter(p => p.estado_venta === 'reservado').length;
            const vend  = parcelas.filter(p => p.estado_venta === 'vendido').length;

            stats.innerHTML = `
                <span style="background:#dcfce7; color:#166534; padding:4px 12px; border-radius:20px; font-size:0.78rem; font-weight:700;">${disp} Disponibles</span>
                <span style="background:#fef3c7; color:#92400e; padding:4px 12px; border-radius:20px; font-size:0.78rem; font-weight:700;">${res2} Reservadas</span>
                <span style="background:#fee2e2; color:#991b1b; padding:4px 12px; border-radius:20px; font-size:0.78rem; font-weight:700;">${vend} Vendidas</span>
                <span style="background:#f1f5f9; color:#475569; padding:4px 12px; border-radius:20px; font-size:0.78rem; font-weight:700;">${parcelas.length} Total</span>`;

            if (parcelas.length === 0) {
                grid.innerHTML = `<div class="im-empty" style="grid-column:1/-1;">
                    <i class="bi bi-inbox"></i>
                    <p>No hay parcelas. ${PUEDE_CREAR ? 'Ve a la pestaña <strong>Agregar Parcela</strong>.' : ''}</p>
                </div>`;
                return;
            }
            grid.innerHTML = '';
            parcelas.forEach(p => {
                const chip = document.createElement('a');
                chip.href  = `/admin/inmobiliaria/parcela/${p.id}`;
                chip.className = `im-parcela-chip estado-${p.estado_venta}`;
                chip.innerHTML = `
                    <span class="im-parcela-num">${p.numero_parcela}</span>
                    ${p.numero_rol_parcela ? `<span class="im-parcela-rol">${escapeHtml(p.numero_rol_parcela)}</span>` : ''}
                    ${p.precio_actual ? `<span class="im-parcela-precio">$${fmt(p.precio_actual)}</span>` : ''}
                    ${p.cliente_nombre ? `<span style="font-size:0.63rem; color:#64748b; text-align:center; margin-top:2px;">${escapeHtml(p.cliente_nombre.split(' ')[0])}</span>` : ''}`;
                grid.appendChild(chip);
            });
        }

        // ---- Agregar parcela individual ----
        document.getElementById('form-add-individual').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = e.submitter || e.target.querySelector('[type="submit"]');
            const numStr = document.getElementById('ind-numero').value.trim().toUpperCase();
            if (!numStr) { showToast('Ingresa un número de parcela.', 'error'); return; }

            // Verificar duplicado en las parcelas ya cargadas del proyecto
            const existentes = document.querySelectorAll('#parcelas-grid-modal .im-parcela-num');
            const duplicado = Array.from(existentes).some(el => el.textContent.trim().toUpperCase() === numStr);
            if (duplicado) {
                const w = document.getElementById('ind-numero-warn');
                if (w) { w.style.display='flex'; w.style.alignItems='center'; w.style.gap='4px'; w.querySelector('span').textContent=`La parcela "${numStr}" ya existe en este proyecto.`; }
                showToast(`La parcela "${numStr}" ya existe en este proyecto.`, 'warning'); return;
            }
            document.getElementById('ind-numero-warn').style.display = 'none';

            if (btn) { btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Guardando...'; }
            try {
                const precioRaw = document.getElementById('ind-precio').value.replace(/\./g, '');
                const body = {
                    proyecto_id: currentProyectoId,
                    numero_parcela: numStr,
                    numero_rol_parcela: document.getElementById('ind-rol').value.trim() || null,
                    metraje: document.getElementById('ind-metraje').value || null,
                    precio_actual: precioRaw || null
                };
                const res = await fetch('/api/im/parcelas', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
                if (!res.ok) { const err = await res.json().catch(()=>({})); throw new Error(err.message || `Error ${res.status}`); }
                document.getElementById('form-add-individual').reset();
                document.getElementById('ind-numero-warn').style.display = 'none';
                showToast(`Parcela "${numStr}" creada.`, 'success');
                await loadParcelasModal(currentProyectoId);
                loadProyectos();
            } catch (err) {
                showToast(err.message, 'error', 'No se pudo crear la parcela');
            } finally {
                if (btn) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-plus-circle"></i> Agregar Esta Parcela'; }
            }
        });

        // ---- Agregar rango de parcelas ----
        document.getElementById('form-add-rango').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = e.submitter || e.target.querySelector('[type="submit"]');
            if (btn) { btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i>...'; }
            try {
                const body = {
                    proyecto_id: currentProyectoId,
                    desde: parseInt(document.getElementById('rango-desde').value, 10),
                    hasta: parseInt(document.getElementById('rango-hasta').value, 10)
                };
                if (isNaN(body.desde) || isNaN(body.hasta)) throw new Error('Ingresa valores numéricos.');
                if (body.desde > body.hasta) throw new Error('El inicio debe ser menor al fin.');
                const res = await fetch('/api/im/parcelas/bulk', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
                if (!res.ok) { const err = await res.json().catch(()=>({})); throw new Error(err.message || `Error ${res.status}`); }
                const data = await res.json();
                document.getElementById('form-add-rango').reset();
                showToast(data.message || 'Parcelas creadas.', 'success');
                await loadParcelasModal(currentProyectoId);
                loadProyectos();
            } catch (err) {
                showToast(err.message, 'error', 'No se pudo crear el rango');
            } finally {
                if (btn) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-stack"></i> Generar Rango'; }
            }
        });

        // ---- Documentos del Proyecto ----
        function buildUploaderHtml(tipo, asociacionId) {
            return `
            <div style="background:#f8fafc; border:1px solid #e2e8f0; border-radius:12px; padding:16px; margin-bottom:14px;">
                <p style="font-size:0.78rem; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.4px; margin:0 0 12px;">
                    <i class="bi bi-cloud-upload"></i> Subir Documento
                </p>
                <form id="doc-form-${tipo}-${asociacionId}" enctype="multipart/form-data">
                    <div class="im-input-group">
                        <label>Nombre del Documento <span style="color:#ef4444;">*</span></label>
                        <input type="text" name="nombre_personalizado" class="styled-input" placeholder="Ej: Escritura de propiedad, Plano..." required>
                    </div>
                    <div class="im-upload-zone" id="zone-${tipo}">
                        <input type="file" name="archivo" accept="image/*,.pdf,.doc,.docx,.xls,.xlsx" multiple
                            onchange="(function(inp){const n=inp.files.length;const el=document.getElementById('fname-${tipo}');if(!el)return;if(!n){el.style.display='none';el.textContent='';return;}el.style.display='block';el.textContent=n===1?(inp.files[0].name):(n+' archivos seleccionados');})(this)">
                        <i class="bi bi-cloud-arrow-up im-upload-icon"></i>
                        <p class="im-upload-text">Arrastra archivos o haz clic aquí</p>
                        <p class="im-upload-hint">Varios a la vez · imágenes máx. 20 MB · PDF/docs máx. 100 MB</p>
                        <span id="fname-${tipo}" style="display:none; margin-top:4px; font-size:0.78rem; font-weight:700; color:#2563eb;"></span>
                    </div>
                    <button type="submit" class="im-btn im-btn-primary im-btn-full" style="margin-top:12px;">
                        <i class="bi bi-upload"></i> Subir Documento
                    </button>
                </form>
            </div>`;
        }

        let projDocsInit = false;
        async function initProjDocs(proyectoId) {
            const uploader = document.getElementById('proj-doc-uploader');
            const list = document.getElementById('proj-doc-list');

            if (!projDocsInit) {
                uploader.innerHTML = buildUploaderHtml('proyecto', proyectoId);
                document.getElementById(`doc-form-proyecto-${proyectoId}`).addEventListener('submit', (e) => handleDocSubmit(e, 'proyecto', proyectoId));
                projDocsInit = true;
            }
            await loadDocs('proyecto', proyectoId, list);
        }

        async function handleDocSubmit(e, tipo, asociacionId) {
            e.preventDefault();
            const form = e.target;
            const btn = form.querySelector('[type="submit"]');
            const fileInput = form.querySelector('input[type="file"]');
            const files = Array.from(fileInput?.files || []);
            if (!files.length) { showToast('Selecciona al menos un archivo.', 'error'); return; }
            if (window.IMUpload) {
                const errs = IMUpload.validateFiles(files);
                if (errs.length) { showToast(errs.join(' · '), 'error', 'Archivo demasiado pesado'); return; }
            }
            const nombreBase = (form.querySelector('[name="nombre_personalizado"]')?.value || '').trim();
            if (btn) { btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Subiendo...'; }
            try {
                let ok = 0;
                for (let i = 0; i < files.length; i++) {
                    const f = files[i];
                    const fd = new FormData();
                    fd.append('archivo', f, f.name);
                    fd.append('tipo_asociacion', tipo);
                    fd.append('asociacion_id', asociacionId);
                    const nombre = files.length === 1
                        ? (nombreBase || f.name.replace(/\.[^/.]+$/, ''))
                        : ((nombreBase ? nombreBase + ' — ' : '') + f.name.replace(/\.[^/.]+$/, ''));
                    fd.append('nombre_personalizado', nombre);
                    const res = await fetch('/api/im/documentos', { method: 'POST', body: fd });
                    if (!res.ok) {
                        const msg = window.IMUpload
                            ? await IMUpload.readErrorMessage(res, `Error ${res.status}`)
                            : ((await res.json().catch(()=>({}))).message || `Error ${res.status}`);
                        throw new Error(msg);
                    }
                    ok++;
                }
                form.reset();
                const fnameEl = document.getElementById(`fname-${tipo}`);
                if (fnameEl) { fnameEl.textContent = ''; fnameEl.style.display = 'none'; }
                showToast(ok === 1 ? 'Documento subido correctamente.' : `${ok} documentos subidos.`, 'success');
                const listEl = tipo === 'proyecto' ? document.getElementById('proj-doc-list') : null;
                if (listEl) loadDocs(tipo, asociacionId, listEl);
            } catch (err) {
                showToast(err.message, 'error', 'Error al subir documento');
            } finally {
                if (btn) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-upload"></i> Subir Documento'; }
            }
        }

        async function loadDocs(tipo, asociacionId, container) {
            if (!container) return;
            container.innerHTML = (window.IMSkeleton && IMSkeleton.docs(3)) || '<div class="im-sk im-sk-line" style="height:40px;"></div>';
            try {
                const res = await fetch(`/api/im/documentos?tipo_asociacion=${tipo}&asociacion_id=${asociacionId}`);
                if (!res.ok) throw new Error(`Error ${res.status}`);
                const docs = await res.json();

                if (docs.length === 0) {
                    container.innerHTML = '<div class="im-empty" style="padding:20px;"><i class="bi bi-folder2-open"></i><p>Sin documentos.</p></div>';
                    return;
                }
                container.innerHTML = docs.map(doc => {
                    const ext  = (doc.storage_path || '').split('.').pop().toLowerCase();
                    const icon = ['pdf'].includes(ext) ? 'bi-file-earmark-pdf' :
                                 ['jpg','jpeg','png','webp','gif'].includes(ext) ? 'bi-file-earmark-image' :
                                 ['doc','docx'].includes(ext) ? 'bi-file-earmark-word' : 'bi-file-earmark';
                    const fecha = new Date(doc.creado_at).toLocaleDateString('es-CL', { day:'2-digit', month:'short', year:'numeric' });
                    return `<div class="im-doc-item">
                        <i class="bi ${icon} im-doc-icon"></i>
                        <div class="im-doc-info">
                            <div class="im-doc-name">${escapeHtml(doc.nombre_personalizado)}</div>
                            <div class="im-doc-date">${fecha}</div>
                        </div>
                        <div class="im-doc-actions">
                            <a href="${escapeHtml(doc.url_storage)}" target="_blank" class="im-btn im-btn-sm im-btn-ghost" title="Ver">
                                <i class="bi bi-eye"></i>
                            </a>
                            ${(IS_ADMIN||PUEDE_CREAR) ? `<button class="im-btn im-btn-sm im-btn-danger" onclick="eliminarDoc(${doc.id}, '${tipo}', '${asociacionId}')"><i class="bi bi-trash3"></i></button>` : ''}
                        </div>
                    </div>`;
                }).join('');
            } catch (err) {
                container.innerHTML = `<div class="im-empty" style="color:#ef4444;"><i class="bi bi-exclamation-triangle"></i><p>${escapeHtml(err.message)}</p></div>`;
            }
        }

        async function eliminarDoc(id, tipo, asociacionId) {
            if (!confirm('¿Eliminar este documento? No se puede deshacer.')) return;
            try {
                const res = await fetch(`/api/im/documentos/${id}`, { method: 'DELETE' });
                if (!res.ok) throw new Error(`Error ${res.status}`);
                showToast('Documento eliminado.', 'success');
                const listEl = tipo === 'proyecto' ? document.getElementById('proj-doc-list') : null;
                if (listEl) loadDocs(tipo, asociacionId, listEl);
            } catch (e) { showToast(e.message, 'error'); }
        }

        // ---- Gestión de Accesos ----
        async function loadAccesos() {
            const list = document.getElementById('accesos-list');
            list.innerHTML = (window.IMSkeleton && IMSkeleton.listRows(5)) || '<div class="im-sk im-sk-block"></div>';
            try {
                const res = await fetch('/api/im/accesos');
                if (!res.ok) throw new Error(`Error ${res.status}`);
                const users = await res.json();

                if (users.length === 0) {
                    list.innerHTML = '<div class="im-empty"><i class="bi bi-people"></i><p>No hay usuarios en el equipo.</p></div>';
                    return;
                }

                list.innerHTML = `<div class="management-table" style="border-radius:12px; border:1px solid #e2e8f0; overflow:hidden;">
                    <table style="width:100%; border-collapse:collapse;">
                        <thead style="background:#f8fafc;">
                            <tr>
                                <th style="padding:12px 16px; text-align:left; font-size:0.75rem; color:#64748b; font-weight:700; text-transform:uppercase;">Usuario</th>
                                <th style="padding:12px 16px; text-align:center; font-size:0.75rem; color:#64748b; font-weight:700; text-transform:uppercase;">Ver Módulo</th>
                                <th style="padding:12px 16px; text-align:center; font-size:0.75rem; color:#64748b; font-weight:700; text-transform:uppercase;">Puede Crear</th>
                            </tr>
                        </thead>
                        <tbody id="accesos-tbody"></tbody>
                    </table>
                </div>`;

                const tbody = document.getElementById('accesos-tbody');
                users.forEach(u => {
                    if (u.role === 'admin') return; // Los admins siempre tienen acceso
                    const tr = document.createElement('tr');
                    tr.style.borderBottom = '1px solid #f1f5f9';
                    tr.innerHTML = `
                        <td style="padding:12px 16px;">
                            <span style="font-weight:600; color:#0f172a; font-size:0.88rem;">${escapeHtml(u.name)}</span>
                            <span style="display:block; font-size:0.75rem; color:#94a3b8;">${escapeHtml(u.email)}</span>
                        </td>
                        <td style="padding:12px 16px; text-align:center;">
                            <label style="position:relative; display:inline-flex; align-items:center; cursor:pointer; gap:6px;">
                                <input type="checkbox" id="ac-ver-${u.id}" ${u.tiene_acceso ? 'checked' : ''} 
                                    onchange="toggleAcceso('${u.id}', this.checked, document.getElementById('ac-crear-${u.id}').checked)"
                                    style="width:18px; height:18px; cursor:pointer; accent-color:#2563eb;">
                            </label>
                        </td>
                        <td style="padding:12px 16px; text-align:center;">
                            <label style="position:relative; display:inline-flex; align-items:center; cursor:pointer; gap:6px;">
                                <input type="checkbox" id="ac-crear-${u.id}" ${u.puede_crear ? 'checked' : ''} ${!u.tiene_acceso ? 'disabled' : ''}
                                    onchange="toggleAcceso('${u.id}', true, this.checked)"
                                    style="width:18px; height:18px; cursor:pointer; accent-color:#10b981;">
                            </label>
                        </td>`;
                    tbody.appendChild(tr);
                });
            } catch (e) {
                list.innerHTML = `<div class="im-empty" style="color:#ef4444;"><i class="bi bi-exclamation-triangle"></i><p>${escapeHtml(e.message)}</p></div>`;
            }
        }

        async function toggleAcceso(userId, tieneAcceso, puedeCrear) {
            const verEl   = document.getElementById(`ac-ver-${userId}`);
            const crearEl = document.getElementById(`ac-crear-${userId}`);
            try {
                if (tieneAcceso) {
                    await fetch('/api/im/accesos', {
                        method: 'POST',
                        headers: {'Content-Type':'application/json'},
                        body: JSON.stringify({ user_id: userId, puede_crear: puedeCrear })
                    });
                    if (crearEl) crearEl.disabled = false;
                    showToast('Acceso actualizado.', 'success');
                } else {
                    await fetch(`/api/im/accesos/${userId}`, { method: 'DELETE' });
                    if (crearEl) { crearEl.checked = false; crearEl.disabled = true; }
                    showToast('Acceso revocado.', 'info');
                }
            } catch (e) {
                showToast(e.message, 'error');
                if (verEl) verEl.checked = !tieneAcceso;
            }
        }

        // (openModal ya unificado arriba)

        // ---- Init ----
        document.addEventListener('DOMContentLoaded', loadProyectos);
    </script>
</body>
</html>
