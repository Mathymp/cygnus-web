function showStitchOverlay(visible) {
    const ov = document.getElementById('stitchOverlay');
    if (visible) ov.classList.add('visible');
    else ov.classList.remove('visible');
}

function setStitchProgress(pct, text, sub) {
    document.getElementById('stitchBar').style.width  = pct + '%';
    document.getElementById('stitchText').textContent = text;
    document.getElementById('stitchSub').textContent  = sub || '';
}

// =============================================================
//  FILTROS CSS — GPU, 60fps
// =============================================================
function applyFilters() {
    if (!threeRenderer) return;
    const cv = threeRenderer.domElement;
    const brightness = Math.pow(2, filters.exposure / 100).toFixed(3);
    const contrast   = Math.max(0, 1 + filters.contrast   / 100).toFixed(3);
    const saturate   = Math.max(0, 1 + filters.saturation / 100).toFixed(3);

    let f = `brightness(${brightness}) contrast(${contrast}) saturate(${saturate})`;

    if (filters.temperature > 0)
        f += ` sepia(${(filters.temperature*0.25).toFixed(1)}%) hue-rotate(-${(filters.temperature*0.2).toFixed(1)}deg)`;
    else if (filters.temperature < 0)
        f += ` hue-rotate(${(Math.abs(filters.temperature)*0.3).toFixed(1)}deg)`;

    if (filters.sharpness < 0)
        f += ` blur(${(Math.abs(filters.sharpness)*0.04).toFixed(2)}px)`;
    else if (filters.sharpness > 0)
        f += ` contrast(${(1 + filters.sharpness*0.006).toFixed(3)})`;

    cv.style.filter = f;

    let vig = document.getElementById('vigOv');
    if (!vig) {
        vig = document.createElement('div');
        vig.id = 'vigOv';
        vig.style.cssText = 'position:absolute;inset:0;pointer-events:none;z-index:1;transition:background 0.3s;';
        document.querySelector('.ev-panel').appendChild(vig);
    }
    vig.style.background = filters.vignette > 0
        ? `radial-gradient(ellipse at center,transparent 40%,rgba(0,0,0,${(filters.vignette/100*0.8).toFixed(2)}) 100%)`
        : 'none';
}

function onSl(name, el) {
    filters[name] = parseInt(el.value, 10);
    const v = filters[name];
    document.getElementById('v-' + name).textContent = v > 0 ? '+' + v : String(v);
    updateSlGradient(el);
    applyFilters();
}

function updateSlGradient(el) {
    const pct = ((parseFloat(el.value) - parseFloat(el.min)) / (parseFloat(el.max) - parseFloat(el.min)) * 100).toFixed(1) + '%';
    el.style.setProperty('--pct', pct);
}

function resetSl(name) {
    const el = document.getElementById('sl-' + name);
    el.value = 0; filters[name] = 0;
    document.getElementById('v-' + name).textContent = '0';
    updateSlGradient(el);
    applyFilters();
}

const PRESETS = {
    natural:  { exposure:5,  contrast:5,  saturation:15, sharpness:10, temperature:5,  vignette:0  },
    vivid:    { exposure:10, contrast:20, saturation:40, sharpness:15, temperature:0,  vignette:10 },
    warm:     { exposure:5,  contrast:5,  saturation:10, sharpness:5,  temperature:35, vignette:5  },
    cool:     { exposure:0,  contrast:10, saturation:5,  sharpness:5,  temperature:-30,vignette:5  },
    dramatic: { exposure:-5, contrast:40, saturation:20, sharpness:20, temperature:-5, vignette:50 },
    reset:    { exposure:0,  contrast:0,  saturation:0,  sharpness:0,  temperature:0,  vignette:0  }
};

function applyPreset(name) {
    Object.assign(filters, PRESETS[name]);
    Object.keys(filters).forEach(k => {
        const sl = document.getElementById('sl-' + k);
        if (sl) { sl.value = filters[k]; updateSlGradient(sl); }
        const vl = document.getElementById('v-' + k);
        if (vl) vl.textContent = filters[k] > 0 ? '+' + filters[k] : String(filters[k]);
    });
    applyFilters();
    document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('active'));
    event.currentTarget.classList.add('active');
}

// =============================================================
//  GUARDAR
// =============================================================
function canvasToBlob(canvas, quality) {
    return new Promise(res => canvas.toBlob(res, 'image/jpeg', quality || 0.88));
}

async function saveProject() {
    const name = document.getElementById('projectName').value.trim();
    if (!name) {
        Swal.fire({ icon: 'warning', title: 'Falta el nombre', text: 'Escribe el nombre del proyecto' });
        document.getElementById('projectName').focus();
        return;
    }

    const hasNew      = !!(stitchedCanvas || selectedSingleFile);
    const hasExisting = !!(EXISTING && EXISTING.image_url);
    if (!hasNew && !hasExisting) {
        Swal.fire({ icon: 'warning', title: 'Sin imagen', text: 'Carga una carpeta DJI o una imagen primero' });
        return;
    }

    const btn = document.getElementById('btnSave');
    const txt = document.getElementById('btnSaveTxt');
    btn.disabled = true;
    txt.textContent = 'Subiendo...';
    document.getElementById('uploadBar').classList.add('v');

    let prog = 0;
    const pt = setInterval(() => {
        prog = Math.min(prog + Math.random() * 12, 88);
        document.getElementById('uploadBarFill').style.width = prog + '%';
    }, 400);

    try {
        const fd = new FormData();
        fd.append('name', name);
        fd.append('settings_json', JSON.stringify(filters));
        if (panoramaId) fd.append('panorama_id', panoramaId);

        if (stitchedCanvas) {
            const blob = await canvasToBlob(stitchedCanvas);
            fd.append('panorama_file', blob, 'pano_stitched.jpg');
        } else if (selectedSingleFile) {
            fd.append('panorama_file', selectedSingleFile, selectedSingleFile.name);
        } else {
            fd.append('existing_image_url', EXISTING.image_url);
            fd.append('existing_public_id',  EXISTING.public_id || '');
        }

        const res  = await fetch('/admin/360/save', { method: 'POST', body: fd });
        const data = await res.json();

        clearInterval(pt);
        document.getElementById('uploadBarFill').style.width = '100%';

        if (!data.success) throw new Error(data.error || 'Error desconocido');

        panoramaId = data.panorama.id;
        const link = window.location.origin + '/view/360/' + data.panorama.public_token;

        document.getElementById('savedUrl').textContent  = link;
        document.getElementById('savedOpen').href        = link;
        document.getElementById('savedBox').classList.add('visible');

        setTimeout(() => {
            document.getElementById('uploadBar').classList.remove('v');
            document.getElementById('uploadBarFill').style.width = '0%';
            btn.disabled = false;
            txt.textContent = 'Actualizar';
        }, 800);

        Swal.fire({
            icon: 'success', title: '¡Guardado!',
            html: `Link del cliente:<br><a href="${link}" target="_blank" style="color:#3b82f6;word-break:break-all;">${link}</a>`,
            confirmButtonText: 'Copiar link', confirmButtonColor: '#2563eb',
            showCancelButton: true, cancelButtonText: 'Cerrar'
        }).then(r => { if (r.isConfirmed) navigator.clipboard.writeText(link); });

    } catch (err) {
        clearInterval(pt);
        document.getElementById('uploadBar').classList.remove('v');
        btn.disabled = false;
        txt.textContent = 'Guardar en Cloudinary';
        Swal.fire('Error al guardar', err.message, 'error');
    }
}

function copyLink() {
    navigator.clipboard.writeText(document.getElementById('savedUrl').textContent).then(() => {
        const b = document.querySelector('.sb-copy');
        b.textContent = '✅ Copiado';
        setTimeout(() => { b.innerHTML = '<i class="ph-bold ph-copy"></i> Copiar'; }, 2000);
    });
}

// =============================================================
//  INIT
// =============================================================
window.addEventListener('DOMContentLoaded', () => {
    initThree();
    document.querySelectorAll('.psl').forEach(updateSlGradient);
});
</script>
</body>
