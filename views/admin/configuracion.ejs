<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <title>Configuración | Cygnus Group</title>
    
    <!-- External Libraries -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" rel="stylesheet">
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    
    <!-- Custom Dashboard CSS -->
    <link rel="stylesheet" href="/css/config-dashboard.css">
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js"></script>
</head>
<body>
    
    <div class="app-layout">
        <%- include('../partials/sidebar-admin') %>
        
        <main class="main-content">
            
            <!-- ========================================
                 DASHBOARD DE CONFIGURACIÓN
                 ======================================== -->
            <div class="config-dashboard-wrapper">
                
                <!-- ========================================
                     PANEL IZQUIERDO - EDITOR (450px)
                     ======================================== -->
                <div class="config-editor-panel">
                    
                    <!-- Header del Editor -->
                    <div class="config-editor-header">
                        <h1 class="config-title">
                            <i class="fas fa-cog"></i>
                            Configuración del Sitio
                        </h1>
                        <p class="config-subtitle">Gestiona el contenido y apariencia de tu sitio web</p>
                    </div>
                    
                    <!-- Contenido del Editor -->
                    <div class="config-editor-content">
                        <form id="configForm">
                            
                            <!-- Hidden Fields -->
                            <input type="hidden" name="promo_strips_json" id="promoStripsJson">
                            <input type="hidden" name="ticker_speed" id="tickerSpeedHidden" value="<%= config.ticker_speed || 35 %>">
                            
                            <!-- ========================================
                                 SECCIÓN: MODO MANTENIMIENTO
                                 ======================================== -->
                            <section class="config-section">
                                <div class="section-header">
                                    <h2 class="section-title">
                                        <i class="fas fa-hard-hat"></i>
                                        Modo Mantenimiento
                                    </h2>
                                    <label class="toggle-switch">
                                        <input type="checkbox" name="maintenance_active" id="maintSwitch" <%= config.maintenance_active ? 'checked' : '' %>>
                                        <span class="toggle-track"></span>
                                    </label>
                                </div>
                                
                                <div class="form-group">
                                    <label class="form-label">Mensaje para los visitantes</label>
                                    <div id="maintQuill" class="quill-editor">
                                        <%- config.maintenance_message || '<h2>Sitio en Mantenimiento</h2><p>Volvemos pronto con mejoras.</p>' %>
                                    </div>
                                </div>
                                
                                <div class="form-group">
                                    <label class="form-label">Tiempo estimado de regreso</label>
                                    <input type="text" class="form-input" name="maintenance_eta" value="<%= config.maintenance_eta || '2 horas' %>" placeholder="Ej: 2 horas, mañana">
                                    <p class="form-hint">Este texto se mostrará en la página de mantenimiento</p>
                                </div>
                            </section>
                            
                            <!-- ========================================
                                 SECCIÓN: BARRA SUPERIOR
                                 ======================================== -->
                            <section class="config-section">
                                <div class="section-header">
                                    <h2 class="section-title">
                                        <i class="fas fa-bullhorn"></i>
                                        Barra de Anuncios
                                    </h2>
                                    <label class="toggle-switch">
                                        <input type="checkbox" name="announcement_active" id="annSwitch" <%= config.announcement_active ? 'checked' : '' %>>
                                        <span class="toggle-track"></span>
                                    </label>
                                </div>
                                
                                <div class="color-picker-group mb-3">
                                    <div class="color-picker-box">
                                        <div class="color-preview" id="previewAnnBg" style="background-color: <%= config.announcement_bg || '#1e293b' %>;"></div>
                                        <div class="color-input-wrapper">
                                            <label class="form-label mb-2">Fondo</label>
                                            <input type="color" name="announcement_bg" id="annBg" value="<%= config.announcement_bg || '#1e293b' %>">
                                            <p class="color-hex"><%= config.announcement_bg || '#1e293b' %></p>
                                        </div>
                                    </div>
                                    
                                    <div class="color-picker-box">
                                        <div class="color-preview" id="previewAnnColor" style="background-color: <%= config.announcement_color || '#ffffff' %>;"></div>
                                        <div class="color-input-wrapper">
                                            <label class="form-label mb-2">Texto</label>
                                            <input type="color" name="announcement_color" id="annColor" value="<%= config.announcement_color || '#ffffff' %>">
                                            <p class="color-hex"><%= config.announcement_color || '#ffffff' %></p>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="form-group">
                                    <label class="form-label">Contenido del anuncio</label>
                                    <div id="annQuill" class="quill-editor">
                                        <%- config.announcement_text || '¡Contáctanos hoy mismo!' %>
                                    </div>
                                </div>
                            </section>
                            
                            <!-- ========================================
                                 SECCIÓN: HUINCHAS PROMOCIONALES
                                 ======================================== -->
                            <section class="config-section">
                                <div class="section-header">
                                    <h2 class="section-title">
                                        <i class="fas fa-ribbon"></i>
                                        Huinchas Promocionales
                                    </h2>
                                    <label class="toggle-switch">
                                        <input type="checkbox" name="ticker_active" id="tickerSwitch" <%= (config.ticker_active !== false) ? 'checked' : '' %>>
                                        <span class="toggle-track"></span>
                                    </label>
                                </div>
                                
                                <div class="form-group">
                                    <label class="form-label">Velocidad de desplazamiento</label>
                                    <input type="range" min="20" max="60" value="<%= config.ticker_speed || 35 %>" id="tickerSpeedRange" class="range-slider">
                                    <p class="form-hint mt-2">Velocidad: <strong id="speedDisplay"><%= config.ticker_speed || 35 %>s</strong></p>
                                </div>
                                
                                <div id="huinchasContainer">
                                    <!-- Huinchas se cargan dinámicamente -->
                                </div>
                                
                                <button type="button" class="btn btn-secondary btn-block mt-3" onclick="addHuincha()">
                                    <i class="fas fa-plus"></i>
                                    Agregar Huincha
                                </button>
                            </section>
                            
                            <!-- ========================================
                                 SECCIÓN: SLIDER DE BANNERS
                                 ======================================== -->
                            <section class="config-section">
                                <div class="section-header">
                                    <h2 class="section-title">
                                        <i class="fas fa-images"></i>
                                        Slider de Banners
                                    </h2>
                                    <div style="display: flex; align-items: center; gap: 12px;">
                                        <label class="form-label" style="margin: 0;">Velocidad</label>
                                        <input type="range" name="slider_speed" id="sliderSpeed" min="2" max="10" value="<%= config.slider_speed || 5 %>" class="range-slider" style="width: 100px;">
                                        <span class="text-sm text-muted"><strong id="sliderSpeedText"><%= config.slider_speed || 5 %>s</strong></span>
                                    </div>
                                </div>
                                
                                <div class="upload-zone" id="uploadZone">
                                    <i class="fas fa-cloud-upload-alt upload-icon"></i>
                                    <p class="upload-text">Arrastra imágenes o haz click</p>
                                    <p class="upload-hint">JPG, PNG, WebP (Máx 10MB)</p>
                                    <input type="file" id="fileInput" multiple accept="image/*" style="display:none;">
                                </div>
                                
                                <div class="banners-grid" id="bannersContainer">
                                    <% if(config.banners && config.banners.length > 0) { %>
                                        <% config.banners.forEach((b, idx) => { %>
                                            <div class="banner-item <%= idx === 0 ? 'first-banner' : '' %>" 
                                                 data-type="existing"
                                                 data-url="<%= b.url %>" 
                                                 data-align="<%= b.align || '50% 50%' %>"
                                                 data-duration="<%= b.duration || 5 %>"
                                                 data-animation="<%= b.animation || 'fade' %>">
                                                
                                                <img src="<%= b.url %>" style="object-position: <%= b.align || '50% 50%' %>;">
                                                
                                                <% if(idx === 0) { %>
                                                    <div class="banner-badge first">Original</div>
                                                <% } %>
                                                
                                                <div class="banner-timing"><%= b.duration || 5 %>s</div>
                                                
                                                <div class="banner-overlay">
                                                    <div class="banner-actions">
                                                        <button type="button" class="btn btn-primary btn-sm" onclick="editBanner(this)">
                                                            <i class="fas fa-edit"></i> Editar
                                                        </button>
                                                        <% if(idx !== 0) { %>
                                                            <button type="button" class="btn btn-danger btn-sm" onclick="deleteBanner(this)">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            </div>
                                        <% }) %>
                                    <% } %>
                                </div>
                            </section>
                            
                        </form>
                    </div>
                    
                    <!-- Footer del Editor -->
                    <div class="config-editor-footer">
                        <button type="button" class="btn btn-primary btn-block" onclick="saveAllConfiguration()">
                            <i class="fas fa-save"></i>
                            Guardar Todos los Cambios
                        </button>
                    </div>
                    
                </div>
                
                <!-- ========================================
                     PANEL DERECHO - PREVIEW GIGANTE
                     ======================================== -->
                <div class="config-preview-panel">
                    
                    <!-- Header del Preview -->
                    <div class="preview-header">
                        <h3 class="preview-title">
                            <i class="fas fa-eye"></i>
                            Vista Previa en Vivo
                        </h3>
                        <div class="device-selector">
                            <button type="button" class="device-btn active" data-device="desktop">
                                <i class="fas fa-desktop"></i> Escritorio
                            </button>
                            <button type="button" class="device-btn" data-device="mobile">
                                <i class="fas fa-mobile-alt"></i> Móvil
                            </button>
                        </div>
                    </div>
                    
                    <!-- Viewport del Preview -->
                    <div class="preview-viewport">
                        <div class="preview-frame desktop" id="previewFrame">
                            <iframe id="liveIframe" src="/"></iframe>
                        </div>
                    </div>
                    
                </div>
                
            </div>
            
        </main>
    </div>
    
    <!-- ========================================
         MODAL: EDITAR BANNER
         ======================================== -->
    <div class="modal-backdrop" id="modalEditBanner">
        <div class="modal-container">
            <div class="modal-header">
                <h3 class="modal-title">
                    <i class="fas fa-crop"></i>
                    Editar Banner
                </h3>
                <button type="button" class="btn-close-modal" onclick="closeModal('modalEditBanner')">&times;</button>
            </div>
            
            <div class="modal-body">
                <div class="cropper-container" id="cropperContainer">
                    <img id="cropperImage" src="" style="max-width: 100%;">
                </div>
                
                <div class="grid-2 mt-4">
                    <div class="form-group">
                        <label class="form-label">Duración (segundos)</label>
                        <input type="number" id="bannerDuration" class="form-input" min="2" max="15" value="5">
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Animación</label>
                        <select id="bannerAnimation" class="form-select">
                            <option value="fade">Fade</option>
                            <option value="slide">Slide</option>
                            <option value="zoom">Zoom</option>
                        </select>
                    </div>
                </div>
            </div>
            
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('modalEditBanner')">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="applyBannerEdit()">
                    <i class="fas fa-check"></i>
                    Aplicar Cambios
                </button>
            </div>
        </div>
    </div>
    
    <!-- ========================================
         JAVASCRIPT
         ======================================== -->
    <script>
        // ========== ESTADO GLOBAL ==========
        let qMaint, qAnn;
        let currentCropper = null;
        let currentEditingBanner = null;
        let bannerUploads = [];
        let huinchasData = [];
        
        // ========== INICIALIZACIÓN ==========
        document.addEventListener('DOMContentLoaded', () => {
            initEditors();
            initListeners();
            initHuinchas();
            initBannersSortable();
        });
        
        // ========== EDITORES QUILL ==========
        function initEditors() {
            qMaint = new Quill('#maintQuill', {
                theme: 'snow',
                modules: {
                    toolbar: [
                        ['bold', 'italic'],
                        [{ 'header': [1, 2, 3, false] }],
                        [{ 'color': [] }, { 'align': [] }]
                    ]
                }
            });
            
            qAnn = new Quill('#annQuill', {
                theme: 'snow',
                modules: {
                    toolbar: [['bold', 'italic'], [{ 'color': [] }]]
                }
            });
        }
        
        // ========== LISTENERS ==========
        function initListeners() {
            // Color pickers
            document.getElementById('annBg').addEventListener('input', (e) => {
                document.getElementById('previewAnnBg').style.backgroundColor = e.target.value;
                e.target.nextElementSibling.textContent = e.target.value;
            });
            
            document.getElementById('annColor').addEventListener('input', (e) => {
                document.getElementById('previewAnnColor').style.backgroundColor = e.target.value;
                e.target.nextElementSibling.textContent = e.target.value;
            });
            
            // Sliders
            document.getElementById('sliderSpeed').addEventListener('input', (e) => {
                document.getElementById('sliderSpeedText').textContent = e.target.value + 's';
            });
            
            document.getElementById('tickerSpeedRange').addEventListener('input', (e) => {
                document.getElementById('speedDisplay').textContent = e.target.value + 's';
                document.getElementById('tickerSpeedHidden').value = e.target.value;
            });
            
            // Upload zone
            const uploadZone = document.getElementById('uploadZone');
            const fileInput = document.getElementById('fileInput');
            
            uploadZone.onclick = () => fileInput.click();
            
            uploadZone.addEventListener('dragover', (e) => {
                e.preventDefault();
                uploadZone.style.borderColor = 'var(--config-primary)';
            });
            
            uploadZone.addEventListener('dragleave', () => {
                uploadZone.style.borderColor = 'var(--config-gray-300)';
            });
            
            uploadZone.addEventListener('drop', (e) => {
                e.preventDefault();
                uploadZone.style.borderColor = 'var(--config-gray-300)';
                handleFiles(e.dataTransfer.files);
            });
            
            fileInput.addEventListener('change', (e) => {
                handleFiles(e.target.files);
                fileInput.value = '';
            });
            
            // Device selector
            document.querySelectorAll('.device-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    document.querySelectorAll('.device-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    
                    const device = btn.dataset.device;
                    const frame = document.getElementById('previewFrame');
                    frame.className = `preview-frame ${device}`;
                });
            });
        }
        
        // ========== HUINCHAS ==========
        function initHuinchas() {
            try {
                const stored = <%= JSON.stringify(config.promo_strips || []) %>;
                huinchasData = Array.isArray(stored) ? stored : [];
            } catch(e) {
                huinchasData = [];
            }
            renderHuinchas();
        }
        
        function addHuincha() {
            huinchasData.push({
                id: Date.now(),
                text: 'Nueva promoción',
                icon: 'fa-star',
                bgColor: '#2563eb',
                textColor: '#ffffff',
                active: true
            });
            renderHuinchas();
        }
        
        function renderHuinchas() {
            const container = document.getElementById('huinchasContainer');
            container.innerHTML = huinchasData.map((h, idx) => `
                <div class="config-card">
                    <div class="card-header">
                        <h4 class="card-title">Huincha #${idx + 1}</h4>
                        <div class="card-actions">
                            <label class="toggle-switch">
                                <input type="checkbox" ${h.active ? 'checked' : ''} onchange="toggleHuincha(${idx}, this.checked)">
                                <span class="toggle-track"></span>
                            </label>
                            <button type="button" class="btn btn-danger btn-sm" onclick="deleteHuincha(${idx})">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                    <div class="grid-2">
                        <div class="form-group">
                            <label class="form-label">Texto</label>
                            <input type="text" class="form-input" value="${h.text}" onchange="updateHuincha(${idx}, 'text', this.value)">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Icono</label>
                            <input type="text" class="form-input" value="${h.icon}" onchange="updateHuincha(${idx}, 'icon', this.value)" placeholder="fa-star">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Color Fondo</label>
                            <input type="color" class="form-input" value="${h.bgColor}" onchange="updateHuincha(${idx}, 'bgColor', this.value)">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Color Texto</label>
                            <input type="color" class="form-input" value="${h.textColor}" onchange="updateHuincha(${idx}, 'textColor', this.value)">
                        </div>
                    </div>
                </div>
            `).join('');
        }
        
        function toggleHuincha(idx, active) {
            huinchasData[idx].active = active;
        }
        
        function updateHuincha(idx, field, value) {
            huinchasData[idx][field] = value;
        }
        
        function deleteHuincha(idx) {
            Swal.fire({
                title: '¿Eliminar huincha?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    huinchasData.splice(idx, 1);
                    renderHuinchas();
                }
            });
        }
        
        // ========== BANNERS ==========
        function handleFiles(files) {
            Array.from(files).forEach(file => {
                if (!file.type.startsWith('image/')) return;
                
                const reader = new FileReader();
                reader.onload = (e) => {
                    const uid = Date.now() + Math.random();
                    bannerUploads.push({
                        id: uid,
                        file: file,
                        url: e.target.result,
                        align: '50% 50%',
                        duration: 5,
                        animation: 'fade'
                    });
                    createBannerCard(uid, e.target.result, '50% 50%', 5, 'fade', true);
                };
                reader.readAsDataURL(file);
            });
        }
        
        function createBannerCard(id, url, align, duration, animation, isNew) {
            const container = document.getElementById('bannersContainer');
            const div = document.createElement('div');
            div.className = 'banner-item';
            div.dataset.type = isNew ? 'new' : 'existing';
            div.dataset.id = id;
            div.dataset.url = url;
            div.dataset.align = align;
            div.dataset.duration = duration;
            div.dataset.animation = animation;
            
            div.innerHTML = `
                <img src="${url}" style="object-position: ${align};">
                <div class="banner-timing">${duration}s</div>
                <div class="banner-overlay">
                    <div class="banner-actions">
                        <button type="button" class="btn btn-primary btn-sm" onclick="editBanner(this)">
                            <i class="fas fa-edit"></i> Editar
                        </button>
                        <button type="button" class="btn btn-danger btn-sm" onclick="deleteBanner(this)">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </div>
            `;
            
            container.appendChild(div);
        }
        
        function initBannersSortable() {
            new Sortable(document.getElementById('bannersContainer'), {
                animation: 200,
                ghostClass: 'sortable-ghost'
            });
        }
        
        function editBanner(btn) {
            const card = btn.closest('.banner-item');
            currentEditingBanner = card;
            
            const img = card.querySelector('img');
            document.getElementById('cropperImage').src = img.src;
            document.getElementById('bannerDuration').value = card.dataset.duration || 5;
            document.getElementById('bannerAnimation').value = card.dataset.animation || 'fade';
            
            openModal('modalEditBanner');
            
            setTimeout(() => {
                if (currentCropper) currentCropper.destroy();
                currentCropper = new Cropper(document.getElementById('cropperImage'), {
                    aspectRatio: 16 / 9,
                    viewMode: 1,
                    autoCropArea: 1
                });
            }, 300);
        }
        
        function applyBannerEdit() {
            if (!currentEditingBanner || !currentCropper) return;
            
            const canvas = currentCropper.getCroppedCanvas();
            const newUrl = canvas.toDataURL();
            
            currentEditingBanner.querySelector('img').src = newUrl;
            currentEditingBanner.dataset.url = newUrl;
            currentEditingBanner.dataset.duration = document.getElementById('bannerDuration').value;
            currentEditingBanner.dataset.animation = document.getElementById('bannerAnimation').value;
            currentEditingBanner.querySelector('.banner-timing').textContent = document.getElementById('bannerDuration').value + 's';
            
            closeModal('modalEditBanner');
        }
        
        function deleteBanner(btn) {
            const card = btn.closest('.banner-item');
            if (card.classList.contains('first-banner')) {
                Swal.fire('No permitido', 'No puedes eliminar el banner original', 'error');
                return;
            }
            
            Swal.fire({
                title: '¿Eliminar banner?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    card.remove();
                }
            });
        }
        
        // ========== MODALES ==========
        function openModal(id) {
            document.getElementById(id).classList.add('active');
        }
        
        function closeModal(id) {
            document.getElementById(id).classList.remove('active');
            if (currentCropper) {
                currentCropper.destroy();
                currentCropper = null;
            }
        }
        
        // ========== GUARDAR CONFIGURACIÓN ==========
        async function saveAllConfiguration() {
            const formData = new FormData();
            
            // Mantenimiento
            formData.append('maintenance_active', document.getElementById('maintSwitch').checked);
            formData.append('maintenance_message', qMaint.root.innerHTML);
            formData.append('maintenance_eta', document.querySelector('[name="maintenance_eta"]').value);
            
            // Announcement
            formData.append('announcement_active', document.getElementById('annSwitch').checked);
            formData.append('announcement_bg', document.getElementById('annBg').value);
            formData.append('announcement_color', document.getElementById('annColor').value);
            formData.append('announcement_text', qAnn.root.innerHTML);
            
            // Huinchas
            formData.append('ticker_active', document.getElementById('tickerSwitch').checked);
            formData.append('ticker_speed', document.getElementById('tickerSpeedRange').value);
            formData.append('promo_strips_json', JSON.stringify(huinchasData));
            
            // Slider
            formData.append('slider_speed', document.getElementById('sliderSpeed').value);
            
            // Banners
            const banners = [];
            document.querySelectorAll('.banner-item').forEach((card, idx) => {
                if (card.dataset.type === 'existing') {
                    banners.push({
                        url: card.dataset.url,
                        align: card.dataset.align,
                        duration: card.dataset.duration,
                        animation: card.dataset.animation
                    });
                }
            });
            formData.append('banners', JSON.stringify(banners));
            
            // Nuevos banners
            bannerUploads.forEach((upload, idx) => {
                formData.append(`new_banner_${idx}`, upload.file);
                formData.append(`new_banner_${idx}_duration`, upload.duration);
                formData.append(`new_banner_${idx}_animation`, upload.animation);
            });
            
            try {
                const response = await fetch('/admin/configuracion/update', {
                    method: 'POST',
                    body: formData
                });
                
                const result = await response.json();
                
                if (result.success) {
                    Swal.fire('¡Guardado!', 'Configuración actualizada correctamente', 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    Swal.fire('Error', result.message || 'No se pudo guardar', 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                Swal.fire('Error', 'Error de conexión', 'error');
            }
        }
    </script>
    
</body>
</html>
