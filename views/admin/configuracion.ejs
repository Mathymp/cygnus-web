<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <title>Configuración Ultra | Cygnus Group</title>
    
    <!-- External Libraries -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" rel="stylesheet">
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    
    <!-- Custom Styles -->
    <link rel="stylesheet" href="/css/config-ultra.css">
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js"></script>
</head>
<body>
    
    <div class="config-ultra-layout">
        
        <!-- ========================================
             SIDEBAR IZQUIERDO - NAVEGACIÓN FIJA
             ======================================== -->
        <aside class="config-sidebar">
            <div class="sidebar-header">
                <div class="sidebar-logo">
                    <img src="/img/logo.png" alt="Cygnus">
                    <h2>Cygnus</h2>
                </div>
                <p class="sidebar-subtitle">Panel de Control</p>
            </div>
            
            <nav class="sidebar-nav">
                <div class="nav-section">
                    <div class="nav-section-title">Sistema</div>
                    <div class="nav-item active" data-section="maintenance">
                        <i class="fas fa-hard-hat"></i>
                        <span>Mantenimiento</span>
                    </div>
                    <div class="nav-item" data-section="huinchas">
                        <i class="fas fa-ribbon"></i>
                        <span>Huinchas</span>
                    </div>
                    <div class="nav-item" data-section="announcement">
                        <i class="fas fa-bullhorn"></i>
                        <span>Barra Superior</span>
                    </div>
                </div>
                
                <div class="nav-section">
                    <div class="nav-section-title">Contenido</div>
                    <div class="nav-item" data-section="banners">
                        <i class="fas fa-images"></i>
                        <span>Slider Banners</span>
                    </div>
                    <div class="nav-item" data-section="brand">
                        <i class="fas fa-palette"></i>
                        <span>Marca</span>
                    </div>
                </div>
            </nav>
            
            <div class="sidebar-footer">
                <button type="button" class="btn-save-all" onclick="saveAllConfiguration()">
                    <i class="fas fa-save"></i>
                    Guardar Todo
                </button>
            </div>
        </aside>
        
        <!-- ========================================
             COLUMNA EDITOR - SCROLL INDEPENDIENTE
             ======================================== -->
        <main class="config-editor">
            <div class="editor-header">
                <h1 class="editor-title">
                    <i class="fas fa-sliders-h"></i>
                    Configuración del Sitio
                </h1>
                <p class="editor-subtitle">Gestiona todos los aspectos visuales y funcionales de tu sitio web</p>
            </div>
            
            <form id="configForm">
                <!-- Hidden Fields -->
                <input type="hidden" name="promo_strips_json" id="promoStripsJson">
                <input type="hidden" name="ticker_speed" id="tickerSpeedHidden" value="<%= config.ticker_speed || 35 %>">
                
                <!-- ========================================
                     SECCIÓN: MODO MANTENIMIENTO
                     ======================================== -->
                <section class="section-panel active" id="section-maintenance">
                    <div class="panel-header">
                        <h2 class="panel-title">
                            <i class="fas fa-hard-hat"></i>
                            Modo Mantenimiento
                        </h2>
                        <label class="toggle-switch">
                            <input type="checkbox" name="maintenance_active" id="maintSwitch" <%= config.maintenance_active ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            <span class="toggle-label">Activar</span>
                        </label>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Mensaje para los visitantes</label>
                        <div id="maintQuill" style="background: white; border-radius: 10px; min-height: 200px;">
                            <%- config.maintenance_message || '<h1 style="text-align: center;">Sitio en Mantenimiento</h1><p style="text-align: center;">Volvemos pronto con mejoras.</p>' %>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Tiempo estimado de regreso</label>
                        <input type="text" class="form-input" name="maintenance_eta" value="<%= config.maintenance_eta || '2 horas' %>" placeholder="Ej: 2 horas, 1 día">
                    </div>
                </section>
                
                <!-- ========================================
                     SECCIÓN: HUINCHAS PROMOCIONALES
                     ======================================== -->
                <section class="section-panel" id="section-huinchas">
                    <div class="panel-header">
                        <h2 class="panel-title">
                            <i class="fas fa-ribbon"></i>
                            Huinchas Promocionales
                        </h2>
                        <label class="toggle-switch">
                            <input type="checkbox" name="ticker_active" id="tickerSwitch" <%= (config.ticker_active !== false) ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            <span class="toggle-label">Activar Ticker</span>
                        </label>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Velocidad de desplazamiento (segundos)</label>
                        <input type="range" min="20" max="60" value="<%= config.ticker_speed || 35 %>" id="tickerSpeedRange" class="form-input">
                        <p class="text-muted text-sm mt-2">Velocidad actual: <strong id="speedDisplay"><%= config.ticker_speed || 35 %>s</strong></p>
                    </div>
                    
                    <div class="huinchas-list" id="huinchasContainer">
                        <!-- Las huinchas se cargarán dinámicamente aquí -->
                    </div>
                    
                    <button type="button" class="btn-add-huincha" onclick="addHuincha()">
                        <i class="fas fa-plus"></i>
                        Agregar Nueva Huincha
                    </button>
                </section>
                
                <!-- ========================================
                     SECCIÓN: BARRA SUPERIOR (ANNOUNCEMENT)
                     ======================================== -->
                <section class="section-panel" id="section-announcement">
                    <div class="panel-header">
                        <h2 class="panel-title">
                            <i class="fas fa-bullhorn"></i>
                            Barra de Anuncios Superior
                        </h2>
                        <label class="toggle-switch">
                            <input type="checkbox" name="announcement_active" id="annSwitch" <%= config.announcement_active ? 'checked' : '' %>>
                            <span class="toggle-slider"></span>
                            <span class="toggle-label">Mostrar</span>
                        </label>
                    </div>
                    
                    <div class="color-picker-group mb-4">
                        <div class="color-picker-item">
                            <div class="color-preview" id="previewAnnBg" style="background-color: <%= config.announcement_bg || '#1e293b' %>;"></div>
                            <div class="color-input">
                                <label class="form-label mb-2">Color de Fondo</label>
                                <input type="color" name="announcement_bg" id="annBg" value="<%= config.announcement_bg || '#1e293b' %>">
                                <p class="color-hex mt-2"><%= config.announcement_bg || '#1e293b' %></p>
                            </div>
                        </div>
                        
                        <div class="color-picker-item">
                            <div class="color-preview" id="previewAnnColor" style="background-color: <%= config.announcement_color || '#ffffff' %>;"></div>
                            <div class="color-input">
                                <label class="form-label mb-2">Color de Texto</label>
                                <input type="color" name="announcement_color" id="annColor" value="<%= config.announcement_color || '#ffffff' %>">
                                <p class="color-hex mt-2"><%= config.announcement_color || '#ffffff' %></p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Contenido del anuncio</label>
                        <div id="annQuill" style="background: white; border-radius: 10px; min-height: 150px;">
                            <%- config.announcement_text || '¡Contáctanos hoy mismo!' %>
                        </div>
                    </div>
                </section>
                
                <!-- ========================================
                     SECCIÓN: SLIDER BANNERS
                     ======================================== -->
                <section class="section-panel" id="section-banners">
                    <div class="panel-header">
                        <h2 class="panel-title">
                            <i class="fas fa-images"></i>
                            Slider de Banners
                        </h2>
                        <div class="form-group" style="margin: 0; max-width: 200px;">
                            <label class="form-label mb-2">Velocidad</label>
                            <input type="range" name="slider_speed" id="sliderSpeed" min="2" max="10" value="<%= config.slider_speed || 5 %>" class="form-input">
                            <p class="text-muted text-sm mt-2"><strong id="sliderSpeedText"><%= config.slider_speed || 5 %>s</strong></p>
                        </div>
                    </div>
                    
                    <div class="upload-zone" id="uploadZone">
                        <i class="fas fa-cloud-upload-alt upload-icon"></i>
                        <p class="upload-text">Arrastra imágenes aquí o haz click</p>
                        <p class="upload-hint">Formatos: JPG, PNG, WebP (Máx 10MB)</p>
                        <input type="file" id="fileInput" multiple accept="image/*" style="display:none;">
                    </div>
                    
                    <div class="banners-grid" id="bannersContainer">
                        <% if(config.banners && config.banners.length > 0) { %>
                            <% config.banners.forEach((b, idx) => { %>
                                <div class="banner-card <%= idx === 0 ? 'first-banner' : '' %>" 
                                     data-type="existing"
                                     data-url="<%= b.url %>" 
                                     data-align="<%= b.align || '50% 50%' %>"
                                     data-duration="<%= b.duration || 5 %>"
                                     data-animation="<%= b.animation || 'fade' %>">
                                    
                                    <img src="<%= b.url %>" style="object-position: <%= b.align || '50% 50%' %>;">
                                    
                                    <% if(idx === 0) { %>
                                        <div class="banner-badge first">Original</div>
                                    <% } %>
                                    
                                    <div class="banner-timing"><%= b.duration || 5 %>s</div>
                                    
                                    <div class="banner-overlay">
                                        <div class="banner-actions">
                                            <button type="button" class="btn-banner edit" onclick="editBanner(this)">
                                                <i class="fas fa-edit"></i> Editar
                                            </button>
                                            <% if(idx !== 0) { %>
                                                <button type="button" class="btn-banner delete" onclick="deleteBanner(this)">
                                                    <i class="fas fa-trash"></i> Eliminar
                                                </button>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } %>
                    </div>
                </section>
                
                <!-- ========================================
                     SECCIÓN: MARCA
                     ======================================== -->
                <section class="section-panel" id="section-brand">
                    <div class="panel-header">
                        <h2 class="panel-title">
                            <i class="fas fa-palette"></i>
                            Identidad de Marca
                        </h2>
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Nombre de la empresa</label>
                        <input type="text" class="form-input" name="company_name" value="<%= config.company_name || 'Cygnus Group Propiedades' %>">
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Slogan</label>
                        <input type="text" class="form-input" name="company_slogan" value="<%= config.company_slogan || 'Tu hogar, nuestra misión' %>">
                    </div>
                    
                    <div class="color-picker-group">
                        <div class="color-picker-item">
                            <div class="color-preview" style="background-color: <%= config.brand_primary || '#2563eb' %>;"></div>
                            <div class="color-input">
                                <label class="form-label mb-2">Color Primario</label>
                                <input type="color" name="brand_primary" value="<%= config.brand_primary || '#2563eb' %>">
                            </div>
                        </div>
                        
                        <div class="color-picker-item">
                            <div class="color-preview" style="background-color: <%= config.brand_secondary || '#764ba2' %>;"></div>
                            <div class="color-input">
                                <label class="form-label mb-2">Color Secundario</label>
                                <input type="color" name="brand_secondary" value="<%= config.brand_secondary || '#764ba2' %>">
                            </div>
                        </div>
                    </div>
                </section>
                
            </form>
        </main>
        
        <!-- ========================================
             LIVE PREVIEW - COLUMNA DERECHA FIJA
             ======================================== -->
        <aside class="config-preview">
            <div class="preview-header">
                <h3 class="preview-title">
                    <i class="fas fa-eye"></i>
                    Vista Previa en Vivo
                </h3>
                <div class="device-selector">
                    <button type="button" class="device-btn active" data-device="desktop">
                        <i class="fas fa-desktop"></i> Escritorio
                    </button>
                    <button type="button" class="device-btn" data-device="mobile">
                        <i class="fas fa-mobile-alt"></i> Móvil
                    </button>
                </div>
            </div>
            
            <div class="preview-viewport">
                <div class="preview-frame desktop" id="previewFrame">
                    <iframe id="liveIframe" src="/"></iframe>
                </div>
            </div>
        </aside>
        
    </div>
    
    <!-- ========================================
         MODAL: EDITAR BANNER
         ======================================== -->
    <div class="modal-backdrop" id="modalEditBanner">
        <div class="modal-container">
            <div class="modal-header">
                <h3 class="modal-title">
                    <i class="fas fa-crop"></i>
                    Editar Banner
                </h3>
                <button type="button" class="btn-close-modal" onclick="closeModal('modalEditBanner')">&times;</button>
            </div>
            
            <div class="modal-body">
                <div class="cropper-container" id="cropperContainer">
                    <img id="cropperImage" src="" style="max-width: 100%;">
                </div>
                
                <div class="grid-2 mt-4">
                    <div class="form-group">
                        <label class="form-label">Duración (segundos)</label>
                        <input type="number" id="bannerDuration" class="form-input" min="2" max="15" value="5">
                    </div>
                    
                    <div class="form-group">
                        <label class="form-label">Animación</label>
                        <select id="bannerAnimation" class="form-input">
                            <option value="fade">Fade</option>
                            <option value="slide">Slide</option>
                            <option value="zoom">Zoom</option>
                        </select>
                    </div>
                </div>
            </div>
            
            <div class="modal-footer">
                <button type="button" class="btn-modal secondary" onclick="closeModal('modalEditBanner')">Cancelar</button>
                <button type="button" class="btn-modal primary" onclick="applyBannerEdit()">Aplicar Cambios</button>
            </div>
        </div>
    </div>
    
    <!-- ========================================
         JAVASCRIPT
         ======================================== -->
    <script>
        // ========== ESTADO GLOBAL ==========
        let qMaint, qAnn;
        let currentCropper = null;
        let currentEditingBanner = null;
        let bannerUploads = [];
        let huinchasData = [];
        
        // ========== INICIALIZACIÓN ==========
        document.addEventListener('DOMContentLoaded', () => {
            initEditors();
            initNavigation();
            initListeners();
            initHuinchas();
            initBannersSortable();
            initPreview();
        });
        
        // ========== EDITORES QUILL ==========
        function initEditors() {
            qMaint = new Quill('#maintQuill', {
                theme: 'snow',
                modules: {
                    toolbar: [
                        ['bold', 'italic', 'underline'],
                        [{ 'header': [1, 2, 3, false] }],
                        [{ 'color': [] }, { 'align': [] }]
                    ]
                }
            });
            
            qAnn = new Quill('#annQuill', {
                theme: 'snow',
                modules: {
                    toolbar: [['bold', 'italic'], [{ 'color': [] }]]
                }
            });
            
            qMaint.on('text-change', updatePreview);
            qAnn.on('text-change', updatePreview);
        }
        
        // ========== NAVEGACIÓN SIDEBAR ==========
        function initNavigation() {
            document.querySelectorAll('.nav-item').forEach(item => {
                item.addEventListener('click', () => {
                    // Actualizar nav activo
                    document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
                    item.classList.add('active');
                    
                    // Mostrar sección correspondiente
                    const section = item.dataset.section;
                    document.querySelectorAll('.section-panel').forEach(panel => {
                        panel.classList.remove('active');
                    });
                    document.getElementById(`section-${section}`).classList.add('active');
                });
            });
        }
        
        // ========== LISTENERS GENERALES ==========
        function initListeners() {
            // Color pickers
            document.getElementById('annBg').addEventListener('input', (e) => {
                document.getElementById('previewAnnBg').style.backgroundColor = e.target.value;
                e.target.nextElementSibling.textContent = e.target.value;
                updatePreview();
            });
            
            document.getElementById('annColor').addEventListener('input', (e) => {
                document.getElementById('previewAnnColor').style.backgroundColor = e.target.value;
                e.target.nextElementSibling.textContent = e.target.value;
                updatePreview();
            });
            
            // Switches
            document.getElementById('maintSwitch').addEventListener('change', updatePreview);
            document.getElementById('annSwitch').addEventListener('change', updatePreview);
            document.getElementById('tickerSwitch').addEventListener('change', updatePreview);
            
            // Sliders
            document.getElementById('sliderSpeed').addEventListener('input', (e) => {
                document.getElementById('sliderSpeedText').textContent = e.target.value + 's';
                updatePreview();
            });
            
            document.getElementById('tickerSpeedRange').addEventListener('input', (e) => {
                document.getElementById('speedDisplay').textContent = e.target.value + 's';
                document.getElementById('tickerSpeedHidden').value = e.target.value;
                updatePreview();
            });
            
            // Upload zone
            const uploadZone = document.getElementById('uploadZone');
            const fileInput = document.getElementById('fileInput');
            
            uploadZone.onclick = () => fileInput.click();
            
            uploadZone.addEventListener('dragover', (e) => {
                e.preventDefault();
                uploadZone.style.borderColor = 'var(--cygnus-primary)';
            });
            
            uploadZone.addEventListener('dragleave', () => {
                uploadZone.style.borderColor = '#cbd5e1';
            });
            
            uploadZone.addEventListener('drop', (e) => {
                e.preventDefault();
                uploadZone.style.borderColor = '#cbd5e1';
                handleFiles(e.dataTransfer.files);
            });
            
            fileInput.addEventListener('change', (e) => {
                handleFiles(e.target.files);
                fileInput.value = '';
            });
            
            // Device selector
            document.querySelectorAll('.device-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    document.querySelectorAll('.device-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    
                    const device = btn.dataset.device;
                    const frame = document.getElementById('previewFrame');
                    frame.className = `preview-frame ${device}`;
                });
            });
            
            // Preview iframe reload
            setTimeout(() => {
                document.getElementById('liveIframe').onload = () => {
                    setTimeout(updatePreview, 500);
                };
            }, 1000);
        }
        
        // ========== HUINCHAS ==========
        function initHuinchas() {
            try {
                const stored = <%= JSON.stringify(config.promo_strips || []) %>;
                huinchasData = Array.isArray(stored) ? stored : [];
            } catch(e) {
                huinchasData = [];
            }
            renderHuinchas();
        }
        
        function addHuincha() {
            huinchasData.push({
                id: Date.now(),
                text: 'Nueva promoción',
                icon: 'fa-star',
                bgColor: '#2563eb',
                textColor: '#ffffff',
                active: true
            });
            renderHuinchas();
            updatePreview();
        }
        
        function renderHuinchas() {
            const container = document.getElementById('huinchasContainer');
            container.innerHTML = huinchasData.map((h, idx) => `
                <div class="huincha-card">
                    <div class="huincha-header">
                        <h4 style="font-size: 1rem; font-weight: 700; color: #0f172a;">Huincha #${idx + 1}</h4>
                        <label class="toggle-switch">
                            <input type="checkbox" ${h.active ? 'checked' : ''} onchange="toggleHuincha(${idx}, this.checked)">
                            <span class="toggle-slider"></span>
                            <span class="toggle-label">Activa</span>
                        </label>
                    </div>
                    <div class="huincha-controls">
                        <div class="form-group">
                            <label class="form-label">Texto</label>
                            <input type="text" class="form-input" value="${h.text}" onchange="updateHuincha(${idx}, 'text', this.value)">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Icono (Font Awesome)</label>
                            <input type="text" class="form-input" value="${h.icon}" onchange="updateHuincha(${idx}, 'icon', this.value)" placeholder="fa-star">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Color Fondo</label>
                            <input type="color" class="form-input" value="${h.bgColor}" onchange="updateHuincha(${idx}, 'bgColor', this.value)">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Color Texto</label>
                            <input type="color" class="form-input" value="${h.textColor}" onchange="updateHuincha(${idx}, 'textColor', this.value)">
                        </div>
                    </div>
                    <button type="button" class="btn-banner delete" style="width: auto; margin-top: 12px;" onclick="deleteHuincha(${idx})">
                        <i class="fas fa-trash"></i> Eliminar
                    </button>
                </div>
            `).join('');
        }
        
        function toggleHuincha(idx, active) {
            huinchasData[idx].active = active;
            updatePreview();
        }
        
        function updateHuincha(idx, field, value) {
            huinchasData[idx][field] = value;
            updatePreview();
        }
        
        function deleteHuincha(idx) {
            Swal.fire({
                title: '¿Eliminar huincha?',
                text: 'Esta acción no se puede deshacer',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    huinchasData.splice(idx, 1);
                    renderHuinchas();
                    updatePreview();
                }
            });
        }
        
        // ========== BANNERS ==========
        function handleFiles(files) {
            Array.from(files).forEach(file => {
                if (!file.type.startsWith('image/')) return;
                
                const reader = new FileReader();
                reader.onload = (e) => {
                    const uid = Date.now() + Math.random();
                    bannerUploads.push({
                        id: uid,
                        file: file,
                        url: e.target.result,
                        align: '50% 50%',
                        duration: 5,
                        animation: 'fade'
                    });
                    createBannerCard(uid, e.target.result, '50% 50%', 5, 'fade', true);
                    updatePreview();
                };
                reader.readAsDataURL(file);
            });
        }
        
        function createBannerCard(id, url, align, duration, animation, isNew) {
            const container = document.getElementById('bannersContainer');
            const div = document.createElement('div');
            div.className = 'banner-card';
            div.dataset.type = isNew ? 'new' : 'existing';
            div.dataset.id = id;
            div.dataset.url = url;
            div.dataset.align = align;
            div.dataset.duration = duration;
            div.dataset.animation = animation;
            
            div.innerHTML = `
                <img src="${url}" style="object-position: ${align};">
                <div class="banner-timing">${duration}s</div>
                <div class="banner-overlay">
                    <div class="banner-actions">
                        <button type="button" class="btn-banner edit" onclick="editBanner(this)">
                            <i class="fas fa-edit"></i> Editar
                        </button>
                        <button type="button" class="btn-banner delete" onclick="deleteBanner(this)">
                            <i class="fas fa-trash"></i> Eliminar
                        </button>
                    </div>
                </div>
            `;
            
            container.appendChild(div);
        }
        
        function initBannersSortable() {
            new Sortable(document.getElementById('bannersContainer'), {
                animation: 200,
                ghostClass: 'sortable-ghost',
                onEnd: updatePreview
            });
        }
        
        function editBanner(btn) {
            const card = btn.closest('.banner-card');
            currentEditingBanner = card;
            
            const img = card.querySelector('img');
            document.getElementById('cropperImage').src = img.src;
            document.getElementById('bannerDuration').value = card.dataset.duration || 5;
            document.getElementById('bannerAnimation').value = card.dataset.animation || 'fade';
            
            openModal('modalEditBanner');
            
            setTimeout(() => {
                if (currentCropper) currentCropper.destroy();
                currentCropper = new Cropper(document.getElementById('cropperImage'), {
                    aspectRatio: 16 / 9,
                    viewMode: 1,
                    autoCropArea: 1
                });
            }, 300);
        }
        
        function applyBannerEdit() {
            if (!currentEditingBanner || !currentCropper) return;
            
            const canvas = currentCropper.getCroppedCanvas();
            const newUrl = canvas.toDataURL();
            
            currentEditingBanner.querySelector('img').src = newUrl;
            currentEditingBanner.dataset.url = newUrl;
            currentEditingBanner.dataset.duration = document.getElementById('bannerDuration').value;
            currentEditingBanner.dataset.animation = document.getElementById('bannerAnimation').value;
            currentEditingBanner.querySelector('.banner-timing').textContent = document.getElementById('bannerDuration').value + 's';
            
            closeModal('modalEditBanner');
            updatePreview();
        }
        
        function deleteBanner(btn) {
            const card = btn.closest('.banner-card');
            if (card.classList.contains('first-banner')) {
                Swal.fire('No permitido', 'No puedes eliminar el banner original', 'error');
                return;
            }
            
            Swal.fire({
                title: '¿Eliminar banner?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    card.remove();
                    updatePreview();
                }
            });
        }
        
        // ========== PREVIEW ==========
        function initPreview() {
            setTimeout(() => {
                updatePreview();
            }, 1500);
        }
        
        function updatePreview() {
            // Esta función inyectaría cambios en el iframe
            // Por ahora solo recarga
            const iframe = document.getElementById('liveIframe');
            if (iframe && iframe.contentWindow) {
                // Aquí podrías inyectar CSS/HTML dinámicamente
                console.log('Preview updated');
            }
        }
        
        // ========== MODALES ==========
        function openModal(id) {
            document.getElementById(id).classList.add('active');
        }
        
        function closeModal(id) {
            document.getElementById(id).classList.remove('active');
            if (currentCropper) {
                currentCropper.destroy();
                currentCropper = null;
            }
        }
        
        // ========== GUARDAR CONFIGURACIÓN ==========
        async function saveAllConfiguration() {
            const formData = new FormData();
            
            // Mantenimiento
            formData.append('maintenance_active', document.getElementById('maintSwitch').checked);
            formData.append('maintenance_message', qMaint.root.innerHTML);
            formData.append('maintenance_eta', document.querySelector('[name="maintenance_eta"]').value);
            
            // Announcement
            formData.append('announcement_active', document.getElementById('annSwitch').checked);
            formData.append('announcement_bg', document.getElementById('annBg').value);
            formData.append('announcement_color', document.getElementById('annColor').value);
            formData.append('announcement_text', qAnn.root.innerHTML);
            
            // Huinchas
            formData.append('ticker_active', document.getElementById('tickerSwitch').checked);
            formData.append('ticker_speed', document.getElementById('tickerSpeedRange').value);
            formData.append('promo_strips_json', JSON.stringify(huinchasData));
            
            // Slider
            formData.append('slider_speed', document.getElementById('sliderSpeed').value);
            
            // Banners
            const banners = [];
            document.querySelectorAll('.banner-card').forEach((card, idx) => {
                if (card.dataset.type === 'existing') {
                    banners.push({
                        url: card.dataset.url,
                        align: card.dataset.align,
                        duration: card.dataset.duration,
                        animation: card.dataset.animation
                    });
                }
            });
            formData.append('banners', JSON.stringify(banners));
            
            // Nuevos banners (archivos)
            bannerUploads.forEach((upload, idx) => {
                formData.append(`new_banner_${idx}`, upload.file);
                formData.append(`new_banner_${idx}_duration`, upload.duration);
                formData.append(`new_banner_${idx}_animation`, upload.animation);
            });
            
            // Marca
            formData.append('company_name', document.querySelector('[name="company_name"]').value);
            formData.append('company_slogan', document.querySelector('[name="company_slogan"]').value);
            formData.append('brand_primary', document.querySelector('[name="brand_primary"]').value);
            formData.append('brand_secondary', document.querySelector('[name="brand_secondary"]').value);
            
            try {
                const response = await fetch('/admin/configuracion/update', {
                    method: 'POST',
                    body: formData
                });
                
                const result = await response.json();
                
                if (result.success) {
                    Swal.fire('¡Guardado!', 'Configuración actualizada correctamente', 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    Swal.fire('Error', result.message || 'No se pudo guardar', 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                Swal.fire('Error', 'Error de conexión', 'error');
            }
        }
    </script>
    
</body>
</html>
