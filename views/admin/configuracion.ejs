<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <title>Configuración | Cygnus Group</title>
    
    <link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" rel="stylesheet">
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/config-dashboard.css">
</head>
<body>
    
    <div class="app-layout">
        <%- include('../partials/sidebar-admin') %>
        
        <main class="main-content">
            
            <div class="config-dashboard-wrapper">
                
                <!-- PANEL IZQUIERDO - EDITOR -->
                <div class="config-editor-panel">
                    
                    <div class="config-editor-header">
                        <h1 class="config-title">
                            <i class="fas fa-cog"></i>
                            Configuración del Sitio
                        </h1>
                        <p class="config-subtitle">Gestiona el contenido y apariencia de tu sitio web</p>
                    </div>
                    
                    <div class="config-editor-content">
                        <form id="configForm" method="POST" action="/admin/configuracion/update" enctype="multipart/form-data">
                            
                            <!-- MODO MANTENIMIENTO -->
                            <section class="config-section">
                                <div class="section-header">
                                    <h2 class="section-title">
                                        <i class="fas fa-hard-hat"></i>
                                        Modo Mantenimiento
                                    </h2>
                                    <label class="toggle-switch">
                                        <input type="checkbox" name="maintenance_active" id="maintSwitch" <%= config.maintenance_active ? 'checked' : '' %>>
                                        <span class="toggle-track"></span>
                                    </label>
                                </div>
                                
                                <div class="form-group">
                                    <label class="form-label">Mensaje para los visitantes</label>
                                    <textarea name="maintenance_message" id="maintenanceMessage" class="form-textarea" rows="4"><%= config.maintenance_message || 'Sitio en Mantenimiento. Volvemos pronto con mejoras.' %></textarea>
                                </div>
                                
                                <div class="form-group">
                                    <label class="form-label">Tiempo estimado de regreso</label>
                                    <input type="text" class="form-input" name="maintenance_eta" value="<%= config.maintenance_eta || '2 horas' %>" placeholder="Ej: 2 horas, mañana">
                                </div>
                            </section>
                            
                            <!-- BARRA DE ANUNCIOS -->
                            <section class="config-section">
                                <div class="section-header">
                                    <h2 class="section-title">
                                        <i class="fas fa-bullhorn"></i>
                                        Barra de Anuncios
                                    </h2>
                                    <label class="toggle-switch">
                                        <input type="checkbox" name="announcement_active" id="annSwitch" <%= config.announcement_active ? 'checked' : '' %>>
                                        <span class="toggle-track"></span>
                                    </label>
                                </div>
                                
                                <div class="color-picker-group mb-3">
                                    <div class="color-picker-box">
                                        <div class="color-preview" style="background-color: <%= config.announcement_bg || '#1e293b' %>;"></div>
                                        <div class="color-input-wrapper">
                                            <label class="form-label mb-2">Fondo</label>
                                            <input type="color" name="announcement_bg" id="annBg" value="<%= config.announcement_bg || '#1e293b' %>">
                                            <p class="color-hex" id="hexAnnBg"><%= config.announcement_bg || '#1e293b' %></p>
                                        </div>
                                    </div>
                                    
                                    <div class="color-picker-box">
                                        <div class="color-preview" style="background-color: <%= config.announcement_color || '#ffffff' %>;"></div>
                                        <div class="color-input-wrapper">
                                            <label class="form-label mb-2">Texto</label>
                                            <input type="color" name="announcement_color" id="annColor" value="<%= config.announcement_color || '#ffffff' %>">
                                            <p class="color-hex" id="hexAnnColor"><%= config.announcement_color || '#ffffff' %></p>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="form-group">
                                    <label class="form-label">Contenido del anuncio</label>
                                    <textarea name="announcement_text" id="announcementText" class="form-textarea" rows="3"><%= config.announcement_text || '¡Contáctanos hoy mismo!' %></textarea>
                                </div>
                            </section>
                            
                            <!-- HUINCHAS PROMOCIONALES -->
                            <section class="config-section">
                                <div class="section-header">
                                    <h2 class="section-title">
                                        <i class="fas fa-ribbon"></i>
                                        Huinchas Promocionales
                                    </h2>
                                    <label class="toggle-switch">
                                        <input type="checkbox" name="ticker_active" id="tickerSwitch" <%= (config.ticker_active !== false) ? 'checked' : '' %>>
                                        <span class="toggle-track"></span>
                                    </label>
                                </div>
                                
                                <div class="form-group">
                                    <label class="form-label">Velocidad de desplazamiento</label>
                                    <input type="range" name="ticker_speed" min="20" max="60" value="<%= config.ticker_speed || 35 %>" id="tickerSpeedRange" class="range-slider">
                                    <p class="form-hint mt-2">Velocidad: <strong id="speedDisplay"><%= config.ticker_speed || 35 %>s</strong></p>
                                </div>
                                
                                <input type="hidden" name="promo_strips_json" id="promoStripsJson">
                                
                                <div id="huinchasContainer"></div>
                                
                                <button type="button" class="btn btn-secondary btn-block mt-3" onclick="addHuincha()">
                                    <i class="fas fa-plus"></i>
                                    Agregar Huincha
                                </button>
                            </section>
                            
                            <!-- SLIDER DE BANNERS -->
                            <section class="config-section">
                                <div class="section-header">
                                    <h2 class="section-title">
                                        <i class="fas fa-images"></i>
                                        Slider de Banners
                                    </h2>
                                    <div style="display: flex; align-items: center; gap: 12px;">
                                        <label class="form-label" style="margin: 0;">Velocidad</label>
                                        <input type="range" name="slider_speed" id="sliderSpeed" min="2" max="10" value="<%= config.slider_speed || 5 %>" class="range-slider" style="width: 100px;">
                                        <span class="text-sm text-muted"><strong id="sliderSpeedText"><%= config.slider_speed || 5 %>s</strong></span>
                                    </div>
                                </div>
                                
                                <div class="upload-zone" id="uploadZone">
                                    <i class="fas fa-cloud-upload-alt upload-icon"></i>
                                    <p class="upload-text">Arrastra imágenes o haz click</p>
                                    <p class="upload-hint">JPG, PNG, WebP (Máx 10MB)</p>
                                    <input type="file" name="new_banners" id="fileInput" multiple accept="image/*" style="display:none;">
                                </div>
                                
                                <div id="existingBannersContainer"></div>
                                
                                <div class="banners-grid" id="bannersContainer">
                                    <% if(config.banners && config.banners.length > 0) { %>
                                        <% config.banners.forEach((b, idx) => { %>
                                            <div class="banner-item <%= idx === 0 ? 'first-banner' : '' %>" data-index="<%= idx %>">
                                                <img src="<%= b.url %>" style="object-position: <%= b.align || '50% 50%' %>;" alt="Banner">
                                                
                                                <% if(idx === 0) { %>
                                                    <div class="banner-badge first">Original</div>
                                                <% } %>
                                                
                                                <div class="banner-timing"><%= b.duration || 5 %>s</div>
                                                
                                                <div class="banner-overlay">
                                                    <div class="banner-actions">
                                                        <% if(idx !== 0) { %>
                                                            <button type="button" class="btn btn-danger btn-sm" onclick="removeBanner(<%= idx %>)">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        <% } %>
                                                    </div>
                                                </div>
                                                
                                                <input type="hidden" name="existing_banners_urls" value="<%= b.url %>">
                                                <input type="hidden" name="existing_banners_align" value="<%= b.align || '50% 50%' %>">
                                            </div>
                                        <% }) %>
                                    <% } %>
                                </div>
                            </section>
                            
                        </form>
                    </div>
                    
                    <div class="config-editor-footer">
                        <button type="button" class="btn btn-primary btn-block" onclick="saveConfiguration()" id="btnSave">
                            <i class="fas fa-save"></i>
                            Guardar Todos los Cambios
                        </button>
                    </div>
                    
                </div>
                
                <!-- PANEL DERECHO - PREVIEW -->
                <div class="config-preview-panel">
                    
                    <div class="preview-header">
                        <h3 class="preview-title">
                            <i class="fas fa-eye"></i>
                            Vista Previa en Vivo
                        </h3>
                        <div class="device-selector">
                            <button type="button" class="device-btn active" data-device="desktop" onclick="switchDevice('desktop')">
                                <i class="fas fa-desktop"></i> Escritorio
                            </button>
                            <button type="button" class="device-btn" data-device="mobile" onclick="switchDevice('mobile')">
                                <i class="fas fa-mobile-alt"></i> Móvil
                            </button>
                        </div>
                    </div>
                    
                    <div class="preview-viewport">
                        <div class="preview-frame desktop" id="previewFrame">
                            <iframe id="liveIframe" src="/" style="width:100%; height:100%; border:none;"></iframe>
                        </div>
                    </div>
                    
                </div>
                
            </div>
            
        </main>
    </div>
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js"></script>
    
    <script>
        // ========== ESTADO GLOBAL ==========
        let huinchasData = [];
        let debounceTimer = null;
        
        // ========== INICIALIZACIÓN ==========
        document.addEventListener('DOMContentLoaded', () => {
            initListeners();
            loadHuinchas();
            initBannersSortable();
            
            // Mostrar mensaje de éxito/error
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('success')) {
                Swal.fire({
                    icon: 'success',
                    title: '¡Guardado!',
                    text: 'Configuración actualizada correctamente',
                    timer: 2000,
                    showConfirmButton: false
                });
                window.history.replaceState({}, '', '/admin/configuracion');
            }
            if (urlParams.get('error')) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'No se pudo guardar la configuración'
                });
                window.history.replaceState({}, '', '/admin/configuracion');
            }
        });
        
        // ========== LISTENERS ==========
        function initListeners() {
            // Color pickers
            document.getElementById('annBg').addEventListener('input', (e) => {
                document.getElementById('hexAnnBg').textContent = e.target.value.toUpperCase();
                updatePreview();
            });
            
            document.getElementById('annColor').addEventListener('input', (e) => {
                document.getElementById('hexAnnColor').textContent = e.target.value.toUpperCase();
                updatePreview();
            });
            
            // Sliders
            document.getElementById('sliderSpeed').addEventListener('input', (e) => {
                document.getElementById('sliderSpeedText').textContent = e.target.value + 's';
            });
            
            document.getElementById('tickerSpeedRange').addEventListener('input', (e) => {
                document.getElementById('speedDisplay').textContent = e.target.value + 's';
            });
            
            // Switches
            document.getElementById('maintSwitch').addEventListener('change', updatePreview);
            document.getElementById('annSwitch').addEventListener('change', updatePreview);
            document.getElementById('tickerSwitch').addEventListener('change', updatePreview);
            
            // Upload zone
            const uploadZone = document.getElementById('uploadZone');
            const fileInput = document.getElementById('fileInput');
            
            uploadZone.onclick = () => fileInput.click();
            
            uploadZone.addEventListener('dragover', (e) => {
                e.preventDefault();
                uploadZone.style.borderColor = 'var(--config-primary)';
            });
            
            uploadZone.addEventListener('dragleave', () => {
                uploadZone.style.borderColor = 'var(--config-gray-300)';
            });
            
            uploadZone.addEventListener('drop', (e) => {
                e.preventDefault();
                uploadZone.style.borderColor = 'var(--config-gray-300)';
                const files = e.dataTransfer.files;
                fileInput.files = files;
                showUploadedFiles(files);
            });
            
            fileInput.addEventListener('change', (e) => {
                showUploadedFiles(e.target.files);
            });
        }
        
        // ========== PREVIEW ==========
        function updatePreview() {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => {
                const iframe = document.getElementById('liveIframe');
                if (iframe) {
                    iframe.src = iframe.src;
                }
            }, 1000);
        }
        
        function switchDevice(device) {
            document.querySelectorAll('.device-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.closest('.device-btn').classList.add('active');
            
            const frame = document.getElementById('previewFrame');
            frame.className = `preview-frame ${device}`;
        }
        
        // ========== HUINCHAS ==========
        function loadHuinchas() {
            try {
                const stored = <%- JSON.stringify(config.promo_strips || []) %>;
                huinchasData = Array.isArray(stored) ? stored : [];
            } catch(e) {
                console.error('Error cargando huinchas:', e);
                huinchasData = [];
            }
            renderHuinchas();
        }
        
        function addHuincha() {
            huinchasData.push({
                id: Date.now(),
                text: 'Nueva promoción',
                icon: 'fa-star',
                bgColor: '#2563eb',
                textColor: '#ffffff',
                active: true
            });
            renderHuinchas();
        }
        
        function renderHuinchas() {
            const container = document.getElementById('huinchasContainer');
            
            if (huinchasData.length === 0) {
                container.innerHTML = '<p class="text-muted text-sm">No hay huinchas configuradas. Agrega una para comenzar.</p>';
                return;
            }
            
            container.innerHTML = huinchasData.map((h, idx) => `
                <div class="config-card">
                    <div class="card-header">
                        <h4 class="card-title">Huincha #${idx + 1}</h4>
                        <div class="card-actions">
                            <label class="toggle-switch">
                                <input type="checkbox" ${h.active ? 'checked' : ''} onchange="toggleHuincha(${idx}, this.checked)">
                                <span class="toggle-track"></span>
                            </label>
                            <button type="button" class="btn btn-danger btn-sm" onclick="deleteHuincha(${idx})">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                    <div class="grid-2">
                        <div class="form-group">
                            <label class="form-label">Texto</label>
                            <input type="text" class="form-input" value="${h.text || ''}" onchange="updateHuincha(${idx}, 'text', this.value)">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Icono (Font Awesome)</label>
                            <input type="text" class="form-input" value="${h.icon || 'fa-star'}" onchange="updateHuincha(${idx}, 'icon', this.value)" placeholder="fa-star">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Color Fondo</label>
                            <input type="color" class="form-input" value="${h.bgColor || '#2563eb'}" onchange="updateHuincha(${idx}, 'bgColor', this.value)">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Color Texto</label>
                            <input type="color" class="form-input" value="${h.textColor || '#ffffff'}" onchange="updateHuincha(${idx}, 'textColor', this.value)">
                        </div>
                    </div>
                </div>
            `).join('');
            
            // Actualizar hidden input
            document.getElementById('promoStripsJson').value = JSON.stringify(huinchasData);
        }
        
        function toggleHuincha(idx, active) {
            huinchasData[idx].active = active;
            document.getElementById('promoStripsJson').value = JSON.stringify(huinchasData);
        }
        
        function updateHuincha(idx, field, value) {
            huinchasData[idx][field] = value;
            document.getElementById('promoStripsJson').value = JSON.stringify(huinchasData);
        }
        
        function deleteHuincha(idx) {
            Swal.fire({
                title: '¿Eliminar huincha?',
                text: 'Esta acción no se puede deshacer',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Eliminar',
                cancelButtonText: 'Cancelar',
                confirmButtonColor: '#ef4444'
            }).then((result) => {
                if (result.isConfirmed) {
                    huinchasData.splice(idx, 1);
                    renderHuinchas();
                }
            });
        }
        
        // ========== BANNERS ==========
        function showUploadedFiles(files) {
            if (files.length === 0) return;
            
            const container = document.getElementById('bannersContainer');
            const uploadZone = document.getElementById('uploadZone');
            
            Array.from(files).forEach((file, idx) => {
                if (!file.type.startsWith('image/')) {
                    Swal.fire('Error', 'Solo se permiten archivos de imagen', 'error');
                    return;
                }
                
                if (file.size > 10 * 1024 * 1024) {
                    Swal.fire('Error', 'El archivo no debe superar 10MB', 'error');
                    return;
                }
                
                const reader = new FileReader();
                reader.onload = (e) => {
                    const div = document.createElement('div');
                    div.className = 'banner-item';
                    div.innerHTML = `
                        <img src="${e.target.result}" alt="Nuevo Banner">
                        <div class="banner-badge" style="background: var(--config-primary);">Nuevo</div>
                        <div class="banner-timing">5s</div>
                        <div class="banner-overlay">
                            <div class="banner-actions">
                                <button type="button" class="btn btn-danger btn-sm" onclick="this.closest('.banner-item').remove()">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    `;
                    container.appendChild(div);
                };
                reader.readAsDataURL(file);
            });
            
            uploadZone.innerHTML = `
                <i class="fas fa-check-circle upload-icon" style="color: var(--config-success);"></i>
                <p class="upload-text">${files.length} archivo(s) seleccionado(s)</p>
                <p class="upload-hint">Click para agregar más</p>
            `;
        }
        
        function removeBanner(index) {
            Swal.fire({
                title: '¿Eliminar banner?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Eliminar',
                cancelButtonText: 'Cancelar',
                confirmButtonColor: '#ef4444'
            }).then((result) => {
                if (result.isConfirmed) {
                    const banner = document.querySelector(`.banner-item[data-index="${index}"]`);
                    if (banner) banner.remove();
                }
            });
        }
        
        function initBannersSortable() {
            new Sortable(document.getElementById('bannersContainer'), {
                animation: 200,
                ghostClass: 'sortable-ghost',
                handle: '.banner-item'
            });
        }
        
        // ========== GUARDAR ==========
        function saveConfiguration() {
            const btnSave = document.getElementById('btnSave');
            const originalText = btnSave.innerHTML;
            
            // Validar que hay al menos un banner
            const existingBanners = document.querySelectorAll('input[name="existing_banners_urls"]').length;
            const newBanners = document.getElementById('fileInput').files.length;
            
            if (existingBanners === 0 && newBanners === 0) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Atención',
                    text: 'Debes tener al menos un banner en el slider'
                });
                return;
            }
            
            // Actualizar JSON de huinchas antes de enviar
            document.getElementById('promoStripsJson').value = JSON.stringify(huinchasData);
            
            // Loader
            btnSave.disabled = true;
            btnSave.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';
            
            // Enviar formulario
            const form = document.getElementById('configForm');
            form.submit();
        }
    </script>
    
</body>
</html>
