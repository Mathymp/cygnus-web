<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/inmobiliaria.css">
    <style>
        html,body.dashboard-body{height:100%!important;overflow:hidden!important}
        body.dashboard-body .app-layout{height:100vh!important;overflow:hidden!important}
        body.dashboard-body .main-content{height:100%!important;min-height:0!important;overflow:hidden!important}
        body.dashboard-body .dashboard-scroll{height:auto!important;min-height:0!important;overflow-y:auto!important;padding-bottom:70px!important}
        .cartera-top{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;flex-wrap:wrap;margin:18px 0 16px}
        .cartera-title{display:flex;gap:12px;align-items:center}
        .cartera-title-icon{width:46px;height:46px;border-radius:13px;background:linear-gradient(135deg,#1d4ed8,#2563eb);color:#fff;display:grid;place-items:center;font-size:1.35rem;box-shadow:0 8px 18px rgba(37,99,235,.2)}
        .cartera-title h1{margin:0;font-size:1.55rem;color:#0f172a}
        .cartera-title p{margin:3px 0 0;font-size:.82rem;color:#64748b}
        .filters{display:flex;gap:8px;align-items:center;flex-wrap:wrap;background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:8px}
        .filters select{border:0;background:#f8fafc;border-radius:8px;padding:9px 12px;font:inherit;font-size:.8rem;color:#334155;outline:none;min-width:165px}
        .kpi-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;margin-bottom:14px}
        .kpi{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:15px 16px;box-shadow:0 2px 8px rgba(15,23,42,.035);position:relative;overflow:hidden}
        .kpi::after{content:"";position:absolute;right:-20px;top:-20px;width:70px;height:70px;border-radius:50%;background:var(--soft,#eff6ff)}
        .kpi-head{display:flex;align-items:center;gap:7px;font-size:.7rem;color:#64748b;font-weight:800;text-transform:uppercase;letter-spacing:.4px;position:relative;z-index:1}
        .kpi-head i{color:var(--color,#2563eb);font-size:.95rem}
        .kpi-value{font-size:1.42rem;font-weight:850;color:#0f172a;margin-top:7px;line-height:1.15;position:relative;z-index:1}
        .kpi-sub{font-size:.7rem;color:#64748b;margin-top:4px;position:relative;z-index:1}
        .section-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:14px;margin-bottom:14px}
        .panel{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:17px;box-shadow:0 2px 8px rgba(15,23,42,.035);min-width:0}
        .panel-title{display:flex;justify-content:space-between;align-items:center;gap:8px;margin-bottom:14px}
        .panel-title h2{margin:0;font-size:.92rem;color:#0f172a;display:flex;align-items:center;gap:7px}
        .panel-title h2 i{color:#2563eb}
        .panel-title small{font-size:.68rem;color:#94a3b8}
        .inv-row{display:grid;grid-template-columns:100px 1fr 55px;align-items:center;gap:9px;margin:10px 0}
        .inv-label{font-size:.76rem;color:#475569;font-weight:650}
        .progress{height:9px;background:#f1f5f9;border-radius:20px;overflow:hidden}
        .progress>span{display:block;height:100%;border-radius:20px}
        .inv-num{text-align:right;font-size:.78rem;font-weight:800;color:#334155}
        .mini-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:9px}
        .mini{border-radius:10px;padding:11px;background:#f8fafc;border:1px solid #f1f5f9}
        .mini-label{font-size:.67rem;text-transform:uppercase;color:#64748b;font-weight:750}
        .mini-value{font-size:1rem;color:#0f172a;font-weight:800;margin-top:3px}
        .insight{display:flex;gap:10px;padding:11px 12px;border-radius:10px;margin-bottom:8px;font-size:.76rem;line-height:1.45}
        .insight i{font-size:1rem;flex-shrink:0;margin-top:1px}
        .insight.info{background:#eff6ff;color:#1e40af;border:1px solid #bfdbfe}
        .insight.warn{background:#fffbeb;color:#92400e;border:1px solid #fde68a}
        .insight.danger{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
        .insight.ok{background:#ecfdf5;color:#065f46;border:1px solid #a7f3d0}
        .table-wrap{overflow-x:auto;border:1px solid #e2e8f0;border-radius:11px}
        .ctable{width:100%;border-collapse:collapse;min-width:800px}
        .ctable th{background:#f8fafc;color:#64748b;font-size:.66rem;text-transform:uppercase;letter-spacing:.4px;text-align:left;padding:10px;white-space:nowrap}
        .ctable td{padding:10px;border-top:1px solid #f1f5f9;font-size:.76rem;color:#334155;vertical-align:middle}
        .ctable tr:hover td{background:#fafcff}
        .type-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
        .type-card{border:1px solid #e2e8f0;border-radius:11px;padding:12px}
        .type-card h3{margin:0 0 9px;font-size:.8rem;color:#0f172a}
        .type-stats{display:flex;gap:6px;flex-wrap:wrap}
        .pill{font-size:.66rem;font-weight:750;padding:3px 7px;border-radius:20px}
        .pill-d{background:#dcfce7;color:#166534}.pill-r{background:#fef3c7;color:#92400e}.pill-v{background:#dbeafe;color:#1e40af}
        .agent-row{display:grid;grid-template-columns:minmax(100px,1fr) 70px 110px;gap:8px;align-items:center;padding:9px 0;border-bottom:1px solid #f1f5f9}
        .agent-row:last-child{border:0}.agent-name{font-size:.76rem;font-weight:700;color:#334155}.agent-meta{font-size:.68rem;color:#94a3b8}
        .trend{display:flex;align-items:flex-end;gap:6px;height:140px;padding-top:10px}
        .trend-col{flex:1;height:100%;display:flex;flex-direction:column;justify-content:flex-end;align-items:center;gap:4px;min-width:18px}
        .trend-bar{width:100%;max-width:28px;background:linear-gradient(180deg,#60a5fa,#2563eb);border-radius:5px 5px 2px 2px;min-height:2px;transition:.2s}
        .trend-col:hover .trend-bar{background:#1d4ed8}
        .trend-label{font-size:.56rem;color:#94a3b8;white-space:nowrap;transform:rotate(-35deg);margin:6px 0 -4px}
        .loading{padding:70px;text-align:center;color:#64748b}
        .loading i{font-size:2rem;display:block;margin-bottom:8px}
        .empty{font-size:.77rem;color:#94a3b8;text-align:center;padding:20px}
        @media(max-width:1100px){.kpi-grid{grid-template-columns:repeat(2,1fr)}.section-grid{grid-template-columns:1fr}}
        @media(max-width:620px){.kpi-grid{grid-template-columns:1fr}.filters{width:100%}.filters select{flex:1;min-width:130px}.type-grid{grid-template-columns:1fr}.dashboard-scroll{padding:1rem!important}}
    </style>
</head>
<body class="dashboard-body">
<div class="app-layout">
    <%- include('../partials/sidebar-admin', { page: 'cartera-im' }) %>
    <main class="main-content">
        <div class="dashboard-scroll">
            <div class="cartera-top">
                <div class="cartera-title">
                    <div class="cartera-title-icon"><i class="bi bi-graph-up-arrow"></i></div>
                    <div><h1>Cartera Ejecutiva</h1><p>Inventario, ventas vigentes y cobranza consolidada · datos reales del sistema</p></div>
                </div>
                <div class="filters">
                    <select id="f-proyecto"><option value="">Todos los proyectos</option></select>
                    <select id="f-tipo">
                        <option value="">Con Rol + En Verde</option>
                        <option value="con_rol_propio">Solo Con Rol</option>
                        <option value="en_verde">Solo En Verde</option>
                    </select>
                    <button class="im-btn im-btn-primary im-btn-sm" onclick="loadCartera()"><i class="bi bi-arrow-clockwise"></i> Actualizar</button>
                </div>
            </div>
            <div id="cartera-root"><div class="loading"><i class="bi bi-hourglass-split"></i>Cargando métricas de cartera...</div></div>
        </div>
    </main>
</div>
<script>
const $=id=>document.getElementById(id);
const n=v=>Number(v)||0;
const fmt=v=>Math.round(n(v)).toLocaleString('es-CL');
const money=v=>'$'+fmt(v);
const pct=(a,b)=>b>0?Math.round((n(a)/n(b))*100):0;
const esc=s=>String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
const shortMoney=v=>{const x=n(v);if(x>=1e9)return '$'+(x/1e9).toFixed(1).replace('.',',')+' mil MM';if(x>=1e6)return '$'+(x/1e6).toFixed(1).replace('.',',')+' MM';return money(x);};

async function loadFilters(){
    try{
        const r=await fetch('/api/im/proyectos');if(!r.ok)return;
        const ps=await r.json();
        $('f-proyecto').innerHTML='<option value="">Todos los proyectos</option>'+ps.map(p=>`<option value="${p.id}">${esc(p.nombre)}</option>`).join('');
    }catch(_){}
}

function kpi(icon,label,value,sub,color='#2563eb',soft='#eff6ff'){
    return `<div class="kpi" style="--color:${color};--soft:${soft}"><div class="kpi-head"><i class="bi ${icon}"></i>${label}</div><div class="kpi-value">${value}</div><div class="kpi-sub">${sub}</div></div>`;
}

function insights(d){
    const i=d.inventario,v=d.ventas,c=d.cobranza,r=d.resciliaciones;
    const out=[];
    const ocup=pct(n(i.reservadas)+n(i.vendidas),n(i.total));
    const sinAsignar=(d.agentes||[]).find(a=>a.agente==='Sin asignar');
    if(sinAsignar&&n(sinAsignar.operaciones)>0)out.push(`<div class="insight warn"><i class="bi bi-person-exclamation"></i><div><strong>Ventas sin ejecutivo:</strong> hay ${sinAsignar.operaciones} operación(es) vigentes sin responsable asignado por ${money(sinAsignar.monto)}.</div></div>`);
    if(n(c.monto_mora)>0)out.push(`<div class="insight danger"><i class="bi bi-exclamation-octagon-fill"></i><div><strong>Atención de cobranza:</strong> hay ${c.cuotas_vencidas} cuota(s) vencida(s) por ${money(c.monto_mora)}, correspondientes a ${c.contratos_en_mora} contrato(s).</div></div>`);
    else out.push(`<div class="insight ok"><i class="bi bi-check-circle-fill"></i><div><strong>Cartera sin mora registrada:</strong> no existen cuotas vencidas en ventas activas bajo este filtro.</div></div>`);
    if(n(i.disponibles)>0)out.push(`<div class="insight info"><i class="bi bi-box-seam-fill"></i><div><strong>Capacidad comercial:</strong> quedan ${i.disponibles} parcelas disponibles por un valor de lista de ${money(i.valor_inventario_disponible)}.</div></div>`);
    if(n(v.reservas_vigentes)>0)out.push(`<div class="insight warn"><i class="bi bi-clock-history"></i><div><strong>Pipeline:</strong> ${v.reservas_vigentes} operación(es) siguen reservadas sin compraventa firmada. Conviene revisar su avance documental.</div></div>`);
    if(n(c.vencen_30_dias)>0)out.push(`<div class="insight info"><i class="bi bi-calendar-event"></i><div><strong>Próximos 30 días:</strong> vencen ${c.vencen_30_dias} cuota(s); prioriza recordatorios preventivos.</div></div>`);
    out.push(`<div class="insight ${ocup>=70?'ok':'info'}"><i class="bi bi-speedometer2"></i><div><strong>Avance comercial global:</strong> ${ocup}% del inventario está vendido o reservado.</div></div>`);
    return out.join('');
}

function render(d){
    const i=d.inventario,v=d.ventas,c=d.cobranza,r=d.resciliaciones;
    const ocup=pct(n(i.reservadas)+n(i.vendidas),n(i.total));
    const maxTrend=Math.max(1,...d.tendencia.map(x=>n(x.monto)));
    const maxAgent=Math.max(1,...d.agentes.map(x=>n(x.monto)));
    $('cartera-root').innerHTML=`
        <div class="kpi-grid">
            ${kpi('bi-grid-3x3-gap-fill','Inventario total',fmt(i.total),`${i.disponibles} disponibles · ${i.reservadas} reservadas · ${i.vendidas} vendidas`)}
            ${kpi('bi-box-seam-fill','Valor disponible',shortMoney(i.valor_inventario_disponible),`${i.disponibles} parcelas listas para comercializar`,'#059669','#ecfdf5')}
            ${kpi('bi-cash-stack','Cartera acordada',shortMoney(v.cartera_acordada),`${v.operaciones_activas} operaciones activas · ticket ${shortMoney(v.ticket_promedio)}`,'#7c3aed','#f5f3ff')}
            ${kpi('bi-exclamation-triangle-fill','Mora vigente',shortMoney(c.monto_mora),`${c.cuotas_vencidas} cuotas · ${c.contratos_en_mora} contratos`,'#dc2626','#fef2f2')}
            ${kpi('bi-check2-circle','Ventas cerradas',fmt(v.ventas_cerradas),`${v.reservas_vigentes} reservas aún en proceso`,'#2563eb','#eff6ff')}
            ${kpi('bi-wallet2','Cobrado en cuotas',shortMoney(c.monto_cobrado),`${c.cuotas_pagadas} cuotas registradas como pagadas`,'#059669','#ecfdf5')}
            ${kpi('bi-hourglass-split','Saldo de cuotas',shortMoney(c.saldo_pendiente),`${c.cuotas_pendientes} cuotas pendientes`,'#d97706','#fffbeb')}
            ${kpi('bi-arrow-counterclockwise','Devoluciones pendientes',shortMoney(r.devolucion_pendiente),`${r.total_resciliaciones} resciliaciones · ${r.devoluciones_abiertas} abiertas`,'#e11d48','#fff1f2')}
        </div>

        <div class="section-grid">
            <section class="panel">
                <div class="panel-title"><h2><i class="bi bi-pie-chart-fill"></i> Inventario y avance comercial</h2><small>${ocup}% comprometido</small></div>
                <div class="inv-row"><span class="inv-label">Disponibles</span><div class="progress"><span style="width:${pct(i.disponibles,i.total)}%;background:#10b981"></span></div><span class="inv-num">${i.disponibles}</span></div>
                <div class="inv-row"><span class="inv-label">Reservadas</span><div class="progress"><span style="width:${pct(i.reservadas,i.total)}%;background:#f59e0b"></span></div><span class="inv-num">${i.reservadas}</span></div>
                <div class="inv-row"><span class="inv-label">Vendidas</span><div class="progress"><span style="width:${pct(i.vendidas,i.total)}%;background:#2563eb"></span></div><span class="inv-num">${i.vendidas}</span></div>
                <div class="mini-grid" style="margin-top:15px">
                    <div class="mini"><div class="mini-label">Metraje total</div><div class="mini-value">${fmt(i.metraje_total)} m²</div></div>
                    <div class="mini"><div class="mini-label">Metraje disponible</div><div class="mini-value">${fmt(i.metraje_disponible)} m²</div></div>
                    <div class="mini"><div class="mini-label">Operaciones contado</div><div class="mini-value">${v.operaciones_contado} · ${shortMoney(v.monto_contado)}</div></div>
                    <div class="mini"><div class="mini-label">Operaciones crédito</div><div class="mini-value">${v.operaciones_credito} · ${shortMoney(v.monto_credito)}</div></div>
                </div>
            </section>
            <section class="panel">
                <div class="panel-title"><h2><i class="bi bi-lightbulb-fill"></i> Lectura ejecutiva</h2><small>Generada con los datos actuales</small></div>
                ${insights(d)}
            </section>
        </div>

        <div class="section-grid">
            <section class="panel">
                <div class="panel-title"><h2><i class="bi bi-bar-chart-line-fill"></i> Operaciones activas · últimos 12 meses</h2><small>Por fecha de venta</small></div>
                <div class="trend">${d.tendencia.map(x=>`<div class="trend-col" title="${esc(x.etiqueta)}: ${x.operaciones} operaciones · ${money(x.monto)}"><span style="font-size:.58rem;color:#64748b">${x.operaciones||''}</span><div class="trend-bar" style="height:${Math.max(2,(n(x.monto)/maxTrend)*100)}%"></div><span class="trend-label">${esc(x.mes.slice(5))}/${esc(x.mes.slice(2,4))}</span></div>`).join('')}</div>
            </section>
            <section class="panel">
                <div class="panel-title"><h2><i class="bi bi-person-badge-fill"></i> Ventas por ejecutivo</h2><small>Asignaciones vigentes guardadas en cada venta</small></div>
                ${d.agentes.length?d.agentes.map(a=>`<div class="agent-row"><div><div class="agent-name">${esc(a.agente)}</div><div class="agent-meta">${a.cerradas} vendidas · ${a.reservas} reservadas · ${pct(a.cerradas,a.operaciones)}% cierre</div></div><div class="agent-meta"><strong>${a.operaciones}</strong> venta${n(a.operaciones)!==1?'s':''}<br>ticket ${shortMoney(a.ticket)}</div><div><div class="agent-name" style="text-align:right">${shortMoney(a.monto)}</div><div class="progress" style="height:4px;margin-top:4px"><span style="width:${(n(a.monto)/maxAgent)*100}%;background:${a.agente==='Sin asignar'?'#f59e0b':'#2563eb'}"></span></div></div></div>`).join(''):'<div class="empty">Sin ventas vigentes asignadas a ejecutivos.</div>'}
            </section>
        </div>

        <section class="panel" style="margin-bottom:14px">
            <div class="panel-title"><h2><i class="bi bi-buildings-fill"></i> Resultado por proyecto</h2><small>Inventario, cartera y cobranza</small></div>
            <div class="table-wrap"><table class="ctable"><thead><tr><th>Proyecto</th><th>Tipo</th><th>Total</th><th>Disponibles</th><th>Reservadas</th><th>Vendidas</th><th>Avance</th><th>Valor disponible</th><th>Cartera</th><th>Saldo cuotas</th><th>Mora</th></tr></thead><tbody>
                ${d.proyectos.map(p=>`<tr><td><a href="/admin/inmobiliaria/proyectos/${p.id}" style="color:#2563eb;font-weight:750">${esc(p.nombre)}</a></td><td><span class="pill ${p.tipo_proyecto==='con_rol_propio'?'pill-d':'pill-r'}">${p.tipo_proyecto==='con_rol_propio'?'Con Rol':'En Verde'}</span></td><td>${p.total}</td><td>${p.disponibles}</td><td>${p.reservadas}</td><td>${p.vendidas}</td><td><strong>${pct(n(p.reservadas)+n(p.vendidas),n(p.total))}%</strong></td><td>${money(p.valor_disponible)}</td><td>${money(p.cartera)}</td><td>${money(p.saldo)}</td><td style="color:${n(p.mora)>0?'#dc2626':'#059669'};font-weight:750">${money(p.mora)}</td></tr>`).join('')||'<tr><td colspan="11" class="empty">Sin proyectos bajo este filtro.</td></tr>'}
            </tbody></table></div>
        </section>

        <div class="section-grid">
            <section class="panel">
                <div class="panel-title"><h2><i class="bi bi-map-fill"></i> Inventario por condición legal</h2><small>Con Rol vs En Verde</small></div>
                <div class="type-grid">${d.tipos.map(t=>`<div class="type-card"><h3>${t.tipo==='con_rol_propio'?'<i class="bi bi-patch-check-fill" style="color:#059669"></i> Con Rol Propio':'<i class="bi bi-hourglass-split" style="color:#d97706"></i> En Verde'}</h3><div style="font-size:1.15rem;font-weight:850;margin-bottom:7px">${t.total} parcelas</div><div class="type-stats"><span class="pill pill-d">${t.disponibles} disponibles</span><span class="pill pill-r">${t.reservadas} reservadas</span><span class="pill pill-v">${t.vendidas} vendidas</span></div></div>`).join('')||'<div class="empty">Sin inventario.</div>'}</div>
            </section>
            <section class="panel">
                <div class="panel-title"><h2><i class="bi bi-bell-fill"></i> Prioridad de cobranza</h2><a href="/admin/inmobiliaria/cuotas" style="font-size:.7rem;color:#2563eb;font-weight:700">Ver todas →</a></div>
                ${d.alertas_mora.length?`<div style="max-height:260px;overflow-y:auto">${d.alertas_mora.map(a=>`<a href="/admin/inmobiliaria/parcela/${a.parcela_id}" style="display:flex;justify-content:space-between;gap:10px;padding:9px 0;border-bottom:1px solid #f1f5f9"><div><div style="font-size:.75rem;font-weight:750;color:#334155">${esc(a.cliente)}</div><div style="font-size:.67rem;color:#94a3b8">${esc(a.proyecto)} · P${esc(a.numero_parcela)} · Cuota ${a.numero_cuota}</div></div><div style="text-align:right"><div style="font-size:.75rem;font-weight:800;color:#dc2626">${money(a.monto)}</div><div style="font-size:.65rem;color:#dc2626">${a.dias_atraso} días atraso</div></div></a>`).join('')}</div>`:'<div class="empty"><i class="bi bi-check-circle-fill" style="color:#10b981;font-size:1.2rem"></i><br>Sin cuotas vencidas en cartera activa.</div>'}
            </section>
        </div>
        <p style="font-size:.66rem;color:#94a3b8;margin:4px 2px">Criterio: cartera y cuotas consideran únicamente ventas activas. “Cobrado en cuotas” no incluye automáticamente pagos al contado ni pies sin confirmación bancaria. Actualizado: ${new Date(d.generado_en).toLocaleString('es-CL')}.</p>`;
}

async function loadCartera(){
    $('cartera-root').innerHTML='<div class="loading"><i class="bi bi-hourglass-split"></i>Calculando métricas reales...</div>';
    const q=new URLSearchParams();
    if($('f-proyecto').value)q.set('proyecto_id',$('f-proyecto').value);
    if($('f-tipo').value)q.set('tipo_proyecto',$('f-tipo').value);
    try{
        const r=await fetch('/api/im/cartera?'+q.toString());
        const d=await r.json().catch(()=>({}));
        if(!r.ok)throw new Error(d.message||d.error||`Error ${r.status}`);
        render(d);
    }catch(e){
        $('cartera-root').innerHTML=`<div class="panel" style="text-align:center;color:#991b1b;padding:35px"><i class="bi bi-exclamation-triangle-fill" style="font-size:2rem"></i><h3>No se pudo calcular la cartera</h3><p>${esc(e.message)}</p><button class="im-btn im-btn-primary" onclick="loadCartera()">Reintentar</button></div>`;
    }
}

$('f-proyecto').addEventListener('change',loadCartera);
$('f-tipo').addEventListener('change',loadCartera);
document.addEventListener('DOMContentLoaded',async()=>{await loadFilters();loadCartera()});
</script>
</body>
</html>
