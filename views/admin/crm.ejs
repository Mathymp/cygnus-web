<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    
    <style>
        .tabs-header { display: flex; gap: 20px; border-bottom: 2px solid #e2e8f0; margin-bottom: 20px; margin-top: 20px;}
        .tab-btn { background: none; border: none; padding: 10px 0; font-size: 1rem; font-weight: 600; color: #94a3b8; cursor: pointer; position: relative; }
        .tab-btn.active { color: #2563eb; }
        .tab-btn.active::after { content: ''; position: absolute; bottom: -2px; left: 0; width: 100%; height: 2px; background: #2563eb; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        
        .modal-overlay { background: rgba(15, 23, 42, 0.85); backdrop-filter: blur(8px); display: flex; justify-content: center; align-items: flex-start; position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1000; opacity: 0; pointer-events: none; transition: 0.3s; padding-top: 5vh; overflow-y: auto;}
        .modal-overlay.show { opacity: 1; pointer-events: auto; }
        .modal-card { background: white; width: 100%; max-width: 600px; border-radius: 16px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); display: flex; flex-direction: column; transform: translateY(20px); transition: transform 0.3s; }
        .modal-overlay.show .modal-card { transform: translateY(0); }
        .modal-header { padding: 20px 25px; border-bottom: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center; }
        .modal-body { padding: 25px; }

        .switch-group { background: #f1f5f9; padding: 4px; border-radius: 12px; display: flex; margin-bottom: 20px; gap: 5px; }
        .switch-btn { flex: 1; padding: 10px; border: none; border-radius: 8px; background: transparent; font-weight: 600; color: #64748b; cursor: pointer; transition: 0.2s; font-size: 0.85rem; }
        .switch-btn.active { box-shadow: 0 2px 5px rgba(0,0,0,0.05); color: white; }
        #btn-type-visita.active { background: #2563eb; }
        #btn-type-reserva.active { background: #f59e0b; }
        #btn-type-venta.active { background: #10b981; }

        .price-box { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 15px; margin-top: 10px; }
        .price-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; font-size: 0.9rem; color: #64748b; }
        .price-row.total { border-top: 1px solid #cbd5e1; padding-top: 10px; margin-top: 10px; color: #0f172a; font-weight: 700; font-size: 1.1rem; }
        .price-val { font-family: monospace; font-size: 1rem; }
        
        .input-group { margin-bottom: 15px; }
        .input-group label { display: block; margin-bottom: 5px; font-weight: 600; font-size: 0.85rem; color: #334155; }
        .styled-input { width: 100%; padding: 10px 14px; border: 1px solid #cbd5e1; border-radius: 8px; font-family: inherit; }
    </style>
</head>
<body class="dashboard-body">

    <%- include('../partials/alerts') %>

    <div class="app-layout">
        <%- include('../partials/sidebar-admin', { page: 'crm' }) %>

        <main class="main-content">
            <div class="dashboard-scroll">
                <div class="dashboard-header" style="margin-top: 20px;">
                    <div>
                        <h1 class="page-title">Gestión Comercial y Clientes</h1>
                        <p style="color:#64748b; margin-top: 5px;">Control total de tu base de clientes y operaciones.</p>
                    </div>
                    <div style="display: flex; gap: 10px;">
                        <button class="btn-primary-block" style="width: auto; margin:0; background: #3b82f6;" onclick="openModal('cliente')"><i class="bi bi-person-plus-fill"></i> Nuevo Cliente</button>
                        <button class="btn-primary-block" style="width: auto; margin:0; background: #10b981;" onclick="openCRMModal()"><i class="bi bi-plus-circle-fill"></i> Nueva Operación</button>
                    </div>
                </div>

                <div class="tabs-header">
                    <button class="tab-btn active" onclick="switchTab('ventas')">💰 Operaciones y Ventas</button>
                    <button class="tab-btn" onclick="switchTab('clientes')">👥 Directorio de Clientes</button>
                </div>

                <div id="tab-ventas" class="tab-content active">
                    <div class="table-responsive">
                        <table class="management-table">
                            <thead>
                                <tr>
                                    <th>Fecha</th><th>Tipo</th><th>Cliente</th><th>Proyecto / Lote</th>
                                    <th style="text-align: right;">Total Op.</th>
                                    <th style="text-align: right;">Pagado</th>
                                    <th style="text-align: center;">Info</th>
                                </tr>
                            </thead>
                            <tbody id="ventas-tbody"><tr><td colspan="7" style="text-align:center; padding:30px;">Cargando operaciones...</td></tr></tbody>
                        </table>
                    </div>
                </div>

                <div id="tab-clientes" class="tab-content">
                    <div class="table-responsive">
                        <table class="management-table">
                            <thead>
                                <tr>
                                    <th>Cliente</th><th>RUT</th><th>Contacto</th><th>Notas</th><th>Registro</th>
                                    <th style="text-align: center;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="clients-table-body"><tr><td colspan="6" style="text-align:center; padding:30px;">Cargando clientes...</td></tr></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="modal-cliente" class="modal-overlay">
        <div class="modal-card" style="max-width: 500px;">
            <div class="modal-header"><h3 id="modal-title-cli">Nuevo Cliente</h3><button class="btn-close" onclick="closeModal('cliente')"><i class="bi bi-x-lg"></i></button></div>
            <form id="form-cliente">
                <input type="hidden" id="client-id" name="id">
                <div class="modal-body">
                    <div class="input-group"><label>Nombre Completo</label><input type="text" class="styled-input" id="input-nombre" name="nombre" required></div>
                    <div class="input-group"><label>RUT</label><input type="text" class="styled-input" id="input-rut" name="rut" maxlength="12"></div>
                    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px;">
                        <div class="input-group"><label>Email</label><input type="email" class="styled-input" name="email"></div>
                        <div class="input-group"><label>Teléfono</label><input type="text" class="styled-input" name="telefono"></div>
                    </div>
                    <div class="input-group"><label>Notas</label><textarea class="styled-input" name="notas" rows="2"></textarea></div>
                    <button type="submit" class="btn-primary-block" id="btn-save-cli">Guardar Cliente</button>
                </div>
            </form>
        </div>
    </div>

    <div id="modal-crm" class="modal-overlay">
        <div class="modal-card">
            <div class="modal-header"><h3 style="margin:0;">Registrar Acción</h3><button class="btn-close" onclick="closeModal('crm')" style="background:transparent;border:none;"><i class="bi bi-x-lg"></i></button></div>
            <div class="modal-body">
                <div class="switch-group">
                    <button class="switch-btn active" onclick="setType('visita')" id="btn-type-visita">Visita</button>
                    <button class="switch-btn" onclick="setType('reserva')" id="btn-type-reserva">Reserva</button>
                    <button class="switch-btn" onclick="setType('venta')" id="btn-type-venta">Venta Final</button>
                </div>
                <form id="crm-form">
                    <input type="hidden" id="action-type" value="visita">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div class="input-group"><label>Proyecto</label><select id="select-proyecto" class="styled-input" onchange="loadLotes(this.value)" required></select></div>
                        <div class="input-group" id="group-lote"><label>Lote</label><select id="select-lote" class="styled-input" onchange="handleLoteChange()" disabled></select></div>
                    </div>
                    
                    <div class="input-group"><label>Cliente</label><select id="select-cliente" class="styled-input" required></select></div>
                    
                    <div id="fields-visita">
                        <div style="display:flex;gap:10px;"><input type="date" id="fecha-input" class="styled-input"><input type="time" id="hora-input" class="styled-input"></div>
                    </div>

                    <div id="fields-finance" style="display:none;">
                        <div class="price-box">
                            <div class="price-row"><span>Precio Lista</span><span class="price-val" id="disp-precio-lista">$0</span></div>
                            <div class="input-group" id="group-precio-acordado"><label>Precio Acordado</label><input type="text" id="input-precio-acordado" class="styled-input" oninput="formatInput(this); updateCalculations()"></div>
                            <div class="input-group" id="group-monto-reserva"><label id="label-reserva">Monto Reserva (Pagado)</label><input type="text" id="input-monto-reserva" class="styled-input" oninput="formatInput(this); updateCalculations()"></div>
                            
                            <div id="extended-finance" style="display:none; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 15px;">
                                <div class="input-group"><label>Monto Pie</label><input type="text" id="input-monto-pie" class="styled-input" placeholder="$0" oninput="formatInput(this); updateCalculations()"></div>
                                <div class="input-group"><label>N° Cuotas</label><input type="number" id="input-cuotas" class="styled-input" value="0"></div>
                                <div class="input-group"><label>Banco / Emisor</label><input type="text" id="input-banco" class="styled-input" placeholder="Ej: Santander"></div>
                                <div class="input-group"><label>N° Documento</label><input type="text" id="input-documento" class="styled-input" placeholder="Vale Vista/Transferencia"></div>
                            </div>
                            
                            <div class="price-row total"><span id="label-total">A Pagar Hoy:</span><span class="price-val" id="disp-total-pagar" style="color:#10b981;">$0</span></div>
                        </div>
                        <div class="input-group" style="margin-top:15px;"><label>Método de Pago</label><select id="metodo-pago" class="styled-input"><option value="Transferencia">Transferencia</option><option value="Vale Vista">Vale Vista</option><option value="Credito Directo">Crédito Directo</option></select></div>
                    </div>

                    <div class="input-group" style="margin-top:10px;"><label>Notas / Comentarios Bancarios</label><textarea id="notas" class="styled-input" rows="2"></textarea></div>
                    <button type="submit" class="btn-primary-block" style="margin-top:15px; width:100%; padding:12px; background:#10b981; color:white; border:none; border-radius:8px; font-weight:bold; cursor:pointer;">Guardar Registro</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        let lotesData = []; 
        let currentTab = 'ventas';

        function switchTab(tab) {
            currentTab = tab;
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
            document.getElementById(`tab-${tab}`).classList.add('active');
            event.target.classList.add('active');
        }

        function parseInput(val) { return parseInt((val || '').toString().replace(/[\$\.\s]/g, '')) || 0; }
        function fmt(val) { return Math.floor(val).toLocaleString('es-CL'); }
        function formatInput(input) { let val = input.value.replace(/\D/g, ''); input.value = val.replace(/\B(?=(\d{3})+(?!\d))/g, "."); }

        function openModal(id) { document.getElementById(`modal-${id}`).classList.add('show'); }
        function openCRMModal() { document.getElementById('modal-crm').classList.add('show'); setType('venta'); }
        function closeModal(id) { document.getElementById(`modal-${id}`).classList.remove('show'); }

        function setType(type) {
            document.getElementById('action-type').value = type;
            document.querySelectorAll('.switch-btn').forEach(b => b.classList.remove('active'));
            document.getElementById(`btn-type-${type}`).classList.add('active');
            
            const isVisita = type === 'visita';
            document.getElementById('fields-visita').style.display = isVisita ? 'block' : 'none';
            document.getElementById('fields-finance').style.display = isVisita ? 'none' : 'block';
            document.getElementById('group-lote').style.visibility = isVisita ? 'hidden' : 'visible'; 
            
            const extFinance = document.getElementById('extended-finance');
            if (type === 'reserva') {
                document.getElementById('group-precio-acordado').style.display = 'none'; 
                extFinance.style.display = 'none';
                document.getElementById('label-reserva').innerText = "Monto Reserva (Pago Actual)";
                document.getElementById('label-total').innerText = "Total Pagado Hoy:";
            } else if (type === 'venta') {
                document.getElementById('group-precio-acordado').style.display = 'block';
                extFinance.style.display = 'grid';
                document.getElementById('label-reserva').innerText = "Menos Reserva (Ya pagada)";
                document.getElementById('label-total').innerText = "Saldo a Financiar / Pagar:";
            }
            updateCalculations();
        }

        async function loadInitialData() {
            const [proyectos, clientes, ventas] = await Promise.all([
                fetch('/api/proyectos').then(r => r.json()),
                fetch('/api/clientes').then(r => r.json()),
                fetch('/api/ventas').then(r => r.json())
            ]);
            
            // Llenar Selects
            const selP = document.getElementById('select-proyecto'); selP.innerHTML = '<option value="">Selecciona...</option>';
            proyectos.forEach(p => selP.innerHTML += `<option value="${p.id}">${p.nombre}</option>`);
            
            const selC = document.getElementById('select-cliente'); selC.innerHTML = '<option value="">Selecciona cliente...</option>';
            const tbodyC = document.getElementById('clients-table-body'); tbodyC.innerHTML = '';
            clientes.forEach(c => {
                selC.innerHTML += `<option value="${c.id}">${c.nombre} (${c.rut || 'S/R'})</option>`;
                tbodyC.innerHTML += `<tr><td><strong>${c.nombre}</strong></td><td>${c.rut||'-'}</td><td>${c.email||'-'}<br>${c.telefono||'-'}</td><td>${c.notas||'-'}</td><td>${new Date(c.creado_en).toLocaleDateString()}</td><td style="text-align:center;"><button onclick="alert('Funciones de edición disponibles próximamente')" style="background:#eff6ff; border:none; padding:5px 10px; border-radius:5px;"><i class="bi bi-pencil" style="color:#2563eb;"></i></button></td></tr>`;
            });

            // Llenar Ventas
            const tbodyV = document.getElementById('ventas-tbody'); tbodyV.innerHTML = '';
            ventas.forEach(v => {
                const tipoBadge = v.tipo_operacion === 'reserva' ? '<span style="background:#fef3c7;color:#d97706;padding:4px 8px;border-radius:6px;font-size:0.75rem;font-weight:bold;">RESERVA</span>' : '<span style="background:#dcfce7;color:#166534;padding:4px 8px;border-radius:6px;font-size:0.75rem;font-weight:bold;">VENTA</span>';
                tbodyV.innerHTML += `<tr><td>${new Date(v.fecha_venta).toLocaleDateString()}</td><td>${tipoBadge}</td><td><strong>${v.cliente_nombre}</strong></td><td>${v.proyecto_nombre} <br><small>Lote: ${v.numero_lote}</small></td><td style="text-align:right;">$${fmt(v.precio_acordado)}</td><td style="text-align:right; font-weight:bold; color:#10b981;">$${fmt(v.valor_final)}</td><td style="text-align:center;"><i class="bi bi-check-circle-fill" style="color:#2563eb;"></i></td></tr>`;
            });
        }

        async function loadLotes(projectId) {
            if(!projectId) return;
            const sel = document.getElementById('select-lote'); sel.disabled = true; sel.innerHTML = '<option>Cargando...</option>';
            const res = await fetch(`/api/lotes/proyecto/${projectId}`);
            const data = await res.json();
            lotesData = data.filter(l => l.tipo === 'lote');
            sel.innerHTML = '<option value="">Selecciona lote...</option>';
            lotesData.forEach(l => {
                if (l.estado_id === 3) return; // No mostrar vendidos
                sel.innerHTML += `<option value="${l.id}">Lote ${l.numero_lote} - $${fmt(l.precio)}</option>`;
            });
            sel.disabled = false;
        }

        function handleLoteChange() {
            const loteId = document.getElementById('select-lote').value;
            const lote = lotesData.find(l => l.id == loteId);
            if(lote) {
                document.getElementById('disp-precio-lista').innerText = `$${fmt(lote.precio)}`;
                document.getElementById('input-precio-acordado').value = fmt(lote.precio);
            }
            updateCalculations();
        }

        function updateCalculations() {
            const type = document.getElementById('action-type').value;
            const precioAcordado = parseInput(document.getElementById('input-precio-acordado').value);
            const reserva = parseInput(document.getElementById('input-monto-reserva').value);
            const pie = parseInput(document.getElementById('input-monto-pie').value);

            if (type === 'reserva') {
                document.getElementById('disp-total-pagar').innerText = `$${fmt(reserva)}`;
            } else if (type === 'venta') {
                const restante = Math.max(0, precioAcordado - reserva - pie);
                document.getElementById('disp-total-pagar').innerText = `$${fmt(restante)}`;
            }
        }

        document.getElementById('form-cliente').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('btn-save-cli'); btn.disabled = true;
            try {
                const data = Object.fromEntries(new FormData(e.target).entries());
                await fetch('/api/clientes', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(data) });
                closeModal('cliente'); loadInitialData();
            } catch(e) {} finally { btn.disabled = false; }
        });

        document.getElementById('crm-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const type = document.getElementById('action-type').value;
            const body = {
                cliente_id: document.getElementById('select-cliente').value,
                proyecto_id: document.getElementById('select-proyecto').value,
                lote_id: document.getElementById('select-lote').value,
                notas_generales: document.getElementById('notas').value
            };
            
            if (type === 'visita') {
                body.fecha_visita = `${document.getElementById('fecha-input').value}T${document.getElementById('hora-input').value}:00`;
                await fetch('/api/visitas', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(body) });
            } else {
                body.tipo_operacion = type; 
                body.precio_lista = parseInput(document.getElementById('disp-precio-lista').innerText);
                body.monto_reserva = parseInput(document.getElementById('input-monto-reserva').value);
                body.precio_acordado = parseInput(document.getElementById('input-precio-acordado').value);
                body.valor_final = parseInput(document.getElementById('disp-total-pagar').innerText);
                body.metodo_pago = document.getElementById('metodo-pago').value;
                
                if (type === 'venta') {
                    body.monto_pie = parseInput(document.getElementById('input-monto-pie').value);
                    body.cantidad_cuotas = document.getElementById('input-cuotas').value;
                    body.banco = document.getElementById('input-banco').value;
                    body.numero_documento = document.getElementById('input-documento').value;
                }
                await fetch('/api/ventas', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(body) });
            }
            closeModal('crm'); loadInitialData(); alert('Acción registrada con éxito. El visor 360 ha sido actualizado.');
        });

        document.addEventListener('DOMContentLoaded', loadInitialData);
    </script>
</body>
</html>