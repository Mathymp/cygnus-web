<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* CSS ORIGINAL DE VENTAS.HTML INTACTO */
        .modal-overlay { background: rgba(15, 23, 42, 0.85); backdrop-filter: blur(8px); align-items: flex-start; padding-top: 5vh; display: flex; justify-content: center; position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1000; opacity: 0; pointer-events: none; transition: 0.3s; }
        .modal-overlay.show { opacity: 1; pointer-events: auto; }
        .modal-card { background: white; width: 100%; max-width: 600px; border-radius: 16px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); max-height: 90vh; display: flex; flex-direction: column; transform: translateY(20px); transition: transform 0.3s; }
        .modal-overlay.show .modal-card { transform: translateY(0); }
        .modal-header { padding: 20px 25px; border-bottom: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center; flex-shrink: 0; }
        .modal-header h3 { margin: 0; font-size: 1.25rem; font-weight: 600; color: #0f172a; }
        .modal-body { flex-grow: 1; overflow-y: auto; padding: 25px; padding-right: 15px; }
        .btn-close { background: none; border: none; color: #64748b; cursor: pointer; font-size: 1.25rem; }
        .btn-icon-info { width: 34px; height: 34px; border-radius: 8px; border: none; cursor: pointer; background: #e0f2fe; color: #0284c7; display: flex; align-items: center; justify-content: center; transition: 0.2s; }
        .btn-icon-info:hover { background: #0284c7; color: white; transform: scale(1.05); }
        .tabs-header { display: flex; gap: 20px; border-bottom: 2px solid #e2e8f0; margin-bottom: 20px; }
        .tab-btn { background: none; border: none; padding: 10px 0; font-size: 1rem; font-weight: 600; color: #94a3b8; cursor: pointer; position: relative; }
        .tab-btn.active { color: #2563eb; }
        .tab-btn.active::after { content: ''; position: absolute; bottom: -2px; left: 0; width: 100%; height: 2px; background: #2563eb; }
        .tab-content { display: none; animation: fadeIn 0.3s ease; }
        .tab-content.active { display: block; }
        .switch-group { background: #f1f5f9; padding: 4px; border-radius: 12px; display: flex; margin-bottom: 20px; gap: 5px; }
        .switch-btn { flex: 1; padding: 10px; border: none; border-radius: 8px; background: transparent; font-weight: 600; color: #64748b; cursor: pointer; transition: 0.2s; font-size: 0.85rem; }
        .switch-btn.active { box-shadow: 0 2px 5px rgba(0,0,0,0.05); color: white; }
        #btn-type-visita.active { background: #2563eb; }
        #btn-type-reserva.active { background: #f59e0b; }
        #btn-type-venta.active { background: #10b981; }
        .price-box { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 15px; margin-top: 10px; }
        .price-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; font-size: 0.9rem; color: #64748b; }
        .price-row.total { border-top: 1px solid #cbd5e1; padding-top: 10px; margin-top: 10px; color: #0f172a; font-weight: 700; font-size: 1.1rem; }
        .price-val { font-family: monospace; font-size: 1rem; }
        .input-group { margin-bottom: 15px; }
        .input-group label { display: block; margin-bottom: 5px; font-weight: 600; font-size: 0.85rem; color: #334155; }
        .styled-input { width: 100%; padding: 10px 14px; border: 1px solid #cbd5e1; border-radius: 8px; font-family: inherit; font-size: 0.9rem; }
        .filters-bar { display: flex; gap: 15px; margin-bottom: 20px; align-items: center; }
        .filter-select { padding: 8px 12px; border-radius: 8px; border: 1px solid #e2e8f0; font-size: 0.9rem; min-width: 200px; color: #64748b; }
        .btn-primary-block { width: 100%; padding: 12px; background: #2563eb; color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer; transition: 0.2s; }
        .btn-primary-block:hover { background: #1d4ed8; }
        .btn-secondary { padding: 10px 20px; background: white; color: #475569; border: 1px solid #e2e8f0; border-radius: 8px; font-weight: 600; cursor: pointer; }
    </style>
</head>
<body class="dashboard-body">
    <%- include('../partials/alerts') %>
    <div class="app-layout">
        <%- include('../partials/sidebar-admin', { page: 'crm' }) %>

        <main class="main-content">
            <div class="dashboard-scroll">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 20px;">
                    <div><h1 style="font-size: 1.75rem; font-weight: 700; margin: 0;">Gestión Comercial</h1><p style="color:#64748b;">Control total de visitas, reservas y cierres.</p></div>
                    <button class="btn-primary-block" style="width: auto; margin:0;" onclick="openCRMModal()"><i class="bi bi-plus-circle-fill"></i> Nueva Acción</button>
                </div>
                
                <div class="filters-bar" style="margin-top: 20px;">
                    <i class="bi bi-funnel-fill" style="color:#94a3b8;"></i>
                    <select id="filter-proyecto" class="filter-select" onchange="applyFilters()"><option value="">Todos los Proyectos</option></select>
                </div>

                <div class="tabs-header">
                    <button class="tab-btn active" onclick="switchTab('ventas')">💰 Operaciones Financieras</button>
                    <button class="tab-btn" onclick="switchTab('visitas')">📅 Visitas</button>
                </div>

                <div id="tab-visitas" class="tab-content"><div class="projects-grid" id="visitas-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;"></div></div>

                <div id="tab-ventas" class="tab-content active">
                    <div class="table-responsive">
                        <table class="management-table" style="width: 100%; border-collapse: collapse; background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.04);">
                            <thead style="background: #f8fafc; text-align: left;">
                                <tr>
                                    <th style="padding: 15px;">Fecha</th><th>Tipo</th><th>Cliente</th><th>Proyecto</th><th>Lote</th>
                                    <th style="text-align: right;">Total Op.</th>
                                    <th style="text-align: right;">Pagado</th>
                                    <th style="text-align: center; padding: 15px;">Info</th>
                                </tr>
                            </thead>
                            <tbody id="ventas-tbody"><tr><td colspan="8" style="text-align:center; padding:30px;">Cargando...</td></tr></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="modal-crm" class="modal-overlay">
        <div class="modal-card">
            <div class="modal-header"><h3>Registrar Acción</h3><button class="btn-close" onclick="closeModal('crm')"><i class="bi bi-x-lg"></i></button></div>
            <div class="modal-body">
                <div class="switch-group">
                    <button class="switch-btn active" onclick="setType('visita')" id="btn-type-visita">Visita</button>
                    <button class="switch-btn" onclick="setType('reserva')" id="btn-type-reserva">Reserva</button>
                    <button class="switch-btn" onclick="setType('venta')" id="btn-type-venta">Venta Final</button>
                </div>
                <form id="crm-form">
                    <input type="hidden" id="action-type" value="visita">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div class="input-group"><label>Proyecto</label><select id="select-proyecto" class="styled-input" onchange="loadLotes(this.value)" required><option value="">Selecciona...</option></select></div>
                        <div class="input-group" id="group-lote"><label>Lote</label><select id="select-lote" class="styled-input" onchange="handleLoteChange()" disabled><option value="">Esperando...</option></select></div>
                    </div>
                    
                    <div class="input-group"><label>Cliente</label><select id="select-cliente" class="styled-input" required><option value="">Cargando...</option></select></div>
                    
                    <div id="fields-visita">
                        <label style="display:block; margin-bottom:5px; font-weight:600; font-size:0.85rem; color:#334155;">Fecha y Hora</label>
                        <div style="display:flex;gap:10px;"><input type="date" id="fecha-input" class="styled-input"><input type="time" id="hora-input" class="styled-input" style="max-width:120px;"></div>
                    </div>

                    <div id="fields-finance" style="display:none;">
                        <div class="price-box">
                            <div class="price-row"><span>Precio de Lista</span><span class="price-val" id="disp-precio-lista">$0</span></div>
                            <div class="input-group" id="group-precio-acordado" style="margin-bottom:10px;"><label>Precio Acordado</label><input type="text" id="input-precio-acordado" class="styled-input" placeholder="$0" oninput="formatInput(this); updateCalculations()"></div>
                            <div class="input-group" id="group-monto-reserva" style="margin-bottom:10px;"><label id="label-reserva">Monto Reserva (Pagado)</label><input type="text" id="input-monto-reserva" class="styled-input" placeholder="$0" oninput="formatInput(this); updateCalculations()"></div>
                            
                            <div id="campos-credito" style="display:none; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 15px;">
                                <div class="input-group"><label>Monto Pie Extra</label><input type="text" id="input-monto-pie" class="styled-input" placeholder="$0" oninput="formatInput(this); updateCalculations()"></div>
                                <div class="input-group"><label>Cantidad Cuotas</label><input type="number" id="input-cuotas" class="styled-input" value="0"></div>
                                <div class="input-group"><label>Banco</label><input type="text" id="input-banco" class="styled-input" placeholder="Ej: Santander"></div>
                                <div class="input-group"><label>N° Documento</label><input type="text" id="input-documento" class="styled-input" placeholder="Cheque / Vale Vista"></div>
                            </div>

                            <div class="price-row total"><span id="label-total">Total a Pagar Hoy:</span><span class="price-val" id="disp-total-pagar" style="color:var(--primary);">$0</span></div>
                        </div>
                        <div class="input-group" style="margin-top:15px;"><label>Método de Pago</label><select id="metodo-pago" class="styled-input"><option value="Transferencia">Transferencia</option><option value="Efectivo">Efectivo</option><option value="Vale Vista">Vale Vista</option><option value="Crédito Directo">Crédito Directo</option></select></div>
                    </div>

                    <div class="input-group" style="margin-top:10px;"><label>Notas</label><textarea id="notas" class="styled-input" rows="2" placeholder="Detalles..."></textarea></div>
                    <button type="submit" class="btn-primary-block" style="margin-top:15px; background: #10b981;">Guardar Registro</button>
                </form>
            </div>
        </div>
    </div>

    <div id="modal-info" class="modal-overlay">
        <div class="modal-card" style="max-width:400px;">
            <div class="modal-header"><h3>Detalle Operación</h3><button class="btn-close" onclick="closeModal('info')"><i class="bi bi-x-lg"></i></button></div>
            <div class="modal-body" id="info-body"></div>
            <div class="modal-footer" style="padding: 20px; border-top: 1px solid #e2e8f0; display:flex; justify-content: flex-end;"><button class="btn-secondary" style="width:100%;" onclick="closeModal('info')">Cerrar</button></div>
        </div>
    </div>

    <script>
        let lotesData = []; 
        let ventasData = []; 
        let visitasData = [];

        function parseDB(val) { return Math.floor(parseFloat(val || 0)); }
        function parseInput(val) { return parseInt((val || '').toString().replace(/[\$\.\s]/g, '')) || 0; }
        function fmt(val) { return Math.floor(val).toLocaleString('es-CL'); }
        function formatInput(input) { let val = input.value.replace(/\D/g, ''); input.value = val.replace(/\B(?=(\d{3})+(?!\d))/g, "."); }

        function switchTab(tab) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
            document.getElementById(`tab-${tab}`).classList.add('active');
            event.target.classList.add('active');
        }

        function openCRMModal() { document.getElementById('modal-crm').classList.add('show'); setType('venta'); }
        function closeModal(id) { document.getElementById(`modal-${id}`).classList.remove('show'); document.getElementById('crm-form').reset(); }

        function setType(type) {
            document.getElementById('action-type').value = type;
            document.querySelectorAll('.switch-btn').forEach(b => b.classList.remove('active'));
            document.getElementById(`btn-type-${type}`).classList.add('active');
            
            const isVisita = type === 'visita';
            document.getElementById('fields-visita').style.display = isVisita ? 'block' : 'none';
            document.getElementById('fields-finance').style.display = isVisita ? 'none' : 'block';
            document.getElementById('group-lote').style.visibility = isVisita ? 'hidden' : 'visible'; 
            
            if (type === 'reserva') {
                document.getElementById('group-precio-acordado').style.display = 'none'; 
                document.getElementById('campos-credito').style.display = 'none';
                document.getElementById('label-reserva').innerText = "Monto a Pagar para Reservar";
                document.getElementById('label-total').innerText = "Total Reserva:";
            } else if (type === 'venta') {
                document.getElementById('group-precio-acordado').style.display = 'block';
                document.getElementById('campos-credito').style.display = 'grid';
                document.getElementById('label-reserva').innerText = "Menos Reserva (Ya pagada)";
                document.getElementById('label-total').innerText = "Restante a Financiar / Pagar:";
            }
            updateCalculations();
        }

        async function loadInitialData() {
            const [proyectos, clientes, ventas, visitas] = await Promise.all([
                fetch('/api/proyectos').then(r => r.json()),
                fetch('/api/clientes').then(r => r.json()),
                fetch('/api/ventas').then(r => r.json()),
                fetch('/api/visitas').then(r => r.json())
            ]);
            
            const selP = document.getElementById('select-proyecto'); selP.innerHTML = '<option value="">Selecciona...</option>';
            const filterP = document.getElementById('filter-proyecto'); filterP.innerHTML = '<option value="">Todos los Proyectos</option>';
            proyectos.forEach(p => {
                selP.innerHTML += `<option value="${p.id}">${p.nombre}</option>`;
                filterP.innerHTML += `<option value="${p.id}">${p.nombre}</option>`;
            });
            
            const selC = document.getElementById('select-cliente'); selC.innerHTML = '<option value="">Selecciona cliente...</option>';
            clientes.forEach(c => selC.innerHTML += `<option value="${c.id}">${c.nombre} (${c.rut || 'S/R'})</option>`);
            
            ventasData = ventas;
            visitasData = visitas;
            applyFilters();
        }

        async function loadLotes(projectId) {
            if(!projectId) return;
            const sel = document.getElementById('select-lote'); sel.disabled = true; sel.innerHTML = '<option>Cargando...</option>';
            const res = await fetch(`/api/lotes/proyecto/${projectId}`);
            const data = await res.json();
            lotesData = data.filter(l => l.tipo === 'lote');
            sel.innerHTML = '<option value="">Selecciona lote...</option>';
            lotesData.forEach(l => {
                const type = document.getElementById('action-type').value;
                if (type === 'venta' && l.estado_id === 3) return; 
                sel.innerHTML += `<option value="${l.id}">Lote ${l.numero_lote} - $${fmt(l.precio)}</option>`;
            });
            sel.disabled = false;
        }

        async function handleLoteChange() {
            const loteId = document.getElementById('select-lote').value;
            if (!loteId) return;
            const lote = lotesData.find(l => l.id == loteId);
            if(lote) {
                document.getElementById('disp-precio-lista').innerText = `$${fmt(parseDB(lote.precio))}`;
                document.getElementById('input-precio-acordado').value = fmt(parseDB(lote.precio));
            }
            updateCalculations();
        }

        function updateCalculations() {
            const type = document.getElementById('action-type').value;
            const precioLista = parseInput(document.getElementById('disp-precio-lista').innerText);
            if (type === 'reserva') {
                const monto = parseInput(document.getElementById('input-monto-reserva').value);
                document.getElementById('disp-total-pagar').innerText = `$${fmt(monto)}`;
            } else if (type === 'venta') {
                const precioAcordado = parseInput(document.getElementById('input-precio-acordado').value) || precioLista;
                const reserva = parseInput(document.getElementById('input-monto-reserva').value);
                const pie = parseInput(document.getElementById('input-monto-pie').value);
                const restante = Math.max(0, precioAcordado - reserva - pie);
                document.getElementById('disp-total-pagar').innerText = `$${fmt(restante)}`;
            }
        }

        document.getElementById('crm-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const type = document.getElementById('action-type').value;
            const body = {
                cliente_id: document.getElementById('select-cliente').value,
                proyecto_id: document.getElementById('select-proyecto').value,
                lote_id: document.getElementById('select-lote').value || null,
                notas: document.getElementById('notas').value
            };
            
            if (type === 'visita') {
                body.fecha_visita = `${document.getElementById('fecha-input').value}T${document.getElementById('hora-input').value}:00`;
                await fetch('/api/visitas', { method: 'POST', headers: { 'Content-Type': 'application/json'}, body: JSON.stringify(body) });
            } else {
                body.tipo_operacion = type; 
                body.precio_lista = parseInput(document.getElementById('disp-precio-lista').innerText);
                body.monto_reserva = parseInput(document.getElementById('input-monto-reserva').value);
                body.metodo_pago = document.getElementById('metodo-pago').value;
                
                if (type === 'venta') {
                    body.precio_acordado = parseInput(document.getElementById('input-precio-acordado').value) || body.precio_lista;
                    body.valor_final = parseInput(document.getElementById('disp-total-pagar').innerText); 
                    body.monto_pie = parseInput(document.getElementById('input-monto-pie').value);
                    body.cantidad_cuotas = document.getElementById('input-cuotas').value;
                    body.banco = document.getElementById('input-banco').value;
                    body.numero_documento = document.getElementById('input-documento').value;
                } else {
                    body.precio_acordado = body.precio_lista; 
                    body.valor_final = body.monto_reserva; 
                }
                await fetch('/api/ventas', { method: 'POST', headers: { 'Content-Type': 'application/json'}, body: JSON.stringify(body) });
            }
            closeModal('crm');
            loadInitialData(); 
        });

        function applyFilters() {
            const filterVal = document.getElementById('filter-proyecto').value;
            const vFiltered = filterVal ? ventasData.filter(i => i.proyecto_id == filterVal) : ventasData;
            
            const tbody = document.getElementById('ventas-tbody'); tbody.innerHTML = '';
            if(vFiltered.length===0) return tbody.innerHTML = '<tr><td colspan="8" style="text-align:center; padding:30px;">No hay operaciones.</td></tr>';
            
            vFiltered.forEach((v) => {
                const tipoBadge = v.tipo_operacion === 'reserva' ? '<span style="background:#fef3c7;color:#d97706;padding:4px 8px;border-radius:4px;font-size:0.75rem;font-weight:700;">RESERVA</span>' : '<span style="background:#dcfce7;color:#166534;padding:4px 8px;border-radius:4px;font-size:0.75rem;font-weight:700;">VENTA</span>';
                const jsonData = JSON.stringify(v).replace(/"/g, '&quot;');
                tbody.innerHTML += `<tr><td style="padding:15px;">${new Date(v.fecha_venta).toLocaleDateString()}</td><td>${tipoBadge}</td><td><strong>${v.cliente_nombre}</strong></td><td>${v.proyecto_nombre}<br><small>Lote ${v.numero_lote}</small></td><td style="text-align:right;">$${fmt(parseDB(v.precio_acordado) || parseDB(v.precio_lista))}</td><td style="text-align:right; font-weight:700; color:#166534;">$${fmt(parseDB(v.valor_final))}</td><td style="text-align:center; padding:15px;"><button class="btn-icon-info" onclick="viewSaleDetails(${jsonData})"><i class="bi bi-eye-fill"></i></button></td></tr>`;
            });
        }

        function viewSaleDetails(v) {
            const body = document.getElementById('info-body');
            body.innerHTML = `
                <div style="margin-bottom: 10px;"><strong>Tipo:</strong> ${v.tipo_operacion.toUpperCase()}</div>
                <div style="margin-bottom: 10px;"><strong>Cliente:</strong> ${v.cliente_nombre}</div>
                <div style="margin-bottom: 10px;"><strong>Proyecto/Lote:</strong> ${v.proyecto_nombre} - Lote ${v.numero_lote}</div>
                <div style="margin-bottom: 10px;"><strong>Precio Lista:</strong> $${fmt(parseDB(v.precio_lista))}</div>
                <div style="margin-bottom: 10px;"><strong>Precio Acordado:</strong> $${fmt(parseDB(v.precio_acordado))}</div>
                <div style="margin-top: 15px; padding-top: 10px; border-top: 1px solid #ccc; font-weight: bold; color: #10b981; font-size: 1.1rem;">TOTAL PAGADO: $${fmt(parseDB(v.valor_final))}</div>
            `;
            document.getElementById('modal-info').classList.add('show');
        }

        document.addEventListener('DOMContentLoaded', loadInitialData);
    </script>
</body>
</html>