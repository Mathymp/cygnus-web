                    +row('Dirección',venta.direccion||'—','bi-geo-alt-fill')
                )}

                <!-- Cónyuge (si aplica) -->
                ${venta.nombre_conyugue?section('Cónyuge / Conviviente Civil','#faf5ff',
                    row('Nombre',venta.nombre_conyugue,'bi-person-fill')
