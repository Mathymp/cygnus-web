        $('cuotas-list').innerHTML=`<div style="text-align:center;padding:20px;color:#94a3b8;font-size:.85rem;"><i class="bi bi-inbox" style="font-size:1.5rem;display:block;margin-bottom:6px;"></i>No hay cuotas registradas.</div>`;
