let clienteSoloLectura=false;
let _buscarTimer=null;
const CLI_CAMPOS=['cli-nombre','cli-rut','cli-telefono','cli-email','cli-direccion','cli-conyuge-nombre','cli-conyuge-rut','cli-conyuge-email','cli-conyuge-tel'];
