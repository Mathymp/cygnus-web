                                <i class="bi bi-receipt" style="font-size:1.5rem;display:block;margin-bottom:6px;"></i>Registra una venta primero para subir documentos de la venta.
                            </div>
                            <div id="dm-venta"></div>
                        </div>

                        <!-- ─── TAB DOCS PERSONA ─── -->
                        <div id="tab-docs-persona" class="im-tab-content">
                            <div id="no-cliente-msg" style="background:#fef3c7;border:1px solid #fde68a;border-radius:10px;padding:16px;text-align:center;color:#92400e;font-size:.85rem;">
                                <i class="bi bi-person-exclamation" style="font-size:1.5rem;display:block;margin-bottom:6px;"></i>Asigna un comprador primero para ver sus documentos.
                            </div>
                            <div id="dm-persona"></div>
                        </div>

                        <!-- ─── TAB DOCS LOTE ─── -->
