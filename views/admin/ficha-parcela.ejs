<script>
const PARCELA_ID  = '<%= parcelaId %>';
const IS_ADMIN    = '<%= user && user.role === "admin" ? "true" : "false" %>' === 'true';
const PUEDE_CREAR = '<%= typeof puedeCrear !== "undefined" && puedeCrear ? "true" : "false" %>' === 'true';

let parcelaData=null, ventaData=null, cuotasData=[], currentClienteId=null, proyectoId=null;
let pagoTipoActual = 'contado';
let fechasCuotasGeneradas = [];
let usuariosList = [];
let _docsCache = {};
let historialPreciosCache = [];
let historialVentasCache = [];
const CURRENT_USER_ID   = '<%= user.id %>';
const CURRENT_USER_NAME = '<%= user.name %>';

// ──────────────── UTILS ────────────────
const $ = id => document.getElementById(id);
function fmt(n){return Math.floor(parseFloat(n)||0).toLocaleString('es-CL');}
function escH(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function getDocExt(doc){
    const fromPath=(doc.storage_path||'').split('.').pop().toLowerCase();
    if(fromPath&&fromPath.length<=5&&!fromPath.includes('/'))return fromPath;
    const fromUrl=(doc.url_storage||'').split('?')[0].split('.').pop().toLowerCase();
    if(fromUrl&&fromUrl.length<=5&&!fromUrl.includes('/'))return fromUrl;
    return '';
}
function fmtPrecio(input){input.value=input.value.replace(/\D/g,'').replace(/\B(?=(\d{3})+(?!\d))/g,'.');}
function openModal(id){$(`modal-${id}`).classList.add('show');}
function closeModal(id){$(`modal-${id}`).classList.remove('show');}
function cleanNum(v){return v&&String(v).trim()?parseFloat(String(v).replace(/\./g,'').replace(',','.')):null;}
/** Fecha segura para UI (evita Invalid Date cuando PG manda ISO completo). */
function ymd(val){
    if(val==null||val==='')return '';
    const m=String(val).match(/(\d{4}-\d{2}-\d{2})/);
    return m?m[1]:'';
}
function fmtFechaCL(val,opts){
    const day=ymd(val);
    if(!day)return '—';
    const d=new Date(day+'T12:00:00');
    if(Number.isNaN(d.getTime()))return '—';
    return d.toLocaleDateString('es-CL',opts||{day:'2-digit',month:'long',year:'numeric'});
}
function hoyYmd(){return new Date().toISOString().split('T')[0];}

function showToast(msg,type='success',title=''){
    const t=$('im-toast'),i=$('im-toast-inner');
    const cfg={success:{bg:'#dcfce7',c:'#166534',b:'#86efac',ic:'bi-check-circle-fill',d:'Éxito'},error:{bg:'#fee2e2',c:'#991b1b',b:'#fca5a5',ic:'bi-exclamation-triangle-fill',d:'Error'},warning:{bg:'#fef3c7',c:'#92400e',b:'#fde68a',ic:'bi-exclamation-circle-fill',d:'Atención'},info:{bg:'#eff6ff',c:'#1e40af',b:'#bfdbfe',ic:'bi-info-circle-fill',d:'Info'}};
    const s=cfg[type]||cfg.info;
    i.style.cssText=`background:${s.bg};color:${s.c};border:1.5px solid ${s.b};padding:14px 18px;border-radius:12px;box-shadow:0 8px 30px rgba(0,0,0,.12);display:flex;align-items:flex-start;gap:10px;`;
    i.innerHTML=`<i class="bi ${s.ic}" style="font-size:1.1rem;flex-shrink:0;margin-top:1px;"></i><div><div style="font-weight:700;font-size:.88rem;">${title||s.d}</div><div style="font-size:.82rem;margin-top:2px;opacity:.9;word-break:break-word;">${escH(msg)}</div></div>`;
    t.style.opacity='1';t.style.transform='translateX(0)';t.style.pointerEvents='auto';
    clearTimeout(t._t);t._t=setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(30px)';t.style.pointerEvents='none';},5000);
}

function autoFmtRut(input,statusId){
    // Extraer solo dígitos y K, limitar a 9 chars (8 dígitos cuerpo + 1 DV)
    let v=input.value.replace(/[^0-9kK]/g,'').toUpperCase().slice(0,9);
    if(v.length>1)v=v.slice(0,-1).replace(/\B(?=(\d{3})+(?!\d))/g,'.')+'-'+v.slice(-1);
    input.value=v;
    const el=$(statusId);if(!el)return;
    if(v.length<3){el.textContent='';input.style.borderColor='';return;}
    const ok=validarRut(v);
    el.textContent=ok?'✅':'❌';
    input.style.borderColor=ok?'#10b981':(v.length>4?'#ef4444':'');
}
function validarRut(rut){
    const c=rut.replace(/[^0-9kK]/g,'').toUpperCase();if(c.length<2)return false;
    const body=c.slice(0,-1),dv=c.slice(-1);
    let s=0,m=2;for(let i=body.length-1;i>=0;i--){s+=parseInt(body[i],10)*m;m=m>=7?2:m+1;}
    const r=11-(s%11);const dc=r===11?'0':r===10?'K':String(r);return dv===dc;
}
function autoFmtTel(input){
    // Formato: +XX X XXXX XXXX  (ej: +56 9 1234 5678)
    const raw=input.value.replace(/[^\d]/g,'').slice(0,11);
    let f='';
    if(raw.length>0)f='+'+raw.slice(0,2);
    if(raw.length>2)f+=' '+raw.slice(2,3);
    if(raw.length>3)f+=' '+raw.slice(3,7);
    if(raw.length>7)f+=' '+raw.slice(7,11);
    input.value=f;
}
let formVentaVisible = false;
function toggleFormVenta(){
    formVentaVisible=!formVentaVisible;
    $('form-venta-wrapper').style.display=formVentaVisible?'block':'none';
    const btn=$('btn-toggle-form');
    btn.innerHTML=formVentaVisible
        ?'<i class="bi bi-chevron-up"></i> Ocultar formulario'
        :'<i class="bi bi-pencil-square"></i> Editar datos de la venta / comprador';
}

function toggleConyuge(val){
    $('section-conyuge').style.display=(val==='Casado/a'||val==='Conviviente Civil')?'block':'none';
    const rb=$('box-regimen');if(rb)rb.style.display=(val==='Casado/a')?'flex':'none';
}

function switchTab(name,btn){
    document.querySelectorAll('.im-tab-btn').forEach(b=>b.classList.remove('active'));
    document.querySelectorAll('.im-tab-content').forEach(c=>c.classList.remove('active'));
    if(btn)btn.classList.add('active');
    $(`tab-${name}`).classList.add('active');
    if(name==='docs-venta'){
        if(ventaData&&ventaData.id){
            $('no-venta-doc-msg').style.display='none';
            initDM('venta',ventaData.id,true);
            loadDocs('venta',ventaData.id);
        } else {
            $('no-venta-doc-msg').style.display='block';
            $('dm-venta').innerHTML='';
            delete dmState.venta;
        }
    }
    if(name==='docs-persona'){
        if(currentClienteId){
            $('no-cliente-msg').style.display='none';
            initDM('persona',currentClienteId,true);
            loadDocs('persona',currentClienteId);
        } else {
            $('no-cliente-msg').style.display='block';
            $('dm-persona').innerHTML='';
            delete dmState.persona;
        }
    }
    if(name==='docs-lote'){initDM('lote',PARCELA_ID);loadDocs('parcela',PARCELA_ID);}
    if(name==='docs-proyecto'&&proyectoId){initDM('proyecto',proyectoId);loadDocs('proyecto',proyectoId);}
    if(name==='auditoria')loadAuditoria();
}

function setPagoTipo(tipo){
    pagoTipoActual=tipo==='credito'?'credito':'contado';
    const tabC=$('tab-contado'),tabR=$('tab-credito'),secC=$('section-contado'),secR=$('section-credito');
    if(tabC)tabC.classList.toggle('active',pagoTipoActual==='contado');
    if(tabR)tabR.classList.toggle('active',pagoTipoActual==='credito');
    if(secC)secC.style.display=pagoTipoActual==='contado'?'block':'none';
    if(secR)secR.style.display=pagoTipoActual==='credito'?'block':'none';
}

function resolverTipoPago(venta){
    if(!venta)return 'contado';
    if(venta.tipo_pago==='credito'||venta.tipo_pago==='contado')return venta.tipo_pago;
    const fp=String(venta.forma_pago||'').toLowerCase();
    if(fp.includes('cr')||fp.includes('cuota'))return 'credito';
    if(Number(venta.numero_cuotas)>0||Number(venta.monto_cuota)>0)return 'credito';
    return 'contado';
}

function habilitarDocsVentaCliente(ventaId,clienteId){
    if(ventaId){
        $('no-venta-doc-msg').style.display='none';
        initDM('venta',ventaId,true);
    }
    if(clienteId){
        currentClienteId=clienteId;
        $('no-cliente-msg').style.display='none';
        initDM('persona',clienteId,true);
    }
}

// ──────────────── CUOTAS GENERATOR ────────────────
function recalcularCuotas(){/* live update if fecha set */generarFechasCuotas();}

function generarFechasCuotas(){
    const n=parseInt($('venta-num-cuotas').value,10);
    const montoRaw=cleanNum($('venta-monto-cuota').value);
    const fechaBase=$('venta-primera-cuota').value;
    if(!n||n<1){$('cuotas-preview').style.display='none';return;}

    const monto=montoRaw||0;
    const preview=$('cuotas-preview-list');
    fechasCuotasGeneradas=[];

    let rows='';
    for(let i=0;i<n;i++){
        let fecha='';
        if(fechaBase){
            const d=new Date(fechaBase+'T12:00:00');
            d.setMonth(d.getMonth()+i);
            fecha=d.toISOString().split('T')[0];
        }
        fechasCuotasGeneradas.push({numero:i+1,monto,fecha});
        const fechaFmt=fecha?new Date(fecha+'T12:00:00').toLocaleDateString('es-CL',{day:'2-digit',month:'short',year:'numeric'}):'Sin fecha';
        rows+=`<div style="display:grid;grid-template-columns:36px 1fr 120px 140px;gap:8px;align-items:center;padding:8px 12px;background:#fff;border:1px solid #e2e8f0;border-radius:8px;margin-bottom:6px;font-size:.82rem;">
            <span style="font-weight:800;color:#2563eb;text-align:center;">${i+1}</span>
            <span style="color:#64748b;">Cuota mensual</span>
            <span style="font-weight:700;color:#0f172a;">${monto?'$'+fmt(monto):'—'}</span>
            <input type="date" value="${fecha}" style="border:1px solid #e2e8f0;border-radius:6px;padding:4px 8px;font-size:.78rem;font-family:inherit;" onchange="fechasCuotasGeneradas[${i}].fecha=this.value">
        </div>`;
    }
    preview.innerHTML=rows;
    $('cuotas-preview').style.display='block';
}

// ──────────────── INIT ────────────────
async function loadAgentes(){
    try{
        const res=await fetch('/api/im/usuarios');
        if(!res.ok)return;
        usuariosList=await res.json();
        const sel=$('venta-agente-id');
        sel.innerHTML=`<option value="" data-nombre="">— Sin asignar / No se sabe —</option>`
            +usuariosList.map(u=>`<option value="${u.id}" data-nombre="${escH(u.name)}">${escH(u.name)} (${u.role==='admin'?'Admin':'Corredor'})</option>`).join('');
        // Default: sin asignar
        sel.value='';
        $('venta-agente-nombre').value='';
    }catch(_){}
}

function onAgenteChange(sel){
    const opt=sel.options[sel.selectedIndex];
    $('venta-agente-nombre').value=opt?opt.dataset.nombre||opt.textContent:'';
}

async function init(){
    try{
        const [parcelaRes]=await Promise.all([
            fetch(`/api/im/parcelas/${PARCELA_ID}`),
            loadAgentes()
        ]);
        if(!parcelaRes.ok){
            const errBody=await parcelaRes.json().catch(()=>({}));
            throw new Error(errBody.message||`No se pudo cargar la parcela (HTTP ${parcelaRes.status}). Verifica tu conexión e intenta de nuevo.`);
        }
        const data=await parcelaRes.json();
        parcelaData=data.parcela;ventaData=data.venta;cuotasData=data.cuotas||[];
        historialPreciosCache=data.historial_precios||[];
        historialVentasCache=data.historial_ventas||[];
        proyectoId=parcelaData.proyecto_id;
        renderParcela(data);
        initDM('lote',PARCELA_ID);
    }catch(e){
        $('parcela-titulo').textContent='Error al cargar';
        showToast(e.message,'error','No se pudo cargar la parcela');
    }
}

function renderParcela(data){
