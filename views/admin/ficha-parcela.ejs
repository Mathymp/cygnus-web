                    +row('Régimen',venta.regimen_matrimonial||'—')
                    +row('Teléfono',venta.telefono_conyugue||'—','bi-telephone')
                    +row('Email',venta.email_conyugue||'—','bi-envelope')
                ):''}

                <!-- Venta -->
                ${section('Datos de la Operación','#eff6ff',
                    row('Fecha de Venta',venta.fecha_venta?new Date(venta.fecha_venta+'T12:00').toLocaleDateString('es-CL',{day:'2-digit',month:'long',year:'numeric'}):'—','bi-calendar-event')
                    +row('Modalidad de Pago',tipoPago==='contado'?'Al Contado':'Crédito / Cuotas','bi-wallet2')
                    +row('Precio Lista',venta.precio_lista?'$'+fmt(venta.precio_lista):'—','bi-tag')
                    +row('Precio Acordado',venta.precio_acordado?'$'+fmt(venta.precio_acordado):'—','bi-currency-dollar')
                    +(tipoPago==='credito'&&venta.monto_pie?row('Pie','$'+fmt(venta.monto_pie),'bi-cash'):'')
                    +(tipoPago==='credito'&&venta.numero_credito?row('N° Crédito',venta.numero_credito,'bi-bank'):'')
                    +(cuotasTotales>0?row('Cuotas',`${cuotasPagadas} de ${cuotasTotales} pagadas${saldoPendiente>0?' · Saldo: $'+fmt(saldoPendiente):'  ✓ Al día'}`,'bi-list-check'):'')
                    +row('Agente',venta.agente_nombre||'Sin asignar','bi-person-badge')
                )}

                <!-- Condiciones / Notas -->
                ${venta.condiciones_compra?`<div style="background:#fffbeb;border:1px solid #fde68a;border-radius:8px;padding:10px 14px;margin-bottom:12px;"><p style="font-size:.72rem;font-weight:700;color:#92400e;text-transform:uppercase;margin:0 0 4px;"><i class="bi bi-file-text"></i> Condiciones de Compra</p><p style="font-size:.83rem;color:#78350f;margin:0;line-height:1.5;">${escH(venta.condiciones_compra)}</p></div>`:''}
                ${venta.notas?`<div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:10px 14px;margin-bottom:12px;"><p style="font-size:.72rem;font-weight:700;color:#475569;text-transform:uppercase;margin:0 0 4px;"><i class="bi bi-sticky"></i> Notas</p><p style="font-size:.83rem;color:#475569;margin:0;font-style:italic;">${escH(venta.notas)}</p></div>`:''}

                <!-- Comprobante -->
                ${venta.comprobante_url?`<div style="display:flex;gap:8px;margin-bottom:4px;">
                    <a href="${escH(venta.comprobante_url)}" target="_blank" class="im-btn im-btn-sm im-btn-ghost"><i class="bi bi-eye"></i> Ver comprobante pago</a>
                    <a href="${escH(venta.comprobante_url)}" download class="im-btn im-btn-sm im-btn-ghost"><i class="bi bi-download"></i> Descargar</a>
                </div>`:''}

                <a href="/admin/inmobiliaria/clientes" style="font-size:.75rem;color:#2563eb;text-decoration:none;display:inline-flex;align-items:center;gap:4px;margin-top:4px;"><i class="bi bi-arrow-up-right"></i> Ver ficha completa del cliente</a>
            </div>
        </div>`;

        // Ocultar formulario y mostrar botón editar (ya hay venta)
        $('form-venta-wrapper').style.display='none';
        $('btn-editar-venta-wrap').style.display='block';
        formVentaVisible=false;

        // Pre-fill form
        $('venta-cliente-id').value=venta.cliente_id;
        $('cli-nombre').value=venta.nombre_completo;
        $('cli-rut').value=venta.rut;
        $('cli-telefono').value=venta.telefono||'';if(venta.telefono){autoFmtTel($('cli-telefono'));}
        $('cli-email').value=venta.email||'';
        $('cli-direccion').value=venta.direccion||'';
        $('cli-estado-civil').value=venta.estado_civil;
        toggleConyuge(venta.estado_civil);
        if(venta.regimen_matrimonial&&$('cli-regimen'))$('cli-regimen').value=venta.regimen_matrimonial;
        $('cli-conyuge-nombre').value=venta.nombre_conyugue||'';
        $('cli-conyuge-rut').value=venta.rut_conyugue||'';
        $('cli-conyuge-email').value=venta.email_conyugue||'';
        $('cli-conyuge-tel').value=venta.telefono_conyugue||'';if(venta.telefono_conyugue){autoFmtTel($('cli-conyuge-tel'));}
        $('venta-fecha').value=venta.fecha_venta?venta.fecha_venta.split('T')[0]:'';
        $('venta-promesa').checked=venta.firmo_promesa;
        $('venta-compraventa').checked=venta.firmo_compraventa;
        $('venta-notas').value=venta.notas||'';
        $('venta-condiciones').value=venta.condiciones_compra||'';
        if(venta.precio_lista)$('venta-precio-lista').value=Number(venta.precio_lista).toLocaleString('es-CL');
        if(venta.precio_acordado)$('venta-precio-acordado').value=Number(venta.precio_acordado).toLocaleString('es-CL');

        // Agente
        if(venta.agente_id){
            const sel=$('venta-agente-id');if(sel)sel.value=venta.agente_id;
            $('venta-agente-nombre').value=venta.agente_nombre||'';
        }

        // Pago tipo
        setPagoTipo(tipoPago);
        if(tipoPago==='credito'){
            if(venta.monto_pie)$('venta-monto-pie').value=Number(venta.monto_pie).toLocaleString('es-CL');
            if(venta.numero_credito)$('venta-numero-credito').value=venta.numero_credito;
            if(venta.numero_cuotas)$('venta-num-cuotas').value=venta.numero_cuotas;
            if(venta.monto_cuota)$('venta-monto-cuota').value=Number(venta.monto_cuota).toLocaleString('es-CL');
        }

        // Cuotas panel
        if(cuotas.length>0){
            renderCuotasPanel(venta,cuotas);
        }

        $('no-cliente-msg').style.display='none';
        initDM('persona',venta.cliente_id);
    }else{
        $('venta-actual').innerHTML='';
        $('venta-fecha').value=new Date().toISOString().split('T')[0];
        if(p.precio_actual)$('venta-precio-lista').value=Number(p.precio_actual).toLocaleString('es-CL');
    }

    renderHistorialVentas(histVentas);
}

function renderHistorialVentas(histVentas){
    const sec=$('historial-ventas-section');
    if(!sec)return;
    if(!histVentas||histVentas.length===0){sec.style.display='none';return;}
    sec.style.display='block';
    const estadoBadge=estado=>{
        if(estado==='resciliada')return`<span style="font-size:.68rem;font-weight:700;padding:2px 8px;border-radius:999px;background:#fee2e2;color:#991b1b;">Resciliada</span>`;
        if(estado==='liberada')return`<span style="font-size:.68rem;font-weight:700;padding:2px 8px;border-radius:999px;background:#f1f5f9;color:#64748b;">Liberada</span>`;
        return`<span style="font-size:.68rem;font-weight:700;padding:2px 8px;border-radius:999px;background:#fef3c7;color:#92400e;">${estado}</span>`;
    };
    sec.innerHTML=`
    <details style="border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;" open>
        <summary style="padding:12px 16px;cursor:pointer;background:#f8fafc;font-size:.82rem;font-weight:700;color:#475569;display:flex;align-items:center;gap:8px;list-style:none;">
            <i class="bi bi-clock-history" style="color:#f59e0b;"></i>
            Historial de Operaciones Anteriores
            <span style="margin-left:auto;font-size:.73rem;font-weight:400;color:#94a3b8;">${histVentas.length} registro${histVentas.length!==1?'s':''}</span>
        </summary>
        <div style="padding:12px;display:flex;flex-direction:column;gap:10px;">
        ${histVentas.map(v=>{
            const fechaVenta=v.fecha_venta?new Date(v.fecha_venta).toLocaleDateString('es-CL',{day:'2-digit',month:'short',year:'numeric'}):'—';
            const precio=v.precio_acordado?'$'+fmt(v.precio_acordado):'—';
            const modPago=v.tipo_pago==='credito'?'🏦 Crédito':'💵 Contado';
            const rescInfo=v.resc_id?`
                <div style="margin-top:8px;padding-top:8px;border-top:1px dashed #fca5a5;font-size:.78rem;color:#7f1d1d;">
                    <i class="bi bi-file-earmark-x-fill" style="color:#ef4444;"></i>
                    <strong>Resciliación:</strong>
                    ${v.resc_fecha?new Date(v.resc_fecha+'T12:00:00').toLocaleDateString('es-CL',{day:'2-digit',month:'short',year:'numeric'}):'—'}
                    — ${escH(v.resc_motivo||'Sin motivo')}
                    ${v.resc_agente?`<span style="color:#94a3b8;"> · Por: ${escH(v.resc_agente)}</span>`:''}
                    ${v.resc_notas?`<div style="margin-top:4px;color:#92400e;font-style:italic;">${escH(v.resc_notas)}</div>`:''}
                </div>`:'';
            return`<div style="border:1px solid ${v.estado==='resciliada'?'#fca5a5':'#e2e8f0'};border-radius:8px;padding:12px;background:${v.estado==='resciliada'?'#fff5f5':'#fafafa'};">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap;">
                    ${estadoBadge(v.estado)}
                    <span style="font-size:.82rem;font-weight:600;color:#0f172a;">${escH(v.nombre_completo)}</span>
                    <span style="font-size:.78rem;color:#64748b;">RUT ${escH(v.rut)}</span>
                    <span style="margin-left:auto;font-size:.78rem;color:#64748b;">${fechaVenta}</span>
                </div>
                <div style="display:flex;gap:12px;font-size:.79rem;color:#64748b;flex-wrap:wrap;">
                    <span><i class="bi bi-cash"></i> ${precio}</span>
                    <span>${modPago}</span>
                    ${v.agente_nombre?`<span><i class="bi bi-person"></i> ${escH(v.agente_nombre)}</span>`:''}
                    ${v.firmo_promesa?`<span style="color:#16a34a;"><i class="bi bi-check-circle-fill"></i> Promesa</span>`:''}
                    ${v.firmo_compraventa?`<span style="color:#16a34a;"><i class="bi bi-check-circle-fill"></i> Compraventa</span>`:''}
                </div>
                ${rescInfo}
            </div>`;
        }).join('')}
        </div>
    </details>`;
}

function renderCuotasPanel(venta,cuotas){
    const pagadas=cuotas.filter(c=>c.pagado).length;
    const pendientes=cuotas.length-pagadas;
    const totalPagado=cuotas.filter(c=>c.pagado).reduce((s,c)=>s+(parseFloat(c.monto)||0),0);
    const totalPendiente=cuotas.filter(c=>!c.pagado).reduce((s,c)=>s+(parseFloat(c.monto)||0),0);

    // Obtener info del cliente desde la venta actual
    const clienteNombre = venta.nombre_completo || '—';
    const clienteTel    = venta.telefono || '';
    const clienteEmail  = venta.email   || '';

    $('section-cuotas-venta').style.display='block';

    // Encabezado: quién debe pagar y resumen
    $('cuotas-resumen').innerHTML=`
        <div style="width:100%;margin-bottom:10px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
            <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:8px 14px;display:flex;align-items:center;gap:8px;">
                <i class="bi bi-person-fill" style="color:#16a34a;"></i>
                <div>
                    <div style="font-weight:700;font-size:.88rem;color:#0f172a;">${escH(clienteNombre)}</div>
                    ${clienteTel?`<div style="font-size:.75rem;color:#64748b;"><i class="bi bi-telephone"></i> ${escH(clienteTel)}</div>`:''}
                    ${clienteEmail?`<div style="font-size:.75rem;color:#64748b;"><i class="bi bi-envelope"></i> ${escH(clienteEmail)}</div>`:''}
                </div>
            </div>
        </div>
        <div><span style="font-size:.72rem;color:#64748b;display:block;">Cuotas pagadas</span><strong style="color:#166534;">${pagadas} / ${cuotas.length}</strong></div>
        <div><span style="font-size:.72rem;color:#64748b;display:block;">Total pagado</span><strong style="color:#10b981;">$${fmt(totalPagado)}</strong></div>
        <div><span style="font-size:.72rem;color:#64748b;display:block;">Saldo pendiente</span><strong style="color:${totalPendiente>0?'#f59e0b':'#16a34a'};">$${fmt(totalPendiente)}</strong></div>
        ${venta.numero_credito?`<div><span style="font-size:.72rem;color:#64748b;display:block;">N° Crédito</span><strong>${escH(venta.numero_credito)}</strong></div>`:''}
        ${venta.monto_pie?`<div><span style="font-size:.72rem;color:#64748b;display:block;">Pie pagado</span><strong>$${fmt(venta.monto_pie)}</strong></div>`:''}`;

    const hoy=new Date().toISOString().split('T')[0];

    if(cuotas.length===0){
        $('cuotas-list').innerHTML=`<div style="text-align:center;padding:20px;color:#94a3b8;font-size:.85rem;"><i class="bi bi-inbox" style="font-size:1.5rem;display:block;margin-bottom:6px;"></i>No hay cuotas registradas.</div>`;
        return;
    }

    $('cuotas-list').innerHTML=`
    <div style="overflow-x:auto;">
    <table style="width:100%;border-collapse:collapse;font-size:.82rem;">
        <thead>
            <tr style="background:#f8fafc;border-bottom:2px solid #e2e8f0;">
                <th style="padding:8px 10px;text-align:left;font-weight:700;color:#64748b;white-space:nowrap;">#</th>
                <th style="padding:8px 10px;text-align:left;font-weight:700;color:#64748b;">Monto</th>
                <th style="padding:8px 10px;text-align:left;font-weight:700;color:#64748b;white-space:nowrap;">Fecha Venc.</th>
                <th style="padding:8px 10px;text-align:left;font-weight:700;color:#64748b;white-space:nowrap;">Fecha Pago</th>
                <th style="padding:8px 10px;text-align:left;font-weight:700;color:#64748b;">Estado</th>
                <th style="padding:8px 10px;text-align:left;font-weight:700;color:#64748b;">Notas</th>
                <th style="padding:8px 10px;"></th>
            </tr>
        </thead>
        <tbody>
        ${cuotas.map(c=>{
            const vencida=!c.pagado&&c.fecha_vencimiento&&c.fecha_vencimiento<hoy;
            const rowBg=c.pagado?'#f0fdf4':vencida?'#fff5f5':'#fff';
            const fechaVenc=c.fecha_vencimiento?new Date(c.fecha_vencimiento+'T12:00:00').toLocaleDateString('es-CL',{day:'2-digit',month:'short',year:'numeric'}):'—';
            const fechaPago=c.fecha_pago?new Date(c.fecha_pago+'T12:00:00').toLocaleDateString('es-CL',{day:'2-digit',month:'short',year:'numeric'}):'—';
            const badge=c.pagado
                ?`<span style="background:#dcfce7;color:#166534;border-radius:20px;padding:2px 10px;font-weight:700;white-space:nowrap;"><i class="bi bi-check-circle-fill"></i> Pagada</span>`
                :vencida
                    ?`<span style="background:#fee2e2;color:#991b1b;border-radius:20px;padding:2px 10px;font-weight:700;white-space:nowrap;"><i class="bi bi-exclamation-triangle-fill"></i> Vencida</span>`
                    :`<span style="background:#fef3c7;color:#92400e;border-radius:20px;padding:2px 10px;font-weight:700;white-space:nowrap;"><i class="bi bi-clock"></i> Pendiente</span>`;
            const cData=JSON.stringify(c).replace(/"/g,'&quot;');
            return `<tr style="border-bottom:1px solid #f1f5f9;background:${rowBg};">
                <td style="padding:8px 10px;font-weight:700;color:#334155;">Cuota ${c.numero_cuota}</td>
                <td style="padding:8px 10px;font-weight:700;color:#0f172a;">${c.monto?'$'+fmt(c.monto):'—'}</td>
                <td style="padding:8px 10px;color:#475569;white-space:nowrap;">${fechaVenc}</td>
                <td style="padding:8px 10px;color:#475569;white-space:nowrap;">${c.pagado?fechaPago:'—'}</td>
                <td style="padding:8px 10px;">${badge}</td>
                <td style="padding:8px 10px;color:#64748b;font-style:italic;max-width:160px;word-break:break-word;">${c.notas?escH(c.notas):'—'}</td>
                <td style="padding:8px 10px;white-space:nowrap;display:flex;gap:4px;align-items:center;">
                    ${c.comprobante_url?`<a href="${escH(c.comprobante_url)}" target="_blank" class="im-btn im-btn-sm im-btn-ghost" title="Ver comprobante"><i class="bi bi-eye"></i></a>`:''}
                    <button class="im-btn im-btn-sm ${c.pagado?'im-btn-ghost':'im-btn-success'}" onclick="openCuotaModal(${cData})" title="${c.pagado?'Editar':'Marcar como pagada'}">
                        <i class="bi bi-${c.pagado?'pencil':'check-lg'}"></i> ${c.pagado?'Editar':'Pagar'}
                    </button>
                </td>
            </tr>`;
        }).join('')}
        </tbody>
    </table>
    </div>`;
}

// ──────────────── MODAL CUOTA ────────────────
function openCuotaModal(c){
    $('cuota-modal-id').value=c.id;
    $('cuota-modal-title').innerHTML=`<i class="bi bi-cash"></i> Cuota N° ${c.numero_cuota}`;
    $('cuota-modal-monto').value=c.monto?Number(c.monto).toLocaleString('es-CL'):'';
    $('cuota-modal-venc').value=c.fecha_vencimiento||'';
    $('cuota-modal-fpago').value=c.fecha_pago||'';
    $('cuota-modal-pagada').checked=c.pagado;
    $('cuota-modal-notas').value=c.notas||'';
    $('cuota-modal-file').value='';
    openModal('cuota');
}

async function saveCuota(){
    const id=$('cuota-modal-id').value;
    const pagada=$('cuota-modal-pagada').checked;
    try{
        const body={pagado:pagada,fecha_pago:$('cuota-modal-fpago').value||null,monto:$('cuota-modal-monto').value,fecha_vencimiento:$('cuota-modal-venc').value||null,notas:$('cuota-modal-notas').value||null};
        const res=await fetch(`/api/im/cuotas/${id}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
        if(!res.ok){const e=await res.json().catch(()=>({}));throw new Error(e.message||`Error ${res.status}`);}

        const file=$('cuota-modal-file').files[0];
        if(file){
            const fd=new FormData();fd.append('archivo',file,file.name);
            const r2=await fetch(`/api/im/cuotas/${id}/comprobante`,{method:'POST',body:fd});
            if(!r2.ok){const e=await r2.json().catch(()=>({}));showToast(e.message||'Error al subir comprobante','warning');}
        }

        closeModal('cuota');
        showToast(pagada?'Cuota marcada como pagada.':'Cuota actualizada.','success');
        init();
    }catch(e){showToast(e.message,'error');}
}

// ──────────────── GUARDAR PARCELA ────────────────
async function guardarParcela(event){
    const btn=event.currentTarget;btn.disabled=true;btn.innerHTML='<i class="bi bi-hourglass-split"></i> Guardando...';
    try{
        const body={numero_rol_parcela:$('edit-rol').value.trim()||null,metraje:$('edit-metraje').value||null,precio_actual:$('edit-precio').value.replace(/\./g,'')||null,estado_venta:$('edit-estado').value};
        const res=await fetch(`/api/im/parcelas/${PARCELA_ID}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
        if(!res.ok){const e=await res.json().catch(()=>({}));throw new Error(e.message||`Error ${res.status}`);}
        showToast('Parcela actualizada correctamente.','success');init();
    }catch(e){showToast(e.message,'error','No se pudo guardar');}
    finally{btn.disabled=false;btn.innerHTML='<i class="bi bi-save"></i> Guardar Cambios';}
}

