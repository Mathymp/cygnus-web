// ──────────────── BUSCAR CLIENTE ────────────────
async function buscarCliente(){
    const rut=$('buscar-rut').value.trim();if(!rut)return;
    const el=$('cliente-encontrado');el.style.display='block';
    el.innerHTML='<div style="color:#64748b;font-size:.82rem;"><i class="bi bi-hourglass-split"></i> Buscando...</div>';
    try{
        const res=await fetch(`/api/im/clientes/buscar?rut=${encodeURIComponent(rut)}`);
        if(res.status===404){el.innerHTML='<div style="background:#fef3c7;border:1px solid #fde68a;border-radius:8px;padding:10px;font-size:.85rem;color:#92400e;"><i class="bi bi-exclamation-triangle"></i> No se encontró ningún cliente con ese RUT. Puedes crearlo en el formulario de abajo.</div>';return;}
        if(!res.ok){const eb=await res.json().catch(()=>({}));throw new Error(eb.message||`Error al buscar cliente (HTTP ${res.status}).`);}
        const c=await res.json();
        el.innerHTML=`<div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:12px;display:flex;justify-content:space-between;align-items:center;gap:10px;">
            <div><span style="font-size:.9rem;font-weight:700;color:#0f172a;">${escH(c.nombre_completo)}</span>
            <span style="font-size:.8rem;color:#64748b;display:block;">${c.rut} · ${c.estado_civil}${c.email?' · '+c.email:''}</span></div>
            <button class="im-btn im-btn-sm im-btn-primary" onclick='cargarCliente(${JSON.stringify(c)})'>
                <i class="bi bi-person-check"></i> Usar este
            </button></div>`;
    }catch(e){showToast(e.message,'error','Error al buscar');el.style.display='none';}
}

function cargarCliente(c){
    $('venta-cliente-id').value=c.id;$('cli-nombre').value=c.nombre_completo;$('cli-rut').value=c.rut;
    $('cli-telefono').value=c.telefono||'';if(c.telefono)autoFmtTel($('cli-telefono'));$('cli-email').value=c.email||'';$('cli-direccion').value=c.direccion||'';
    $('cli-estado-civil').value=c.estado_civil;toggleConyuge(c.estado_civil);
    $('cli-conyuge-nombre').value=c.nombre_conyugue||'';$('cli-conyuge-rut').value=c.rut_conyugue||'';
    showToast(`Cliente "${c.nombre_completo}" cargado.`,'info');
}

// ──────────────── GUARDAR VENTA ────────────────
$('form-venta').addEventListener('submit',async(e)=>{
    e.preventDefault();
    const btn=e.submitter||e.target.querySelector('[type="submit"]');
    if(btn){btn.disabled=true;btn.innerHTML='<i class="bi bi-hourglass-split"></i> Guardando...';}
    try{
        if(!validarRut($('cli-rut').value)){showToast('RUT del comprador inválido (Módulo 11).','error','RUT inválido');return;}
        let clienteId=$('venta-cliente-id').value;
            const estadoCivil=$('cli-estado-civil').value;
            const clienteBody={nombre_completo:$('cli-nombre').value,rut:$('cli-rut').value,email:$('cli-email').value||null,telefono:$('cli-telefono').value||null,direccion:$('cli-direccion').value||null,estado_civil:estadoCivil,regimen_matrimonial:(estadoCivil==='Casado/a'&&$('cli-regimen'))?$('cli-regimen').value:null,nombre_conyugue:$('cli-conyuge-nombre').value||null,rut_conyugue:$('cli-conyuge-rut').value||null,email_conyugue:$('cli-conyuge-email').value||null,telefono_conyugue:$('cli-conyuge-tel').value||null};
        if(clienteId){
            const r=await fetch(`/api/im/clientes/${clienteId}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(clienteBody)});
            if(!r.ok){const err=await r.json().catch(()=>({}));throw new Error(err.message||`Error ${r.status}`);}
        }else{
            const r=await fetch('/api/im/clientes',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(clienteBody)});
            if(!r.ok){const err=await r.json().catch(()=>({}));throw new Error(err.message||`Error ${r.status}`);}
            clienteId=(await r.json()).id;$('venta-cliente-id').value=clienteId;
        }

        const agenteSelId  = $('venta-agente-id')  ? $('venta-agente-id').value  : CURRENT_USER_ID;
        const agenteSelNom = $('venta-agente-nombre') ? $('venta-agente-nombre').value : CURRENT_USER_NAME;

        const ventaBody={
            parcela_id:PARCELA_ID,cliente_id:clienteId,
            firmo_promesa:$('venta-promesa').checked,firmo_compraventa:$('venta-compraventa').checked,
            fecha_venta:$('venta-fecha').value,
            precio_lista:cleanNum($('venta-precio-lista').value),
            precio_acordado:cleanNum($('venta-precio-acordado').value),
            notas:$('venta-notas').value||null,
            condiciones_compra:$('venta-condiciones').value||null,
            tipo_pago:pagoTipoActual,
            monto_pie:cleanNum($('venta-monto-pie').value),
            numero_credito:$('venta-numero-credito').value||null,
            numero_cuotas:parseInt($('venta-num-cuotas').value,10)||0,
            monto_cuota:cleanNum($('venta-monto-cuota').value),
            fechas_cuotas:pagoTipoActual==='credito'?fechasCuotasGeneradas:[],
            forma_pago:pagoTipoActual==='contado'?'Contado':'Crédito',
            agente_id:   agenteSelId  || CURRENT_USER_ID,
            agente_nombre: agenteSelNom || CURRENT_USER_NAME
        };
        const vRes=await fetch('/api/im/ventas',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(ventaBody)});
        if(!vRes.ok){const err=await vRes.json().catch(()=>({}));throw new Error(err.message||`Error ${vRes.status}`);}
        const ventaGuardada=await vRes.json();

        // Upload comprobante contado
        if(pagoTipoActual==='contado'){
            const file=$('comprobante-contado').files[0];
            if(file&&ventaGuardada.id){
                const fd=new FormData();fd.append('archivo',file,file.name);
                await fetch(`/api/im/ventas/${ventaGuardada.id}/comprobante`,{method:'POST',body:fd}).catch(()=>{});
            }
        }

        showToast('Comprador y venta guardados correctamente.','success');init();
    }catch(err){showToast(err.message,'error','No se pudo guardar');}
    finally{if(btn){btn.disabled=false;btn.innerHTML='<i class="bi bi-person-check-fill"></i> Guardar Comprador y Venta';}}
});

