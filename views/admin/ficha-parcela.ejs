                    ${c.comprobante_url?`<a href="${escH(c.comprobante_url)}" target="_blank" class="im-btn im-btn-sm im-btn-ghost" title="Ver comprobante"><i class="bi bi-eye"></i></a>`:''}
                    <button class="im-btn im-btn-sm ${c.pagado?'im-btn-ghost':'im-btn-success'}" onclick="openCuotaModal(${cData})" title="${c.pagado?'Editar':'Marcar como pagada'}">
                        <i class="bi bi-${c.pagado?'pencil':'check-lg'}"></i> ${c.pagado?'Editar':'Pagar'}
