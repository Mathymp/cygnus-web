        <div>
            <div style="font-weight:700;font-size:.88rem;color:#0f172a;">${escH(c.nombre_completo)}</div>
            <div style="font-size:.76rem;color:#64748b;">${escH(c.rut)}${c.estado_civil?' · '+escH(c.estado_civil):''}${c.telefono?' · '+escH(c.telefono):''}</div>
        </div>
        <button class="im-btn im-btn-sm im-btn-primary" onclick='cargarCliente(${data})'><i class="bi bi-person-check"></i> Usar</button>
    </div>`;
}

async function buscarCliente(){
    const q=$('buscar-rut').value.trim();
    if(!q){showToast('Escribe un nombre o RUT para buscar.','warning');return;}
    const el=$('cliente-encontrado');el.style.display='block';
    el.innerHTML='<div style="color:#64748b;font-size:.82rem;padding:8px 0;"><i class="bi bi-hourglass-split"></i> Buscando...</div>';
    try{
        const res=await fetch(`/api/im/clientes/buscar?q=${encodeURIComponent(q)}`);
        if(res.status===404){
            el.innerHTML=`<div style="background:#fef3c7;border:1px solid #fde68a;border-radius:8px;padding:10px 14px;font-size:.84rem;color:#92400e;">
                <i class="bi bi-exclamation-triangle"></i> No se encontró ningún cliente. Puedes crearlo directamente en el formulario de abajo.</div>`;
            return;
        }
        if(!res.ok){const eb=await res.json().catch(()=>({}));throw new Error(eb.message||`Error ${res.status}`);}
        const data=await res.json();
        if(data.multiple){
            el.innerHTML=`<div style="font-size:.78rem;color:#64748b;margin-bottom:6px;font-weight:600;">Se encontraron ${data.clientes.length} clientes — selecciona uno:</div>`
                +data.clientes.map(clienteCard).join('');
        } else {
            el.innerHTML=`<div style="font-size:.78rem;color:#64748b;margin-bottom:6px;font-weight:600;">Cliente encontrado:</div>`+clienteCard(data);
        }
    }catch(e){showToast(e.message,'error','Error al buscar');el.style.display='none';}
}

function cargarCliente(c){
    $('venta-cliente-id').value=c.id;$('cli-nombre').value=c.nombre_completo;$('cli-rut').value=c.rut;
    $('cli-telefono').value=c.telefono||'';if(c.telefono)autoFmtTel($('cli-telefono'));$('cli-email').value=c.email||'';$('cli-direccion').value=c.direccion||'';
    $('cli-estado-civil').value=c.estado_civil;toggleConyuge(c.estado_civil);
    $('cli-conyuge-nombre').value=c.nombre_conyugue||'';$('cli-conyuge-rut').value=c.rut_conyugue||'';
    showToast(`Cliente "${c.nombre_completo}" cargado.`,'info');
}

// ──────────────── GUARDAR VENTA ────────────────
$('form-venta').addEventListener('submit',async(e)=>{
    e.preventDefault();
    const btn=e.submitter||e.target.querySelector('[type="submit"]');
    if(btn){btn.disabled=true;btn.innerHTML='<i class="bi bi-hourglass-split"></i> Guardando...';}
    try{
        if(!validarRut($('cli-rut').value)){showToast('RUT del comprador inválido (Módulo 11).','error','RUT inválido');return;}
        let clienteId=$('venta-cliente-id').value;
            const estadoCivil=$('cli-estado-civil').value;
            const clienteBody={nombre_completo:$('cli-nombre').value,rut:$('cli-rut').value,email:$('cli-email').value||null,telefono:$('cli-telefono').value||null,direccion:$('cli-direccion').value||null,estado_civil:estadoCivil,regimen_matrimonial:(estadoCivil==='Casado/a'&&$('cli-regimen'))?$('cli-regimen').value:null,nombre_conyugue:$('cli-conyuge-nombre').value||null,rut_conyugue:$('cli-conyuge-rut').value||null,email_conyugue:$('cli-conyuge-email').value||null,telefono_conyugue:$('cli-conyuge-tel').value||null};
        if(clienteId){
            const r=await fetch(`/api/im/clientes/${clienteId}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(clienteBody)});
            if(!r.ok){const err=await r.json().catch(()=>({}));throw new Error(err.message||`Error ${r.status}`);}
        }else{
            const r=await fetch('/api/im/clientes',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(clienteBody)});
            if(!r.ok){const err=await r.json().catch(()=>({}));throw new Error(err.message||`Error ${r.status}`);}
            clienteId=(await r.json()).id;$('venta-cliente-id').value=clienteId;
        }

        const agenteSelId  = $('venta-agente-id')  ? $('venta-agente-id').value  : CURRENT_USER_ID;
        const agenteSelNom = $('venta-agente-nombre') ? $('venta-agente-nombre').value : CURRENT_USER_NAME;

        const ventaBody={
            parcela_id:PARCELA_ID,cliente_id:clienteId,
            firmo_promesa:$('venta-promesa').checked,firmo_compraventa:$('venta-compraventa').checked,
            fecha_venta:$('venta-fecha').value,
            precio_lista:cleanNum($('venta-precio-lista').value),
            precio_acordado:cleanNum($('venta-precio-acordado').value),
            notas:$('venta-notas').value||null,
            condiciones_compra:$('venta-condiciones').value||null,
            tipo_pago:pagoTipoActual,
            monto_pie:cleanNum($('venta-monto-pie').value),
            numero_credito:$('venta-numero-credito').value||null,
            numero_cuotas:parseInt($('venta-num-cuotas').value,10)||0,
            monto_cuota:cleanNum($('venta-monto-cuota').value),
            fechas_cuotas:pagoTipoActual==='credito'?fechasCuotasGeneradas:[],
            forma_pago:pagoTipoActual==='contado'?'Contado':'Crédito',
            agente_id:   agenteSelId  || null,
            agente_nombre: agenteSelNom || null
        };
        const vRes=await fetch('/api/im/ventas',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(ventaBody)});
        if(!vRes.ok){const err=await vRes.json().catch(()=>({}));throw new Error(err.message||`Error ${vRes.status}`);}
        const ventaGuardada=await vRes.json();

        // Upload comprobante contado
        if(pagoTipoActual==='contado'){
            const file=$('comprobante-contado').files[0];
            if(file&&ventaGuardada.id){
                const fd=new FormData();fd.append('archivo',file,file.name);
                await fetch(`/api/im/ventas/${ventaGuardada.id}/comprobante`,{method:'POST',body:fd}).catch(()=>{});
            }
        }

        showToast('Comprador y venta guardados correctamente.','success');init();
    }catch(err){showToast(err.message,'error','No se pudo guardar');}
    finally{if(btn){btn.disabled=false;btn.innerHTML='<i class="bi bi-person-check-fill"></i> Guardar Comprador y Venta';}}
});

// ──────────────── RESCILIACIÓN ────────────────
function openResciliarModal(){
    $('resc-fecha').value=new Date().toISOString().split('T')[0];
    $('resc-motivo').value='Desistimiento del comprador';
    $('resc-notas').value='';
    $('resc-file-list').innerHTML='';
    openModal('liberar');
}

document.getElementById('resc-file-input').addEventListener('change',function(){
    const list=$('resc-file-list');
    list.innerHTML=Array.from(this.files).map((f,i)=>`
        <div style="display:flex;align-items:center;gap:8px;background:#f1f5f9;border-radius:6px;padding:6px 10px;font-size:.78rem;">
            <i class="bi bi-paperclip" style="color:#2563eb;"></i>
            <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${escH(f.name)}</span>
            <span style="color:#94a3b8;">${(f.size/1024/1024).toFixed(1)}MB</span>
        </div>`).join('');
});

async function resciliarContrato(){
    if(!ventaData){showToast('No hay venta activa para resciliar.','error');return;}
    const btn=$('btn-resciliar');
    btn.disabled=true;btn.innerHTML='<i class="bi bi-hourglass-split"></i> Procesando...';
    try{
        const body={
            fecha:  $('resc-fecha').value,
            motivo: $('resc-motivo').value,
            notas:  $('resc-notas').value.trim()||null
        };
        const res=await fetch(`/api/im/ventas/${ventaData.id}/resciliar`,{
            method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)
        });
        if(!res.ok){const e=await res.json().catch(()=>({}));throw new Error(e.message||`Error ${res.status}`);}

        // Subir documentos de resciliación al lote (si hay)
        const files=$('resc-file-input').files;
        if(files.length>0){
            for(const f of files){
                const fd=new FormData();
                fd.append('archivo',f);
                fd.append('nombre_personalizado',`Resciliación — ${f.name.replace(/\.[^/.]+$/,'')}`);
                fd.append('tipo_asociacion','parcela');
                fd.append('asociacion_id',PARCELA_ID);
                await fetch('/api/im/documentos',{method:'POST',body:fd});
            }
        }

        closeModal('liberar');
        currentClienteId=null;
        showToast('Resciliación registrada. La parcela volvió a Disponible.','success');
        init();
    }catch(e){showToast(e.message,'error');}
    finally{btn.disabled=false;btn.innerHTML='<i class="bi bi-file-earmark-x"></i> Confirmar Resciliación';}
}

// ──────────────── DOCUMENT MANAGER ────────────────
const dmState={};

function initDM(tipo,asociacionId){
    const container=$(`dm-${tipo}`);if(!container)return;
    if(dmState[tipo]&&dmState[tipo].asociacionId===asociacionId)return;
    dmState[tipo]={asociacionId,initialized:true};
    container.innerHTML=`
        <div class="step-box" style="margin-bottom:14px;">
            <p class="step-title"><i class="bi bi-cloud-upload"></i> Subir Documentos</p>
            <p style="font-size:.8rem;color:#64748b;margin:0 0 10px;">Selecciona archivos — se suben automáticamente al instante.</p>
            <div class="im-upload-zone" id="dz-${tipo}">
                <input type="file" multiple accept="image/*,.pdf,.doc,.docx,.xls,.xlsx,.zip,.rar" id="file-input-${tipo}"
                    onchange="handleFileSelect('${tipo}','${asociacionId}',this.files)">
                <i class="bi bi-cloud-arrow-up im-upload-icon"></i>
                <p class="im-upload-text">Arrastra archivos aquí o <strong>haz clic</strong></p>
                <p class="im-upload-hint">PDF, imágenes, Word, Excel · múltiples archivos · máx. 100 MB c/u</p>
            </div>
            <div id="dq-${tipo}"></div>
        </div>
        <div>
            <p class="step-title"><i class="bi bi-folder2-open"></i> Documentos Subidos</p>
            <div id="dl-${tipo}" class="im-doc-list"><div class="im-empty" style="padding:16px;"><i class="bi bi-hourglass-split"></i><p>Cargando...</p></div></div>
        </div>`;
    loadDocs(tipo==='lote'?'parcela':tipo==='venta'?'venta':tipo,asociacionId);
}

const ext2icon=ext=>['pdf'].includes(ext)?'bi-file-earmark-pdf':['jpg','jpeg','png','webp','gif'].includes(ext)?'bi-file-earmark-image':['doc','docx'].includes(ext)?'bi-file-earmark-word':'bi-file-earmark';

async function handleFileSelect(tipo,asociacionId,files){
    const qEl=$(`dq-${tipo}`);
    const inp=$(`file-input-${tipo}`);if(inp)inp.value='';
    const tipoApi=tipo==='lote'?'parcela':tipo==='venta'?'venta':tipo==='persona'?'persona':'proyecto';
    let ok=0,fail=0;

    for(const f of Array.from(files)){
        const uid='f'+Date.now()+Math.random().toString(36).slice(2);
        const ext=f.name.split('.').pop().toLowerCase();
        const size=(f.file?f.file.size:f.size)/1024/1024;
        const nombre=f.name.replace(/\.[^/.]+$/,'').replace(/[_-]/g,' ');

        // Agregar fila de progreso
        const row=document.createElement('div');
        row.id=`urow-${uid}`;
        row.style.cssText='display:flex;align-items:center;gap:10px;padding:8px 10px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;margin-bottom:6px;';
        row.innerHTML=`
            <i class="bi ${ext2icon(ext)}" style="font-size:1.3rem;color:#2563eb;flex-shrink:0;"></i>
            <div style="flex:1;min-width:0;">
                <div style="font-size:.82rem;font-weight:600;color:#0f172a;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${escH(nombre)}</div>
                <div style="font-size:.72rem;color:#94a3b8;">${size.toFixed(1)} MB · Subiendo...</div>
                <div style="height:4px;background:#e2e8f0;border-radius:2px;margin-top:4px;overflow:hidden;">
                    <div id="pbar-${uid}" style="height:100%;width:0%;background:#2563eb;border-radius:2px;transition:width .3s;"></div>
                </div>
            </div>`;
        if(qEl)qEl.appendChild(row);
        const pbar=$(`pbar-${uid}`);if(pbar)pbar.style.width='25%';

        try{
            const fd=new FormData();
            fd.append('archivo',f,f.name);
            fd.append('nombre_personalizado',nombre);
            fd.append('tipo_asociacion',tipoApi);
            fd.append('asociacion_id',asociacionId);
            if(pbar)pbar.style.width='60%';
            const res=await fetch('/api/im/documentos',{method:'POST',body:fd});
            if(!res.ok){const e=await res.json().catch(()=>({}));throw new Error(e.message||`Error ${res.status}`);}
            if(pbar){pbar.style.width='100%';pbar.style.background='#16a34a';}
            row.style.borderColor='#86efac';row.style.background='#f0fdf4';
            row.querySelector('div>div:nth-child(2)').textContent=`${size.toFixed(1)} MB · ¡Subido!`;
            ok++;
        }catch(e){
            if(pbar){pbar.style.width='100%';pbar.style.background='#ef4444';}
            row.style.borderColor='#fca5a5';row.style.background='#fff5f5';
            row.querySelector('div>div:nth-child(2)').textContent=`Error: ${e.message}`;
            fail++;
        }
        setTimeout(()=>row.remove(),3000);
    }

    if(ok>0){showToast(`${ok} documento${ok>1?'s':''} subido${ok>1?'s':''}  correctamente.`,'success');}
    if(fail>0){showToast(`${fail} archivo${fail>1?'s':''} no se pudo${fail>1?'ron':''} subir.`,'error');}
    loadDocs(tipoApi,asociacionId);
}

async function loadDocs(tipo_asociacion,asociacionId){
    const dlId=tipo_asociacion==='proyecto'?'dl-proyecto':tipo_asociacion==='parcela'?'dl-lote':tipo_asociacion==='venta'?'dl-venta':'dl-persona';
    const dl=$(dlId);if(!dl)return;
    dl.innerHTML='<div class="im-empty" style="padding:16px;"><i class="bi bi-hourglass-split"></i><p>Cargando...</p></div>';
    try{
        const res=await fetch(`/api/im/documentos?tipo_asociacion=${tipo_asociacion}&asociacion_id=${asociacionId}`);
        if(!res.ok){const eb=await res.json().catch(()=>({}));throw new Error(eb.message||`No se pudieron cargar los documentos (HTTP ${res.status}).`);}
        const docs=await res.json();
        if(docs.length===0){dl.innerHTML='<div class="im-empty" style="padding:16px;"><i class="bi bi-folder2-open"></i><p>Sin documentos aún.</p></div>';return;}
        const ext2icon=ext=>['pdf'].includes(ext)?'bi-file-earmark-pdf bi-doc-red':['jpg','jpeg','png','webp','gif'].includes(ext)?'bi-file-earmark-image bi-doc-blue':'bi-file-earmark';
        const canPreview=ext=>['pdf','jpg','jpeg','png','webp','gif'].includes(ext);
        dl.innerHTML=docs.map(doc=>{
            const ext=(doc.storage_path||'').split('.').pop().toLowerCase();
            const fecha=new Date(doc.creado_at).toLocaleDateString('es-CL',{day:'2-digit',month:'short',year:'numeric'});
            return `<div class="im-doc-item" id="docitem-${doc.id}">
                <i class="bi ${ext2icon(ext)} im-doc-icon"></i>
                <div class="im-doc-info" style="flex:1;min-width:0;">
                    <div class="im-doc-name doc-item-name-display" id="dname-${doc.id}" title="${escH(doc.nombre_personalizado)}">${escH(doc.nombre_personalizado)}</div>
                    <input class="doc-item-name-edit" id="dedit-${doc.id}" value="${escH(doc.nombre_personalizado)}"
                        onkeydown="if(event.key==='Enter'){saveRename(${doc.id},'${tipo_asociacion}','${asociacionId}');}if(event.key==='Escape'){cancelRename(${doc.id});}">
                    <div class="im-doc-date">${fecha}</div>
                </div>
                <div class="im-doc-actions">
                    ${canPreview(ext)?`<button class="im-btn im-btn-sm im-btn-ghost" onclick="previewDoc('${escH(doc.url_storage)}','${escH(doc.nombre_personalizado)}','${ext}')" title="Ver"><i class="bi bi-eye"></i></button>`:''}
                    <a href="${escH(doc.url_storage)}" download="${escH(doc.nombre_personalizado)}.${ext}" target="_blank" class="im-btn im-btn-sm im-btn-ghost" title="Descargar"><i class="bi bi-download"></i></a>
                    <button class="im-btn im-btn-sm im-btn-ghost" onclick="startRename(${doc.id})" title="Renombrar"><i class="bi bi-pencil"></i></button>
                    <button class="im-btn im-btn-sm" id="save-rename-${doc.id}" style="display:none;" onclick="saveRename(${doc.id},'${tipo_asociacion}','${asociacionId}')"><i class="bi bi-check-lg"></i></button>
                    ${(IS_ADMIN||PUEDE_CREAR)?`<button class="im-btn im-btn-sm im-btn-danger" onclick="deleteDoc(${doc.id},'${tipo_asociacion}','${asociacionId}')" title="Eliminar"><i class="bi bi-trash3"></i></button>`:''}
                </div>
            </div>`;
        }).join('');
    }catch(e){dl.innerHTML=`<div class="im-empty" style="color:#ef4444;padding:16px;"><i class="bi bi-exclamation-triangle"></i><p>${escH(e.message)}</p></div>`;}
}

function startRename(id){const d=$(`dname-${id}`),ed=$(`dedit-${id}`),sb=$(`save-rename-${id}`);if(!d||!ed)return;d.classList.add('hidden');ed.classList.add('active');if(sb)sb.style.display='flex';ed.focus();ed.select();}
function cancelRename(id){const d=$(`dname-${id}`),ed=$(`dedit-${id}`),sb=$(`save-rename-${id}`);if(d)d.classList.remove('hidden');if(ed)ed.classList.remove('active');if(sb)sb.style.display='none';}

async function saveRename(id,tipo_asociacion,asociacionId){
    const ed=$(`dedit-${id}`);if(!ed)return;const n=ed.value.trim();if(!n)return;
    try{
        const res=await fetch(`/api/im/documentos/${id}`,{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({nombre_personalizado:n})});
        if(!res.ok){const e=await res.json().catch(()=>({}));throw new Error(e.message||`Error ${res.status}`);}
        showToast('Nombre actualizado.','success');loadDocs(tipo_asociacion,asociacionId);
    }catch(e){showToast(e.message,'error');cancelRename(id);}
}

async function deleteDoc(id,tipo_asociacion,asociacionId){
    if(!confirm('¿Eliminar este documento? Esta acción no se puede deshacer.'))return;
    try{
        const res=await fetch(`/api/im/documentos/${id}`,{method:'DELETE'});
        if(!res.ok){const eb=await res.json().catch(()=>({}));throw new Error(eb.message||`No se pudo eliminar el documento (HTTP ${res.status}).`);}
        showToast('Documento eliminado.','success');loadDocs(tipo_asociacion,asociacionId);loadAuditoria();
    }catch(e){showToast(e.message,'error');}
}

function previewDoc(url,nombre,ext){
    $('preview-title').innerHTML=`<i class="bi bi-eye"></i> ${escH(nombre)}`;
    $('preview-download').href=url;$('preview-download').download=nombre+'.'+ext;
    const imgs=['jpg','jpeg','png','webp','gif'];
    let content='';
    if(imgs.includes(ext))content=`<img src="${url}" style="max-width:100%;max-height:480px;border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,.1);" alt="${escH(nombre)}">`;
    else if(ext==='pdf')content=`<iframe src="${url}" class="preview-frame"></iframe>`;
    else content=`<div style="padding:40px;color:#64748b;text-align:center;"><i class="bi bi-file-earmark-text" style="font-size:3rem;display:block;margin-bottom:12px;"></i><p>Vista previa no disponible para este tipo de archivo.</p><a href="${url}" target="_blank" class="im-btn im-btn-primary" style="margin-top:10px;display:inline-flex;"><i class="bi bi-box-arrow-up-right"></i> Abrir en nueva pestaña</a></div>`;
    $('preview-content').innerHTML=content;
    openModal('preview');
}

// ──────────────── AUDITORÍA ────────────────
async function loadAuditoria(){
    const list=$('auditoria-list');
    list.innerHTML='<div class="im-empty"><i class="bi bi-hourglass-split"></i><p>Cargando...</p></div>';
    try{
        const [r1,r2]=await Promise.all([
            fetch(`/api/im/auditoria?entidad_id=${PARCELA_ID}`).then(r=>r.json()),
            proyectoId?fetch(`/api/im/auditoria?entidad_id=${proyectoId}`).then(r=>r.json()):[]
        ]);
        const all=[...(Array.isArray(r1)?r1:[]),...(Array.isArray(r2)?r2:[])].sort((a,b)=>new Date(b.fecha)-new Date(a.fecha));
        if(all.length===0){list.innerHTML='<div class="im-empty"><i class="bi bi-clock-history"></i><p>Sin registros aún.</p></div>';return;}
        list.innerHTML=all.map(a=>`<div class="im-audit-item">
            <div class="im-audit-dot"></div>
            <div class="im-audit-body">
                <div class="im-audit-accion">${escH(a.accion)}</div>
                ${a.descripcion?`<div class="im-audit-desc">${escH(a.descripcion)}</div>`:''}
                <div class="im-audit-meta">${new Date(a.fecha).toLocaleString('es-CL',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'})} · ${escH(a.usuario_nombre||'Sistema')}</div>
            </div>
        </div>`).join('');
    }catch(e){list.innerHTML=`<div class="im-empty" style="color:#ef4444;"><i class="bi bi-exclamation-triangle"></i><p>${escH(e.message)}</p></div>`;}
}

document.addEventListener('DOMContentLoaded',init);
</script>
