<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/inmobiliaria.css">
    <style>
        .step-badge{display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;border-radius:50%;background:#2563eb;color:#fff;font-size:.75rem;font-weight:800;flex-shrink:0}
        .step-title{font-size:.8rem;font-weight:700;color:#334155;text-transform:uppercase;letter-spacing:.4px;margin:0 0 12px;display:flex;align-items:center;gap:8px}
        .step-box{background:#f8fafc;border:1px solid #e2e8f0;border-radius:12px;padding:16px;margin-bottom:14px}
        .step-box.highlight{background:#f0fdf4;border-color:#86efac}
        .rut-input-wrap{position:relative}.rut-status{position:absolute;right:12px;top:50%;transform:translateY(-50%);font-size:1rem}
        .dm-queue{display:flex;flex-direction:column;gap:8px;margin-top:10px}
        .dm-queue-item{display:flex;align-items:center;gap:10px;background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:8px 12px}
        .dm-queue-item input{flex:1;border:1px solid #e2e8f0;border-radius:6px;padding:6px 10px;font-size:.82rem;font-family:inherit}
        .dm-progress{height:4px;background:#e2e8f0;border-radius:4px;margin-top:4px;overflow:hidden}
        .dm-progress-bar{height:100%;background:#10b981;border-radius:4px;transition:width .3s}
        .doc-item-name-edit{display:none;flex:1;border:1px solid #2563eb;border-radius:6px;padding:4px 8px;font-size:.82rem;font-family:inherit}
        .doc-item-name-edit.active{display:block}.doc-item-name-display.hidden{display:none}
        .preview-frame{width:100%;height:100%;min-height:calc(90vh - 130px);border:none;border-radius:0;background:#525659;display:block}
        #modal-preview .im-modal-card.im-preview-tall{width:min(960px,calc(100vw - 32px));height:min(92vh,calc(100vh - 32px));max-width:none;max-height:none}
        #modal-preview .im-modal-body.im-preview-fill{flex:1;min-height:0;padding:0;overflow:hidden;display:block;background:#525659}
        #modal-preview #preview-content.im-preview-fill{height:100%;text-align:left}
        #modal-preview #preview-content.im-preview-fill img{max-width:100%;max-height:100%;width:auto;height:auto;object-fit:contain;display:block;margin:0 auto}
        .price-hint{font-size:.75rem;color:#64748b;margin-top:3px}
        .pago-tab{padding:8px 16px;border-radius:8px;border:2px solid #e2e8f0;background:#fff;cursor:pointer;font-size:.82rem;font-weight:700;color:#64748b;transition:all .2s}
        .pago-tab.active{border-color:#2563eb;background:#eff6ff;color:#2563eb}
        .cuota-row{display:grid;grid-template-columns:32px 1fr 130px 110px 100px auto;align-items:center;gap:8px;padding:10px 12px;border-radius:10px;border:1px solid #e2e8f0;background:#fff;margin-bottom:8px}
        .cuota-row.pagada{background:#f0fdf4;border-color:#86efac}
        .cuota-row.vencida{background:#fff1f2;border-color:#fca5a5}
        .cuota-num{font-size:.8rem;font-weight:800;color:#2563eb;width:28px;height:28px;border-radius:50%;background:#eff6ff;display:flex;align-items:center;justify-content:center}
        .cuota-monto{font-weight:700;color:#0f172a;font-size:.88rem}
        .cuota-fecha{font-size:.78rem;color:#64748b}
        .cuota-badge-pagada{background:#dcfce7;color:#166534;border:1px solid #86efac;border-radius:20px;padding:3px 10px;font-size:.72rem;font-weight:700}
        .cuota-badge-pendiente{background:#fef3c7;color:#92400e;border:1px solid #fde68a;border-radius:20px;padding:3px 10px;font-size:.72rem;font-weight:700}
        .cuota-badge-vencida{background:#fee2e2;color:#991b1b;border:1px solid #fca5a5;border-radius:20px;padding:3px 10px;font-size:.72rem;font-weight:700}
        @media(max-width:700px){.cuota-row{grid-template-columns:28px 1fr 100px auto;}.cuota-row .cuota-fecha,.cuota-row .cuota-badge-pagada,.cuota-row .cuota-badge-pendiente,.cuota-row .cuota-badge-vencida{display:none}}
    </style>
</head>
<body class="dashboard-body">
    <%- include('../partials/alerts') %>

    <!-- Toast -->
    <div id="im-toast" style="position:fixed;top:20px;right:20px;z-index:9999;pointer-events:none;opacity:0;transform:translateX(30px);transition:all .3s ease;max-width:420px;">
        <div id="im-toast-inner" style="padding:14px 18px;border-radius:12px;box-shadow:0 8px 30px rgba(0,0,0,.15);display:flex;align-items:flex-start;gap:10px;"></div>
    </div>

    <!-- Preview Modal -->
    <div id="modal-preview" class="im-modal-overlay">
        <div class="im-modal-card im-preview-tall">
            <div class="im-modal-header">
                <h3 id="preview-title"><i class="bi bi-eye"></i> Vista Previa</h3>
                <div style="display:flex;gap:8px;align-items:center;">
                    <a id="preview-download" href="#" download class="im-btn im-btn-sm im-btn-ghost" target="_blank"><i class="bi bi-download"></i> Descargar</a>
                    <button class="btn-close" onclick="closeModal('preview')"><i class="bi bi-x-lg"></i></button>
                </div>
            </div>
            <div class="im-modal-body im-preview-fill">
                <div id="preview-content"></div>
            </div>
        </div>
    </div>

    <!-- Modal eliminar documento -->
    <div id="modal-del-doc" class="im-modal-overlay">
        <div class="im-modal-card" style="max-width:420px;">
            <div class="im-modal-header" style="background:linear-gradient(135deg,#dc2626,#ef4444);">
                <h3 style="display:flex;align-items:center;gap:8px;"><i class="bi bi-trash3-fill"></i> Eliminar Documento</h3>
                <button class="btn-close" onclick="closeModal('del-doc')"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="im-modal-body" style="padding:24px;">
                <div style="text-align:center;margin-bottom:20px;">
                    <div style="width:56px;height:56px;background:#fee2e2;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;">
                        <i class="bi bi-exclamation-triangle-fill" style="font-size:1.6rem;color:#dc2626;"></i>
                    </div>
                    <p style="font-weight:700;font-size:.95rem;color:#0f172a;margin:0 0 6px;">¿Eliminar este documento?</p>
                    <p id="del-doc-nombre" style="font-size:.85rem;color:#64748b;margin:0;word-break:break-word;"></p>
                    <p style="font-size:.78rem;color:#ef4444;margin:10px 0 0;font-weight:600;"><i class="bi bi-exclamation-circle"></i> Esta acción no se puede deshacer.</p>
                </div>
                <div style="display:flex;gap:8px;">
                    <button onclick="closeModal('del-doc')" class="im-btn im-btn-ghost" style="flex:1;">Cancelar</button>
                    <button id="btn-confirm-del-doc" onclick="confirmDeleteDoc()" class="im-btn im-btn-danger" style="flex:1;">
                        <i class="bi bi-trash3"></i> Sí, eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Resciliar contrato modal -->
    <div id="modal-liberar" class="im-modal-overlay">
        <div class="im-modal-card" style="max-width:640px;max-height:92vh;overflow:auto;">
            <div class="im-modal-header">
                <h3><i class="bi bi-file-earmark-x"></i> Resciliar Contrato</h3>
                <button class="btn-close" onclick="closeModal('liberar')"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="im-modal-body" style="padding:20px;display:flex;flex-direction:column;gap:14px;">
                <div style="background:#fef3c7;border:1px solid #fde68a;border-radius:10px;padding:12px 14px;font-size:.83rem;color:#92400e;">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    Se registra el <strong>contrato de resciliación</strong>, se libera la parcela a <strong>Disponible</strong>
                    y queda el historial de la venta (precio, pie, docs). Define también cómo se devolverá el dinero.
                </div>

                <div id="resc-resumen-venta" style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:12px 14px;font-size:.82rem;color:#334155;"></div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div>
                        <label style="font-size:.78rem;font-weight:600;color:#475569;display:block;margin-bottom:4px;">Fecha de Resciliación</label>
                        <input type="date" id="resc-fecha" class="styled-input">
                    </div>
                    <div>
                        <label style="font-size:.78rem;font-weight:600;color:#475569;display:block;margin-bottom:4px;">Motivo</label>
                        <select id="resc-motivo" class="styled-input">
                            <option value="Desistimiento del comprador">Desistimiento del comprador</option>
                            <option value="Incumplimiento de pago">Incumplimiento de pago</option>
                            <option value="Acuerdo mutuo">Acuerdo mutuo</option>
                            <option value="Resolución judicial">Resolución judicial</option>
                            <option value="Otro">Otro</option>
                        </select>
                    </div>
                </div>
                <div>
                    <label style="font-size:.78rem;font-weight:600;color:#475569;display:block;margin-bottom:4px;">Notas del contrato <span style="font-weight:400;color:#94a3b8;">(opcional)</span></label>
                    <textarea id="resc-notas" class="styled-input" rows="2" placeholder="Acuerdos, referencias a escrituras, observaciones..."></textarea>
                </div>

                <!-- Plan de devolución -->
                <div style="border:1.5px solid #fecaca;border-radius:12px;padding:14px;background:#fff;">
                    <p style="font-size:.78rem;font-weight:800;color:#991b1b;text-transform:uppercase;margin:0 0 10px;letter-spacing:.4px;">
                        <i class="bi bi-arrow-return-left"></i> Plan de devolución al cliente
                    </p>
                    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;">
                        <button type="button" class="im-btn im-btn-sm resc-dev-tab active" id="resc-tab-contado" onclick="setRescDevTipo('contado')">Al Contado</button>
                        <button type="button" class="im-btn im-btn-sm resc-dev-tab" id="resc-tab-cuotas" onclick="setRescDevTipo('cuotas')">En Cuotas</button>
                        <button type="button" class="im-btn im-btn-sm resc-dev-tab" id="resc-tab-pie" onclick="setRescDevTipo('pie_mas_cuotas')">Pie + Cuotas</button>
                        <button type="button" class="im-btn im-btn-sm resc-dev-tab" id="resc-tab-sin" onclick="setRescDevTipo('sin_devolucion')">Sin devolución</button>
                    </div>

                    <div id="resc-dev-campos">
                        <div class="im-form-row" style="margin-bottom:10px;">
                            <div class="im-input-group">
                                <label>Monto total a devolver (CLP)</label>
                                <input type="text" id="resc-monto-total" class="styled-input" placeholder="Ej: 5.000.000" oninput="fmtPrecio(this);recalcRescCuotas()">
                            </div>
                            <div class="im-input-group" id="resc-pie-wrap" style="display:none;">
                                <label>Pago inicial / pie de resciliación</label>
                                <input type="text" id="resc-monto-pie" class="styled-input" placeholder="Ej: 1.000.000" oninput="fmtPrecio(this);recalcRescCuotas()">
                            </div>
                        </div>
                        <div id="resc-cuotas-wrap" style="display:none;">
                            <div class="im-form-row" style="margin-bottom:10px;">
                                <div class="im-input-group">
                                    <label>N° de cuotas</label>
                                    <input type="number" id="resc-num-cuotas" class="styled-input" min="1" max="120" value="6" oninput="recalcRescCuotas()">
                                </div>
                                <div class="im-input-group">
                                    <label>Monto por cuota</label>
                                    <input type="text" id="resc-monto-cuota" class="styled-input" placeholder="Auto" oninput="fmtPrecio(this)">
                                </div>
                                <div class="im-input-group">
                                    <label>Primera fecha de pago</label>
                                    <input type="date" id="resc-primera-cuota" class="styled-input" onchange="recalcRescCuotas()">
                                </div>
                            </div>
                            <div id="resc-cuotas-preview" style="display:none;">
                                <p style="font-size:.75rem;font-weight:700;color:#64748b;margin:0 0 6px;">Calendario de devoluciones</p>
                                <div id="resc-cuotas-preview-list"></div>
                            </div>
                        </div>
                    </div>
                    <p id="resc-sin-dev-msg" style="display:none;font-size:.8rem;color:#64748b;margin:0;">No se registrará plan de devolución monetaria.</p>
                </div>

                <div>
                    <label style="font-size:.78rem;font-weight:600;color:#475569;display:block;margin-bottom:6px;"><i class="bi bi-paperclip"></i> Documentos de resciliación <span style="font-weight:400;color:#94a3b8;">(opcional)</span></label>
                    <p style="font-size:.76rem;color:#64748b;margin:0 0 8px;">Contrato de resciliación, notificaciones, comprobantes. Quedan en la carpeta del lote (los docs de la venta se conservan).</p>
                    <div class="im-upload-zone" style="padding:14px;" onclick="document.getElementById('resc-file-input').click()">
                        <input type="file" id="resc-file-input" multiple accept="image/*,.pdf,.doc,.docx" style="display:none">
                        <i class="bi bi-cloud-arrow-up" style="font-size:1.6rem;color:#94a3b8;"></i>
                        <p style="font-size:.8rem;color:#64748b;margin:4px 0 0;">Haz clic o arrastra archivos aquí</p>
                    </div>
                    <div id="resc-file-list" style="margin-top:8px;display:flex;flex-direction:column;gap:4px;"></div>
                </div>
            </div>
            <div class="im-modal-footer">
                <button class="im-btn im-btn-ghost" onclick="closeModal('liberar')">Cancelar</button>
                <button class="im-btn im-btn-danger" id="btn-resciliar" onclick="resciliarContrato()">
                    <i class="bi bi-file-earmark-x"></i> Confirmar Resciliación
                </button>
            </div>
        </div>
    </div>

    <!-- Cuota detail modal -->
    <div id="modal-cuota" class="im-modal-overlay">
        <div class="im-modal-card" style="max-width:480px;">
            <div class="im-modal-header">
                <h3 id="cuota-modal-title"><i class="bi bi-cash"></i> Editar Cuota</h3>
                <button class="btn-close" onclick="closeModal('cuota')"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="im-modal-body" style="padding:20px;">
                <input type="hidden" id="cuota-modal-id">
                <div class="im-form-row">
                    <div class="im-input-group">
                        <label>Monto Cuota (CLP)</label>
                        <input type="text" id="cuota-modal-monto" class="styled-input" oninput="fmtPrecio(this)">
                    </div>
                    <div class="im-input-group">
                        <label>Fecha Vencimiento</label>
                        <input type="date" id="cuota-modal-venc" class="styled-input">
                    </div>
                </div>
                <div class="im-input-group">
                    <label>Fecha de Pago</label>
                    <input type="date" id="cuota-modal-fpago" class="styled-input">
                </div>
                <div class="im-checkbox-row" style="margin-bottom:12px;">
                    <input type="checkbox" id="cuota-modal-pagada">
                    <label for="cuota-modal-pagada" style="font-weight:700;">Marcar como Pagada</label>
                </div>
                <div class="im-input-group">
                    <label>Notas</label>
                    <input type="text" id="cuota-modal-notas" class="styled-input" placeholder="Observaciones opcionales">
                </div>
                <div style="border-top:1px solid #e2e8f0;margin-top:14px;padding-top:14px;">
                    <p style="font-size:.78rem;font-weight:700;color:#475569;margin:0 0 8px;">
                        <i class="bi bi-paperclip"></i> Comprobante de Pago (foto/PDF)
                    </p>
                    <input type="file" id="cuota-modal-file" accept="image/*,.pdf" class="styled-input" style="padding:6px;">
                    <p class="price-hint">Foto de transferencia, vale vista, recibo, etc.</p>
                </div>
            </div>
            <div class="im-modal-footer">
                <button class="im-btn im-btn-ghost" onclick="closeModal('cuota')">Cancelar</button>
                <button class="im-btn im-btn-success" onclick="saveCuota()"><i class="bi bi-save"></i> Guardar</button>
            </div>
        </div>
    </div>

    <div class="app-layout">
        <%- include('../partials/sidebar-admin', { page: 'inmobiliaria' }) %>
        <main class="main-content">
            <div class="dashboard-scroll">

                <div style="display:flex;align-items:center;gap:8px;margin-top:16px;margin-bottom:16px;font-size:.85rem;color:#64748b;flex-wrap:wrap;">
                    <a href="/admin/inmobiliaria" style="color:#2563eb;text-decoration:none;font-weight:600;"><i class="bi bi-arrow-left"></i> Gestión de Campos</a>
                    <span>›</span><span id="bc-proyecto" style="color:#64748b;">Proyecto</span>
                    <span>›</span><b id="bc-parcela" style="color:#0f172a;">Parcela</b>
                </div>

                <div class="im-page-header" id="parcela-header" style="margin-top:0;margin-bottom:16px;">
                    <div>
                        <h1 id="parcela-titulo" style="font-size:1.5rem;">Cargando...</h1>
                        <div id="parcela-estado-badge" style="margin-top:6px;"></div>
                    </div>
                    <div style="display:flex;gap:10px;flex-wrap:wrap;" id="header-actions"></div>
                </div>

                <div class="im-ficha-layout">
                    <!-- ══ COLUMNA IZQUIERDA ══ -->
                    <div style="display:flex;flex-direction:column;gap:16px;">
                        <div class="im-panel" id="panel-detalles">
                            <p class="im-panel-title"><i class="bi bi-info-circle"></i> Información de la Parcela</p>
                            <div id="detalle-rows"><div class="im-empty"><i class="bi bi-hourglass-split"></i><p>Cargando...</p></div></div>
                            <div style="margin-top:18px;padding-top:14px;border-top:1px solid #e2e8f0;">
                                <p class="step-title" style="margin-bottom:10px;"><i class="bi bi-pencil-square"></i> Actualizar Datos</p>
                                <div class="im-form-row">
                                    <div class="im-input-group"><label>N° Rol Parcela</label><input type="text" id="edit-rol" class="styled-input" placeholder="Ej: 123-45-01"></div>
                                    <div class="im-input-group"><label>Metraje (m²)</label><input type="number" id="edit-metraje" class="styled-input" step="0.01" placeholder="Ej: 5000"></div>
                                </div>
                                <div class="im-form-row">
                                    <div class="im-input-group">
                                        <label>Precio de Lista (CLP)</label>
                                        <input type="text" id="edit-precio" class="styled-input" placeholder="Ej: 25.000.000" oninput="fmtPrecio(this)">
                                        <p class="price-hint">Precio publicado / de referencia</p>
                                    </div>
                                    <div class="im-input-group">
                                        <label>Estado de Venta</label>
                                        <select id="edit-estado" class="styled-input">
                                            <option value="disponible">Disponible</option>
                                            <option value="reservado">Reservado</option>
                                            <option value="vendido">Vendido</option>
                                        </select>
                                    </div>
                                </div>
                                <button class="im-btn im-btn-primary im-btn-full" onclick="guardarParcela(event)"><i class="bi bi-save"></i> Guardar Cambios</button>
                            </div>
                        </div>

                        <div class="im-panel">
                            <p class="im-panel-title"><i class="bi bi-graph-up"></i> Historial de Precios</p>
                            <div id="historial-precios"><div class="im-empty"><i class="bi bi-clock-history"></i><p>Sin historial aún.</p></div></div>
                        </div>
                    </div>

                    <!-- ══ COLUMNA DERECHA ══ -->
                    <div class="im-panel" style="min-height:600px;">
                        <div class="im-tabs-header">
                            <button class="im-tab-btn active" onclick="switchTab('comprador',this)"><i class="bi bi-person-fill"></i> Comprador</button>
                            <button class="im-tab-btn" onclick="switchTab('docs-venta',this)"><i class="bi bi-receipt"></i> Docs Venta</button>
                            <button class="im-tab-btn" onclick="switchTab('docs-persona',this)"><i class="bi bi-person-vcard"></i> Docs Cliente</button>
                            <button class="im-tab-btn" onclick="switchTab('docs-lote',this)"><i class="bi bi-file-earmark-text"></i> Docs Lote</button>
                            <button class="im-tab-btn" onclick="switchTab('docs-proyecto',this)"><i class="bi bi-folder2"></i> Docs Proyecto</button>
                            <button class="im-tab-btn" onclick="switchTab('auditoria',this)"><i class="bi bi-clock-history"></i> Auditoría</button>
                        </div>

                        <!-- ─── TAB COMPRADOR ─── -->
                        <div id="tab-comprador" class="im-tab-content active">
                            <div id="banner-en-verde" style="display:none;background:#fef9c3;border:1px solid #fde047;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:.83rem;color:#713f12;">
                                <i class="bi bi-tree-fill" style="color:#65a30d;"></i>
                                <strong>Proyecto en Verde</strong> — Este proyecto se encuentra en proceso de tramitación.
                                Las parcelas pueden ser vendidas antes de contar con rol propio asignado.
                            </div>
                            <div id="venta-actual" style="margin-bottom:16px;"></div>

                            <!-- Botón para editar cuando ya hay venta -->
                            <div id="btn-editar-venta-wrap" style="display:none;margin-bottom:14px;">
                                <button class="im-btn im-btn-ghost" onclick="toggleFormVenta()" id="btn-toggle-form">
                                    <i class="bi bi-pencil-square"></i> Editar datos de la venta / comprador
                                </button>
                            </div>

                            <div id="historial-ventas-section" style="display:none;margin-bottom:20px;"></div>

                            <!-- Formulario (visible solo si no hay venta, o al editar) -->
                            <div id="form-venta-wrapper">

                            <!-- PASO 1 -->
                            <div class="step-box">
                                <p class="step-title"><span class="step-badge">1</span> Buscar Cliente Existente</p>
                                <div style="display:flex;gap:8px;align-items:center;">
                                    <div style="flex:1;position:relative;">
                                        <i class="bi bi-search" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:.9rem;pointer-events:none;"></i>
                                        <input type="text" id="buscar-rut"
                                            style="padding-left:36px;"
                                            class="styled-input"
                                            placeholder="Nombre o RUT del cliente..."
                                            oninput="buscarClienteLive()"
                                            onkeydown="if(event.key==='Enter'){event.preventDefault();buscarCliente();}">
                                    </div>
                                    <button class="im-btn im-btn-primary" onclick="buscarCliente()"><i class="bi bi-search"></i> Buscar</button>
                                </div>
