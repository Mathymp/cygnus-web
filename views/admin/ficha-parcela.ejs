            ${c.nombre_conyugue?`<div style="font-size:.72rem;color:#7c3aed;margin-top:1px;"><i class="bi bi-people"></i> Cónyuge: ${escH(c.nombre_conyugue)}${c.rut_conyugue?' · '+escH(c.rut_conyugue):''}</div>`:''}
            ${c.parcelas_compradas?`<div style="font-size:.72rem;color:#166534;margin-top:1px;"><i class="bi bi-bag-check"></i> Compró: ${escH(c.parcelas_compradas)}</div>`:''}
