                        <!-- ─── TAB AUDITORÍA ─── -->
                        <div id="tab-auditoria" class="im-tab-content">
                            <div id="auditoria-list" class="im-audit-list"><div class="im-empty"><i class="bi bi-clock-history"></i><p>Cargando...</p></div></div>
