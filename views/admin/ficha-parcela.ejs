<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/inmobiliaria.css">
    <style>
        .step-badge{display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;border-radius:50%;background:#2563eb;color:#fff;font-size:.75rem;font-weight:800;flex-shrink:0}
        .step-title{font-size:.8rem;font-weight:700;color:#334155;text-transform:uppercase;letter-spacing:.4px;margin:0 0 12px;display:flex;align-items:center;gap:8px}
        .step-box{background:#f8fafc;border:1px solid #e2e8f0;border-radius:12px;padding:16px;margin-bottom:14px}
        .step-box.highlight{background:#f0fdf4;border-color:#86efac}
        .rut-input-wrap{position:relative}.rut-status{position:absolute;right:12px;top:50%;transform:translateY(-50%);font-size:1rem}
        .dm-queue{display:flex;flex-direction:column;gap:8px;margin-top:10px}
        .dm-queue-item{display:flex;align-items:center;gap:10px;background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:8px 12px}
        .dm-queue-item input{flex:1;border:1px solid #e2e8f0;border-radius:6px;padding:6px 10px;font-size:.82rem;font-family:inherit}
        .dm-progress{height:4px;background:#e2e8f0;border-radius:4px;margin-top:4px;overflow:hidden}
        .dm-progress-bar{height:100%;background:#10b981;border-radius:4px;transition:width .3s}
        .doc-item-name-edit{display:none;flex:1;border:1px solid #2563eb;border-radius:6px;padding:4px 8px;font-size:.82rem;font-family:inherit}
        .doc-item-name-edit.active{display:block}.doc-item-name-display.hidden{display:none}
        .preview-frame{width:100%;height:500px;border:none;border-radius:8px;background:#f1f5f9}
        .price-hint{font-size:.75rem;color:#64748b;margin-top:3px}
        .pago-tab{padding:8px 16px;border-radius:8px;border:2px solid #e2e8f0;background:#fff;cursor:pointer;font-size:.82rem;font-weight:700;color:#64748b;transition:all .2s}
        .pago-tab.active{border-color:#2563eb;background:#eff6ff;color:#2563eb}
        .cuota-row{display:grid;grid-template-columns:32px 1fr 130px 110px 100px auto;align-items:center;gap:8px;padding:10px 12px;border-radius:10px;border:1px solid #e2e8f0;background:#fff;margin-bottom:8px}
        .cuota-row.pagada{background:#f0fdf4;border-color:#86efac}
        .cuota-row.vencida{background:#fff1f2;border-color:#fca5a5}
        .cuota-num{font-size:.8rem;font-weight:800;color:#2563eb;width:28px;height:28px;border-radius:50%;background:#eff6ff;display:flex;align-items:center;justify-content:center}
        .cuota-monto{font-weight:700;color:#0f172a;font-size:.88rem}
        .cuota-fecha{font-size:.78rem;color:#64748b}
        .cuota-badge-pagada{background:#dcfce7;color:#166534;border:1px solid #86efac;border-radius:20px;padding:3px 10px;font-size:.72rem;font-weight:700}
        .cuota-badge-pendiente{background:#fef3c7;color:#92400e;border:1px solid #fde68a;border-radius:20px;padding:3px 10px;font-size:.72rem;font-weight:700}
        .cuota-badge-vencida{background:#fee2e2;color:#991b1b;border:1px solid #fca5a5;border-radius:20px;padding:3px 10px;font-size:.72rem;font-weight:700}
        @media(max-width:700px){.cuota-row{grid-template-columns:28px 1fr 100px auto;}.cuota-row .cuota-fecha,.cuota-row .cuota-badge-pagada,.cuota-row .cuota-badge-pendiente,.cuota-row .cuota-badge-vencida{display:none}}
    </style>
</head>
<body class="dashboard-body">
    <%- include('../partials/alerts') %>

    <!-- Toast -->
    <div id="im-toast" style="position:fixed;top:20px;right:20px;z-index:9999;pointer-events:none;opacity:0;transform:translateX(30px);transition:all .3s ease;max-width:420px;">
        <div id="im-toast-inner" style="padding:14px 18px;border-radius:12px;box-shadow:0 8px 30px rgba(0,0,0,.15);display:flex;align-items:flex-start;gap:10px;"></div>
    </div>

    <!-- Preview Modal -->
    <div id="modal-preview" class="im-modal-overlay">
        <div class="im-modal-card" style="max-width:820px;">
            <div class="im-modal-header">
                <h3 id="preview-title"><i class="bi bi-eye"></i> Vista Previa</h3>
                <div style="display:flex;gap:8px;align-items:center;">
                    <a id="preview-download" href="#" download class="im-btn im-btn-sm im-btn-ghost" target="_blank"><i class="bi bi-download"></i> Descargar</a>
                    <button class="btn-close" onclick="closeModal('preview')"><i class="bi bi-x-lg"></i></button>
                </div>
            </div>
            <div class="im-modal-body" style="padding:16px;background:#f1f5f9;min-height:300px;display:flex;align-items:center;justify-content:center;">
                <div id="preview-content" style="width:100%;text-align:center;"></div>
            </div>
        </div>
    </div>

    <!-- Resciliar contrato modal -->
    <div id="modal-liberar" class="im-modal-overlay">
        <div class="im-modal-card" style="max-width:520px;">
            <div class="im-modal-header">
                <h3><i class="bi bi-file-earmark-x"></i> Resciliar Contrato</h3>
                <button class="btn-close" onclick="closeModal('liberar')"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="im-modal-body" style="padding:20px;display:flex;flex-direction:column;gap:14px;">
                <div style="background:#fef3c7;border:1px solid #fde68a;border-radius:10px;padding:12px 14px;font-size:.83rem;color:#92400e;">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    Esta operación registrará formalmente la <strong>resciliación del contrato</strong>.
                    La parcela volverá al estado <strong>Disponible</strong> y quedará un historial completo de la operación.
                    <strong>No se elimina ningún dato.</strong>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div>
                        <label style="font-size:.78rem;font-weight:600;color:#475569;display:block;margin-bottom:4px;">Fecha de Resciliación</label>
                        <input type="date" id="resc-fecha" class="styled-input">
                    </div>
                    <div>
                        <label style="font-size:.78rem;font-weight:600;color:#475569;display:block;margin-bottom:4px;">Motivo</label>
                        <select id="resc-motivo" class="styled-input">
                            <option value="Desistimiento del comprador">Desistimiento del comprador</option>
                            <option value="Incumplimiento de pago">Incumplimiento de pago</option>
                            <option value="Acuerdo mutuo">Acuerdo mutuo</option>
                            <option value="Resolución judicial">Resolución judicial</option>
                            <option value="Otro">Otro</option>
                        </select>
                    </div>
                </div>
                <div>
                    <label style="font-size:.78rem;font-weight:600;color:#475569;display:block;margin-bottom:4px;">Notas adicionales <span style="font-weight:400;color:#94a3b8;">(opcional)</span></label>
                    <textarea id="resc-notas" class="styled-input" rows="3" placeholder="Observaciones, acuerdos, referencias a documentos..."></textarea>
                </div>
                <div>
                    <label style="font-size:.78rem;font-weight:600;color:#475569;display:block;margin-bottom:6px;"><i class="bi bi-paperclip"></i> Documentos de resciliación <span style="font-weight:400;color:#94a3b8;">(opcional)</span></label>
                    <p style="font-size:.76rem;color:#64748b;margin:0 0 8px;">Escritura de resciliación, notificaciones, comprobantes. Se guardarán en la carpeta del lote.</p>
                    <div class="im-upload-zone" style="padding:14px;" onclick="document.getElementById('resc-file-input').click()">
                        <input type="file" id="resc-file-input" multiple accept="image/*,.pdf,.doc,.docx" style="display:none">
                        <i class="bi bi-cloud-arrow-up" style="font-size:1.6rem;color:#94a3b8;"></i>
                        <p style="font-size:.8rem;color:#64748b;margin:4px 0 0;">Haz clic o arrastra archivos aquí</p>
                    </div>
                    <div id="resc-file-list" style="margin-top:8px;display:flex;flex-direction:column;gap:4px;"></div>
                </div>
            </div>
            <div class="im-modal-footer">
                <button class="im-btn im-btn-ghost" onclick="closeModal('liberar')">Cancelar</button>
                <button class="im-btn im-btn-danger" id="btn-resciliar" onclick="resciliarContrato()">
                    <i class="bi bi-file-earmark-x"></i> Confirmar Resciliación
                </button>
            </div>
        </div>
    </div>

    <!-- Cuota detail modal -->
    <div id="modal-cuota" class="im-modal-overlay">
        <div class="im-modal-card" style="max-width:480px;">
            <div class="im-modal-header">
                <h3 id="cuota-modal-title"><i class="bi bi-cash"></i> Editar Cuota</h3>
                <button class="btn-close" onclick="closeModal('cuota')"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="im-modal-body" style="padding:20px;">
                <input type="hidden" id="cuota-modal-id">
                <div class="im-form-row">
                    <div class="im-input-group">
                        <label>Monto Cuota (CLP)</label>
                        <input type="text" id="cuota-modal-monto" class="styled-input" oninput="fmtPrecio(this)">
                    </div>
                    <div class="im-input-group">
                        <label>Fecha Vencimiento</label>
                        <input type="date" id="cuota-modal-venc" class="styled-input">
                    </div>
                </div>
                <div class="im-input-group">
                    <label>Fecha de Pago</label>
                    <input type="date" id="cuota-modal-fpago" class="styled-input">
                </div>
                <div class="im-checkbox-row" style="margin-bottom:12px;">
                    <input type="checkbox" id="cuota-modal-pagada">
                    <label for="cuota-modal-pagada" style="font-weight:700;">Marcar como Pagada</label>
                </div>
                <div class="im-input-group">
                    <label>Notas</label>
                    <input type="text" id="cuota-modal-notas" class="styled-input" placeholder="Observaciones opcionales">
                </div>
                <div style="border-top:1px solid #e2e8f0;margin-top:14px;padding-top:14px;">
                    <p style="font-size:.78rem;font-weight:700;color:#475569;margin:0 0 8px;">
                        <i class="bi bi-paperclip"></i> Comprobante de Pago (foto/PDF)
                    </p>
                    <input type="file" id="cuota-modal-file" accept="image/*,.pdf" class="styled-input" style="padding:6px;">
                    <p class="price-hint">Foto de transferencia, vale vista, recibo, etc.</p>
                </div>
            </div>
            <div class="im-modal-footer">
                <button class="im-btn im-btn-ghost" onclick="closeModal('cuota')">Cancelar</button>
                <button class="im-btn im-btn-success" onclick="saveCuota()"><i class="bi bi-save"></i> Guardar</button>
            </div>
        </div>
    </div>

    <div class="app-layout">
        <%- include('../partials/sidebar-admin', { page: 'inmobiliaria' }) %>
        <main class="main-content">
            <div class="dashboard-scroll">

                <div style="display:flex;align-items:center;gap:8px;margin-top:16px;margin-bottom:16px;font-size:.85rem;color:#64748b;flex-wrap:wrap;">
                    <a href="/admin/inmobiliaria" style="color:#2563eb;text-decoration:none;font-weight:600;"><i class="bi bi-arrow-left"></i> Gestión de Campos</a>
                    <span>›</span><span id="bc-proyecto" style="color:#64748b;">Proyecto</span>
                    <span>›</span><b id="bc-parcela" style="color:#0f172a;">Parcela</b>
                </div>

                <div class="im-page-header" id="parcela-header" style="margin-top:0;margin-bottom:16px;">
                    <div>
                        <h1 id="parcela-titulo" style="font-size:1.5rem;">Cargando...</h1>
                        <div id="parcela-estado-badge" style="margin-top:6px;"></div>
                    </div>
                    <div style="display:flex;gap:10px;flex-wrap:wrap;" id="header-actions"></div>
                </div>

                <div class="im-ficha-layout">
                    <!-- ══ COLUMNA IZQUIERDA ══ -->
                    <div style="display:flex;flex-direction:column;gap:16px;">
                        <div class="im-panel" id="panel-detalles">
                            <p class="im-panel-title"><i class="bi bi-info-circle"></i> Información de la Parcela</p>
                            <div id="detalle-rows"><div class="im-empty"><i class="bi bi-hourglass-split"></i><p>Cargando...</p></div></div>
                            <div style="margin-top:18px;padding-top:14px;border-top:1px solid #e2e8f0;">
                                <p class="step-title" style="margin-bottom:10px;"><i class="bi bi-pencil-square"></i> Actualizar Datos</p>
                                <div class="im-form-row">
                                    <div class="im-input-group"><label>N° Rol Parcela</label><input type="text" id="edit-rol" class="styled-input" placeholder="Ej: 123-45-01"></div>
                                    <div class="im-input-group"><label>Metraje (m²)</label><input type="number" id="edit-metraje" class="styled-input" step="0.01" placeholder="Ej: 5000"></div>
                                </div>
                                <div class="im-form-row">
                                    <div class="im-input-group">
                                        <label>Precio de Lista (CLP)</label>
                                        <input type="text" id="edit-precio" class="styled-input" placeholder="Ej: 25.000.000" oninput="fmtPrecio(this)">
                                        <p class="price-hint">Precio publicado / de referencia</p>
                                    </div>
                                    <div class="im-input-group">
                                        <label>Estado de Venta</label>
                                        <select id="edit-estado" class="styled-input">
                                            <option value="disponible">Disponible</option>
                                            <option value="reservado">Reservado</option>
                                            <option value="vendido">Vendido</option>
                                        </select>
                                    </div>
                                </div>
                                <button class="im-btn im-btn-primary im-btn-full" onclick="guardarParcela(event)"><i class="bi bi-save"></i> Guardar Cambios</button>
                            </div>
                        </div>

                        <div class="im-panel">
                            <p class="im-panel-title"><i class="bi bi-graph-up"></i> Historial de Precios</p>
                            <div id="historial-precios"><div class="im-empty"><i class="bi bi-clock-history"></i><p>Sin historial aún.</p></div></div>
                        </div>
                    </div>

                    <!-- ══ COLUMNA DERECHA ══ -->
                    <div class="im-panel" style="min-height:600px;">
                        <div class="im-tabs-header">
                            <button class="im-tab-btn active" onclick="switchTab('comprador',this)"><i class="bi bi-person-fill"></i> Comprador</button>
                            <button class="im-tab-btn" onclick="switchTab('docs-proyecto',this)"><i class="bi bi-folder2"></i> Proyecto</button>
                            <button class="im-tab-btn" onclick="switchTab('docs-lote',this)"><i class="bi bi-file-earmark-text"></i> Lote</button>
                            <button class="im-tab-btn" onclick="switchTab('docs-persona',this)"><i class="bi bi-person-vcard"></i> Persona</button>
                            <button class="im-tab-btn" onclick="switchTab('auditoria',this)"><i class="bi bi-clock-history"></i> Auditoría</button>
                        </div>

                        <!-- ─── TAB COMPRADOR ─── -->
                        <div id="tab-comprador" class="im-tab-content active">
                            <div id="banner-en-verde" style="display:none;background:#fef9c3;border:1px solid #fde047;border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:.83rem;color:#713f12;">
                                <i class="bi bi-tree-fill" style="color:#65a30d;"></i>
                                <strong>Proyecto en Verde</strong> — Este proyecto se encuentra en proceso de tramitación.
                                Las parcelas pueden ser vendidas antes de contar con rol propio asignado.
                            </div>
                            <div id="venta-actual" style="margin-bottom:16px;"></div>
                            <div id="historial-ventas-section" style="display:none;margin-bottom:20px;"></div>

                            <!-- PASO 1 -->
                            <div class="step-box">
                                <p class="step-title"><span class="step-badge">1</span> Buscar Cliente Existente por RUT</p>
                                <div style="display:flex;gap:8px;align-items:center;">
                                    <div class="rut-input-wrap" style="flex:1;">
                                        <input type="text" id="buscar-rut" class="styled-input" placeholder="Ej: 12.345.678-9"
                                            oninput="autoFmtRut(this,'buscar-rut-status')" style="padding-right:38px;">
                                        <span id="buscar-rut-status" class="rut-status"></span>
                                    </div>
                                    <button class="im-btn im-btn-ghost" onclick="buscarCliente()"><i class="bi bi-search"></i> Buscar</button>
                                </div>
                                <div id="cliente-encontrado" style="margin-top:10px;display:none;"></div>
                            </div>

                            <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
                                <div style="flex:1;height:1px;background:#e2e8f0;"></div>
                                <span style="font-size:.75rem;color:#94a3b8;font-weight:600;white-space:nowrap;">o completar / crear cliente nuevo</span>
                                <div style="flex:1;height:1px;background:#e2e8f0;"></div>
                            </div>

                            <form id="form-venta" autocomplete="off">
                                <input type="hidden" id="venta-cliente-id">

                                <!-- PASO 2: Datos del comprador -->
                                <div class="step-box highlight">
                                    <p class="step-title"><span class="step-badge" style="background:#10b981;">2</span> Datos del Comprador</p>
                                    <div class="im-input-group"><label>Nombre Completo <span style="color:#ef4444;">*</span></label><input type="text" id="cli-nombre" class="styled-input" placeholder="Nombre y apellidos"></div>
                                    <div class="im-form-row">
                                        <div class="im-input-group">
                                            <label>RUT <span style="color:#ef4444;">*</span></label>
                                            <div class="rut-input-wrap"><input type="text" id="cli-rut" class="styled-input" placeholder="12.345.678-9" oninput="autoFmtRut(this,'cli-rut-status')" style="padding-right:38px;"><span id="cli-rut-status" class="rut-status"></span></div>
                                        </div>
                                        <div class="im-input-group"><label>Teléfono</label><input type="tel" id="cli-telefono" class="styled-input" placeholder="+56 9 1234 5678" oninput="autoFmtTel(this)"></div>
                                    </div>
                                    <div class="im-input-group"><label>Correo Electrónico</label><input type="email" id="cli-email" class="styled-input" placeholder="correo@ejemplo.cl"></div>
                                    <div class="im-input-group"><label>Dirección</label><textarea id="cli-direccion" class="styled-input" rows="2" placeholder="Calle, número, ciudad, región" style="resize:vertical;"></textarea></div>
                                    <div class="im-form-row">
                                        <div class="im-input-group">
                                            <label>Estado Civil</label>
                                            <select id="cli-estado-civil" class="styled-input" onchange="toggleConyuge(this.value)">
                                                <option value="Soltero/a">Soltero/a</option>
                                                <option value="Casado/a">Casado/a</option>
                                                <option value="Divorciado/a">Divorciado/a</option>
                                                <option value="Viudo/a">Viudo/a</option>
                                                <option value="Conviviente Civil">Conviviente Civil</option>
                                            </select>
                                        </div>
                                        <div class="im-input-group" id="box-regimen" style="display:none;">
                                            <label>Régimen Matrimonial</label>
                                            <select id="cli-regimen" class="styled-input">
                                                <option value="Sociedad Conyugal">Sociedad Conyugal</option>
                                                <option value="Separación de Bienes">Separación de Bienes</option>
                                                <option value="Participación en los Gananciales">Participación en los Gananciales</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div id="section-conyuge" style="display:none;background:#faf5ff;border:1px solid #e9d5ff;border-radius:10px;padding:12px;margin-top:8px;">
                                        <p style="font-size:.78rem;font-weight:700;color:#7c3aed;margin:0 0 10px;"><i class="bi bi-people-fill"></i> Cónyuge / Conviviente Civil</p>
                                        <div class="im-form-row">
                                            <div class="im-input-group"><label>Nombre Cónyuge</label><input type="text" id="cli-conyuge-nombre" class="styled-input" placeholder="Nombre y apellidos"></div>
                                            <div class="im-input-group">
                                                <label>RUT Cónyuge</label>
                                                <div class="rut-input-wrap"><input type="text" id="cli-conyuge-rut" class="styled-input" placeholder="12.345.678-9" oninput="autoFmtRut(this,'conyuge-rut-status')" style="padding-right:38px;"><span id="conyuge-rut-status" class="rut-status"></span></div>
                                            </div>
                                        </div>
                                        <div class="im-form-row">
                                            <div class="im-input-group">
                                                <label>Email Cónyuge <span style="color:#94a3b8;font-weight:400;font-size:.75rem;">(opcional)</span></label>
                                                <input type="email" id="cli-conyuge-email" class="styled-input" placeholder="email@ejemplo.cl">
                                            </div>
                                            <div class="im-input-group">
                                                <label>Teléfono Cónyuge <span style="color:#94a3b8;font-weight:400;font-size:.75rem;">(opcional)</span></label>
                                                <input type="tel" id="cli-conyuge-tel" class="styled-input" placeholder="+56 9 1234 5678" oninput="autoFmtTel(this)">
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- PASO 3: Condiciones de venta -->
                                <div class="step-box">
                                    <p class="step-title"><span class="step-badge" style="background:#f59e0b;">3</span> Condiciones de la Venta</p>

                                    <!-- Selector tipo de pago -->
                                    <div style="margin-bottom:14px;">
                                        <p style="font-size:.78rem;font-weight:700;color:#475569;margin:0 0 8px;text-transform:uppercase;letter-spacing:.4px;">Modalidad de Pago</p>
                                        <div style="display:flex;gap:10px;flex-wrap:wrap;">
                                            <button type="button" class="pago-tab active" id="tab-contado" onclick="setPagoTipo('contado')"><i class="bi bi-cash-coin"></i> Al Contado</button>
                                            <button type="button" class="pago-tab" id="tab-credito" onclick="setPagoTipo('credito')"><i class="bi bi-bank"></i> Crédito / Cuotas</button>
                                        </div>
                                    </div>

                                    <div class="im-form-row">
                                        <div class="im-input-group">
                                            <label>Precio de Lista (CLP)</label>
                                            <input type="text" id="venta-precio-lista" class="styled-input" placeholder="Precio publicado" oninput="fmtPrecio(this)">
                                            <p class="price-hint">Precio publicado / de referencia</p>
                                        </div>
                                        <div class="im-input-group">
                                            <label>Precio Acordado (CLP)</label>
                                            <input type="text" id="venta-precio-acordado" class="styled-input" placeholder="Precio final negociado" oninput="fmtPrecio(this)">
                                            <p class="price-hint">Precio real que pagó el comprador</p>
                                        </div>
                                    </div>

                                    <!-- CONTADO fields -->
                                    <div id="section-contado">
                                        <div class="im-input-group">
                                            <label><i class="bi bi-paperclip"></i> Comprobante de Pago</label>
                                            <input type="file" id="comprobante-contado" accept="image/*,.pdf" class="styled-input" style="padding:6px;">
                                            <p class="price-hint">Foto/PDF de la transferencia o vale vista (se sube tras guardar la venta)</p>
                                        </div>
                                    </div>

                                    <!-- CRÉDITO fields -->
                                    <div id="section-credito" style="display:none;">
                                        <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:10px;padding:14px;margin-bottom:12px;">
                                            <p style="font-size:.78rem;font-weight:700;color:#1e40af;margin:0 0 10px;"><i class="bi bi-bank2"></i> Datos del Crédito / Financiamiento</p>
                                            <div class="im-form-row">
                                                <div class="im-input-group">
                                                    <label>Pie / Entrada (CLP)</label>
                                                    <input type="text" id="venta-monto-pie" class="styled-input" placeholder="Monto del pie" oninput="fmtPrecio(this)">
                                                </div>
                                                <div class="im-input-group">
                                                    <label>N° Crédito / Hipoteca</label>
                                                    <input type="text" id="venta-numero-credito" class="styled-input" placeholder="Número de referencia">
                                                </div>
                                            </div>
                                            <div class="im-form-row">
                                                <div class="im-input-group">
                                                    <label>Cantidad de Cuotas</label>
                                                    <input type="number" id="venta-num-cuotas" class="styled-input" min="1" placeholder="Ej: 12" oninput="recalcularCuotas()">
                                                </div>
                                                <div class="im-input-group">
                                                    <label>Valor por Cuota (CLP)</label>
                                                    <input type="text" id="venta-monto-cuota" class="styled-input" placeholder="Ej: 500.000" oninput="fmtPrecio(this)">
                                                </div>
                                            </div>
                                            <div class="im-input-group">
                                                <label>Primera Cuota (fecha inicio)</label>
                                                <input type="date" id="venta-primera-cuota" class="styled-input" onchange="generarFechasCuotas()">
                                            </div>
                                            <button type="button" class="im-btn im-btn-ghost" onclick="generarFechasCuotas()" style="margin-top:6px;">
                                                <i class="bi bi-calendar-plus"></i> Generar tabla de cuotas
                                            </button>
                                        </div>

                                        <!-- Preview tabla de cuotas -->
                                        <div id="cuotas-preview" style="display:none;margin-bottom:12px;">
                                            <p style="font-size:.78rem;font-weight:700;color:#475569;margin:0 0 8px;text-transform:uppercase;">Vista previa del plan de pagos</p>
                                            <div id="cuotas-preview-list"></div>
                                        </div>
                                    </div>

                                    <div class="im-form-row">
                                        <div class="im-input-group">
                                            <label>Fecha de Venta</label>
                                            <input type="date" id="venta-fecha" class="styled-input">
                                        </div>
                                        <div class="im-input-group" style="display:flex;flex-direction:column;justify-content:flex-end;gap:6px;">
                                            <div class="im-checkbox-row" style="padding:6px 0;"><input type="checkbox" id="venta-promesa"><label for="venta-promesa">Firmó Promesa de Compraventa</label></div>
                                            <div class="im-checkbox-row" style="padding:6px 0;"><input type="checkbox" id="venta-compraventa"><label for="venta-compraventa">Firmó Escritura de Compraventa</label></div>
                                        </div>
                                    </div>

                                    <!-- Agente responsable -->
                                    <div class="im-input-group">
                                        <label><i class="bi bi-person-badge"></i> Agente Responsable de la Venta / Reserva</label>
                                        <select id="venta-agente-id" class="styled-input" onchange="onAgenteChange(this)">
                                            <option value="">Cargando agentes...</option>
                                        </select>
                                        <input type="hidden" id="venta-agente-nombre">
                                        <p class="price-hint">Corredor o agente que gestionó esta operación</p>
                                    </div>

                                    <div class="im-input-group">
                                        <label><i class="bi bi-file-text"></i> Glosa / Condiciones Especiales de Compra</label>
                                        <textarea id="venta-condiciones" class="styled-input" rows="3" placeholder="Condiciones especiales, acuerdos particulares, observaciones legales, plazos especiales, referencias a escrituras, etc." style="resize:vertical;"></textarea>
                                    </div>
                                    <div class="im-input-group">
                                        <label>Notas Adicionales</label>
                                        <textarea id="venta-notas" class="styled-input" rows="2" placeholder="Notas internas, recordatorios..." style="resize:vertical;"></textarea>
                                    </div>
                                </div>

                                <button type="submit" class="im-btn im-btn-success im-btn-full"><i class="bi bi-person-check-fill"></i> Guardar Comprador y Venta</button>
                            </form>

                            <!-- Sección de cuotas (solo visible si hay venta tipo crédito) -->
                            <div id="section-cuotas-venta" style="display:none;margin-top:20px;border-top:2px solid #e2e8f0;padding-top:16px;">
                                <p class="step-title"><i class="bi bi-list-check"></i> Plan de Pagos / Cuotas</p>
                                <div id="cuotas-resumen" style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:10px;padding:12px;margin-bottom:12px;font-size:.85rem;display:flex;gap:20px;flex-wrap:wrap;"></div>
                                <div id="cuotas-list"></div>
                            </div>
                        </div>

                        <!-- ─── TAB DOCS PROYECTO ─── -->
                        <div id="tab-docs-proyecto" class="im-tab-content"><div id="dm-proyecto"></div></div>

                        <!-- ─── TAB DOCS LOTE ─── -->
                        <div id="tab-docs-lote" class="im-tab-content"><div id="dm-lote"></div></div>

                        <!-- ─── TAB DOCS PERSONA ─── -->
                        <div id="tab-docs-persona" class="im-tab-content">
                            <div id="no-cliente-msg" style="background:#fef3c7;border:1px solid #fde68a;border-radius:10px;padding:16px;text-align:center;color:#92400e;font-size:.85rem;">
                                <i class="bi bi-person-exclamation" style="font-size:1.5rem;display:block;margin-bottom:6px;"></i>Asigna un comprador primero.
                            </div>
                            <div id="dm-persona"></div>
                        </div>

                        <!-- ─── TAB AUDITORÍA ─── -->
                        <div id="tab-auditoria" class="im-tab-content">
                            <div id="auditoria-list" class="im-audit-list"><div class="im-empty"><i class="bi bi-clock-history"></i><p>Cargando...</p></div></div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

<script>
const PARCELA_ID  = '<%= parcelaId %>';
const IS_ADMIN    = '<%= user && user.role === "admin" ? "true" : "false" %>' === 'true';
const PUEDE_CREAR = '<%= typeof puedeCrear !== "undefined" && puedeCrear ? "true" : "false" %>' === 'true';

let parcelaData=null, ventaData=null, cuotasData=[], currentClienteId=null, proyectoId=null;
let pagoTipoActual = 'contado';
let fechasCuotasGeneradas = [];
let usuariosList = [];
const CURRENT_USER_ID   = '<%= user.id %>';
const CURRENT_USER_NAME = '<%= user.name %>';

// ──────────────── UTILS ────────────────
const $ = id => document.getElementById(id);
function fmt(n){return Math.floor(parseFloat(n)||0).toLocaleString('es-CL');}
function escH(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function fmtPrecio(input){input.value=input.value.replace(/\D/g,'').replace(/\B(?=(\d{3})+(?!\d))/g,'.');}
function openModal(id){$(`modal-${id}`).classList.add('show');}
function closeModal(id){$(`modal-${id}`).classList.remove('show');}
function cleanNum(v){return v&&String(v).trim()?parseFloat(String(v).replace(/\./g,'').replace(',','.')):null;}

function showToast(msg,type='success',title=''){
    const t=$('im-toast'),i=$('im-toast-inner');
    const cfg={success:{bg:'#dcfce7',c:'#166534',b:'#86efac',ic:'bi-check-circle-fill',d:'Éxito'},error:{bg:'#fee2e2',c:'#991b1b',b:'#fca5a5',ic:'bi-exclamation-triangle-fill',d:'Error'},warning:{bg:'#fef3c7',c:'#92400e',b:'#fde68a',ic:'bi-exclamation-circle-fill',d:'Atención'},info:{bg:'#eff6ff',c:'#1e40af',b:'#bfdbfe',ic:'bi-info-circle-fill',d:'Info'}};
    const s=cfg[type]||cfg.info;
    i.style.cssText=`background:${s.bg};color:${s.c};border:1.5px solid ${s.b};padding:14px 18px;border-radius:12px;box-shadow:0 8px 30px rgba(0,0,0,.12);display:flex;align-items:flex-start;gap:10px;`;
    i.innerHTML=`<i class="bi ${s.ic}" style="font-size:1.1rem;flex-shrink:0;margin-top:1px;"></i><div><div style="font-weight:700;font-size:.88rem;">${title||s.d}</div><div style="font-size:.82rem;margin-top:2px;opacity:.9;word-break:break-word;">${escH(msg)}</div></div>`;
    t.style.opacity='1';t.style.transform='translateX(0)';t.style.pointerEvents='auto';
    clearTimeout(t._t);t._t=setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(30px)';t.style.pointerEvents='none';},5000);
}

function autoFmtRut(input,statusId){
    // Extraer solo dígitos y K, limitar a 9 chars (8 dígitos cuerpo + 1 DV)
    let v=input.value.replace(/[^0-9kK]/g,'').toUpperCase().slice(0,9);
    if(v.length>1)v=v.slice(0,-1).replace(/\B(?=(\d{3})+(?!\d))/g,'.')+'-'+v.slice(-1);
    input.value=v;
    const el=$(statusId);if(!el)return;
    if(v.length<3){el.textContent='';input.style.borderColor='';return;}
    const ok=validarRut(v);
    el.textContent=ok?'✅':'❌';
    input.style.borderColor=ok?'#10b981':(v.length>4?'#ef4444':'');
}
function validarRut(rut){
    const c=rut.replace(/[^0-9kK]/g,'').toUpperCase();if(c.length<2)return false;
    const body=c.slice(0,-1),dv=c.slice(-1);
    let s=0,m=2;for(let i=body.length-1;i>=0;i--){s+=parseInt(body[i],10)*m;m=m>=7?2:m+1;}
    const r=11-(s%11);const dc=r===11?'0':r===10?'K':String(r);return dv===dc;
}
function autoFmtTel(input){
    // Formato: +XX X XXXX XXXX  (ej: +56 9 1234 5678)
    const raw=input.value.replace(/[^\d]/g,'').slice(0,11);
    let f='';
    if(raw.length>0)f='+'+raw.slice(0,2);
    if(raw.length>2)f+=' '+raw.slice(2,3);
    if(raw.length>3)f+=' '+raw.slice(3,7);
    if(raw.length>7)f+=' '+raw.slice(7,11);
    input.value=f;
}
function toggleConyuge(val){
    $('section-conyuge').style.display=(val==='Casado/a'||val==='Conviviente Civil')?'block':'none';
    const rb=$('box-regimen');if(rb)rb.style.display=(val==='Casado/a')?'flex':'none';
}

function switchTab(name,btn){
    document.querySelectorAll('.im-tab-btn').forEach(b=>b.classList.remove('active'));
    document.querySelectorAll('.im-tab-content').forEach(c=>c.classList.remove('active'));
    if(btn)btn.classList.add('active');
    $(`tab-${name}`).classList.add('active');
    if(name==='docs-proyecto'&&proyectoId){initDM('proyecto',proyectoId);loadDocs('proyecto',proyectoId);}
    if(name==='docs-lote'){initDM('lote',PARCELA_ID);loadDocs('parcela',PARCELA_ID);}
    if(name==='docs-persona'&&currentClienteId){initDM('persona',currentClienteId);loadDocs('persona',currentClienteId);}
    if(name==='auditoria')loadAuditoria();
}

function setPagoTipo(tipo){
    pagoTipoActual=tipo;
    $('tab-contado').classList.toggle('active',tipo==='contado');
    $('tab-credito').classList.toggle('active',tipo==='credito');
    $('section-contado').style.display=tipo==='contado'?'block':'none';
    $('section-credito').style.display=tipo==='credito'?'block':'none';
}

// ──────────────── CUOTAS GENERATOR ────────────────
function recalcularCuotas(){/* live update if fecha set */generarFechasCuotas();}

function generarFechasCuotas(){
    const n=parseInt($('venta-num-cuotas').value,10);
    const montoRaw=cleanNum($('venta-monto-cuota').value);
    const fechaBase=$('venta-primera-cuota').value;
    if(!n||n<1){$('cuotas-preview').style.display='none';return;}

    const monto=montoRaw||0;
    const preview=$('cuotas-preview-list');
    fechasCuotasGeneradas=[];

    let rows='';
    for(let i=0;i<n;i++){
        let fecha='';
        if(fechaBase){
            const d=new Date(fechaBase+'T12:00:00');
            d.setMonth(d.getMonth()+i);
            fecha=d.toISOString().split('T')[0];
        }
        fechasCuotasGeneradas.push({numero:i+1,monto,fecha});
        const fechaFmt=fecha?new Date(fecha+'T12:00:00').toLocaleDateString('es-CL',{day:'2-digit',month:'short',year:'numeric'}):'Sin fecha';
        rows+=`<div style="display:grid;grid-template-columns:36px 1fr 120px 140px;gap:8px;align-items:center;padding:8px 12px;background:#fff;border:1px solid #e2e8f0;border-radius:8px;margin-bottom:6px;font-size:.82rem;">
            <span style="font-weight:800;color:#2563eb;text-align:center;">${i+1}</span>
            <span style="color:#64748b;">Cuota mensual</span>
            <span style="font-weight:700;color:#0f172a;">${monto?'$'+fmt(monto):'—'}</span>
            <input type="date" value="${fecha}" style="border:1px solid #e2e8f0;border-radius:6px;padding:4px 8px;font-size:.78rem;font-family:inherit;" onchange="fechasCuotasGeneradas[${i}].fecha=this.value">
        </div>`;
    }
    preview.innerHTML=rows;
    $('cuotas-preview').style.display='block';
}

// ──────────────── INIT ────────────────
async function loadAgentes(){
    try{
        const res=await fetch('/api/im/usuarios');
        if(!res.ok)return;
        usuariosList=await res.json();
        const sel=$('venta-agente-id');
        sel.innerHTML=usuariosList.map(u=>`<option value="${u.id}" data-nombre="${escH(u.name)}">${escH(u.name)} (${u.role==='admin'?'Admin':'Corredor'})</option>`).join('');
        // Default: current user
        sel.value=CURRENT_USER_ID;
        $('venta-agente-nombre').value=CURRENT_USER_NAME;
    }catch(_){}
}

function onAgenteChange(sel){
    const opt=sel.options[sel.selectedIndex];
    $('venta-agente-nombre').value=opt?opt.dataset.nombre||opt.textContent:'';
}

async function init(){
    try{
        const [parcelaRes]=await Promise.all([
            fetch(`/api/im/parcelas/${PARCELA_ID}`),
            loadAgentes()
        ]);
        if(!parcelaRes.ok){
            const errBody=await parcelaRes.json().catch(()=>({}));
            throw new Error(errBody.message||`No se pudo cargar la parcela (HTTP ${parcelaRes.status}). Verifica tu conexión e intenta de nuevo.`);
        }
        const data=await parcelaRes.json();
        parcelaData=data.parcela;ventaData=data.venta;cuotasData=data.cuotas||[];
        proyectoId=parcelaData.proyecto_id;
        renderParcela(data);
        initDM('lote',PARCELA_ID);
    }catch(e){
        $('parcela-titulo').textContent='Error al cargar';
        showToast(e.message,'error','No se pudo cargar la parcela');
    }
}

function renderParcela(data){
    const p=data.parcela,venta=data.venta,hist=data.historial_precios||[],cuotas=data.cuotas||[],histVentas=data.historial_ventas||[];

    // Banner en verde
    const bannerEl=$('banner-en-verde');
    if(bannerEl) bannerEl.style.display=(p.tipo_proyecto==='en_verde')?'block':'none';

    $('bc-proyecto').textContent=p.proyecto_nombre||'Proyecto';
    $('bc-parcela').textContent=`Parcela N° ${p.numero_parcela}`;
    $('parcela-titulo').textContent=`Parcela N° ${p.numero_parcela} — ${p.proyecto_nombre}`;

    const eMap={disponible:{cl:'disponible',ic:'bi-circle-fill',t:'Disponible'},reservado:{cl:'reservado',ic:'bi-clock-history',t:'Reservado'},vendido:{cl:'vendido',ic:'bi-bag-check-fill',t:'Vendido'}};
    const e=eMap[p.estado_venta]||eMap.disponible;
    $('parcela-estado-badge').innerHTML=`<span class="im-status-badge ${e.cl}"><i class="bi ${e.ic}"></i> ${e.t}</span>`;
    $('header-actions').innerHTML=(IS_ADMIN&&venta)
        ?`<button class="im-btn im-btn-warning" onclick="openResciliarModal()" style="background:#f59e0b;color:#fff;border-color:#f59e0b;">
            <i class="bi bi-file-earmark-x"></i> Resciliar Contrato</button>`:'';

    const rows=[['N° Parcela',p.numero_parcela],['N° Rol Parcela',p.numero_rol_parcela||'—'],['Metraje',p.metraje?`${Number(p.metraje).toLocaleString('es-CL')} m²`:'—'],['Precio de Lista',p.precio_actual?`$${fmt(p.precio_actual)}`:'—'],['Proyecto',p.proyecto_nombre],['N° Rol 1',p.numero_rol_1||'—'],['N° Rol 2',p.numero_rol_2||'—'],['N° Matriz',p.numero_matriz||'—']];
    $('detalle-rows').innerHTML=rows.map(([k,v])=>`<div class="im-detail-row"><span class="im-detail-key">${k}</span><span class="im-detail-val">${v}</span></div>`).join('');
    $('edit-rol').value=p.numero_rol_parcela||'';
    $('edit-metraje').value=p.metraje||'';
    if(p.precio_actual)$('edit-precio').value=Number(p.precio_actual).toLocaleString('es-CL');
    $('edit-estado').value=p.estado_venta;

    // Historial precios
    if(hist.length===0){
        $('historial-precios').innerHTML='<div class="im-empty"><i class="bi bi-clock-history"></i><p>Sin historial.</p></div>';
    }else{
        $('historial-precios').innerHTML=`<div class="im-price-timeline">${hist.map((h,i)=>`
            <div class="im-price-entry ${i===hist.length-1?'latest':''}">
                <div class="im-price-meta">
                    <span class="im-price-amount">$${fmt(h.precio)}</span>
                    <span class="im-price-date">${new Date(h.fecha_registro).toLocaleDateString('es-CL',{day:'2-digit',month:'short',year:'numeric'})}</span>
                </div>
            </div>`).join('')}</div>`;
    }

    // Venta actual
    if(venta){
        currentClienteId=venta.cliente_id;
        const tipoPago=venta.tipo_pago||'contado';
        const cuotasPagadas=cuotas.filter(c=>c.pagado).length;
        const cuotasTotales=cuotas.length;

        $('venta-actual').innerHTML=`
            <div style="background:#f0fdf4;border:1px solid #86efac;border-radius:12px;padding:16px;">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;">
                    <p style="font-size:.78rem;font-weight:700;color:#166534;margin:0;text-transform:uppercase;letter-spacing:.4px;"><i class="bi bi-person-check-fill"></i> Comprador Asignado</p>
                    <a href="/admin/inmobiliaria/clientes" style="font-size:.75rem;color:#2563eb;text-decoration:none;"><i class="bi bi-arrow-up-right"></i> Ver todos los clientes</a>
                </div>
                ${[
                    ['Nombre',venta.nombre_completo],['RUT',venta.rut],
                    ['Email',venta.email||'—'],['Teléfono',venta.telefono||'—'],
                    ['Estado Civil',venta.estado_civil+(venta.regimen_matrimonial?` — ${venta.regimen_matrimonial}`:'')],
                    venta.nombre_conyugue?['Cónyuge',`${venta.nombre_conyugue} · ${venta.rut_conyugue||'S/R'}${venta.email_conyugue?' · '+venta.email_conyugue:''}${venta.telefono_conyugue?' · '+venta.telefono_conyugue:''}`]:null,
                    ['Agente',venta.agente_nombre||'—'],
                    ['Modalidad',tipoPago==='contado'?'💵 Al Contado':'🏦 Crédito / Cuotas'],
                    ['Precio Lista',venta.precio_lista?`$${fmt(venta.precio_lista)}`:'—'],
                    ['Precio Acordado',venta.precio_acordado?`$${fmt(venta.precio_acordado)}`:'—'],
                    tipoPago==='credito'&&venta.monto_pie?['Pie',`$${fmt(venta.monto_pie)}`]:null,
                    tipoPago==='credito'&&venta.numero_credito?['N° Crédito',venta.numero_credito]:null,
                    tipoPago==='credito'?['Cuotas',`${cuotasPagadas}/${cuotasTotales} pagadas`]:null,
                    ['Fecha Venta',venta.fecha_venta?new Date(venta.fecha_venta).toLocaleDateString('es-CL'):'—'],
                    venta.condiciones_compra?['Condiciones',venta.condiciones_compra]:null,
                ].filter(Boolean).map(([k,v])=>`<div class="im-detail-row"><span class="im-detail-key">${k}</span><span class="im-detail-val">${escH(String(v))}</span></div>`).join('')}
                <div style="display:flex;gap:16px;margin-top:10px;padding-top:10px;border-top:1px solid #bbf7d0;">
                    <span style="font-size:.85rem;color:${venta.firmo_promesa?'#166534':'#94a3b8'};font-weight:600;"><i class="bi ${venta.firmo_promesa?'bi-check-circle-fill':'bi-circle'}"></i> Promesa</span>
                    <span style="font-size:.85rem;color:${venta.firmo_compraventa?'#166534':'#94a3b8'};font-weight:600;"><i class="bi ${venta.firmo_compraventa?'bi-check-circle-fill':'bi-circle'}"></i> Compraventa</span>
                </div>
                ${venta.comprobante_url?`<div style="margin-top:8px;display:flex;gap:8px;">
                    <a href="${escH(venta.comprobante_url)}" target="_blank" class="im-btn im-btn-sm im-btn-ghost"><i class="bi bi-eye"></i> Ver comprobante</a>
                    <a href="${escH(venta.comprobante_url)}" download class="im-btn im-btn-sm im-btn-ghost"><i class="bi bi-download"></i> Descargar</a>
                </div>`:''}
                ${venta.notas?`<div style="margin-top:8px;font-size:.82rem;color:#475569;font-style:italic;background:#fff;border-radius:6px;padding:8px 10px;">${escH(venta.notas)}</div>`:''}
            </div>`;

        // Pre-fill form
        $('venta-cliente-id').value=venta.cliente_id;
        $('cli-nombre').value=venta.nombre_completo;
        $('cli-rut').value=venta.rut;
        $('cli-telefono').value=venta.telefono||'';if(venta.telefono){autoFmtTel($('cli-telefono'));}
        $('cli-email').value=venta.email||'';
        $('cli-direccion').value=venta.direccion||'';
        $('cli-estado-civil').value=venta.estado_civil;
        toggleConyuge(venta.estado_civil);
        if(venta.regimen_matrimonial&&$('cli-regimen'))$('cli-regimen').value=venta.regimen_matrimonial;
        $('cli-conyuge-nombre').value=venta.nombre_conyugue||'';
        $('cli-conyuge-rut').value=venta.rut_conyugue||'';
        $('cli-conyuge-email').value=venta.email_conyugue||'';
        $('cli-conyuge-tel').value=venta.telefono_conyugue||'';if(venta.telefono_conyugue){autoFmtTel($('cli-conyuge-tel'));}
        $('venta-fecha').value=venta.fecha_venta?venta.fecha_venta.split('T')[0]:'';
        $('venta-promesa').checked=venta.firmo_promesa;
        $('venta-compraventa').checked=venta.firmo_compraventa;
        $('venta-notas').value=venta.notas||'';
        $('venta-condiciones').value=venta.condiciones_compra||'';
        if(venta.precio_lista)$('venta-precio-lista').value=Number(venta.precio_lista).toLocaleString('es-CL');
        if(venta.precio_acordado)$('venta-precio-acordado').value=Number(venta.precio_acordado).toLocaleString('es-CL');

        // Agente
        if(venta.agente_id){
            const sel=$('venta-agente-id');if(sel)sel.value=venta.agente_id;
            $('venta-agente-nombre').value=venta.agente_nombre||'';
        }

        // Pago tipo
        setPagoTipo(tipoPago);
        if(tipoPago==='credito'){
            if(venta.monto_pie)$('venta-monto-pie').value=Number(venta.monto_pie).toLocaleString('es-CL');
            if(venta.numero_credito)$('venta-numero-credito').value=venta.numero_credito;
            if(venta.numero_cuotas)$('venta-num-cuotas').value=venta.numero_cuotas;
            if(venta.monto_cuota)$('venta-monto-cuota').value=Number(venta.monto_cuota).toLocaleString('es-CL');
        }

        // Cuotas panel
        if(tipoPago==='credito'&&cuotas.length>0){
            renderCuotasPanel(venta,cuotas);
        }

        $('no-cliente-msg').style.display='none';
        initDM('persona',venta.cliente_id);
    }else{
        $('venta-actual').innerHTML='';
        $('venta-fecha').value=new Date().toISOString().split('T')[0];
        if(p.precio_actual)$('venta-precio-lista').value=Number(p.precio_actual).toLocaleString('es-CL');
    }

    renderHistorialVentas(histVentas);
}

function renderHistorialVentas(histVentas){
    const sec=$('historial-ventas-section');
    if(!sec)return;
    if(!histVentas||histVentas.length===0){sec.style.display='none';return;}
    sec.style.display='block';
    const estadoBadge=estado=>{
        if(estado==='resciliada')return`<span style="font-size:.68rem;font-weight:700;padding:2px 8px;border-radius:999px;background:#fee2e2;color:#991b1b;">Resciliada</span>`;
        if(estado==='liberada')return`<span style="font-size:.68rem;font-weight:700;padding:2px 8px;border-radius:999px;background:#f1f5f9;color:#64748b;">Liberada</span>`;
        return`<span style="font-size:.68rem;font-weight:700;padding:2px 8px;border-radius:999px;background:#fef3c7;color:#92400e;">${estado}</span>`;
    };
    sec.innerHTML=`
    <details style="border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;" open>
        <summary style="padding:12px 16px;cursor:pointer;background:#f8fafc;font-size:.82rem;font-weight:700;color:#475569;display:flex;align-items:center;gap:8px;list-style:none;">
            <i class="bi bi-clock-history" style="color:#f59e0b;"></i>
            Historial de Operaciones Anteriores
            <span style="margin-left:auto;font-size:.73rem;font-weight:400;color:#94a3b8;">${histVentas.length} registro${histVentas.length!==1?'s':''}</span>
        </summary>
        <div style="padding:12px;display:flex;flex-direction:column;gap:10px;">
        ${histVentas.map(v=>{
            const fechaVenta=v.fecha_venta?new Date(v.fecha_venta).toLocaleDateString('es-CL',{day:'2-digit',month:'short',year:'numeric'}):'—';
            const precio=v.precio_acordado?'$'+fmt(v.precio_acordado):'—';
            const modPago=v.tipo_pago==='credito'?'🏦 Crédito':'💵 Contado';
            const rescInfo=v.resc_id?`
                <div style="margin-top:8px;padding-top:8px;border-top:1px dashed #fca5a5;font-size:.78rem;color:#7f1d1d;">
                    <i class="bi bi-file-earmark-x-fill" style="color:#ef4444;"></i>
                    <strong>Resciliación:</strong>
                    ${v.resc_fecha?new Date(v.resc_fecha+'T12:00:00').toLocaleDateString('es-CL',{day:'2-digit',month:'short',year:'numeric'}):'—'}
                    — ${escH(v.resc_motivo||'Sin motivo')}
                    ${v.resc_agente?`<span style="color:#94a3b8;"> · Por: ${escH(v.resc_agente)}</span>`:''}
                    ${v.resc_notas?`<div style="margin-top:4px;color:#92400e;font-style:italic;">${escH(v.resc_notas)}</div>`:''}
                </div>`:'';
            return`<div style="border:1px solid ${v.estado==='resciliada'?'#fca5a5':'#e2e8f0'};border-radius:8px;padding:12px;background:${v.estado==='resciliada'?'#fff5f5':'#fafafa'};">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap;">
                    ${estadoBadge(v.estado)}
                    <span style="font-size:.82rem;font-weight:600;color:#0f172a;">${escH(v.nombre_completo)}</span>
                    <span style="font-size:.78rem;color:#64748b;">RUT ${escH(v.rut)}</span>
                    <span style="margin-left:auto;font-size:.78rem;color:#64748b;">${fechaVenta}</span>
                </div>
                <div style="display:flex;gap:12px;font-size:.79rem;color:#64748b;flex-wrap:wrap;">
                    <span><i class="bi bi-cash"></i> ${precio}</span>
                    <span>${modPago}</span>
                    ${v.agente_nombre?`<span><i class="bi bi-person"></i> ${escH(v.agente_nombre)}</span>`:''}
                    ${v.firmo_promesa?`<span style="color:#16a34a;"><i class="bi bi-check-circle-fill"></i> Promesa</span>`:''}
                    ${v.firmo_compraventa?`<span style="color:#16a34a;"><i class="bi bi-check-circle-fill"></i> Compraventa</span>`:''}
                </div>
                ${rescInfo}
            </div>`;
        }).join('')}
        </div>
    </details>`;
}

function renderCuotasPanel(venta,cuotas){
    const pagadas=cuotas.filter(c=>c.pagado).length;
    const pendientes=cuotas.length-pagadas;
    const totalPagado=cuotas.filter(c=>c.pagado).reduce((s,c)=>s+(parseFloat(c.monto)||0),0);
    const totalPendiente=cuotas.filter(c=>!c.pagado).reduce((s,c)=>s+(parseFloat(c.monto)||0),0);

    $('section-cuotas-venta').style.display='block';
    $('cuotas-resumen').innerHTML=`
        <div><span style="font-size:.72rem;color:#64748b;display:block;">Cuotas pagadas</span><strong style="color:#166534;">${pagadas} / ${cuotas.length}</strong></div>
        <div><span style="font-size:.72rem;color:#64748b;display:block;">Total pagado</span><strong style="color:#10b981;">$${fmt(totalPagado)}</strong></div>
        <div><span style="font-size:.72rem;color:#64748b;display:block;">Saldo pendiente</span><strong style="color:#f59e0b;">$${fmt(totalPendiente)}</strong></div>
        ${venta.numero_credito?`<div><span style="font-size:.72rem;color:#64748b;display:block;">N° Crédito</span><strong>${escH(venta.numero_credito)}</strong></div>`:''}`;

    const hoy=new Date().toISOString().split('T')[0];
    $('cuotas-list').innerHTML=cuotas.map(c=>{
        const vencida=!c.pagado&&c.fecha_vencimiento&&c.fecha_vencimiento<hoy;
        const cl=c.pagado?'pagada':vencida?'vencida':'';
        const fechaVenc=c.fecha_vencimiento?new Date(c.fecha_vencimiento+'T12:00:00').toLocaleDateString('es-CL',{day:'2-digit',month:'short',year:'numeric'}):'—';
        const fechaPago=c.fecha_pago?new Date(c.fecha_pago+'T12:00:00').toLocaleDateString('es-CL',{day:'2-digit',month:'short',year:'numeric'}):'—';
        const badge=c.pagado?`<span class="cuota-badge-pagada"><i class="bi bi-check-circle-fill"></i> Pagada</span>`:vencida?`<span class="cuota-badge-vencida"><i class="bi bi-exclamation-triangle-fill"></i> Vencida</span>`:`<span class="cuota-badge-pendiente"><i class="bi bi-clock"></i> Pendiente</span>`;
        return `<div class="cuota-row ${cl}">
            <div class="cuota-num">${c.numero_cuota}</div>
            <div>
                <div class="cuota-monto">${c.monto?'$'+fmt(c.monto):'—'}</div>
                <div class="cuota-fecha">Vence: ${fechaVenc}${c.pagado&&c.fecha_pago?' · Pagada: '+fechaPago:''}</div>
                ${c.notas?`<div style="font-size:.72rem;color:#64748b;font-style:italic;">${escH(c.notas)}</div>`:''}
            </div>
            ${badge}
            <div>
                ${c.comprobante_url?`<a href="${escH(c.comprobante_url)}" target="_blank" class="im-btn im-btn-sm im-btn-ghost" title="Ver comprobante"><i class="bi bi-eye"></i></a>`:''}
            </div>
            <div style="display:flex;gap:4px;">
                <button class="im-btn im-btn-sm im-btn-ghost" onclick="openCuotaModal(${JSON.stringify(c).replace(/"/g,'&quot;')})" title="Editar cuota"><i class="bi bi-pencil"></i></button>
            </div>
        </div>`;
    }).join('');
}

