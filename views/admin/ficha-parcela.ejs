function renderResultadosClientes(lista){
    const el=$('cliente-encontrado');el.style.display='block';
    el.innerHTML=`<div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:10px;">
        <div style="font-size:.76rem;color:#64748b;margin-bottom:8px;font-weight:700;"><i class="bi bi-list-ul"></i> ${lista.length} cliente${lista.length!==1?'s':''} encontrado${lista.length!==1?'s':''} — revisa la información y pulsa "Usar":</div>
        ${lista.map(clienteCard).join('')}
    </div>`;
}

function buscarClienteLive(){
    clearTimeout(_buscarTimer);
    const q=$('buscar-rut').value.trim();
    if(q.length<2){$('cliente-encontrado').style.display='none';return;}
    _buscarTimer=setTimeout(()=>buscarCliente(true),350);
}

async function buscarCliente(silencioso=false){
    const q=$('buscar-rut').value.trim();
    if(!q){if(!silencioso)showToast('Escribe un nombre o RUT para buscar.','warning');return;}
    const el=$('cliente-encontrado');el.style.display='block';
    if(!silencioso)el.innerHTML='<div style="color:#64748b;font-size:.82rem;padding:8px 0;"><i class="bi bi-hourglass-split"></i> Buscando...</div>';
    try{
        const res=await fetch(`/api/im/clientes/buscar?q=${encodeURIComponent(q)}`);
        if(res.status===404){
            el.innerHTML=`<div style="background:#fef3c7;border:1px solid #fde68a;border-radius:8px;padding:10px 14px;font-size:.84rem;color:#92400e;">
                <i class="bi bi-exclamation-triangle"></i> No se encontró ningún cliente con "<strong>${escH(q)}</strong>". Puedes crearlo directamente en el formulario de abajo.</div>`;
            return;
        }
        if(!res.ok){const eb=await res.json().catch(()=>({}));throw new Error(eb.message||eb.error||`Error ${res.status}`);}
        const data=await res.json();
        const lista=data.multiple?(data.clientes||[]):[data];
        if(lista.length===0){
            el.innerHTML=`<div style="background:#fef3c7;border:1px solid #fde68a;border-radius:8px;padding:10px 14px;font-size:.84rem;color:#92400e;">
                <i class="bi bi-exclamation-triangle"></i> No se encontró ningún cliente con "<strong>${escH(q)}</strong>". Puedes crearlo directamente en el formulario de abajo.</div>`;
            return;
        }
        renderResultadosClientes(lista);
    }catch(e){
        if(!silencioso){showToast(e.message,'error','Error al buscar');}
        el.style.display='none';
    }
}

function cargarClienteFromBtn(btn){
    try{
        const raw=(btn.getAttribute('data-cliente')||'').replace(/&quot;/g,'"').replace(/&#39;/g,"'").replace(/&amp;/g,'&');
        cargarCliente(JSON.parse(raw));
    }catch(e){showToast('No se pudo cargar el cliente.','error');}
}

function setClienteReadonly(ro){
    clienteSoloLectura=ro;
    CLI_CAMPOS.forEach(id=>{const f=$(id);if(f){f.readOnly=ro;f.style.background=ro?'#f8fafc':'';f.style.color=ro?'#475569':'';}});
    CLI_SELECTS.forEach(id=>{const f=$(id);if(f){f.disabled=ro;f.style.background=ro?'#f8fafc':'';f.style.color=ro?'#475569':'';}});
}

function cargarCliente(c){
    if(!c||!c.id){showToast('Cliente inválido.','error');return;}
    $('venta-cliente-id').value=c.id;
    $('cli-nombre').value=c.nombre_completo||'';
    $('cli-rut').value=c.rut||'';
    $('cli-telefono').value=c.telefono||'';if(c.telefono)autoFmtTel($('cli-telefono'));
    $('cli-email').value=c.email||'';
    $('cli-direccion').value=c.direccion||'';
    $('cli-estado-civil').value=c.estado_civil||'Soltero/a';
    toggleConyuge(c.estado_civil||'Soltero/a');
    if($('cli-regimen'))$('cli-regimen').value=c.regimen_matrimonial||'';
    $('cli-conyuge-nombre').value=c.nombre_conyugue||'';
    $('cli-conyuge-rut').value=c.rut_conyugue||'';
    $('cli-conyuge-email').value=c.email_conyugue||'';
    $('cli-conyuge-tel').value=c.telefono_conyugue||'';
    if(c.telefono_conyugue)autoFmtTel($('cli-conyuge-tel'));

    // Modo visualización: el cliente ya existe, sus datos son solo lectura
    setClienteReadonly(true);
    $('cliente-modo-banner').style.display='block';
    const nCompras=parseInt(c.total_compras)||0;
    $('cliente-modo-compras').textContent=c.parcelas_compradas
        ?`Ya compró: ${c.parcelas_compradas}. Esta venta se agregará como nueva compra.`
        :(nCompras>0?`Tiene ${nCompras} compra${nCompras!==1?'s':''} registrada${nCompras!==1?'s':''}.`:'Sin compras anteriores registradas.');
    // Colapsar la lista de resultados
    $('cliente-encontrado').style.display='none';
    $('buscar-rut').value='';
    showToast(`Cliente "${c.nombre_completo}" seleccionado. Continúa con las condiciones de la venta.`,'success');
    $('cli-nombre').scrollIntoView({behavior:'smooth',block:'center'});
}

function habilitarEdicionCliente(){
    setClienteReadonly(false);
    showToast('Edición habilitada. Los cambios actualizarán la ficha del cliente al guardar.','info');
}

function quitarClienteSeleccionado(){
    $('venta-cliente-id').value='';
    setClienteReadonly(false);
    $('cliente-modo-banner').style.display='none';
    CLI_CAMPOS.forEach(id=>{const f=$(id);if(f)f.value='';});
    $('cli-estado-civil').value='Soltero/a';
    toggleConyuge('Soltero/a');
    showToast('Cliente quitado. Puedes buscar otro o crear uno nuevo.','info');
}

// ──────────────── GUARDAR VENTA ────────────────
$('form-venta').addEventListener('submit',async(e)=>{
    e.preventDefault();
    const btn=e.submitter||e.target.querySelector('[type="submit"]');
    if(btn){btn.disabled=true;btn.innerHTML='<i class="bi bi-hourglass-split"></i> Guardando...';}
    try{
        const nombre=($('cli-nombre').value||'').trim();
        const rut=($('cli-rut').value||'').trim();
        if(!nombre){showToast('Ingresa el nombre del comprador.','warning');return;}
        if(!validarRut(rut)){showToast('RUT del comprador inválido (Módulo 11).','error','RUT inválido');return;}

        // Si precio acordado vacío, copiar precio de lista en el formulario
        if(!cleanNum($('venta-precio-acordado').value)&&cleanNum($('venta-precio-lista').value)){
            $('venta-precio-acordado').value=$('venta-precio-lista').value;
        }

        let clienteId=$('venta-cliente-id').value;
        const estadoCivil=$('cli-estado-civil').value;
        const clienteBody={
            nombre_completo:nombre,rut,
            email:$('cli-email').value||null,
            telefono:$('cli-telefono').value||null,
            direccion:$('cli-direccion').value||null,
            estado_civil:estadoCivil,
            regimen_matrimonial:(estadoCivil==='Casado/a'&&$('cli-regimen'))?$('cli-regimen').value:null,
            nombre_conyugue:$('cli-conyuge-nombre').value||null,
            rut_conyugue:$('cli-conyuge-rut').value||null,
            email_conyugue:$('cli-conyuge-email').value||null,
            telefono_conyugue:$('cli-conyuge-tel').value||null,
            reuse_if_exists:true
        };

        if(clienteId&&clienteSoloLectura){
            // Cliente existente en modo visualización: no tocar sus datos
        }else if(clienteId){
            const r=await fetch(`/api/im/clientes/${clienteId}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(clienteBody)});
            if(!r.ok){
                const err=await r.json().catch(()=>({}));
                if(r.status===409&&err.cliente&&err.cliente.id){
                    clienteId=err.cliente.id;$('venta-cliente-id').value=clienteId;
                }else{
                    throw new Error(err.message||err.error||`Error al actualizar cliente (${r.status})`);
                }
            }
        }else{
            const r=await fetch('/api/im/clientes',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(clienteBody)});
            const body=await r.json().catch(()=>({}));
            if(!r.ok){
                if((r.status===409||r.status===200)&&body.cliente&&body.cliente.id){
                    clienteId=body.cliente.id;$('venta-cliente-id').value=clienteId;
                }else{
                    throw new Error(body.message||body.error||`Error al crear cliente (${r.status})`);
                }
            }else{
                clienteId=body.id||(body.cliente&&body.cliente.id);
                if(!clienteId) throw new Error('El servidor no devolvió el ID del cliente creado.');
                $('venta-cliente-id').value=clienteId;
            }
        }
        if(!clienteId) throw new Error('No se pudo obtener el ID del cliente.');

        const estadoOp=($('venta-estado-op')&&$('venta-estado-op').value)||'vendido';
        // Reservado implica promesa; escritura queda como el usuario la marcó (no se fuerza)
        if(estadoOp==='reservado'){
            $('venta-promesa').checked=true;
            $('venta-compraventa').checked=false;
        }

        const agenteSelId  = $('venta-agente-id')  ? $('venta-agente-id').value  : '';
        const agenteSelNom = $('venta-agente-nombre') ? $('venta-agente-nombre').value : '';

        const ventaBody={
            parcela_id:PARCELA_ID,
            cliente_id:clienteId,
            estado_operacion:estadoOp,
            firmo_promesa:$('venta-promesa').checked,
            firmo_compraventa:$('venta-compraventa').checked,
            fecha_venta:($('venta-fecha').value||hoyYmd()),
            precio_lista:cleanNum($('venta-precio-lista').value),
            precio_acordado:cleanNum($('venta-precio-acordado').value),
            notas:$('venta-notas').value||null,
            condiciones_compra:$('venta-condiciones').value||null,
            tipo_pago:pagoTipoActual,
            monto_pie:cleanNum($('venta-monto-pie').value),
            numero_credito:$('venta-numero-credito').value||null,
            numero_cuotas:parseInt($('venta-num-cuotas').value,10)||0,
            monto_cuota:cleanNum($('venta-monto-cuota').value),
            fechas_cuotas:pagoTipoActual==='credito'?fechasCuotasGeneradas:[],
            forma_pago:pagoTipoActual==='contado'?'Contado':'Crédito',
            agente_id:   agenteSelId  || null,
            agente_nombre: agenteSelNom || null
        };

        // Solo actualizar si la venta activa pertenece a ESTA parcela
        const ventaExistenteId=(ventaData&&ventaData.id&&String(ventaData.parcela_id||PARCELA_ID)===String(PARCELA_ID))?ventaData.id:null;
        const ventaUrl=ventaExistenteId?`/api/im/ventas/${ventaExistenteId}`:'/api/im/ventas';
        const vRes=await fetch(ventaUrl,{method:ventaExistenteId?'PUT':'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(ventaBody)});
        const ventaGuardada=await vRes.json().catch(()=>({}));
        if(!vRes.ok){
            throw new Error(ventaGuardada.message||ventaGuardada.error||`Error al guardar la venta (${vRes.status})`);
        }
        if(!ventaGuardada.id){
            throw new Error('El servidor no confirmó el ID de la venta. No se guardó correctamente.');
        }
        if(!ventaGuardada.cliente_id){
            throw new Error('La venta se guardó sin cliente asociado. Intenta de nuevo.');
        }

        // Upload comprobante contado (no bloquea la venta)
        if(pagoTipoActual==='contado'){
            const file=$('comprobante-contado').files[0];
            if(file&&ventaGuardada.id){
                const fd=new FormData();fd.append('archivo',file,file.name);
                await fetch(`/api/im/ventas/${ventaGuardada.id}/comprobante`,{method:'POST',body:fd}).catch(()=>{});
            }
        }

        // Pintar UI solo tras confirmación del servidor
        const snapshot={
            parcela:Object.assign({},parcelaData||{},{
                id:PARCELA_ID,
                estado_venta:ventaGuardada.parcela_estado||estadoOp
            }),
            venta:ventaGuardada,
            cuotas:ventaGuardada.cuotas||[],
            historial_precios:historialPreciosCache||[],
            historial_ventas:historialVentasCache||[]
        };
        ventaData=ventaGuardada;
        currentClienteId=ventaGuardada.cliente_id;
        parcelaData=snapshot.parcela;
        cuotasData=snapshot.cuotas;

        // Revalidar contra GET: si no está en BD, NO mostrar éxito
        await init();
        if(!ventaData||!ventaData.id||String(ventaData.id)!==String(ventaGuardada.id)){
            throw new Error('El servidor respondió OK pero la venta no quedó en la base de datos. Espera el redeploy o revisa en Render que DATABASE_URL use puerto 5432 (Session), no 6543.');
        }
        if(!parcelaData||!['vendido','reservado'].includes(String(parcelaData.estado_venta||''))){
            // Puede venir sincronizado por la venta; si hay venta activa igual OK
            if(!ventaData||!ventaData.id){
                throw new Error('La parcela no quedó marcada como vendida/reservada en la base de datos.');
            }
        }

        habilitarDocsVentaCliente(ventaGuardada.id,ventaGuardada.cliente_id);
        showToast(
            (ventaGuardada.parcela_estado||estadoOp)==='reservado'
                ? 'Venta guardada. Parcela marcada como Reservada.'
                : 'Venta guardada. Parcela marcada como Vendida.',
            'success'
        );
    }catch(err){showToast(err.message,'error','No se pudo guardar');}
    finally{if(btn){btn.disabled=false;btn.innerHTML='<i class="bi bi-person-check-fill"></i> Guardar Comprador y Venta';}}
});

// ──────────────── RESCILIACIÓN ────────────────
let rescDevTipo='contado';
let rescFechasCuotas=[];

function setRescDevTipo(tipo){
    rescDevTipo=tipo||'contado';
    ['contado','cuotas','pie','sin'].forEach(k=>{
        const el=$('resc-tab-'+k);
        if(el)el.classList.toggle('active',
            (k==='contado'&&rescDevTipo==='contado')||
            (k==='cuotas'&&rescDevTipo==='cuotas')||
            (k==='pie'&&rescDevTipo==='pie_mas_cuotas')||
            (k==='sin'&&rescDevTipo==='sin_devolucion')
        );
    });
    const sin=rescDevTipo==='sin_devolucion';
    const conCuotas=rescDevTipo==='cuotas'||rescDevTipo==='pie_mas_cuotas';
    if($('resc-dev-campos'))$('resc-dev-campos').style.display=sin?'none':'block';
    if($('resc-sin-dev-msg'))$('resc-sin-dev-msg').style.display=sin?'block':'none';
    if($('resc-pie-wrap'))$('resc-pie-wrap').style.display=rescDevTipo==='pie_mas_cuotas'?'block':'none';
    if($('resc-cuotas-wrap'))$('resc-cuotas-wrap').style.display=conCuotas?'block':'none';
    if(conCuotas)recalcRescCuotas();
}

function recalcRescCuotas(){
    if(rescDevTipo!=='cuotas'&&rescDevTipo!=='pie_mas_cuotas'){
        if($('resc-cuotas-preview'))$('resc-cuotas-preview').style.display='none';
        rescFechasCuotas=[];
        return;
    }
    const n=parseInt($('resc-num-cuotas').value,10)||0;
    const total=cleanNum($('resc-monto-total').value)||0;
    const pie=rescDevTipo==='pie_mas_cuotas'?(cleanNum($('resc-monto-pie').value)||0):0;
    const resto=Math.max(0,total-pie);
    let montoCuota=cleanNum($('resc-monto-cuota').value);
    if((!montoCuota||montoCuota<=0)&&n>0&&resto>0){
        montoCuota=Math.round(resto/n);
        $('resc-monto-cuota').value=Number(montoCuota).toLocaleString('es-CL');
    }
    const fechaBase=$('resc-primera-cuota').value||hoyYmd();
    rescFechasCuotas=[];
    if(!n||n<1){$('resc-cuotas-preview').style.display='none';return;}
    let rows='';
    for(let i=0;i<n;i++){
        const d=new Date(fechaBase+'T12:00:00');
        d.setMonth(d.getMonth()+i);
        const fecha=d.toISOString().split('T')[0];
        rescFechasCuotas.push({numero:i+1,monto:montoCuota||0,fecha});
        rows+=`<div style="display:grid;grid-template-columns:36px 1fr 110px 130px;gap:6px;align-items:center;padding:6px 10px;background:#fff;border:1px solid #fee2e2;border-radius:8px;margin-bottom:5px;font-size:.78rem;">
            <span style="font-weight:800;color:#dc2626;text-align:center;">${i+1}</span>
            <span style="color:#64748b;">Devolución</span>
            <span style="font-weight:700;">${montoCuota?'$'+fmt(montoCuota):'—'}</span>
            <input type="date" value="${fecha}" style="border:1px solid #e2e8f0;border-radius:6px;padding:3px 6px;font-size:.75rem;font-family:inherit;" onchange="rescFechasCuotas[${i}].fecha=this.value">
        </div>`;
    }
    $('resc-cuotas-preview-list').innerHTML=rows;
    $('resc-cuotas-preview').style.display='block';
}

function openResciliarModal(){
    if(!ventaData){showToast('No hay venta activa para resciliar.','error');return;}
    $('resc-fecha').value=hoyYmd();
    $('resc-motivo').value='Desistimiento del comprador';
    $('resc-notas').value='';
    $('resc-file-list').innerHTML='';
    if($('resc-file-input'))$('resc-file-input').value='';
    $('resc-monto-total').value=ventaData.precio_acordado?Number(ventaData.precio_acordado).toLocaleString('es-CL'):'';
    $('resc-monto-pie').value=ventaData.monto_pie?Number(ventaData.monto_pie).toLocaleString('es-CL'):'';
    $('resc-num-cuotas').value='6';
    $('resc-monto-cuota').value='';
    $('resc-primera-cuota').value=hoyYmd();
    const resumen=$('resc-resumen-venta');
    if(resumen){
        resumen.innerHTML=`
            <div style="font-weight:800;color:#0f172a;margin-bottom:6px;"><i class="bi bi-receipt"></i> Venta a resciliar</div>
            <div style="display:flex;flex-wrap:wrap;gap:10px 16px;">
                <span><strong>Cliente:</strong> ${escH(ventaData.nombre_completo||'—')}</span>
                <span><strong>Compró en:</strong> ${fmtFechaCL(ventaData.fecha_venta,{day:'2-digit',month:'short',year:'numeric'})}</span>
                <span><strong>Precio:</strong> ${ventaData.precio_acordado?'$'+fmt(ventaData.precio_acordado):'—'}</span>
                ${ventaData.monto_pie?`<span><strong>Pie pagado:</strong> $${fmt(ventaData.monto_pie)}</span>`:''}
                <span><strong>Modalidad:</strong> ${resolverTipoPago(ventaData)==='credito'?'Crédito':'Contado'}</span>
            </div>
            <p style="margin:8px 0 0;font-size:.75rem;color:#64748b;">Los documentos de venta/cliente/lote se conservan. Puedes marcar cuotas de devolución después en <a href="/admin/inmobiliaria/resciliaciones" target="_blank">Resciliaciones</a>.</p>`;
    }
    setRescDevTipo('contado');
    openModal('liberar');
}

document.getElementById('resc-file-input').addEventListener('change',function(){
    const list=$('resc-file-list');
    list.innerHTML=Array.from(this.files).map((f)=>`
        <div style="display:flex;align-items:center;gap:8px;background:#f1f5f9;border-radius:6px;padding:6px 10px;font-size:.78rem;">
            <i class="bi bi-paperclip" style="color:#2563eb;"></i>
            <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${escH(f.name)}</span>
            <span style="color:#94a3b8;">${(f.size/1024/1024).toFixed(1)}MB</span>
        </div>`).join('');
});

async function resciliarContrato(){
    if(!ventaData){showToast('No hay venta activa para resciliar.','error');return;}
    const btn=$('btn-resciliar');
    btn.disabled=true;btn.innerHTML='<i class="bi bi-hourglass-split"></i> Procesando...';
    try{
        if(rescDevTipo!=='sin_devolucion'){
            const monto=cleanNum($('resc-monto-total').value);
            if(!monto||monto<=0)throw new Error('Indica el monto total a devolver (o elige Sin devolución).');
            if((rescDevTipo==='cuotas'||rescDevTipo==='pie_mas_cuotas')&&rescFechasCuotas.length===0){
                recalcRescCuotas();
                if(rescFechasCuotas.length===0)throw new Error('Configura el número de cuotas y la primera fecha de pago.');
            }
        }
        const body={
            fecha:  $('resc-fecha').value||hoyYmd(),
            motivo: $('resc-motivo').value,
            notas:  $('resc-notas').value.trim()||null,
            tipo_devolucion: rescDevTipo,
            monto_total_devolucion: rescDevTipo==='sin_devolucion'?null:cleanNum($('resc-monto-total').value),
            monto_pie_devolucion: rescDevTipo==='pie_mas_cuotas'?cleanNum($('resc-monto-pie').value):null,
            numero_cuotas_devolucion: (rescDevTipo==='cuotas'||rescDevTipo==='pie_mas_cuotas')?(parseInt($('resc-num-cuotas').value,10)||0):0,
            monto_cuota_devolucion: (rescDevTipo==='cuotas'||rescDevTipo==='pie_mas_cuotas')?cleanNum($('resc-monto-cuota').value):null,
            fechas_cuotas_devolucion: (rescDevTipo==='cuotas'||rescDevTipo==='pie_mas_cuotas')?rescFechasCuotas:[]
        };
        const res=await fetch(`/api/im/ventas/${ventaData.id}/resciliar`,{
            method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)
        });
        const payload=await res.json().catch(()=>({}));
        if(!res.ok)throw new Error(payload.message||payload.error||`Error ${res.status}`);
        if(!payload.id)throw new Error('La resciliación no quedó confirmada en la base de datos.');

        const files=$('resc-file-input').files;
        if(files.length>0){
            for(const f of files){
                const fd=new FormData();
                fd.append('archivo',f);
                fd.append('nombre_personalizado',`Resciliación — ${f.name.replace(/\.[^/.]+$/,'')}`);
                fd.append('tipo_asociacion','parcela');
                fd.append('asociacion_id',PARCELA_ID);
                await fetch('/api/im/documentos',{method:'POST',body:fd}).catch(()=>{});
            }
            if(payload.id){
                const first=files[0];
                const fd2=new FormData();
                fd2.append('archivo',first);
                await fetch(`/api/im/resciliaciones/${payload.id}/documento`,{method:'POST',body:fd2}).catch(()=>{});
            }
        }

        closeModal('liberar');
        currentClienteId=null;
        ventaData=null;
        showToast('Resciliación guardada. Parcela liberada. Revisa devoluciones en Resciliaciones.','success');
        await init();
    }catch(e){showToast(e.message,'error','No se pudo resciliar');}
    finally{btn.disabled=false;btn.innerHTML='<i class="bi bi-file-earmark-x"></i> Confirmar Resciliación';}
}

// ──────────────── DOCUMENT MANAGER ────────────────
const dmState={};

function initDM(tipo,asociacionId,force=false){
    const container=$(`dm-${tipo}`);if(!container||!asociacionId)return;
    if(!force&&dmState[tipo]&&dmState[tipo].asociacionId===String(asociacionId)&&container.innerHTML.trim())return;
    dmState[tipo]={asociacionId:String(asociacionId),initialized:true};
    container.innerHTML=`
        <div class="step-box" style="margin-bottom:14px;">
            <p class="step-title"><i class="bi bi-cloud-upload"></i> Subir Documentos</p>
            <p style="font-size:.8rem;color:#64748b;margin:0 0 10px;">Selecciona archivos — se suben automáticamente al instante.</p>
            <div class="im-upload-zone" id="dz-${tipo}">
                <input type="file" multiple accept="image/*,.pdf,.doc,.docx,.xls,.xlsx,.zip,.rar" id="file-input-${tipo}"
                    onchange="handleFileSelect('${tipo}','${asociacionId}',this.files)">
                <i class="bi bi-cloud-arrow-up im-upload-icon"></i>
                <p class="im-upload-text">Arrastra archivos aquí o <strong>haz clic</strong></p>
                <p class="im-upload-hint">PDF, imágenes, Word, Excel · múltiples archivos · máx. 100 MB c/u</p>
            </div>
            <div id="dq-${tipo}"></div>
        </div>
        <div>
            <p class="step-title"><i class="bi bi-folder2-open"></i> Documentos Subidos</p>
            <div id="dl-${tipo}" class="im-doc-list"><div class="im-empty" style="padding:16px;"><i class="bi bi-hourglass-split"></i><p>Cargando...</p></div></div>
        </div>`;
    loadDocs(tipo==='lote'?'parcela':tipo==='venta'?'venta':tipo,asociacionId);
}

const ext2icon=ext=>['pdf'].includes(ext)?'bi-file-earmark-pdf':['jpg','jpeg','png','webp','gif'].includes(ext)?'bi-file-earmark-image':['doc','docx'].includes(ext)?'bi-file-earmark-word':'bi-file-earmark';

async function handleFileSelect(tipo,asociacionId,files){
    // Convertir FileList a Array ANTES de cualquier otra operacion para evitar
    // que inp.value='' invalide la referencia en algunos navegadores
    const fileArray=Array.from(files||[]);
    if(!fileArray.length)return;

    const inp=$(`file-input-${tipo}`);
    if(inp) setTimeout(()=>{ try{inp.value='';}catch(_){} },100);

    const qEl=$(`dq-${tipo}`);
    const tipoApi=tipo==='lote'?'parcela':tipo==='venta'?'venta':tipo==='persona'?'persona':'proyecto';
    let ok=0,failMsgs=[];

    for(const f of fileArray){
        const uid='u'+Date.now()+Math.random().toString(36).slice(2,7);
        const ext=(f.name||'').split('.').pop().toLowerCase();
        const sizeMB=(f.size/1024/1024).toFixed(1);
        const nombre=(f.name||'archivo').replace(/\.[^/.]+$/,'').replace(/[_-]/g,' ');

        // Crear fila de progreso con referencias directas
        const row=document.createElement('div');
        row.style.cssText='display:flex;align-items:center;gap:10px;padding:8px 10px;background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:8px;margin-bottom:6px;transition:all .3s;';

        const statusEl=document.createElement('div');
        statusEl.style.cssText='font-size:.72rem;color:#94a3b8;margin-top:2px;';
        statusEl.textContent=`${sizeMB} MB · Subiendo...`;

        const pbarEl=document.createElement('div');
        pbarEl.style.cssText='height:100%;width:15%;background:#2563eb;border-radius:2px;transition:width .4s;';

        const progWrap=document.createElement('div');
        progWrap.style.cssText='height:4px;background:#e2e8f0;border-radius:2px;margin-top:4px;overflow:hidden;';
        progWrap.appendChild(pbarEl);

        const info=document.createElement('div');
        info.style.cssText='flex:1;min-width:0;';
        const nameEl=document.createElement('div');
        nameEl.style.cssText='font-size:.82rem;font-weight:600;color:#0f172a;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;';
        nameEl.textContent=nombre;
        info.appendChild(nameEl);
        info.appendChild(statusEl);
        info.appendChild(progWrap);

        const iconEl=document.createElement('i');
        iconEl.className=`bi ${ext2icon(ext)}`;
        iconEl.style.cssText='font-size:1.3rem;color:#2563eb;flex-shrink:0;';

        // Boton de cerrar (solo para errores, inicialmente oculto)
        const closeBtn=document.createElement('button');
        closeBtn.textContent='×';
        closeBtn.style.cssText='border:none;background:none;font-size:1.1rem;color:#94a3b8;cursor:pointer;padding:0 2px;display:none;flex-shrink:0;';
        closeBtn.onclick=()=>{ try{row.remove();}catch(_){} };

        row.appendChild(iconEl);
        row.appendChild(info);
        row.appendChild(closeBtn);
        if(qEl)qEl.appendChild(row);

        pbarEl.style.width='25%';

        let uploadOk=false;
        try{
            const fd=new FormData();
            fd.append('archivo',f,f.name);
            fd.append('nombre_personalizado',nombre);
            fd.append('tipo_asociacion',tipoApi);
            fd.append('asociacion_id',String(asociacionId));
            pbarEl.style.width='60%';

            const res=await fetch('/api/im/documentos',{method:'POST',body:fd});
            let body={};
            try{ body=await res.clone().json(); }catch(_){}

            if(!res.ok){
                const msg=body.message||body.error||`Error del servidor (HTTP ${res.status})`;
                throw new Error(msg);
            }
            // Éxito
            pbarEl.style.width='100%';
            pbarEl.style.background='#16a34a';
            row.style.borderColor='#86efac';
            row.style.background='#f0fdf4';
            iconEl.style.color='#16a34a';
            statusEl.textContent=`${sizeMB} MB · ¡Subido!`;
            statusEl.style.color='#16a34a';
            ok++;
            uploadOk=true;
            setTimeout(()=>{ try{row.remove();}catch(_){} },3500);
        }catch(err){
            // Error: mostrar y NO auto-eliminar — el usuario puede cerrar con ×
            pbarEl.style.width='100%';
            pbarEl.style.background='#ef4444';
            row.style.borderColor='#fca5a5';
            row.style.background='#fff5f5';
            iconEl.style.color='#ef4444';
            statusEl.style.color='#ef4444';
            statusEl.style.fontWeight='600';
            statusEl.textContent=`⚠ ${err.message}`;
            closeBtn.style.display='block';
            failMsgs.push(`"${nombre}": ${err.message}`);
            console.error('[Doc Upload Error]',err.message,'tipo:',tipoApi,'id:',asociacionId);
        }
    }

    if(ok>0) showToast(`${ok} documento${ok>1?'s':''} subido${ok>1?'s':''} correctamente.`,'success');
    if(failMsgs.length>0){
        // Mostrar el primer error con detalle real
        showToast(`Error al subir: ${failMsgs[0]}`,'error');
    }
    await loadDocs(tipoApi,asociacionId);
}

async function loadDocs(tipo_asociacion,asociacionId){
    const dlId=tipo_asociacion==='proyecto'?'dl-proyecto':tipo_asociacion==='parcela'?'dl-lote':tipo_asociacion==='venta'?'dl-venta':'dl-persona';
    const dl=$(dlId);if(!dl)return;
    dl.innerHTML='<div class="im-empty" style="padding:16px;"><i class="bi bi-hourglass-split"></i><p>Cargando...</p></div>';
    try{
        const res=await fetch(`/api/im/documentos?tipo_asociacion=${tipo_asociacion}&asociacion_id=${asociacionId}`);
        if(!res.ok){const eb=await res.json().catch(()=>({}));throw new Error(eb.message||`No se pudieron cargar los documentos (HTTP ${res.status}).`);}
        const docs=await res.json();
        if(docs.length===0){dl.innerHTML='<div class="im-empty" style="padding:16px;"><i class="bi bi-folder2-open"></i><p>Sin documentos aún.</p></div>';return;}
        const ext2icon=ext=>['pdf'].includes(ext)?'bi-file-earmark-pdf bi-doc-red':['jpg','jpeg','png','webp','gif'].includes(ext)?'bi-file-earmark-image bi-doc-blue':'bi-file-earmark';
        const canPreview=ext=>['pdf','jpg','jpeg','png','webp','gif'].includes(ext);
        _docsCache={};
        dl.innerHTML=docs.map(doc=>{
            _docsCache[doc.id]=doc;
            const ext=getDocExt(doc);
            if(['jpg','jpeg','png','webp','gif'].includes(ext)&&doc.url_storage){
                const pre=new Image();pre.decoding='async';pre.src=doc.url_storage;
            }
            const fecha=new Date(doc.creado_at).toLocaleDateString('es-CL',{day:'2-digit',month:'short',year:'numeric'});
            return `<div class="im-doc-item" id="docitem-${doc.id}">
                <i class="bi ${ext2icon(ext)} im-doc-icon"></i>
                <div class="im-doc-info" style="flex:1;min-width:0;">
                    <div class="im-doc-name doc-item-name-display" id="dname-${doc.id}" title="${escH(doc.nombre_personalizado)}">${escH(doc.nombre_personalizado)}</div>
                    <input class="doc-item-name-edit" id="dedit-${doc.id}" value="${escH(doc.nombre_personalizado)}"
                        onkeydown="if(event.key==='Enter'){saveRename(${doc.id},'${tipo_asociacion}','${asociacionId}');}if(event.key==='Escape'){cancelRename(${doc.id});}">
                    <div class="im-doc-date">${fecha}</div>
                </div>
                <div class="im-doc-actions">
                    ${canPreview(ext)?`<button type="button" class="im-btn im-btn-sm im-btn-ghost" onclick="previewDocById(${doc.id})" title="Ver"><i class="bi bi-eye"></i></button>`:''}
                    <a href="${escH(doc.url_storage)}" download="${escH(doc.nombre_personalizado)}.${ext}" target="_blank" class="im-btn im-btn-sm im-btn-ghost" title="Descargar"><i class="bi bi-download"></i></a>
                    <button class="im-btn im-btn-sm im-btn-ghost" onclick="startRename(${doc.id})" title="Renombrar"><i class="bi bi-pencil"></i></button>
                    <button class="im-btn im-btn-sm" id="save-rename-${doc.id}" style="display:none;" onclick="saveRename(${doc.id},'${tipo_asociacion}','${asociacionId}')"><i class="bi bi-check-lg"></i></button>
                    ${(IS_ADMIN||PUEDE_CREAR)?`<button class="im-btn im-btn-sm im-btn-danger" onclick="deleteDoc(${doc.id},'${tipo_asociacion}','${asociacionId}','${escH(doc.nombre_personalizado)}')" title="Eliminar"><i class="bi bi-trash3"></i></button>`:''}
                </div>
            </div>`;
        }).join('');
    }catch(e){dl.innerHTML=`<div class="im-empty" style="color:#ef4444;padding:16px;"><i class="bi bi-exclamation-triangle"></i><p>${escH(e.message)}</p></div>`;}
}

function startRename(id){const d=$(`dname-${id}`),ed=$(`dedit-${id}`),sb=$(`save-rename-${id}`);if(!d||!ed)return;d.classList.add('hidden');ed.classList.add('active');if(sb)sb.style.display='flex';ed.focus();ed.select();}
function cancelRename(id){const d=$(`dname-${id}`),ed=$(`dedit-${id}`),sb=$(`save-rename-${id}`);if(d)d.classList.remove('hidden');if(ed)ed.classList.remove('active');if(sb)sb.style.display='none';}

async function saveRename(id,tipo_asociacion,asociacionId){
    const ed=$(`dedit-${id}`);if(!ed)return;const n=ed.value.trim();if(!n)return;
    try{
        const res=await fetch(`/api/im/documentos/${id}`,{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({nombre_personalizado:n})});
        if(!res.ok){const e=await res.json().catch(()=>({}));throw new Error(e.message||`Error ${res.status}`);}
        showToast('Nombre actualizado.','success');loadDocs(tipo_asociacion,asociacionId);
    }catch(e){showToast(e.message,'error');cancelRename(id);}
}

let _delDocPending={id:null,tipo:null,asocId:null};
function deleteDoc(id,tipo_asociacion,asociacionId,nombre){
    _delDocPending={id,tipo:tipo_asociacion,asocId:asociacionId};
    $('del-doc-nombre').textContent=nombre||'Documento seleccionado';
    openModal('del-doc');
}
async function confirmDeleteDoc(){
    const {id,tipo,asocId}=_delDocPending;if(!id)return;
    const btn=$('btn-confirm-del-doc');
    btn.disabled=true;btn.innerHTML='<i class="bi bi-hourglass-split"></i> Eliminando...';
    try{
        const res=await fetch(`/api/im/documentos/${id}`,{method:'DELETE'});
        if(!res.ok){const eb=await res.json().catch(()=>({}));throw new Error(eb.message||`No se pudo eliminar (HTTP ${res.status}).`);}
        closeModal('del-doc');
        showToast('Documento eliminado correctamente.','success');
        loadDocs(tipo,asocId);loadAuditoria();
    }catch(e){showToast(e.message,'error');}
    finally{btn.disabled=false;btn.innerHTML='<i class="bi bi-trash3"></i> Sí, eliminar';}
}

function previewDocById(id){
    const doc=_docsCache[id];
    if(!doc)return;
    previewDoc(doc.url_storage,doc.nombre_personalizado,getDocExt(doc));
}

function previewDoc(url,nombre,ext){
    $('preview-title').innerHTML=`<i class="bi bi-eye"></i> ${escH(nombre)}`;
    $('preview-download').href=url;$('preview-download').download=nombre+(ext?'.'+ext:'');
    const cont=$('preview-content');
    const imgs=['jpg','jpeg','png','webp','gif'];
    let content='';
    cont.className='im-preview-fill';
    if(imgs.includes(ext)){
        openModal('preview');
        cont.style.cssText='height:100%;display:flex;align-items:center;justify-content:center;background:#0f172a;padding:16px;box-sizing:border-box;';
        content=`<div style="color:#94a3b8;font-size:.85rem;margin-bottom:8px;"><i class="bi bi-hourglass-split"></i> Cargando...</div><img src="${escH(url)}" decoding="async" style="max-width:100%;max-height:100%;object-fit:contain;border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,.3);display:none;" alt="${escH(nombre)}" onload="this.style.display='block';this.previousElementSibling&&(this.previousElementSibling.style.display='none');">`;
    }else if(ext==='pdf'){
        cont.style.cssText='height:100%;';
        const pdfSrc=escH(url)+'#toolbar=1&navpanes=1&scrollbar=1&view=FitH';
        content=`<iframe src="${pdfSrc}" class="preview-frame"></iframe>`;
    }else{
        cont.style.cssText='height:100%;display:flex;align-items:center;justify-content:center;background:#f1f5f9;padding:24px;box-sizing:border-box;text-align:center;';
        content=`<div style="color:#64748b;"><i class="bi bi-file-earmark-text" style="font-size:3rem;display:block;margin-bottom:12px;"></i><p>Vista previa no disponible para este tipo de archivo.</p><a href="${escH(url)}" target="_blank" class="im-btn im-btn-primary" style="margin-top:10px;display:inline-flex;"><i class="bi bi-box-arrow-up-right"></i> Abrir en nueva pestaña</a></div>`;
    }
    cont.innerHTML=content;
    if(!imgs.includes(ext)) openModal('preview');
}

// ──────────────── AUDITORÍA ────────────────
async function loadAuditoria(){
    const list=$('auditoria-list');
    list.innerHTML='<div class="im-empty"><i class="bi bi-hourglass-split"></i><p>Cargando...</p></div>';
    try{
        const [r1,r2]=await Promise.all([
            fetch(`/api/im/auditoria?entidad_id=${PARCELA_ID}`).then(r=>r.json()),
            proyectoId?fetch(`/api/im/auditoria?entidad_id=${proyectoId}`).then(r=>r.json()):[]
        ]);
        const all=[...(Array.isArray(r1)?r1:[]),...(Array.isArray(r2)?r2:[])].sort((a,b)=>new Date(b.fecha)-new Date(a.fecha));
        if(all.length===0){list.innerHTML='<div class="im-empty"><i class="bi bi-clock-history"></i><p>Sin registros aún.</p></div>';return;}
        list.innerHTML=all.map(a=>`<div class="im-audit-item">
            <div class="im-audit-dot"></div>
            <div class="im-audit-body">
                <div class="im-audit-accion">${escH(a.accion)}</div>
                ${a.descripcion?`<div class="im-audit-desc">${escH(a.descripcion)}</div>`:''}
                <div class="im-audit-meta">${new Date(a.fecha).toLocaleString('es-CL',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'})} · ${escH(a.usuario_nombre||'Sistema')}</div>
            </div>
        </div>`).join('');
    }catch(e){list.innerHTML=`<div class="im-empty" style="color:#ef4444;"><i class="bi bi-exclamation-triangle"></i><p>${escH(e.message)}</p></div>`;}
}

document.addEventListener('DOMContentLoaded',init);
</script>
</body>
</html>
