<aside class="sidebar" id="adminSidebar">
    
    <div class="sidebar-header">
        <a href="/dashboard" class="brand-link">
            <img src="/img/logo.png" alt="Cygnus Group" class="brand-logo">
        </a>
    </div>

    <nav class="sidebar-nav">
        <div class="nav-group-label">Principal</div>
        <ul class="nav-list">
            <li>
                <a href="/dashboard" class="nav-link <%= (typeof page !== 'undefined' && page === 'dashboard') ? 'active' : '' %>">
                    <i class="ph-bold ph-squares-four"></i>
                    <span>Dashboard</span>
                </a>
            </li>

            <li>
                <a href="/admin/propiedades" class="nav-link <%= (typeof page !== 'undefined' && page === 'propiedades') ? 'active' : '' %>">
                    <i class="ph-bold ph-house-line"></i>
                    <span>Propiedades</span>
                </a>
            </li>

            <li>
                <a href="/admin/publicar" class="nav-link <%= (typeof page !== 'undefined' && page === 'publicar') ? 'active' : '' %>">
                    <i class="ph-bold ph-plus-circle"></i>
                    <span>Publicar</span>
                </a>
            </li>
        </ul>

        <div class="nav-group-label">Herramientas</div>
        <ul class="nav-list">
            <li>
                <a href="/admin/marca" class="nav-link <%= (typeof activePage !== 'undefined' && activePage === 'marca') ? 'active' : '' %>">
                    <i class="ph-bold ph-stamp"></i>
                    <span>Centro de Marca</span>
                </a>
            </li>
            <li>
                <a href="/admin/360" class="nav-link <%= (typeof page !== 'undefined' && page === 'pano360') ? 'active' : '' %>">
                    <i class="ph-bold ph-globe-hemisphere-west"></i>
                    <span>Visor 360 Pro</span>
                </a>
            </li>
        </ul>

        <% const _imAdmin = user && (user.role === 'admin' || String(user.role || '').toLowerCase() === 'administrador'); %>
        <% if (user && (_imAdmin || (typeof imPuedeVer !== 'undefined' && imPuedeVer))) { %>
            
            <div class="nav-group-label">Gestión de Campos</div>
            <ul class="nav-list">
                <li>
                    <a href="/admin/inmobiliaria" class="nav-link <%= (typeof page !== 'undefined' && page === 'inmobiliaria') ? 'active' : '' %>">
                        <i class="ph-bold ph-farm"></i>
                        <span>Venta de Campos</span>
                    </a>
                </li>
                <li>
                    <a href="/admin/inmobiliaria/cartera" class="nav-link <%= (typeof page !== 'undefined' && page === 'cartera-im') ? 'active' : '' %>">
                        <i class="ph-bold ph-chart-line-up"></i>
                        <span>Cartera Ejecutiva</span>
                    </a>
                </li>
                <li>
                    <a href="/admin/inmobiliaria/clientes" class="nav-link <%= (typeof page !== 'undefined' && page === 'clientes-im') ? 'active' : '' %>">
                        <i class="ph-bold ph-users"></i>
                        <span>Clientes</span>
                    </a>
                </li>
                <li>
                    <a href="/admin/inmobiliaria/cuotas" class="nav-link <%= (typeof page !== 'undefined' && page === 'cuotas-im') ? 'active' : '' %>">
                        <i class="ph-bold ph-calendar-check"></i>
                        <span>Pago de Cuotas</span>
                    </a>
                </li>
                <li>
                    <a href="/admin/inmobiliaria/resciliaciones" class="nav-link <%= (typeof page !== 'undefined' && page === 'resciliaciones-im') ? 'active' : '' %>">
                        <i class="ph-bold ph-file-x"></i>
                        <span>Resciliaciones</span>
                    </a>
                </li>
            </ul>
        <% } %>

        <% if (user && user.role === 'admin') { %>
            <div class="nav-group-label">Módulo Parcelas 360</div>
            <ul class="nav-list">
                <li>
                    <a href="/admin/proyectos" class="nav-link <%= (typeof page !== 'undefined' && page === 'proyectos') ? 'active' : '' %>">
                        <i class="ph-bold ph-map-trifold"></i>
                        <span>Proyectos 360</span>
                    </a>
                </li>
                <li>
                    <a href="/admin/lotes" class="nav-link <%= (typeof page !== 'undefined' && page === 'lotes') ? 'active' : '' %>">
                        <i class="ph-bold ph-grid-four"></i>
                        <span>Visor de Lotes</span>
                    </a>
                </li>
                <li>
                    <a href="/admin/crm" class="nav-link <%= (typeof page !== 'undefined' && page === 'crm') ? 'active' : '' %>">
                        <i class="ph-bold ph-currency-circle-dollar"></i>
                        <span>CRM & Finanzas</span>
                    </a>
                </li>
            </ul>

            <div class="nav-group-label">Administración</div>
            <ul class="nav-list">
                <li>
                    <a href="/admin/team" class="nav-link <%= (typeof page !== 'undefined' && page === 'team') ? 'active' : '' %>">
                        <i class="ph-bold ph-users-three"></i>
                        <span>Equipo</span>
                    </a>
                </li>
                
                <li>
                    <a href="/admin/configuracion" class="nav-link <%= (typeof page !== 'undefined' && page === 'config') ? 'active' : '' %>">
                        <i class="ph-bold ph-gear"></i>
                        <span>Configuración</span>
                    </a>
                </li>
            </ul>
        <% } %>
    </nav>

    <div class="sidebar-footer">
        <div class="user-card">
            <div class="avatar-box">
                <% if (user && user.avatar) { %>
                    <img src="<%= user.avatar %>" alt="User" class="user-img">
                <% } else { %>
                    <i class="ph-fill ph-user-circle user-icon-fallback"></i>
                <% } %>
            </div>
            <div class="user-meta">
                <span class="user-name"><%= user && user.name ? user.name.split(' ')[0] : 'Usuario' %></span>
                <span class="user-badge"><%= user && user.role === 'admin' ? 'Admin' : 'Agente' %></span>
            </div>
        </div>
        
        <a href="/logout" class="btn-exit" title="Cerrar Sesión">
            <i class="ph-bold ph-sign-out"></i>
        </a>
    </div>
</aside>